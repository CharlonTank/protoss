{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Protoss",
  "scopeName": "source.protoss",
  "fileTypes": [
    "protoss"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#elmDefinition"
    },
    {
      "include": "#sexpDefinition"
    },
    {
      "include": "#builtins"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#types"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#capabilities"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.semicolon.protoss",
          "match": ";.*$"
        },
        {
          "name": "comment.line.double-dash.protoss",
          "match": "--.*$"
        }
      ]
    },
    "strings": {
      "name": "string.quoted.double.protoss",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.protoss",
          "match": "\\\\(?:[nrt\"\\\\]|.)"
        }
      ]
    },
    "elmDefinition": {
      "patterns": [
        {
          "name": "meta.definition.type-signature.protoss",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_.]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "entity.name.function.protoss"
            },
            "2": {
              "name": "keyword.operator.type-annotation.protoss"
            }
          }
        },
        {
          "name": "meta.definition.value.protoss",
          "match": "^\\s*([A-Za-z_][A-Za-z0-9_.]*)\\b(?=[^\\n=]*=)",
          "captures": {
            "1": {
              "name": "entity.name.function.protoss"
            }
          }
        },
        {
          "name": "meta.definition.type-alias.protoss",
          "match": "^\\s*(type)\\s+(alias)\\s+([A-Z][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.protoss"
            },
            "2": {
              "name": "keyword.declaration.alias.protoss"
            },
            "3": {
              "name": "entity.name.type.protoss"
            }
          }
        },
        {
          "name": "meta.definition.union.protoss",
          "match": "^\\s*(type)\\s+([A-Z][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.protoss"
            },
            "2": {
              "name": "entity.name.type.protoss"
            }
          }
        }
      ]
    },
    "sexpDefinition": {
      "patterns": [
        {
          "name": "meta.definition.def.protoss",
          "match": "\\((def|defpoly|defcap|defpolycap|defrec|defrecpoly)\\s+([A-Za-z_][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.protoss"
            },
            "2": {
              "name": "entity.name.function.protoss"
            }
          }
        },
        {
          "name": "meta.definition.type.protoss",
          "match": "\\((type|alias|record|variant)\\s+([A-Z][A-Za-z0-9_.]*)",
          "captures": {
            "1": {
              "name": "keyword.declaration.type.protoss"
            },
            "2": {
              "name": "entity.name.type.protoss"
            }
          }
        },
        {
          "name": "meta.module.protoss",
          "match": "\\((module|import|export|capabilities)\\b",
          "captures": {
            "1": {
              "name": "keyword.control.module.protoss"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.protoss",
          "match": "\\b(?:if|then|else|let|in|case|of|module|import|export|capabilities|type|alias)\\b"
        },
        {
          "name": "keyword.operator.expression.protoss",
          "match": "\\b(?:lambda|foldNat|foldList|foldVariant|caseList|match|record|variant|get|inst|done|bind|sendToBackend|broadcast|request|recur|text|image|button|input|column|row|list|when)\\b"
        }
      ]
    },
    "builtins": {
      "patterns": [
        {
          "name": "support.function.builtin.protoss",
          "match": "\\b(?:succ|foldNat|foldList|foldVariant|caseList|recur|text|image|button|input|column|row|list|when|node|attr|on|done|bind|sendToBackend|broadcast)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.builtin.protoss",
          "match": "\\b(?:Unit|Bool|Nat|String|List|View|Process|Record|Variant|Tuple|Maybe|Option|Result|Pair)\\b"
        },
        {
          "name": "entity.name.type.protoss",
          "match": "\\b[A-Z][A-Za-z0-9_.]*\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.protoss",
          "match": "\\b(?:true|false|unit|Nil|Cons)\\b"
        }
      ]
    },
    "capabilities": {
      "patterns": [
        {
          "name": "support.class.capability.protoss",
          "match": "\\b(?:Human\\.ask|Http\\.get|Clock\\.read|Local\\.storage|Local\\.save|Local\\.load|Server\\.request)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.natural.protoss",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.protoss",
          "match": "->"
        },
        {
          "name": "keyword.operator.pipeline.protoss",
          "match": "\\|>"
        },
        {
          "name": "keyword.operator.protoss",
          "match": "[+=:|]"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.section.parens.protoss",
          "match": "[()]"
        },
        {
          "name": "punctuation.section.brackets.protoss",
          "match": "[\\[\\]]"
        },
        {
          "name": "punctuation.section.braces.protoss",
          "match": "[{}]"
        },
        {
          "name": "punctuation.separator.comma.protoss",
          "match": ","
        }
      ]
    }
  }
}
