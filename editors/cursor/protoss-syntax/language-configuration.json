{
  "comments": {
    "lineComment": "--"
  },
  "brackets": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"]
  ],
  "autoClosingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "surroundingPairs": [
    ["(", ")"],
    ["[", "]"],
    ["{", "}"],
    ["\"", "\""]
  ],
  "folding": {
    "markers": {
      "start": "^\\s*(?:\\(def|\\(defpoly|\\(defcap|\\(defrec|\\(type|\\(record|\\(variant|[A-Za-z_][A-Za-z0-9_.]*\\s*(?::|[^=]*=))",
      "end": "^\\s*$"
    }
  },
  "wordPattern": "(-?\\d+)|(\\b[A-Za-z_][A-Za-z0-9_.]*\\b)"
}
