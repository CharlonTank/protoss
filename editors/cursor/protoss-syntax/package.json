{
  "name": "protoss-syntax",
  "displayName": "Protoss Syntax",
  "description": "Syntax highlighting for Protoss .protoss files in Cursor and VS Code.",
  "version": "0.3.2",
  "publisher": "protoss",
  "license": "MIT",
  "main": "./extension.js",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "activationEvents": [
    "onLanguage:protoss"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "scripts": {
    "test": "node test/run-definition-tests.js"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "languages": [
      {
        "id": "protoss",
        "aliases": [
          "Protoss",
          "protoss"
        ],
        "extensions": [
          ".protoss"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "protoss",
        "scopeName": "source.protoss",
        "path": "./syntaxes/protoss.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Protoss",
      "properties": {
        "protoss.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run Protoss checks and publish editor diagnostics for .protoss files."
        },
        "protoss.diagnostics.command": {
          "type": "string",
          "default": "protoss",
          "description": "Command used for Protoss diagnostics."
        },
        "protoss.diagnostics.args": {
          "type": "array",
          "default": [
            "check"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed before the file path when running diagnostics."
        }
      }
    }
  }
}
