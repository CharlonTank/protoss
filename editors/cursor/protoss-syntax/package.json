{
  "name": "protoss-syntax",
  "displayName": "Protoss Syntax",
  "description": "Syntax highlighting for Protoss .protoss and .pt files in Cursor and VS Code.",
  "version": "0.5.0",
  "publisher": "protoss",
  "license": "MIT",
  "main": "./extension.js",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "activationEvents": [
    "onLanguage:protoss",
    "onCommand:protoss.toHuman",
    "onCommand:protoss.toKernel"
  ],
  "engines": {
    "vscode": "^1.80.0"
  },
  "scripts": {
    "test": "node test/run-definition-tests.js && node test/run-switch-tests.js"
  },
  "categories": [
    "Programming Languages"
  ],
  "contributes": {
    "commands": [
      {
        "command": "protoss.toHuman",
        "title": "Protoss: Switch to Human Syntax (Elm-like)"
      },
      {
        "command": "protoss.toKernel",
        "title": "Protoss: Switch to Kernel Syntax (S-expression)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "protoss.toHuman",
          "when": "editorLangId == protoss"
        },
        {
          "command": "protoss.toKernel",
          "when": "editorLangId == protoss"
        }
      ],
      "editor/context": [
        {
          "command": "protoss.toHuman",
          "when": "editorLangId == protoss",
          "group": "1_modification@10"
        },
        {
          "command": "protoss.toKernel",
          "when": "editorLangId == protoss",
          "group": "1_modification@11"
        }
      ]
    },
    "languages": [
      {
        "id": "protoss",
        "aliases": [
          "Protoss",
          "protoss"
        ],
        "extensions": [
          ".protoss",
          ".pt"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "protoss",
        "scopeName": "source.protoss",
        "path": "./syntaxes/protoss.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Protoss",
      "properties": {
        "protoss.diagnostics.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Run Protoss checks and publish editor diagnostics for .protoss and .pt files."
        },
        "protoss.diagnostics.command": {
          "type": "string",
          "default": "protoss",
          "description": "Command used for Protoss diagnostics."
        },
        "protoss.diagnostics.args": {
          "type": "array",
          "default": [
            "check"
          ],
          "items": {
            "type": "string"
          },
          "description": "Arguments passed before the file path when running diagnostics."
        }
      }
    }
  }
}
