(def Protoss.tcCheckExprAs
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> Expr (Result TypeError TypeExpr)))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expected TypeExpr)
        (lambda (expr Expr)
          ((((Protoss.tcCheckExprAsGo expr) typeEnv) termEnv) expected))))))

(def TypecheckState.empty TypecheckState
  (record
    (definitions (inst Assoc.empty String TypeExpr))
    (unsupported (Nil String))
    (error (variant None unit))))

(def TypecheckState.addDefinition
  (-> String (-> TypeExpr (-> TypecheckState TypecheckState)))
  (lambda (name String)
    (lambda (typ TypeExpr)
      (lambda (state TypecheckState)
        (record
          (definitions
            ((((inst Assoc.insert String TypeExpr) name) typ)
              (get state definitions)))
          (unsupported (get state unsupported))
          (error (get state error)))))))

(def TypecheckState.addUnsupported
  (-> String (-> TypecheckState TypecheckState))
  (lambda (name String)
    (lambda (state TypecheckState)
      (record
        (definitions (get state definitions))
        (unsupported (Cons String name (get state unsupported)))
        (error (get state error))))))

(def TypecheckState.withError
  (-> TypeError (-> TypecheckState TypecheckState))
  (lambda (err TypeError)
    (lambda (state TypecheckState)
      (record
        (definitions (get state definitions))
        (unsupported (get state unsupported))
        (error (variant Some err))))))

(def Protoss.tcCheckDef
  (-> TypeEnv (-> TermEnv (-> ProtossDef (Result TypeError TypeExpr))))
  (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (def ProtossDef)
        (case ((((Protoss.tcCheckExprAs typeEnv) termEnv) (get def typ)) (get def expr))
          (Err err (variant Err ((Protoss.tcErrorWithDefinition (get def name)) err)))
          (Ok actual
            (case (((Protoss.tcTypeEq typeEnv) (get def typ)) actual)
              (true (Protoss.tcOk (get def typ)))
              (false
                ((((Protoss.tcMismatch (Protoss.tcSomeDef (get def name)))
                  (get def typ))
                  actual)
                  (Protoss.renderExpr (get def expr)))))))))))

(def Protoss.tcCheckCapDef
  (-> TypeEnv (-> TermEnv (-> ProtossCapDef (Result TypeError TypeExpr))))
  (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (def ProtossCapDef)
        (case ((((Protoss.tcCheckExprAs typeEnv) termEnv) (get def typ)) (get def expr))
          (Err err (variant Err ((Protoss.tcErrorWithDefinition (get def name)) err)))
          (Ok actual
            (case (((Protoss.tcTypeEq typeEnv) (get def typ)) actual)
              (true (Protoss.tcOk (get def typ)))
              (false
                ((((Protoss.tcMismatch (Protoss.tcSomeDef (get def name)))
                  (get def typ))
	                  actual)
	                  (Protoss.renderExpr (get def expr)))))))))))

(def Protoss.tcCheckPolyDef
  (-> TypeEnv (-> TermEnv (-> ProtossPolyDef (Result TypeError TypeExpr))))
  (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (def ProtossPolyDef)
        (case ((((Protoss.tcCheckExprAs typeEnv) termEnv) (get def typ)) (get def expr))
          (Err err (variant Err ((Protoss.tcErrorWithDefinition (get def name)) err)))
          (Ok actual
            (case (((Protoss.tcTypeEq typeEnv) (get def typ)) actual)
              (true (Protoss.tcOk (get def typ)))
              (false
                ((((Protoss.tcMismatch (Protoss.tcSomeDef (get def name)))
                  (get def typ))
                  actual)
                  (Protoss.renderExpr (get def expr)))))))))))

(def Protoss.tcCheckPolyCapDef
  (-> TypeEnv (-> TermEnv (-> ProtossPolyCapDef (Result TypeError TypeExpr))))
  (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (def ProtossPolyCapDef)
        (case ((((Protoss.tcCheckExprAs typeEnv) termEnv) (get def typ)) (get def expr))
          (Err err (variant Err ((Protoss.tcErrorWithDefinition (get def name)) err)))
          (Ok actual
            (case (((Protoss.tcTypeEq typeEnv) (get def typ)) actual)
              (true (Protoss.tcOk (get def typ)))
              (false
                ((((Protoss.tcMismatch (Protoss.tcSomeDef (get def name)))
                  (get def typ))
                  actual)
                  (Protoss.renderExpr (get def expr)))))))))))

(def Protoss.tcCheckDefRecNat
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> TypeExpr (-> ProtossDefRecNat
    (Result TypeError TypeExpr))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (input TypeExpr)
        (lambda (result TypeExpr)
          (lambda (body ProtossDefRecNat)
            (case (((Protoss.tcTypeEq typeEnv) Protoss.tcNat) input)
              (false
                ((((Protoss.tcMismatch Protoss.tcNoDef) Protoss.tcNat) input)
                  "defrec nat input"))
              (true
                (let (paramEnv TermEnv
                  (((TermEnv.insert (get body param)) input) termEnv))
                  (case ((((Protoss.tcCheckExprAs typeEnv) paramEnv) result)
                          (get body zero))
                    (Err err (variant Err err))
                    (Ok checkedZero
                      (let (stepEnv TermEnv
                        (((TermEnv.insert (get body acc)) result) paramEnv))
                        (case ((((Protoss.tcCheckExprAs typeEnv) stepEnv) result)
                                (get body step))
                          (Err err (variant Err err))
                          (Ok checkedStep
                            (Protoss.tcOk ((Protoss.tcFun input) result))))))))))))))))

(def Protoss.tcCheckDefRecListInputError
  (-> TypeExpr (Result TypeError TypeExpr))
  (lambda (input TypeExpr)
    (Protoss.tcErr
      ((((((Protoss.tcError "SELF_TC002") Protoss.tcNoDef)
        Protoss.tcNoType)
        (Protoss.tcSomeType input))
        "defrec list input")
        "defrec list input must be List"))))

(def Protoss.tcCheckDefRecList
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> TypeExpr (-> ProtossDefRecList
    (Result TypeError TypeExpr))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (input TypeExpr)
        (lambda (result TypeExpr)
          (lambda (body ProtossDefRecList)
            (case ((Protoss.tcListItemType typeEnv) input)
              (None _ (Protoss.tcCheckDefRecListInputError input))
              (Some itemType
                (let (paramEnv TermEnv
                  (((TermEnv.insert (get body param)) input) termEnv))
                  (case ((((Protoss.tcCheckExprAs typeEnv) paramEnv) result)
                          (get body nil))
                    (Err err (variant Err err))
                    (Ok checkedNil
                      (let (stepEnv TermEnv
                        (((TermEnv.insert (get body item)) itemType)
                          (((TermEnv.insert (get body acc)) result) paramEnv)))
                        (case ((((Protoss.tcCheckExprAs typeEnv) stepEnv) result)
                                (get body step))
                          (Err err (variant Err err))
                          (Ok checkedStep
                            (Protoss.tcOk ((Protoss.tcFun input) result))))))))))))))))

(def Protoss.tcRunDefRecVariantBranchCheck
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> TypeExpr (-> TypeExpr
    (-> TypecheckExpectedCaseBranchCheck (Result TypeError TypeExpr)))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (target TypeExpr)
        (lambda (result TypeExpr)
          (lambda (payloadType TypeExpr)
            (lambda (branch TypecheckExpectedCaseBranchCheck)
              (case (get branch binder)
                (None _
                  (case (((Protoss.tcTypeEq typeEnv) Protoss.tcUnit) payloadType)
                    (true
                      ((((get branch bodyCheck) typeEnv)
                        ((TermEnv.insertRecurResult result) termEnv))
                        result))
                    (false
                      (Protoss.tcErr
                        ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                          (Protoss.tcSomeType payloadType))
                          Protoss.tcNoType)
                          (get branch constructor))
                          "variant branch requires payload binder")))))
                (Some name
                  (let (payloadEnv TermEnv
                    (((TermEnv.insert name) payloadType) termEnv))
                    (let (recurEnv TermEnv
                      (((((TermEnv.insertDirectRecurPayload typeEnv) target)
                        name)
                        payloadType)
                        ((TermEnv.insertRecurResult result) payloadEnv)))
                      ((((get branch bodyCheck) typeEnv) recurEnv) result))))))))))))

(def Protoss.tcCheckDefRecVariantBranches
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> TypeExpr
    (-> (List TypecheckExpectedCaseBranchCheck)
      (-> (List ProtossVariantCase) (-> Expr (Result TypeError TypeExpr))))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (target TypeExpr)
        (lambda (result TypeExpr)
          (lambda (branches (List TypecheckExpectedCaseBranchCheck))
            (lambda (cases (List ProtossVariantCase))
              (lambda (summaryExpr Expr)
                (case ((Protoss.tcUnknownExpectedVariantCheckBranch cases) branches)
                  (Some unknown
                    (Protoss.tcErr
                      ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                        Protoss.tcNoType)
                        Protoss.tcNoType)
                        unknown)
                        ((String.concat "variant case unknown branch: ") unknown))))
                  (None _
                    (case ((Protoss.tcMissingExpectedVariantCheckBranch cases) branches)
                      (Some missing
                        (Protoss.tcErr
                          ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                            Protoss.tcNoType)
                            Protoss.tcNoType)
                            missing)
                            ((String.concat "variant case missing branch: ") missing))))
                      (None _
                        (foldList cases
                          (Protoss.tcOk result)
                          (lambda (caseDecl ProtossVariantCase)
                            (lambda (acc (Result TypeError TypeExpr))
                              (case acc
                                (Err err (variant Err err))
                                (Ok ignored
                                  (case ((Protoss.tcFindExpectedCaseBranchCheck
                                          (get caseDecl name))
                                          branches)
                                    (None _
                                      (Protoss.tcErr
                                        ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                                          Protoss.tcNoType)
                                          Protoss.tcNoType)
                                          (get caseDecl name))
                                          ((String.concat "variant case missing branch: ")
                                            (get caseDecl name)))))
                                    (Some branch
                                      ((((((Protoss.tcRunDefRecVariantBranchCheck typeEnv)
                                        termEnv)
                                        target)
                                        result)
                                        (get caseDecl payload))
                                        branch))))))))))))))))))))

(def Protoss.tcCheckDefRecVariant
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> TypeExpr (-> ProtossDefRecVariant
    (Result TypeError TypeExpr))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (input TypeExpr)
        (lambda (result TypeExpr)
          (lambda (body ProtossDefRecVariant)
            (case ((Protoss.tcVariantCasesOfType typeEnv) input)
              (None _
                (Protoss.tcErr
                  ((((((Protoss.tcError "SELF_TC002") Protoss.tcNoDef)
                    Protoss.tcNoType)
                    (Protoss.tcSomeType input))
                    (Protoss.renderType input))
                    "defrec variant input must be Variant")))
              (Some variantCases
                (let (branchChecks (List TypecheckExpectedCaseBranchCheck)
                  (foldList (get body branches)
                    (Nil TypecheckExpectedCaseBranchCheck)
                    (lambda (branch ProtossCaseBranch)
                      (lambda (acc (List TypecheckExpectedCaseBranchCheck))
                        (let (bodyCheck (Protoss.tcCheckExprAsGo (get branch body)))
                          (Cons TypecheckExpectedCaseBranchCheck
                            (record
                              (constructor (get branch constructor))
                              (binder (get branch binder))
                              (bodyCheck bodyCheck))
                            acc))))))
                  (let (paramEnv TermEnv
                    (((TermEnv.insert (get body param)) input) termEnv))
                    (case (((((((Protoss.tcCheckDefRecVariantBranches typeEnv) paramEnv)
                            input)
                            result)
                            branchChecks)
                            variantCases)
                            (variant PEVar (get body param)))
                      (Err err (variant Err err))
                      (Ok checkedBranches
                        (Protoss.tcOk ((Protoss.tcFun input) result))))))))))))))

(def Protoss.tcCheckDefRec
  (-> TypeEnv (-> TermEnv (-> ProtossDefRec (Result TypeError TypeExpr))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (def ProtossDefRec)
        (let (checked (Result TypeError TypeExpr)
          (case (get def typ)
            (PTFun pair
              (case (get def body)
                (PDRNat body
                  (((((Protoss.tcCheckDefRecNat typeEnv) termEnv)
                    (get pair first))
                    (get pair second))
                    body))
                (PDRList body
                  (((((Protoss.tcCheckDefRecList typeEnv) termEnv)
                    (get pair first))
                    (get pair second))
                    body))
                (PDRVariant body
                  (((((Protoss.tcCheckDefRecVariant typeEnv) termEnv)
                    (get pair first))
                    (get pair second))
                    body))))
            (_ ((Protoss.tcUnsupported Protoss.tcNoDef) "defrec requires function type"))))
          (case checked
            (Err err (variant Err ((Protoss.tcErrorWithDefinition (get def name)) err)))
            (Ok actual (Protoss.tcOk actual))))))))

(def Protoss.tcDeclStep
  (-> TypeEnv (-> TermEnv (-> Decl (-> TypecheckState TypecheckState))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (decl Decl)
        (lambda (state TypecheckState)
          (case (get state error)
            (Some err state)
            (None
              (case decl
                (PDDef def
                  (case (((Protoss.tcCheckDef typeEnv) termEnv) def)
	                    (Err err ((TypecheckState.withError err) state))
	                    (Ok typ (((TypecheckState.addDefinition (get def name)) typ) state))))
	                (PDDefCap def
	                  (case (((Protoss.tcCheckCapDef typeEnv) termEnv) def)
	                    (Err err ((TypecheckState.withError err) state))
	                    (Ok typ (((TypecheckState.addDefinition (get def name)) typ) state))))
		                (PDDefPoly def
		                  (case (((Protoss.tcCheckPolyDef typeEnv) termEnv) def)
		                    (Err err ((TypecheckState.withError err) state))
		                    (Ok typ (((TypecheckState.addDefinition (get def name)) typ) state))))
                (PDDefPolyCap def
                  (case (((Protoss.tcCheckPolyCapDef typeEnv) termEnv) def)
                    (Err err ((TypecheckState.withError err) state))
                    (Ok typ (((TypecheckState.addDefinition (get def name)) typ) state))))
                (PDDefRec def
                  (case (((Protoss.tcCheckDefRec typeEnv) termEnv) def)
                    (Err err ((TypecheckState.withError err) state))
                    (Ok typ (((TypecheckState.addDefinition (get def name)) typ) state))))
                (_ state)))))))))

(def Protoss.tcDecls (-> (List Decl) (Result TypeError TypecheckReport))
  (lambda (decls (List Decl))
    (case (Protoss.checkStaticDecls decls)
      (Err message
        (variant Err
          ((((((Protoss.tcError "SELF_TC010") Protoss.tcNoDef)
            Protoss.tcNoType)
            Protoss.tcNoType)
            "static frontend")
            message)))
      (Ok staticReport
        (let (typeEnv TypeEnv (Protoss.tcTypeEnvOfDecls decls))
          (let (termEnv TermEnv (Protoss.tcTermEnvOfDecls decls))
            (let (state TypecheckState
              (foldList decls TypecheckState.empty
                (lambda (decl Decl)
                  (lambda (acc TypecheckState)
                    ((((Protoss.tcDeclStep typeEnv) termEnv) decl) acc)))))
              (case (get state error)
                (Some err (variant Err err))
                (None _
                  (variant Ok
                    (record
                      (definitions (get state definitions))
                      (unsupported (get state unsupported)))))))))))))

(def Protoss.tcText (-> String (Result TypeError TypecheckReport))
  (lambda (source String)
    (case (Protoss.parseText source)
      (Err message
        (variant Err
          ((((((Protoss.tcError "SELF_TC008") Protoss.tcNoDef)
            Protoss.tcNoType)
            Protoss.tcNoType)
            "parse")
            message)))
      (Ok decls (Protoss.tcDecls decls)))))

(def Json.null Json
  (variant JNull unit))

(def Json.bool (-> Bool Json)
  (lambda (value Bool)
    (variant JBool value)))

(def Json.nat (-> Nat Json)
  (lambda (value Nat)
    (variant JNat value)))

(def Json.string (-> String Json)
  (lambda (value String)
    (variant JString value)))

(def Json.array (-> (List Json) Json)
  (lambda (items (List Json))
    (variant JArray items)))

(def Json.object (-> (Assoc String Json) Json)
  (lambda (fields (Assoc String Json))
    (variant JObject fields)))

(def Json.singleton (-> String (-> Json Json))
  (lambda (key String)
    (lambda (value Json)
      (Json.object
        ((((inst Assoc.insert String Json) key) value)
          (inst Assoc.empty String Json))))))

(def Json.escapeChar (-> String String)
  (lambda (ch String)
    (case ((String.eqString ch) "\"")
      (true "\\\"")
      (false
        (case ((String.eqString ch) "\\")
          (true "\\\\")
          (false
            (case ((String.eqString ch) "\n")
              (true "\\n")
              (false
                (case ((String.eqString ch) "\r")
                  (true "\\r")
                  (false
                    (case ((String.eqString ch) "\t")
                      (true "\\t")
                      (false ch))))))))))))

(def Json.escapeString (-> String String)
  (lambda (value String)
    (get
      (foldNat (String.length value)
        (record
          (first (TextCursor.start value))
          (second String.empty))
        (lambda (state (Pair TextCursor String))
          (case (TextCursor.current (get state first))
            (None state)
            (Some ch
              (record
                (first (TextCursor.advance (get state first)))
                (second
                  ((String.concat (get state second)) (Json.escapeChar ch))))))))
      second)))

(def Json.renderString (-> String String)
  (lambda (value String)
    ((String.concat "\"") ((String.concat (Json.escapeString value)) "\""))))

(def Json.renderBool (-> Bool String)
  (lambda (value Bool)
    (case value
      (true "true")
      (false "false"))))

(defrec Json.render (-> Json String)
  (variant json)
  (JArray items
    ((String.concat "[")
      ((String.concat
        (foldList items String.empty
          (lambda (item Json)
            (lambda (acc String)
              (let (current String (recur item))
                (case (String.isEmpty acc)
                  (true current)
                  (false ((String.concat current) ((String.concat ",") acc)))))))))
        "]")))
  (JBool value (Json.renderBool value))
  (JNat value (Nat.toString value))
  (JNull "null")
  (JObject fields
    ((String.concat "{")
      ((String.concat
        (foldList fields String.empty
          (lambda (field (Pair String Json))
            (lambda (acc String)
              (let (current String
                ((String.concat (Json.renderString (get field first)))
                  ((String.concat ":") (recur (get field second)))))
                (case (String.isEmpty acc)
                  (true current)
                  (false ((String.concat current) ((String.concat ",") acc)))))))))
        "}")))
  (JString value (Json.renderString value)))

(def JsonLexerState.make
  (-> TextCursor (-> JsonLexMode (-> (List JsonToken) (-> (Maybe String) JsonLexerState))))
  (lambda (cursor TextCursor)
    (lambda (mode JsonLexMode)
      (lambda (tokens (List JsonToken))
        (lambda (error (Maybe String))
          (record (cursor cursor) (mode mode) (tokens tokens) (error error)))))))

(def JsonLexerState.ok (-> TextCursor (-> JsonLexMode (-> (List JsonToken) JsonLexerState)))
  (lambda (cursor TextCursor)
    (lambda (mode JsonLexMode)
      (lambda (tokens (List JsonToken))
        ((((JsonLexerState.make cursor) mode) tokens) (variant None unit))))))

(def JsonLexerState.fail (-> String (-> JsonLexerState JsonLexerState))
  (lambda (message String)
    (lambda (state JsonLexerState)
      ((((JsonLexerState.make (get state cursor)) (get state mode)) (get state tokens))
        (variant Some message)))))

(def JsonLexerState.withMode (-> JsonLexMode (-> JsonLexerState JsonLexerState))
  (lambda (mode JsonLexMode)
    (lambda (state JsonLexerState)
      ((((JsonLexerState.make (get state cursor)) mode) (get state tokens)) (get state error)))))

(def JsonLexerState.advance (-> JsonLexerState JsonLexerState)
  (lambda (state JsonLexerState)
    ((((JsonLexerState.make (TextCursor.advance (get state cursor))) (get state mode))
      (get state tokens))
      (get state error))))

(def JsonLexerState.addToken (-> JsonToken (-> JsonLexerState JsonLexerState))
  (lambda (token JsonToken)
    (lambda (state JsonLexerState)
      ((((JsonLexerState.make (get state cursor)) (get state mode))
        (Cons JsonToken token (get state tokens)))
        (get state error)))))

(def Json.syntaxChars (List String)
  (Cons String "{"
    (Cons String "}"
      (Cons String "["
        (Cons String "]"
          (Cons String ":"
            (Cons String "," (Nil String))))))))

(def Json.isSyntaxChar (-> String Bool)
  (lambda (ch String)
    ((((inst List.member String) String.eqString) ch) Json.syntaxChars)))

(def Json.isTokenBoundary (-> String Bool)
  (lambda (ch String)
    ((Bool.or (String.isWhitespace ch)) (Json.isSyntaxChar ch))))

(def Json.keywordToken (-> String (Result String JsonToken))
  (lambda (keyword String)
    (case ((String.eqString keyword) "true")
      (true (variant Ok (variant JTBool true)))
      (false
        (case ((String.eqString keyword) "false")
          (true (variant Ok (variant JTBool false)))
          (false
            (case ((String.eqString keyword) "null")
              (true (variant Ok (variant JTNull unit)))
              (false (variant Err "invalid JSON keyword")))))))))

(def JsonLexerState.addKeyword (-> String (-> JsonLexerState JsonLexerState))
  (lambda (keyword String)
    (lambda (state JsonLexerState)
      (case (Json.keywordToken keyword)
        (Err err ((JsonLexerState.fail err) state))
        (Ok token ((JsonLexerState.addToken token) state))))))

(def Json.appendDigit (-> Nat (-> String (Result String Nat)))
  (lambda (value Nat)
    (lambda (ch String)
      (case (String.digitValue ch)
        (None (variant Err "expected JSON digit"))
        (Some digit
          (variant Ok ((Nat.add ((Nat.mul value) 10)) digit)))))))

(def Json.lexDefaultChar (-> JsonLexerState (-> String JsonLexerState))
  (lambda (state JsonLexerState)
    (lambda (ch String)
      (case (String.isWhitespace ch)
        (true state)
        (false
          (case ((String.eqString ch) "{")
            (true ((JsonLexerState.addToken (variant JTLBrace unit)) state))
            (false
              (case ((String.eqString ch) "}")
                (true ((JsonLexerState.addToken (variant JTRBrace unit)) state))
                (false
                  (case ((String.eqString ch) "[")
                    (true ((JsonLexerState.addToken (variant JTLBracket unit)) state))
                    (false
                      (case ((String.eqString ch) "]")
                        (true ((JsonLexerState.addToken (variant JTRBracket unit)) state))
                        (false
                          (case ((String.eqString ch) ":")
                            (true ((JsonLexerState.addToken (variant JTColon unit)) state))
                            (false
                              (case ((String.eqString ch) ",")
                                (true ((JsonLexerState.addToken (variant JTComma unit)) state))
                                (false
                                  (case ((String.eqString ch) "\"")
                                    (true ((JsonLexerState.withMode (variant JsonLexString "")) state))
                                    (false
                                      (case (String.digitValue ch)
                                        (Some digit
                                          ((JsonLexerState.withMode (variant JsonLexNumber digit)) state))
                                        (None
                                          (case (String.isAtomChar ch)
                                            (true
                                              ((JsonLexerState.withMode (variant JsonLexKeyword ch)) state))
                                            (false
                                              ((JsonLexerState.fail "unexpected JSON character") state))))))))))))))))))))))))

(def Json.lexNumberChar (-> JsonLexerState (-> Nat (-> String JsonLexerState)))
  (lambda (state JsonLexerState)
    (lambda (value Nat)
      (lambda (ch String)
        (case (String.digitValue ch)
          (Some digit
            (case ((Json.appendDigit value) ch)
              (Err err ((JsonLexerState.fail err) state))
              (Ok next ((JsonLexerState.withMode (variant JsonLexNumber next)) state))))
          (None
            (case (Json.isTokenBoundary ch)
              (true
                ((Json.lexDefaultChar
                  ((JsonLexerState.addToken (variant JTNat value))
                    ((JsonLexerState.withMode (variant JsonLexDefault unit)) state)))
                  ch))
              (false ((JsonLexerState.fail "invalid JSON number") state)))))))))

(def Json.lexKeywordChar (-> JsonLexerState (-> String (-> String JsonLexerState)))
  (lambda (state JsonLexerState)
    (lambda (keyword String)
      (lambda (ch String)
        (case (Json.isTokenBoundary ch)
          (true
            ((Json.lexDefaultChar
              ((JsonLexerState.addKeyword keyword)
                ((JsonLexerState.withMode (variant JsonLexDefault unit)) state)))
              ch))
          (false
            ((JsonLexerState.withMode (variant JsonLexKeyword ((String.concat keyword) ch))) state)))))))

(def Json.lexStringChar (-> JsonLexerState (-> String (-> String JsonLexerState)))
  (lambda (state JsonLexerState)
    (lambda (text String)
      (lambda (ch String)
        (case ((String.eqString ch) "\"")
          (true
            ((JsonLexerState.addToken (variant JTString text))
              ((JsonLexerState.withMode (variant JsonLexDefault unit)) state)))
          (false
            (case ((String.eqString ch) "\\")
              (true ((JsonLexerState.withMode (variant JsonLexEscape text)) state))
              (false
                ((JsonLexerState.withMode (variant JsonLexString ((String.concat text) ch))) state)))))))))

(def Json.lexEscapeChar (-> JsonLexerState (-> String (-> String JsonLexerState)))
  (lambda (state JsonLexerState)
    (lambda (text String)
      (lambda (ch String)
        (case ((String.eqString ch) "\"")
          (true ((JsonLexerState.withMode (variant JsonLexString ((String.concat text) "\""))) state))
          (false
            (case ((String.eqString ch) "\\")
              (true ((JsonLexerState.withMode (variant JsonLexString ((String.concat text) "\\"))) state))
              (false
                (case ((String.eqString ch) "n")
                  (true ((JsonLexerState.withMode (variant JsonLexString ((String.concat text) "\n"))) state))
                  (false
                    (case ((String.eqString ch) "r")
                      (true ((JsonLexerState.withMode (variant JsonLexString ((String.concat text) "\r"))) state))
                      (false
                        (case ((String.eqString ch) "t")
                          (true ((JsonLexerState.withMode (variant JsonLexString ((String.concat text) "\t"))) state))
                          (false ((JsonLexerState.fail "invalid JSON escape") state)))))))))))))))

(def Json.lexStep (-> JsonLexerState (-> String JsonLexerState))
  (lambda (state JsonLexerState)
    (lambda (ch String)
      (case (get state error)
        (Some message state)
        (None
          (case (get state mode)
            (JsonLexDefault (Json.lexDefaultChar state ch))
            (JsonLexString text (((Json.lexStringChar state) text) ch))
            (JsonLexEscape text (((Json.lexEscapeChar state) text) ch))
            (JsonLexNumber value (((Json.lexNumberChar state) value) ch))
            (JsonLexKeyword keyword (((Json.lexKeywordChar state) keyword) ch))))))))

(def Json.lexCurrent (-> JsonLexerState JsonLexerState)
  (lambda (state JsonLexerState)
    (case (TextCursor.current (get state cursor))
      (None state)
      (Some ch (JsonLexerState.advance ((Json.lexStep state) ch))))))

(def Json.lexFinalize (-> JsonLexerState (Result String (List JsonToken)))
  (lambda (state JsonLexerState)
    (case (get state error)
      (Some message (variant Err message))
      (None
        (case (get state mode)
          (JsonLexDefault (variant Ok ((inst List.reverse JsonToken) (get state tokens))))
          (JsonLexNumber value
            (variant Ok
              ((inst List.reverse JsonToken)
                (Cons JsonToken (variant JTNat value) (get state tokens)))))
          (JsonLexKeyword keyword
            (let (next JsonLexerState ((JsonLexerState.addKeyword keyword) state))
              (case (get next error)
                (Some err (variant Err err))
                (None _ (variant Ok ((inst List.reverse JsonToken) (get next tokens)))))))
          (JsonLexString text (variant Err "unterminated JSON string"))
          (JsonLexEscape text (variant Err "unterminated JSON escape")))))))

(def Json.lexTokens (-> String (Result String (List JsonToken)))
  (lambda (source String)
    (Json.lexFinalize
      (foldNat (String.length source)
        (((JsonLexerState.ok (TextCursor.start source)) (variant JsonLexDefault unit)) (Nil JsonToken))
        (lambda (state JsonLexerState)
          (Json.lexCurrent state))))))

(def JsonFrame.array JsonFrame
  (record
    (kind "array")
    (items (Nil Json))
    (fields (inst Assoc.empty String Json))
    (pendingKey (variant None unit))
    (expect "array-value-or-end")))

(def JsonFrame.object JsonFrame
  (record
    (kind "object")
    (items (Nil Json))
    (fields (inst Assoc.empty String Json))
    (pendingKey (variant None unit))
    (expect "object-key-or-end")))

(def JsonFrame.withExpect (-> JsonFrame (-> String JsonFrame))
  (lambda (frame JsonFrame)
    (lambda (expect String)
      (record
        (kind (get frame kind))
        (items (get frame items))
        (fields (get frame fields))
        (pendingKey (get frame pendingKey))
        (expect expect)))))

(def JsonFrame.addItem (-> JsonFrame (-> Json JsonFrame))
  (lambda (frame JsonFrame)
    (lambda (value Json)
      (record
        (kind (get frame kind))
        (items (Cons Json value (get frame items)))
        (fields (get frame fields))
        (pendingKey (get frame pendingKey))
        (expect "array-comma-or-end")))))

(def JsonFrame.setKey (-> JsonFrame (-> String JsonFrame))
  (lambda (frame JsonFrame)
    (lambda (key String)
      (record
        (kind (get frame kind))
        (items (get frame items))
        (fields (get frame fields))
        (pendingKey (variant Some key))
        (expect "object-colon")))))

(def JsonFrame.addField (-> JsonFrame (-> String (-> Json JsonFrame)))
  (lambda (frame JsonFrame)
    (lambda (key String)
      (lambda (value Json)
        (record
          (kind (get frame kind))
          (items (get frame items))
          (fields
            (Cons (Pair String Json)
              (record (first key) (second value))
              (get frame fields)))
          (pendingKey (variant None unit))
          (expect "object-comma-or-end"))))))

(def JsonParserState.make
  (-> (List JsonFrame) (-> (Maybe Json) (-> (Maybe String) JsonParserState)))
  (lambda (stack (List JsonFrame))
    (lambda (value (Maybe Json))
      (lambda (error (Maybe String))
        (record (stack stack) (value value) (error error))))))

(def JsonParserState.initial JsonParserState
  (((JsonParserState.make (Nil JsonFrame)) (variant None unit)) (variant None unit)))

(def JsonParserState.fail (-> String (-> JsonParserState JsonParserState))
  (lambda (message String)
    (lambda (state JsonParserState)
      (((JsonParserState.make (get state stack)) (get state value)) (variant Some message)))))

(def JsonParserState.withStack (-> (List JsonFrame) (-> JsonParserState JsonParserState))
  (lambda (stack (List JsonFrame))
    (lambda (state JsonParserState)
      (((JsonParserState.make stack) (get state value)) (get state error)))))

(def JsonParserState.setTopValue (-> Json (-> JsonParserState JsonParserState))
  (lambda (value Json)
    (lambda (state JsonParserState)
      (((JsonParserState.make (Nil JsonFrame)) (variant Some value)) (get state error)))))

(def JsonParserState.canStartValue (-> JsonParserState Bool)
  (lambda (state JsonParserState)
    (caseList (get state stack)
      (Nil
        (case (get state value)
          (None _ true)
          (Some value false)))
      (Cons frame rest
        (case ((String.eqString (get frame kind)) "array")
          (true
            ((Bool.or ((String.eqString (get frame expect)) "array-value-or-end"))
              ((String.eqString (get frame expect)) "array-value")))
          (false
            (case ((String.eqString (get frame kind)) "object")
              (true ((String.eqString (get frame expect)) "object-value"))
              (false false))))))))

(def JsonParserState.pushFrame (-> JsonFrame (-> JsonParserState JsonParserState))
  (lambda (frame JsonFrame)
    (lambda (state JsonParserState)
      (case (JsonParserState.canStartValue state)
        (true
          (((JsonParserState.make (Cons JsonFrame frame (get state stack)))
            (get state value))
            (get state error)))
        (false ((JsonParserState.fail "unexpected JSON value") state))))))

(def JsonParserState.emitValue (-> Json (-> JsonParserState JsonParserState))
  (lambda (value Json)
    (lambda (state JsonParserState)
      (case (get state error)
        (Some message state)
        (None
          (caseList (get state stack)
            (Nil
              (case (get state value)
                (None _ ((JsonParserState.setTopValue value) state))
                (Some old ((JsonParserState.fail "trailing JSON value") state))))
            (Cons frame rest
              (case ((String.eqString (get frame kind)) "array")
                (true
                  (case
                    ((Bool.or ((String.eqString (get frame expect)) "array-value-or-end"))
                      ((String.eqString (get frame expect)) "array-value"))
                    (true
                      (((JsonParserState.make
                        (Cons JsonFrame ((JsonFrame.addItem frame) value) rest))
                        (get state value))
                        (get state error)))
                    (false ((JsonParserState.fail "unexpected JSON value") state))))
                (false
                  (case ((String.eqString (get frame kind)) "object")
                    (true
                      (case ((String.eqString (get frame expect)) "object-value")
                        (true
                          (case (get frame pendingKey)
                            (None _ ((JsonParserState.fail "missing JSON object key") state))
                            (Some key
                              (((JsonParserState.make
                                (Cons JsonFrame (((JsonFrame.addField frame) key) value) rest))
                                (get state value))
                                (get state error)))))
                        (false ((JsonParserState.fail "unexpected JSON value") state))))
                    (false ((JsonParserState.fail "invalid JSON parser frame") state))))))))))))

(def JsonParserState.emitString (-> String (-> JsonParserState JsonParserState))
  (lambda (text String)
    (lambda (state JsonParserState)
      (case (get state error)
        (Some message state)
        (None
          (caseList (get state stack)
            (Nil ((JsonParserState.emitValue (Json.string text)) state))
            (Cons frame rest
              (case
                ((Bool.and ((String.eqString (get frame kind)) "object"))
                  ((Bool.or ((String.eqString (get frame expect)) "object-key-or-end"))
                    ((String.eqString (get frame expect)) "object-key")))
                (true
                  (((JsonParserState.make
                    (Cons JsonFrame ((JsonFrame.setKey frame) text) rest))
                    (get state value))
                    (get state error)))
                (false ((JsonParserState.emitValue (Json.string text)) state))))))))))

(def JsonParserState.closeArray (-> JsonParserState JsonParserState)
  (lambda (state JsonParserState)
    (case (get state error)
      (Some message state)
      (None
        (caseList (get state stack)
          (Nil ((JsonParserState.fail "unexpected ]") state))
          (Cons frame rest
            (case ((String.eqString (get frame kind)) "array")
              (false ((JsonParserState.fail "unexpected ]") state))
              (true
                (case ((String.eqString (get frame expect)) "array-value")
                  (true ((JsonParserState.fail "expected JSON value") state))
                  (false
                    ((JsonParserState.emitValue
                      (Json.array ((inst List.reverse Json) (get frame items))))
                      (((JsonParserState.make rest) (get state value)) (get state error)))))))))))))

(def JsonParserState.closeObject (-> JsonParserState JsonParserState)
  (lambda (state JsonParserState)
    (case (get state error)
      (Some message state)
      (None
        (caseList (get state stack)
          (Nil ((JsonParserState.fail "unexpected }") state))
          (Cons frame rest
            (case ((String.eqString (get frame kind)) "object")
              (false ((JsonParserState.fail "unexpected }") state))
              (true
                (case ((String.eqString (get frame expect)) "object-key")
                  (true ((JsonParserState.fail "expected JSON object key") state))
                  (false
                    (case ((String.eqString (get frame expect)) "object-colon")
                      (true ((JsonParserState.fail "expected JSON object colon") state))
                      (false
                        (case ((String.eqString (get frame expect)) "object-value")
                          (true ((JsonParserState.fail "expected JSON value") state))
                          (false
                            ((JsonParserState.emitValue
                              (Json.object
                                ((inst List.reverse (Pair String Json)) (get frame fields))))
                              (((JsonParserState.make rest) (get state value))
                                (get state error)))))))))))))))))

(def JsonParserState.comma (-> JsonParserState JsonParserState)
  (lambda (state JsonParserState)
    (case (get state error)
      (Some message state)
      (None
        (caseList (get state stack)
          (Nil ((JsonParserState.fail "unexpected ,") state))
          (Cons frame rest
            (case ((String.eqString (get frame kind)) "array")
              (true
                (case ((String.eqString (get frame expect)) "array-comma-or-end")
                  (true
                    (((JsonParserState.make
                      (Cons JsonFrame ((JsonFrame.withExpect frame) "array-value") rest))
                      (get state value))
                      (get state error)))
                  (false ((JsonParserState.fail "unexpected ,") state))))
              (false
                (case ((String.eqString (get frame kind)) "object")
                  (true
                    (case ((String.eqString (get frame expect)) "object-comma-or-end")
                      (true
                        (((JsonParserState.make
                          (Cons JsonFrame ((JsonFrame.withExpect frame) "object-key") rest))
                          (get state value))
                          (get state error)))
                      (false ((JsonParserState.fail "unexpected ,") state))))
                  (false ((JsonParserState.fail "unexpected ,") state)))))))))))

(def JsonParserState.colon (-> JsonParserState JsonParserState)
  (lambda (state JsonParserState)
    (case (get state error)
      (Some message state)
      (None
        (caseList (get state stack)
          (Nil ((JsonParserState.fail "unexpected :") state))
          (Cons frame rest
            (case
              ((Bool.and ((String.eqString (get frame kind)) "object"))
                ((String.eqString (get frame expect)) "object-colon"))
              (true
                (((JsonParserState.make
                  (Cons JsonFrame ((JsonFrame.withExpect frame) "object-value") rest))
                  (get state value))
                  (get state error)))
              (false ((JsonParserState.fail "unexpected :") state)))))))))

(def Json.parseToken (-> JsonParserState (-> JsonToken JsonParserState))
  (lambda (state JsonParserState)
    (lambda (token JsonToken)
      (case (get state error)
        (Some message state)
        (None
          (case token
            (JTLBrace ((JsonParserState.pushFrame JsonFrame.object) state))
            (JTRBrace (JsonParserState.closeObject state))
            (JTLBracket ((JsonParserState.pushFrame JsonFrame.array) state))
            (JTRBracket (JsonParserState.closeArray state))
            (JTColon (JsonParserState.colon state))
            (JTComma (JsonParserState.comma state))
            (JTNull ((JsonParserState.emitValue Json.null) state))
            (JTBool value ((JsonParserState.emitValue (Json.bool value)) state))
            (JTNat value ((JsonParserState.emitValue (Json.nat value)) state))
            (JTString value ((JsonParserState.emitString value) state))))))))

(def Json.parseFinalize (-> JsonParserState (Result String Json))
  (lambda (state JsonParserState)
    (case (get state error)
      (Some message (variant Err message))
      (None
        (caseList (get state stack)
          (Cons frame rest (variant Err "unterminated JSON container"))
          (Nil
            (case (get state value)
              (None _ (variant Err "expected JSON value"))
              (Some value (variant Ok value)))))))))

(def Json.parseTokens (-> (List JsonToken) (Result String Json))
  (lambda (tokens (List JsonToken))
    (Json.parseFinalize
      (foldList ((inst List.reverse JsonToken) tokens)
        JsonParserState.initial
        (lambda (token JsonToken)
          (lambda (state JsonParserState)
            ((Json.parseToken state) token)))))))

(def Json.parseText (-> String (Result String Json))
  (lambda (source String)
    (case (Json.lexTokens source)
      (Err err (variant Err err))
      (Ok tokens (Json.parseTokens tokens)))))

(def Json.isNull (-> Json Bool)
  (lambda (json Json)
    (case json
      (JArray items false)
      (JBool value false)
      (JNat value false)
      (JNull true)
      (JObject fields false)
      (JString value false))))

(def Json.getField (-> String (-> Json (Maybe Json)))
  (lambda (key String)
    (lambda (json Json)
      (case json
        (JArray items (variant None unit))
        (JBool value (variant None unit))
        (JNat value (variant None unit))
        (JNull (variant None unit))
        (JObject fields ((((inst Assoc.get String Json) String.eqString) key) fields))
        (JString value (variant None unit))))))

(def Json.expectString (-> Json (Result String String))
  (lambda (json Json)
    (case json
      (JArray items (variant Err "expected String"))
      (JBool value (variant Err "expected String"))
      (JNat value (variant Err "expected String"))
      (JNull (variant Err "expected String"))
      (JObject fields (variant Err "expected String"))
      (JString value (variant Ok value)))))

(def Json.expectNat (-> Json (Result String Nat))
  (lambda (json Json)
    (case json
      (JArray items (variant Err "expected Nat"))
      (JBool value (variant Err "expected Nat"))
      (JNat value (variant Ok value))
      (JNull (variant Err "expected Nat"))
      (JObject fields (variant Err "expected Nat"))
      (JString value (variant Err "expected Nat")))))

(def Json.expectBool (-> Json (Result String Bool))
  (lambda (json Json)
    (case json
      (JArray items (variant Err "expected Bool"))
      (JBool value (variant Ok value))
      (JNat value (variant Err "expected Bool"))
      (JNull (variant Err "expected Bool"))
      (JObject fields (variant Err "expected Bool"))
      (JString value (variant Err "expected Bool")))))

(def Json.expectArray (-> Json (Result String (List Json)))
  (lambda (json Json)
    (case json
      (JArray items (variant Ok items))
      (JBool value (variant Err "expected Array"))
      (JNat value (variant Err "expected Array"))
      (JNull (variant Err "expected Array"))
      (JObject fields (variant Err "expected Array"))
      (JString value (variant Err "expected Array")))))

(def Json.expectObject (-> Json (Result String (Assoc String Json)))
  (lambda (json Json)
    (case json
      (JArray items (variant Err "expected Object"))
      (JBool value (variant Err "expected Object"))
      (JNat value (variant Err "expected Object"))
      (JNull (variant Err "expected Object"))
      (JObject fields (variant Ok fields))
      (JString value (variant Err "expected Object")))))

(def Json.expectField (-> String (-> Json (Result String Json)))
  (lambda (key String)
    (lambda (json Json)
      (case json
        (JArray items (variant Err "expected Object"))
        (JBool value (variant Err "expected Object"))
        (JNat value (variant Err "expected Object"))
        (JNull (variant Err "expected Object"))
        (JObject fields
          (case ((((inst Assoc.get String Json) String.eqString) key) fields)
            (None (variant Err "missing field"))
            (Some value (variant Ok value))))
        (JString value (variant Err "expected Object"))))))

(defpoly Json.expectFieldAs (params A)
  (-> (-> Json (Result String A)) (-> String (-> Json (Result String A))))
  (lambda (decode (-> Json (Result String A)))
    (lambda (key String)
      (lambda (json Json)
        (case ((Json.expectField key) json)
          (Err err (variant Err err))
          (Ok value (decode value)))))))

;; Html helpers -------------------------------------------------------------
;; Ergonomic, fully-applicable wrappers over the node/attr/on primitives.
;; Qualified Html.* names avoid collisions. Each is polymorphic in Msg, so the
;; produced Attr/View threads the caller's message type. attr-based helpers
;; build an Attr Unit that unifies into any (List (Attr Msg)).

(defpoly Html.div (params Msg)
  (-> (List (Attr Msg)) (-> (List (View Msg)) (View Msg)))
  (lambda (attrs (List (Attr Msg)))
    (lambda (children (List (View Msg)))
      (node "div" attrs children))))

(defpoly Html.span (params Msg)
  (-> (List (Attr Msg)) (-> (List (View Msg)) (View Msg)))
  (lambda (attrs (List (Attr Msg)))
    (lambda (children (List (View Msg)))
      (node "span" attrs children))))

(defpoly Html.p (params Msg)
  (-> (List (Attr Msg)) (-> (List (View Msg)) (View Msg)))
  (lambda (attrs (List (Attr Msg)))
    (lambda (children (List (View Msg)))
      (node "p" attrs children))))

(defpoly Html.ul (params Msg)
  (-> (List (Attr Msg)) (-> (List (View Msg)) (View Msg)))
  (lambda (attrs (List (Attr Msg)))
    (lambda (children (List (View Msg)))
      (node "ul" attrs children))))

(defpoly Html.li (params Msg)
  (-> (List (Attr Msg)) (-> (List (View Msg)) (View Msg)))
  (lambda (attrs (List (Attr Msg)))
    (lambda (children (List (View Msg)))
      (node "li" attrs children))))

(defpoly Html.a (params Msg)
  (-> (List (Attr Msg)) (-> (List (View Msg)) (View Msg)))
  (lambda (attrs (List (Attr Msg)))
    (lambda (children (List (View Msg)))
      (node "a" attrs children))))

(defpoly Html.class (params Msg) (-> String (Attr Msg))
  (lambda (value String) (attr "class" value)))

(defpoly Html.id (params Msg) (-> String (Attr Msg))
  (lambda (value String) (attr "id" value)))

(defpoly Html.href (params Msg) (-> String (Attr Msg))
  (lambda (value String) (attr "href" value)))

(defpoly Html.style (params Msg) (-> String (Attr Msg))
  (lambda (value String) (attr "style" value)))

(defpoly Html.onClick (params Msg) (-> Msg (Attr Msg))
  (lambda (m Msg) (on "click" m)))

(defpoly Html.onInput (params Msg) (-> Msg (Attr Msg))
  (lambda (m Msg) (on "input" m)))

;; ====================================================================
;; Self-hosted frontend — JSON report serialization & CLI entrypoints.
;; These run through the normal Protoss evaluator (see `protoss self ...`).
;; The trusted OCaml kernel still owns canonicalization, typechecking and
;; the content-addressed DefIds; everything below only *reports*.
;; ====================================================================

(def Protoss.jf (-> String (-> Json (Pair String Json)))
  (lambda (key String)
    (lambda (value Json)
      (record (first key) (second value)))))

(def Protoss.jsonObjectOf (-> (List (Pair String Json)) Json)
  (lambda (fields (List (Pair String Json)))
    (Json.object
      (foldList fields (inst Assoc.empty String Json)
        (lambda (field (Pair String Json))
          (lambda (acc (Assoc String Json))
            ((((inst Assoc.insert String Json) (get field first)) (get field second)) acc)))))))

(def Protoss.jsonStrings (-> (List String) Json)
  (lambda (xs (List String))
    (Json.array (((inst List.map String Json) xs) Json.string))))

(def Protoss.jsonError (-> String Json)
  (lambda (message String)
    (Protoss.jsonObjectOf
      (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "error"))
      (Cons (Pair String Json) ((Protoss.jf "diagnostic") (Json.string message))
      (Nil (Pair String Json)))))))

(def Protoss.depOrderToJson (-> ProtossDepOrder Json)
  (lambda (order ProtossDepOrder)
    (case order
      (PDepOrderOk names
        (Protoss.jsonObjectOf
          (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "ok"))
          (Cons (Pair String Json) ((Protoss.jf "order") (Protoss.jsonStrings names))
          (Nil (Pair String Json))))))
      (PDepOrderCycle names
        (Protoss.jsonObjectOf
          (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "cycle"))
          (Cons (Pair String Json) ((Protoss.jf "cycle") (Protoss.jsonStrings names))
          (Nil (Pair String Json)))))))))

(def Protoss.resolveReportToJson (-> ProtossResolveReport Json)
  (lambda (report ProtossResolveReport)
    (Protoss.jsonObjectOf
      (Cons (Pair String Json) ((Protoss.jf "definedTerms") (Protoss.jsonStrings (get report definedTerms)))
      (Cons (Pair String Json) ((Protoss.jf "definedTypes") (Protoss.jsonStrings (get report definedTypes)))
      (Cons (Pair String Json) ((Protoss.jf "termRefs") (Protoss.jsonStrings (get report termRefs)))
      (Cons (Pair String Json) ((Protoss.jf "typeRefs") (Protoss.jsonStrings (get report typeRefs)))
      (Cons (Pair String Json) ((Protoss.jf "exports") (Protoss.jsonStrings (get report exports)))
      (Cons (Pair String Json) ((Protoss.jf "missingTerms") (Protoss.jsonStrings (get report missingTerms)))
      (Cons (Pair String Json) ((Protoss.jf "missingTypes") (Protoss.jsonStrings (get report missingTypes)))
      (Cons (Pair String Json) ((Protoss.jf "missingExports") (Protoss.jsonStrings (get report missingExports)))
      (Cons (Pair String Json) ((Protoss.jf "duplicateTerms") (Protoss.jsonStrings (get report duplicateTerms)))
      (Cons (Pair String Json) ((Protoss.jf "duplicateTypes") (Protoss.jsonStrings (get report duplicateTypes)))
      (Nil (Pair String Json)))))))))))))))

(def Protoss.capabilityReportToJson (-> ProtossCapabilityReport Json)
  (lambda (report ProtossCapabilityReport)
    (Protoss.jsonObjectOf
      (Cons (Pair String Json) ((Protoss.jf "declared") (Protoss.jsonStrings (get report declared)))
      (Cons (Pair String Json) ((Protoss.jf "used") (Protoss.jsonStrings (get report used)))
      (Cons (Pair String Json) ((Protoss.jf "scoped") (Protoss.jsonStrings (get report scoped)))
      (Cons (Pair String Json) ((Protoss.jf "unknownCapabilities") (Protoss.jsonStrings (get report unknownCapabilities)))
      (Cons (Pair String Json) ((Protoss.jf "missingDeclarations") (Protoss.jsonStrings (get report missingDeclarations)))
      (Cons (Pair String Json) ((Protoss.jf "duplicateDeclarations") (Protoss.jsonStrings (get report duplicateDeclarations)))
      (Cons (Pair String Json) ((Protoss.jf "duplicateScopes") (Protoss.jsonStrings (get report duplicateScopes)))
      (Nil (Pair String Json))))))))))))

(def Protoss.declImportPaths (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    ((inst List.reverse String)
      (foldList decls (Nil String)
        (lambda (decl ProtossDecl)
          (lambda (acc (List String))
            (case decl
              (PDImport path (Cons String path acc))
              (_ acc))))))))

(def Protoss.staticReportToJson
  (-> String (-> (List String) (-> ProtossStaticReport Json)))
  (lambda (frontendDefId String)
    (lambda (imports (List String))
      (lambda (report ProtossStaticReport)
        (let (resolve ProtossResolveReport (get report resolve))
          (Protoss.jsonObjectOf
            (Cons (Pair String Json) ((Protoss.jf "parseStatus") (Json.string "ok"))
            (Cons (Pair String Json) ((Protoss.jf "definitions") (Protoss.jsonStrings (get resolve definedTerms)))
            (Cons (Pair String Json) ((Protoss.jf "types") (Protoss.jsonStrings (get resolve definedTypes)))
            (Cons (Pair String Json) ((Protoss.jf "exports") (Protoss.jsonStrings (get resolve exports)))
            (Cons (Pair String Json) ((Protoss.jf "imports") (Protoss.jsonStrings imports))
            (Cons (Pair String Json) ((Protoss.jf "termDeps") (Protoss.depOrderToJson (get report termOrder)))
            (Cons (Pair String Json) ((Protoss.jf "typeDeps") (Protoss.depOrderToJson (get (get report typeEnv) order)))
            (Cons (Pair String Json) ((Protoss.jf "capabilityUse") (Protoss.capabilityReportToJson (get report capabilities)))
            (Cons (Pair String Json) ((Protoss.jf "diagnostics") (Protoss.resolveReportToJson resolve))
            (Cons (Pair String Json) ((Protoss.jf "frontendDefId") (Json.string frontendDefId))
            (Nil (Pair String Json))))))))))))))))))

(def Protoss.tcMaybeStringToJson (-> (Maybe String) Json)
  (lambda (value (Maybe String))
    (case value
      (None _ Json.null)
      (Some text (Json.string text)))))

(def Protoss.tcMaybeTypeToJson (-> (Maybe TypeExpr) Json)
  (lambda (value (Maybe TypeExpr))
    (case value
      (None _ Json.null)
      (Some typ (Json.string (Protoss.renderType typ))))))

(def Protoss.tcErrorToJson (-> TypeError Json)
  (lambda (err TypeError)
    (Protoss.jsonObjectOf
      (Cons (Pair String Json) ((Protoss.jf "code") (Json.string (get err code)))
      (Cons (Pair String Json) ((Protoss.jf "definition") (Protoss.tcMaybeStringToJson (get err definition)))
      (Cons (Pair String Json) ((Protoss.jf "expected") (Protoss.tcMaybeTypeToJson (get err expected)))
      (Cons (Pair String Json) ((Protoss.jf "actual") (Protoss.tcMaybeTypeToJson (get err actual)))
      (Cons (Pair String Json) ((Protoss.jf "summary") (Json.string (get err summary)))
      (Cons (Pair String Json) ((Protoss.jf "message") (Json.string (get err message)))
      (Cons (Pair String Json) ((Protoss.jf "span") Json.null)
      (Nil (Pair String Json))))))))))))

(def Protoss.tcDefinitionToJson (-> (Pair String TypeExpr) Json)
  (lambda (entry (Pair String TypeExpr))
    (Protoss.jsonObjectOf
      (Cons (Pair String Json) ((Protoss.jf "name") (Json.string (get entry first)))
      (Cons (Pair String Json) ((Protoss.jf "type") (Json.string (Protoss.renderType (get entry second))))
      (Nil (Pair String Json)))))))

(def Protoss.tcDefinitionsToJson (-> (Assoc String TypeExpr) Json)
  (lambda (definitions (Assoc String TypeExpr))
    (Json.array
      (((inst List.map (Pair String TypeExpr) Json) definitions)
        Protoss.tcDefinitionToJson))))

(def Protoss.tcReportToJson (-> TypecheckReport Json)
  (lambda (report TypecheckReport)
    (Protoss.jsonObjectOf
      (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "ok"))
      (Cons (Pair String Json) ((Protoss.jf "definitions") (Protoss.tcDefinitionsToJson (get report definitions)))
      (Cons (Pair String Json) ((Protoss.jf "unsupported") (Protoss.jsonStrings (get report unsupported)))
      (Nil (Pair String Json))))))))

(def Protoss.canonAsciiTable String
  " !\"#$%&'()*+,-./0123456789:;<=>?@ABCDEFGHIJKLMNOPQRSTUVWXYZ[\\]^_`abcdefghijklmnopqrstuvwxyz{|}~")

(def Protoss.canonCharRank (-> String Nat)
  (lambda (ch String)
    (get
      (foldNat 95
        (record (index 0) (found 0))
        (lambda (acc CanonCharScan)
          (case ((Nat.eqNat (get acc found)) 0)
            (false (record (index (succ (get acc index))) (found (get acc found))))
            (true
              (case ((String.charAt Protoss.canonAsciiTable) (get acc index))
                (None (record (index (succ (get acc index))) (found 0)))
                (Some entry
                  (case ((String.eqString entry) ch)
                    (true
                      (record
                        (index (succ (get acc index)))
                        (found (succ (get acc index)))))
                    (false (record (index (succ (get acc index))) (found 0))))))))))
      found)))

(def Protoss.canonCmpOrder (-> String (-> String Nat))
  (lambda (a String)
    (lambda (b String)
      (let (la (String.length a))
        (let (lb (String.length b))
          (let (maxLen (case ((Nat.lte la) lb) (true lb) (false la)))
            (get
              (foldNat maxLen
                (record (index (prim.Nat.pred maxLen)) (order 1))
                (lambda (acc CanonCmpScan)
                  (let (i (get acc index))
                    (let (next
                      (case ((String.charAt a) i)
                        (None
                          (case ((String.charAt b) i)
                            (None (get acc order))
                            (Some cb 0)))
                        (Some ca
                          (case ((String.charAt b) i)
                            (None 2)
                            (Some cb
                              (case ((String.eqString ca) cb)
                                (true (get acc order))
                                (false
                                  (let (ra (Protoss.canonCharRank ca))
                                    (let (rb (Protoss.canonCharRank cb))
                                      (case ((Nat.eqNat ra) 0)
                                        (true 3)
                                        (false
                                          (case ((Nat.eqNat rb) 0)
                                            (true 3)
                                            (false
                                              (case ((Nat.lt ra) rb)
                                                (true 0)
                                                (false 2)))))))))))))))
                      (record (index (prim.Nat.pred i)) (order next))))))
              order)))))))

(def Protoss.canonInsertString
  (-> Bool (-> String (-> (List String) (Result String (List String)))))
  (lambda (dropEqual Bool)
    (lambda (x String)
      (lambda (xs (List String))
        (let (scan
          (foldList xs
            (variant (Result String CanonStringInsert) Ok
              (record (placed false) (out (Nil String))))
            (lambda (h String)
              (lambda (acc (Result String CanonStringInsert))
                (case acc
                  (Err err (variant Err err))
                  (Ok state
                    (case (get state placed)
                      (true
                        (variant Ok
                          (record (placed true) (out (Cons String h (get state out))))))
                      (false
                        (let (order ((Protoss.canonCmpOrder h) x))
                          (case ((Nat.eqNat order) 3)
                            (true
                              (variant Err
                                "canonical ordering is undefined for non-ASCII names"))
                            (false
                              (case ((Nat.eqNat order) 1)
                                (true
                                  (case dropEqual
                                    (true
                                      (variant Ok
                                        (record (placed true)
                                          (out (Cons String h (get state out))))))
                                    (false
                                      (variant Ok
                                        (record (placed false)
                                          (out (Cons String h (get state out))))))))
                                (false
                                  (case ((Nat.eqNat order) 0)
                                    (true
                                      (variant Ok
                                        (record (placed true)
                                          (out
                                            (Cons String h
                                              (Cons String x (get state out)))))))
                                    (false
                                      (variant Ok
                                        (record (placed false)
                                          (out (Cons String h (get state out))))))))))))))))))))
          (case scan
            (Err err (variant Err err))
            (Ok state
              (case (get state placed)
                (true (variant Ok (get state out)))
                (false (variant Ok (Cons String x (get state out))))))))))))

(def Protoss.canonInsertField
  (-> CanonFieldText (-> (List CanonFieldText) (Result String (List CanonFieldText))))
  (lambda (x CanonFieldText)
    (lambda (xs (List CanonFieldText))
      (let (scan
        (foldList xs
          (variant (Result String CanonFieldInsert) Ok
            (record (placed false) (out (Nil CanonFieldText))))
          (lambda (h CanonFieldText)
            (lambda (acc (Result String CanonFieldInsert))
              (case acc
                (Err err (variant Err err))
                (Ok state
                  (case (get state placed)
                    (true
                      (variant Ok
                        (record (placed true) (out (Cons CanonFieldText h (get state out))))))
                    (false
                      (let (order ((Protoss.canonCmpOrder (get h name)) (get x name)))
                        (case ((Nat.eqNat order) 3)
                          (true
                            (variant Err
                              "canonical ordering is undefined for non-ASCII names"))
                          (false
                            (case ((Nat.eqNat order) 0)
                              (true
                                (variant Ok
                                  (record (placed true)
                                    (out
                                      (Cons CanonFieldText h
                                        (Cons CanonFieldText x (get state out)))))))
                              (false
                                (variant Ok
                                  (record (placed false)
                                    (out (Cons CanonFieldText h (get state out))))))))))))))))))
        (case scan
          (Err err (variant Err err))
          (Ok state
            (case (get state placed)
              (true (variant Ok (get state out)))
              (false (variant Ok (Cons CanonFieldText x (get state out)))))))))))

(def Protoss.canonQuoteChar (-> String String)
  (lambda (ch String)
    (case ((String.eqString ch) "\"")
      (true "\\\"")
      (false
        (case ((String.eqString ch) "\\")
          (true "\\\\")
          (false
            (case ((String.eqString ch) "\n")
              (true "\\n")
              (false
                (case ((String.eqString ch) "\r")
                  (true "\\r")
                  (false
                    (case ((String.eqString ch) "\t")
                      (true "\\t")
                      (false ch))))))))))))

(def Protoss.canonQuote (-> String String)
  (lambda (s String)
    (let (len (String.length s))
      ((String.concat "\"")
        ((String.concat
          (get
            (foldNat len
              (record (index (prim.Nat.pred len)) (text ""))
              (lambda (acc CanonQuoteScan)
                (let (i (get acc index))
                  (case ((String.charAt s) i)
                    (None (record (index (prim.Nat.pred i)) (text (get acc text))))
                    (Some ch
                      (record
                        (index (prim.Nat.pred i))
                        (text ((String.concat (Protoss.canonQuoteChar ch)) (get acc text)))))))))
            text))
          "\"")))))

(def Protoss.canonNatOfDigits (-> String (Maybe Nat))
  (lambda (s String)
    (case (Protoss.isNatLiteralName s)
      (false (variant None unit))
      (true
        (variant Some
          (get
            (foldNat (String.length s)
              (record (first 0) (second 0))
              (lambda (acc (Pair Nat Nat))
                (let (digit
                  (case ((String.charAt s) (get acc first))
                    (None 0)
                    (Some ch
                      (case (String.digitValue ch)
                        (None 0)
                        (Some value value)))))
                  (record
                    (first (succ (get acc first)))
                    (second ((Nat.add ((prim.Nat.mul (get acc second)) 10)) digit))))))
            second))))))

(def Protoss.canonContains (-> (List String) (-> String Bool))
  (lambda (xs (List String))
    (lambda (x String)
      (foldList xs false
        (lambda (h String)
          (lambda (acc Bool)
            (case ((String.eqString h) x)
              (true true)
              (false acc))))))))

(def Protoss.canonAliasLookup (-> (List CanonAlias) (-> String (Maybe CanonAlias)))
  (lambda (aliases (List CanonAlias))
    (lambda (wanted String)
      (foldList aliases (variant (Maybe CanonAlias) None unit)
        (lambda (alias CanonAlias)
          (lambda (acc (Maybe CanonAlias))
            (case ((String.eqString (get alias name)) wanted)
              (true (variant Some alias))
              (false acc))))))))

(def Protoss.canonSigLookup (-> (List CanonSig) (-> String (Maybe CanonSig)))
  (lambda (sigs (List CanonSig))
    (lambda (wanted String)
      (foldList sigs (variant (Maybe CanonSig) None unit)
        (lambda (sig CanonSig)
          (lambda (acc (Maybe CanonSig))
            (case ((String.eqString (get sig name)) wanted)
              (true (variant Some sig))
              (false acc))))))))

(def Protoss.canonDefIdOf (-> CanonCtx (-> String String))
  (lambda (ctx CanonCtx)
    (lambda (wanted String)
      (foldList (get ctx defIds) wanted
        (lambda (entry CanonIdEntry)
          (lambda (acc String)
            (case ((String.eqString (get entry name)) wanted)
              (true (get entry defId))
              (false acc))))))))

(def Protoss.canonBindingLookup
  (-> (List CanonTypeBinding) (-> String (Maybe ProtossType)))
  (lambda (bindings (List CanonTypeBinding))
    (lambda (wanted String)
      (foldList bindings (variant (Maybe ProtossType) None unit)
        (lambda (binding CanonTypeBinding)
          (lambda (acc (Maybe ProtossType))
            (case ((String.eqString (get binding name)) wanted)
              (true (variant Some (get binding typ)))
              (false acc))))))))

(def Protoss.canonLocalLookup
  (-> (List CanonLocal) (-> String (Maybe CanonIndexedLocal)))
  (lambda (locals (List CanonLocal))
    (lambda (wanted String)
      (let (scan
        (foldList locals
          (record (scanned 0) (found (variant (Maybe CanonIndexedLocal) None unit)))
          (lambda (local CanonLocal)
            (lambda (acc CanonLocalScan)
              (record
                (scanned (succ (get acc scanned)))
                (found
                  (case ((String.eqString (get local name)) wanted)
                    (true
                      (variant Some
                        (record (index (get acc scanned)) (typ (get local typ)))))
                    (false (get acc found)))))))))
        (case (get scan found)
          (None (variant (Maybe CanonIndexedLocal) None unit))
          (Some entry
            (variant Some
              (record
                (index
                  ((prim.Nat.sub (prim.Nat.pred (get scan scanned))) (get entry index)))
                (typ (get entry typ))))))))))

(def Protoss.canonScalarTypeName (-> String Bool)
  (lambda (name String)
    (case ((String.eqString name) "Unit")
      (true true)
      (false
        (case ((String.eqString name) "Bool")
          (true true)
          (false
            (case ((String.eqString name) "Nat")
              (true true)
              (false ((String.eqString name) "String")))))))))

(def Protoss.canonBuiltinTypeHeads (List String)
  (Cons String "List"
    (Cons String "Stream"
      (Cons String "View"
        (Cons String "Attr"
          (Cons String "Process"
            (Cons String "Cmd"
              (Cons String "Automaton"
                (Cons String "Record"
                  (Cons String "Variant"
                    (Cons String "SecretRef"
                      (Cons String "Capabilities"
                        (Cons String "capabilities" (Nil String))))))))))))))

(defrec Protoss.canonTypeNames (-> ProtossType (List String))
  (variant t)
  (PTName name (Cons String name (Nil String)))
  (PTFun pair
    ((inst List.append String)
      (recur (get pair first))
      (recur (get pair second))))
  (PTApply app
    (Cons String (get app name)
      (foldList (get app args) (Nil String)
        (lambda (arg ProtossType)
          (lambda (acc (List String))
            (((inst List.append String) (recur arg)) acc)))))))

(def Protoss.canonTypeMentions (-> ProtossType (-> String Bool))
  (lambda (t ProtossType)
    (lambda (wanted String)
      ((Protoss.canonContains (Protoss.canonTypeNames t)) wanted))))

(def Protoss.canonSubstList
  (-> (List CanonTypeSubst)
    (-> (List CanonTypeBinding) (Result String (List ProtossType))))
  (lambda (substs (List CanonTypeSubst))
    (lambda (bindings (List CanonTypeBinding))
      (foldList substs
        (variant (Result String (List ProtossType)) Ok (Nil ProtossType))
        (lambda (subst CanonTypeSubst)
          (lambda (acc (Result String (List ProtossType)))
            (case acc
              (Err err (variant Err err))
              (Ok done
                (case (subst bindings)
                  (Err err (variant Err err))
                  (Ok argT (variant Ok (Cons ProtossType argT done))))))))))))

(defrec Protoss.canonSubstTypeNames
  (-> ProtossType CanonTypeSubst)
  (variant t)
  (PTName name
    (lambda (bindings (List CanonTypeBinding))
      (case ((Protoss.canonBindingLookup bindings) name)
        (Some bound (variant Ok bound))
        (None (variant Ok (variant PTName name))))))
  (PTFun pair
    (let (substFirst (recur (get pair first)))
      (let (substSecond (recur (get pair second)))
        (lambda (bindings (List CanonTypeBinding))
          (case (substFirst bindings)
            (Err err (variant Err err))
            (Ok a
              (case (substSecond bindings)
                (Err err (variant Err err))
                (Ok b (variant Ok (variant PTFun (record (first a) (second b))))))))))))
  (PTApply app
    (let (argSubsts
      (foldList (get app args) (Nil CanonTypeSubst)
        (lambda (arg ProtossType)
          (lambda (acc (List CanonTypeSubst))
            (Cons CanonTypeSubst (recur arg) acc)))))
      (lambda (bindings (List CanonTypeBinding))
        (case ((Protoss.canonBindingLookup bindings) (get app name))
          (Some bound
            (caseList (get app args)
              (Nil (variant Ok bound))
              (Cons firstArg restArgs
                (variant Err
                  ((String.concat "type parameter is not a type constructor: ")
                    (get app name))))))
          (None
            (case ((Protoss.canonSubstList argSubsts) bindings)
              (Err err (variant Err err))
              (Ok newArgs
                (variant Ok
                  (variant PTApply (record (name (get app name)) (args newArgs))))))))))))

(def Protoss.canonZipBindings
  (-> (List String) (-> (List ProtossType) (Result String (List CanonTypeBinding))))
  (lambda (params (List String))
    (lambda (args (List ProtossType))
      (let (state
        (foldList params
          (record
            (remaining ((inst List.reverse ProtossType) args))
            (out (Nil CanonTypeBinding))
            (ok true))
          (lambda (param String)
            (lambda (acc CanonZipState)
              (caseList (get acc remaining)
                (Nil
                  (record
                    (remaining (Nil ProtossType))
                    (out (get acc out))
                    (ok false)))
                (Cons arg rest
                  (record
                    (remaining rest)
                    (out
                      (Cons CanonTypeBinding
                        (record (name param) (typ arg))
                        (get acc out)))
                    (ok (get acc ok)))))))))
        (case (get state ok)
          (false (variant Err "type alias arity mismatch"))
          (true
            (caseList (get state remaining)
              (Nil (variant Ok (get state out)))
              (Cons extra rest (variant Err "type alias arity mismatch")))))))))

(def Protoss.canonStepList
  (-> (List CanonTypeStep) (-> CanonCtx (Result String (List ProtossType))))
  (lambda (steps (List CanonTypeStep))
    (lambda (ctx CanonCtx)
      (foldList steps
        (variant (Result String (List ProtossType)) Ok (Nil ProtossType))
        (lambda (step CanonTypeStep)
          (lambda (acc (Result String (List ProtossType)))
            (case acc
              (Err err (variant Err err))
              (Ok done
                (case (step ctx)
                  (Err err (variant Err err))
                  (Ok argT (variant Ok (Cons ProtossType argT done))))))))))))

(def Protoss.canonNamedPrefix String "__canon-named:")

(def Protoss.canonNamedHead (-> String String)
  (lambda (name String)
    ((String.concat Protoss.canonNamedPrefix) name)))

(def Protoss.canonNamedHeadName (-> String (Maybe String))
  (lambda (head String)
    (case ((String.startsWith head) Protoss.canonNamedPrefix)
      (false (variant None unit))
      (true
        (variant Some
          ((String.drop head) (String.length Protoss.canonNamedPrefix)))))))

(defrec Protoss.canonSubstAliasOnce
  (-> ProtossType CanonTypeStep)
  (variant t)
  (PTName name
    (lambda (ctx CanonCtx)
      (case (Protoss.canonScalarTypeName name)
        (true (variant Ok (variant PTName name)))
        (false
          (case ((Protoss.canonContains (get ctx recNames)) name)
            (true
              (variant Ok
                (variant PTApply
                  (record (name (Protoss.canonNamedHead name)) (args (Nil ProtossType))))))
            (false
              (case ((Protoss.canonAliasLookup (get ctx aliases)) name)
                (None (variant Ok (variant PTName name)))
                (Some alias
                  (caseList (get alias params)
                    (Nil (variant Ok (get alias body)))
                    (Cons param rest
                      (variant Err
                        ((String.concat "type alias expects type arguments: ") name))))))))))))
  (PTFun pair
    (let (stepFirst (recur (get pair first)))
      (let (stepSecond (recur (get pair second)))
        (lambda (ctx CanonCtx)
          (case (stepFirst ctx)
            (Err err (variant Err err))
            (Ok a
              (case (stepSecond ctx)
                (Err err (variant Err err))
                (Ok b (variant Ok (variant PTFun (record (first a) (second b))))))))))))
  (PTApply app
    (let (argSteps
      (foldList (get app args) (Nil CanonTypeStep)
        (lambda (arg ProtossType)
          (lambda (acc (List CanonTypeStep))
            (Cons CanonTypeStep (recur arg) acc)))))
      (lambda (ctx CanonCtx)
        (case ((Protoss.canonStepList argSteps) ctx)
          (Err err (variant Err err))
          (Ok newArgs
            (let (head (get app name))
              (case ((Protoss.canonContains Protoss.canonBuiltinTypeHeads) head)
                (true
                  (variant Ok (variant PTApply (record (name head) (args newArgs)))))
                (false
                  (case ((Protoss.canonContains (get ctx recNames)) head)
                    (true
                      (variant Ok
                        (variant PTApply
                          (record (name (Protoss.canonNamedHead head)) (args newArgs)))))
                    (false
                      (case ((Protoss.canonAliasLookup (get ctx aliases)) head)
                        (None
                          (variant Ok
                            (variant PTApply (record (name head) (args newArgs)))))
                        (Some alias
                          (case ((Protoss.canonZipBindings (get alias params)) newArgs)
                            (Err err
                              (variant Err
                                ((String.concat "type alias arity mismatch: ") head)))
                            (Ok bindings
                              ((Protoss.canonSubstTypeNames (get alias body)) bindings))))))))))))))))

(def Protoss.canonExpandRaw (-> CanonCtx (-> ProtossType (Result String ProtossType)))
  (lambda (ctx CanonCtx)
    (lambda (t ProtossType)
      (foldNat (succ ((inst List.length CanonAlias) (get ctx aliases)))
        (variant (Result String ProtossType) Ok t)
        (lambda (acc (Result String ProtossType))
          (case acc
            (Err err (variant Err err))
            (Ok current ((Protoss.canonSubstAliasOnce current) ctx))))))))

(def Protoss.canonTvarPrefix String "__canon-tvar:")

(def Protoss.canonTvarType (-> Nat ProtossType)
  (lambda (i Nat)
    (variant PTName ((String.concat Protoss.canonTvarPrefix) (Nat.toString i)))))

(def Protoss.canonTvarBindings (-> (List String) (List CanonTypeBinding))
  (lambda (params (List String))
    (let (len ((inst List.length String) params))
      (get
        (foldList params
          (record (first 0) (second (Nil CanonTypeBinding)))
          (lambda (param String)
            (lambda (acc CanonIndexedBindings)
              (record
                (first (succ (get acc first)))
                (second
                  (Cons CanonTypeBinding
                    (record
                      (name param)
                      (typ
                        (Protoss.canonTvarType
                          ((prim.Nat.sub (prim.Nat.pred len)) (get acc first)))))
                    (get acc second)))))))
        second))))

(def Protoss.canonExpandType (-> CanonCtx (-> ProtossType (Result String ProtossType)))
  (lambda (ctx CanonCtx)
    (lambda (t ProtossType)
      (case ((Protoss.canonSubstTypeNames t) (Protoss.canonTvarBindings (get ctx tvars)))
        (Err err (variant Err err))
        (Ok seeded ((Protoss.canonExpandRaw ctx) seeded))))))

(def Protoss.canonUnfoldNamed (-> CanonCtx (-> ProtossType (Result String ProtossType)))
  (lambda (ctx CanonCtx)
    (lambda (t ProtossType)
      (case t
        (PTName name (variant Ok t))
        (PTFun pair (variant Ok t))
        (PTApply app
          (case (Protoss.canonNamedHeadName (get app name))
            (None (variant Ok t))
            (Some aliasName
              (case ((Protoss.canonAliasLookup (get ctx aliases)) aliasName)
                (None
                  (variant Err
                    ((String.concat "unknown recursive type alias: ") aliasName)))
                (Some alias
                  (case ((Protoss.canonZipBindings (get alias params)) (get app args))
                    (Err err (variant Err err))
                    (Ok bindings
                      (case ((Protoss.canonSubstTypeNames (get alias body)) bindings)
                        (Err err (variant Err err))
                        (Ok seeded ((Protoss.canonExpandRaw ctx) seeded))))))))))))))

(def Protoss.canonConPayloads
  (-> (List ProtossType) (Result String (List CanonTypeBinding)))
  (lambda (cases (List ProtossType))
    (foldList cases
      (variant (Result String (List CanonTypeBinding)) Ok (Nil CanonTypeBinding))
      (lambda (entry ProtossType)
        (lambda (acc (Result String (List CanonTypeBinding)))
          (case acc
            (Err err (variant Err err))
            (Ok done
              (case entry
                (PTApply app
                  (caseList (get app args)
                    (Nil (variant Err "malformed structural type field"))
                    (Cons payload rest
                      (caseList rest
                        (Nil
                          (variant Ok
                            (Cons CanonTypeBinding
                              (record (name (get app name)) (typ payload))
                              done)))
                        (Cons extra extraRest
                          (variant Err "malformed structural type field"))))))
                (_ (variant Err "malformed structural type field"))))))))))

(def Protoss.canonWrapTypeHead (-> String Bool)
  (lambda (head String)
    (case ((String.eqString head) "List")
      (true true)
      (false
        (case ((String.eqString head) "Stream")
          (true true)
          (false
            (case ((String.eqString head) "View")
              (true true)
              (false
                (case ((String.eqString head) "Attr")
                  (true true)
                  (false ((String.eqString head) "Automaton")))))))))))

(def Protoss.canonCapabilityScopeText
  (-> (List ProtossType) (Result String String))
  (lambda (caps (List ProtossType))
    (case
      (foldList caps
        (variant (Result String (List String)) Ok (Nil String))
        (lambda (cap ProtossType)
          (lambda (acc (Result String (List String)))
            (case acc
              (Err err (variant Err err))
              (Ok done
                (case cap
                  (PTName capName
                    (case (((Protoss.canonInsertString true) capName) done)
                      (Err err (variant Err err))
                      (Ok inserted (variant Ok inserted))))
                  (_ (variant Err "malformed capability scope"))))))))
      (Err err (variant Err err))
      (Ok sorted
        (caseList sorted
          (Nil (variant Ok "(Capabilities)"))
          (Cons firstCap rest
            (variant Ok
              ((String.concat "(Capabilities ")
                ((String.concat
                  ((String.join " ")
                    (((inst List.map String String) sorted) Protoss.canonQuote)))
                  ")")))))))))

(def Protoss.canonRenderedTexts
  (-> (List CanonRenderedType) (Result String (List String)))
  (lambda (rendered (List CanonRenderedType))
    (foldList rendered
      (variant (Result String (List String)) Ok (Nil String))
      (lambda (entry CanonRenderedType)
        (lambda (acc (Result String (List String)))
          (case acc
            (Err err (variant Err err))
            (Ok done
              (case (get entry text)
                (Err err (variant Err err))
                (Ok text (variant Ok (Cons String text done)))))))))))

(def Protoss.canonWrapText (-> String (-> (List String) String))
  (lambda (head String)
    (lambda (texts (List String))
      ((String.concat "(")
        ((String.concat head)
          ((String.concat " ")
            ((String.concat ((String.join " ") texts)) ")")))))))

(def Protoss.canonApplyText
  (-> String (-> (List CanonRenderedType) (Result String String)))
  (lambda (head String)
    (lambda (rendered (List CanonRenderedType))
      (case false
        (true (variant Err "unreachable"))
        (false
          (case (Protoss.canonNamedHeadName head)
            (Some aliasName
              (case (Protoss.canonRenderedTexts rendered)
                (Err err (variant Err err))
                (Ok texts
                  (caseList texts
                    (Nil
                      (variant Ok
                        ((String.concat "(Named ") ((String.concat aliasName) ")"))))
                    (Cons firstText restTexts
                      (variant Ok
                        ((String.concat "(Named ")
                          ((String.concat aliasName)
                            ((String.concat " ")
                              ((String.concat ((String.join " ") texts)) ")"))))))))))
            (None
              (case (Protoss.canonWrapTypeHead head)
                (true
                  (case (Protoss.canonRenderedTexts rendered)
                    (Err err (variant Err err))
                    (Ok texts (variant Ok ((Protoss.canonWrapText head) texts)))))
                (false
                  (case
                    (case ((String.eqString head) "Process")
                      (true true)
                      (false ((String.eqString head) "Cmd")))
                    (true
                      (caseList rendered
                        (Nil (variant Err "malformed Process type"))
                        (Cons firstEntry rest
                          (caseList rest
                            (Nil
                              (case (get firstEntry text)
                                (Err err (variant Err err))
                                (Ok valueText
                                  (variant Ok
                                    ((Protoss.canonWrapText head)
                                      (Cons String valueText (Nil String)))))))
                            (Cons valueEntry extraRest
                              (caseList extraRest
                                (Nil
                                  (case (get firstEntry raw)
                                    (PTApply scopeApp
                                      (case
                                        (case ((String.eqString (get scopeApp name)) "capabilities")
                                          (true true)
                                          (false
                                            ((String.eqString (get scopeApp name)) "Capabilities")))
                                        (false (variant Err "malformed Process type"))
                                        (true
                                          (case (Protoss.canonCapabilityScopeText (get scopeApp args))
                                            (Err err (variant Err err))
                                            (Ok scopeText
                                              (case (get valueEntry text)
                                                (Err err (variant Err err))
                                                (Ok valueText
                                                  (variant Ok
                                                    ((Protoss.canonWrapText head)
                                                      (Cons String scopeText
                                                        (Cons String valueText (Nil String))))))))))))
                                    (_ (variant Err "malformed Process type"))))
                                (Cons more moreRest
                                  (variant Err "malformed Process type"))))))))
                    (false
                      (case ((String.eqString head) "SecretRef")
                        (true
                          (caseList rendered
                            (Nil (variant Err "malformed SecretRef type"))
                            (Cons scopeEntry rest
                              (caseList rest
                                (Nil (variant Err "malformed SecretRef type"))
                                (Cons valueEntry extraRest
                                  (caseList extraRest
                                    (Nil
                                      (case (get scopeEntry raw)
                                        (PTName scope
                                          (case (get valueEntry text)
                                            (Err err (variant Err err))
                                            (Ok valueText
                                              (variant Ok
                                                ((Protoss.canonWrapText "SecretRef")
                                                  (Cons String scope
                                                    (Cons String valueText (Nil String))))))))
                                        (_ (variant Err "malformed SecretRef type"))))
                                    (Cons more moreRest
                                      (variant Err "malformed SecretRef type"))))))))
                        (false
                          (case
                            (case ((String.eqString head) "Record")
                              (true true)
                              (false ((String.eqString head) "Variant")))
                            (true
                              (case
                                (foldList rendered
                                  (variant (Result String (List CanonFieldText)) Ok
                                    (Nil CanonFieldText))
                                  (lambda (entry CanonRenderedType)
                                    (lambda (acc (Result String (List CanonFieldText)))
                                      (case acc
                                        (Err err (variant Err err))
                                        (Ok done
                                          (case (get entry raw)
                                            (PTApply fieldApp
                                              (case (get entry text)
                                                (Err err (variant Err err))
                                                (Ok fieldText
                                                  (case
                                                    ((Protoss.canonInsertField
                                                      (record
                                                        (name (get fieldApp name))
                                                        (text fieldText)))
                                                      done)
                                                    (Err err (variant Err err))
                                                    (Ok inserted (variant Ok inserted))))))
                                            (_ (variant Err "malformed structural type field"))))))))
                                (Err err (variant Err err))
                                (Ok fields
                                  (variant Ok
                                    ((Protoss.canonWrapText head)
                                      (((inst List.map CanonFieldText String) fields)
                                        (lambda (entry CanonFieldText) (get entry text))))))))
                            (false
                              (caseList rendered
                                (Nil
                                  (variant Err
                                    ((String.concat "unknown type application: ") head)))
                                (Cons payloadEntry rest
                                  (caseList rest
                                    (Nil
                                      (case (get payloadEntry text)
                                        (Err err (variant Err err))
                                        (Ok payloadText
                                          (variant Ok
                                            ((Protoss.canonWrapText head)
                                              (Cons String payloadText (Nil String)))))))
                                    (Cons extra extraRest
                                      (variant Err
                                        ((String.concat "unknown type application: ") head)))))))))))))))))))))

(defrec Protoss.canonTypeText (-> ProtossType (Result String String))
  (variant t)
  (PTName name
    (case (Protoss.canonScalarTypeName name)
      (true (variant Ok name))
      (false
        (case ((String.startsWith name) Protoss.canonTvarPrefix)
          (true
            (variant Ok
              ((String.concat "(TVar ")
                ((String.concat
                  ((String.drop name) (String.length Protoss.canonTvarPrefix)))
                  ")"))))
          (false (variant Err ((String.concat "unknown type name: ") name)))))))
  (PTFun pair
    (case (recur (get pair first))
      (Err err (variant Err err))
      (Ok a
        (case (recur (get pair second))
          (Err err (variant Err err))
          (Ok b
            (variant Ok
              ((String.concat "(Fun ")
                ((String.concat a)
                  ((String.concat " ") ((String.concat b) ")"))))))))))
  (PTApply app
    ((Protoss.canonApplyText (get app name))
      (foldList (get app args) (Nil CanonRenderedType)
        (lambda (arg ProtossType)
          (lambda (acc (List CanonRenderedType))
            (Cons CanonRenderedType
              (record (raw arg) (text (recur arg)))
              acc)))))))
(def Protoss.canonTNat ProtossType (variant PTName "Nat"))
(def Protoss.canonTBool ProtossType (variant PTName "Bool"))
(def Protoss.canonTString ProtossType (variant PTName "String"))
(def Protoss.canonTUnit ProtossType (variant PTName "Unit"))

(def Protoss.canonFun (-> ProtossType (-> ProtossType ProtossType))
  (lambda (a ProtossType)
    (lambda (b ProtossType)
      (variant PTFun (record (first a) (second b))))))

(def Protoss.canonApply1 (-> String (-> ProtossType ProtossType))
  (lambda (head String)
    (lambda (t ProtossType)
      (variant PTApply
        (record (name head) (args (Cons ProtossType t (Nil ProtossType))))))))

(def Protoss.canonProcessOf (-> ProtossType ProtossType) (Protoss.canonApply1 "Process"))
(def Protoss.canonListOf (-> ProtossType ProtossType) (Protoss.canonApply1 "List"))

(def Protoss.canonNat2Type ProtossType
  ((Protoss.canonFun Protoss.canonTNat)
    ((Protoss.canonFun Protoss.canonTNat) Protoss.canonTNat)))

(def Protoss.canonNatCmpType ProtossType
  ((Protoss.canonFun Protoss.canonTNat)
    ((Protoss.canonFun Protoss.canonTNat) Protoss.canonTBool)))

(def Protoss.canonCharAtResultType ProtossType
  (variant PTApply
    (record
      (name "Variant")
      (args
        (Cons ProtossType
          (variant PTApply
            (record (name "None")
              (args (Cons ProtossType Protoss.canonTUnit (Nil ProtossType)))))
          (Cons ProtossType
            (variant PTApply
              (record (name "Some")
                (args (Cons ProtossType Protoss.canonTString (Nil ProtossType)))))
            (Nil ProtossType)))))))

(def Protoss.canonBuiltinSig (-> String (Maybe ProtossType))
  (lambda (name String)
    (case ((String.eqString name) "succ")
      (true (variant Some ((Protoss.canonFun Protoss.canonTNat) Protoss.canonTNat)))
      (false
        (case ((String.eqString name) "prim.Nat.add")
          (true (variant Some Protoss.canonNat2Type))
          (false
            (case ((String.eqString name) "prim.Nat.mul")
              (true (variant Some Protoss.canonNat2Type))
              (false
                (case ((String.eqString name) "prim.Nat.pred")
                  (true
                    (variant Some
                      ((Protoss.canonFun Protoss.canonTNat) Protoss.canonTNat)))
                  (false
                    (case ((String.eqString name) "prim.Nat.sub")
                      (true (variant Some Protoss.canonNat2Type))
                      (false
                        (case ((String.eqString name) "prim.Nat.eq")
                          (true (variant Some Protoss.canonNatCmpType))
                          (false
                            (case ((String.eqString name) "prim.Nat.lte")
                              (true (variant Some Protoss.canonNatCmpType))
                              (false
                                (case ((String.eqString name) "prim.Nat.lt")
                                  (true (variant Some Protoss.canonNatCmpType))
                                  (false
                                    (case ((String.eqString name) "prim.Nat.gte")
                                      (true (variant Some Protoss.canonNatCmpType))
                                      (false
                                        (case ((String.eqString name) "prim.Nat.gt")
                                          (true (variant Some Protoss.canonNatCmpType))
                                          (false
                                            (case ((String.eqString name) "prim.Nat.toString")
                                              (true
                                                (variant Some
                                                  ((Protoss.canonFun Protoss.canonTNat)
                                                    Protoss.canonTString)))
                                              (false
                                                (case ((String.eqString name) "prim.String.concat")
                                                  (true
                                                    (variant Some
                                                      ((Protoss.canonFun Protoss.canonTString)
                                                        ((Protoss.canonFun Protoss.canonTString)
                                                          Protoss.canonTString))))
                                                  (false
                                                    (case ((String.eqString name) "prim.String.eq")
                                                      (true
                                                        (variant Some
                                                          ((Protoss.canonFun Protoss.canonTString)
                                                            ((Protoss.canonFun Protoss.canonTString)
                                                              Protoss.canonTBool))))
                                                      (false
                                                        (case ((String.eqString name) "prim.String.length")
                                                          (true
                                                            (variant Some
                                                              ((Protoss.canonFun Protoss.canonTString)
                                                                Protoss.canonTNat)))
                                                          (false
                                                            (case ((String.eqString name) "prim.String.slice")
                                                              (true
                                                                (variant Some
                                                                  ((Protoss.canonFun Protoss.canonTString)
                                                                    ((Protoss.canonFun Protoss.canonTNat)
                                                                      ((Protoss.canonFun Protoss.canonTNat)
                                                                        Protoss.canonTString)))))
                                                              (false
                                                                (case ((String.eqString name) "prim.String.charAt")
                                                                  (true
                                                                    (variant Some
                                                                      ((Protoss.canonFun Protoss.canonTString)
                                                                        ((Protoss.canonFun Protoss.canonTNat)
                                                                          Protoss.canonCharAtResultType))))
                                                                  (false (variant None unit)))))))))))))))))))))))))))))))))))

(def Protoss.canonRequestText (-> ProtossRequest String)
  (lambda (req ProtossRequest)
    (case req
      (PRAskHuman prompt
        ((String.concat "(AskHuman ")
          ((String.concat (Protoss.canonQuote prompt)) ")")))
      (PRHttpGet url
        ((String.concat "(HttpGet ")
          ((String.concat (Protoss.canonQuote url)) ")")))
      (PRClockRead ignored "ReadClock")
      (PRSaveLocal kv
        ((String.concat "(SaveLocal ")
          ((String.concat (Protoss.canonQuote (get kv key)))
            ((String.concat " ")
              ((String.concat (Protoss.canonQuote (get kv value))) ")")))))
      (PRLoadLocal key
        ((String.concat "(LoadLocal ")
          ((String.concat (Protoss.canonQuote key)) ")")))
      (PRServerRequest rp
        ((String.concat "(ServerRequest ")
          ((String.concat (Protoss.canonQuote (get rp route)))
            ((String.concat " ")
              ((String.concat (Protoss.canonQuote (get rp payload))) ")"))))))))

(def Protoss.canonRequestType (-> ProtossRequest ProtossType)
  (lambda (req ProtossRequest)
    (case req
      (PRSaveLocal kv (Protoss.canonProcessOf Protoss.canonTUnit))
      (_ (Protoss.canonProcessOf Protoss.canonTString)))))

(def Protoss.canonNoExpected (Maybe ProtossType) (variant None unit))

(def Protoss.canonPush (-> CanonScope (-> String (-> ProtossType CanonScope)))
  (lambda (scope CanonScope)
    (lambda (binder String)
      (lambda (typ ProtossType)
        (record
          (locals (Cons CanonLocal (record (name binder) (typ typ)) (get scope locals)))
          (fold (get scope fold)))))))

(def Protoss.canonLambdaScope (-> CanonScope (-> String (-> ProtossType CanonScope)))
  (lambda (scope CanonScope)
    (lambda (binder String)
      (lambda (typ ProtossType)
        (record
          (locals (Cons CanonLocal (record (name binder) (typ typ)) (get scope locals)))
          (fold (variant (Maybe CanonFold) None unit)))))))

(def Protoss.canonNoFoldScope (-> CanonScope CanonScope)
  (lambda (scope CanonScope)
    (record (locals (get scope locals)) (fold (variant (Maybe CanonFold) None unit)))))

(def Protoss.canonProcessValue (-> ProtossType (Maybe ProtossType))
  (lambda (t ProtossType)
    (case t
      (PTApply app
        (case ((String.eqString (get app name)) "Process")
          (false (variant (Maybe ProtossType) None unit))
          (true
            (caseList (get app args)
              (Nil (variant (Maybe ProtossType) None unit))
              (Cons firstArg rest
                (caseList rest
                  (Nil (variant Some firstArg))
                  (Cons secondArg extra
                    (caseList extra
                      (Nil (variant Some secondArg))
                      (Cons more moreRest (variant (Maybe ProtossType) None unit))))))))))
      (_ (variant (Maybe ProtossType) None unit)))))

(def Protoss.canonAppText (-> String (-> String String))
  (lambda (fnText String)
    (lambda (argText String)
      ((String.concat "(app ")
        ((String.concat fnText)
          ((String.concat " ") ((String.concat argText) ")")))))))

(def Protoss.canonApplyChain
  (-> (List CanonExprK)
    (-> CanonCtx (-> CanonScope (-> (Result String CanonOut) (Result String CanonOut)))))
  (lambda (argKs (List CanonExprK))
    (lambda (ctx CanonCtx)
      (lambda (scope CanonScope)
        (lambda (fnRes (Result String CanonOut))
          (foldList ((inst List.reverse CanonExprK) argKs) fnRes
            (lambda (argK CanonExprK)
              (lambda (acc (Result String CanonOut))
                (case acc
                  (Err err (variant Err err))
                  (Ok cur
                    (case (get cur typ)
                      (PTFun pair
                        (case (((argK ctx) scope) (variant Some (get pair first)))
                          (Err err (variant Err err))
                          (Ok argOut
                            (variant Ok
                              (record
                                (typ (get pair second))
                                (text
                                  ((Protoss.canonAppText (get cur text))
                                    (get argOut text))))))))
                      (_ (variant Err "application of non-function")))))))))))))

(def Protoss.canonSplitBranchKs (-> (List CanonBranchK) CanonBranchSplitK)
  (lambda (branches (List CanonBranchK))
    (foldList branches
      (record
        (explicit (Nil CanonBranchK))
        (wildcard (variant (Maybe CanonExprK) None unit)))
      (lambda (branch CanonBranchK)
        (lambda (acc CanonBranchSplitK)
          (case ((String.eqString (get branch constructor)) "_")
            (true
              (case (get branch binder)
                (None
                  (record
                    (explicit (get acc explicit))
                    (wildcard (variant Some (get branch bodyK)))))
                (Some binder
                  (record
                    (explicit (Cons CanonBranchK branch (get acc explicit)))
                    (wildcard (get acc wildcard))))))
            (false
              (record
                (explicit (Cons CanonBranchK branch (get acc explicit)))
                (wildcard (get acc wildcard))))))))))

(def Protoss.canonFindBranchK (-> (List CanonBranchK) (-> String (Maybe CanonBranchK)))
  (lambda (branches (List CanonBranchK))
    (lambda (wanted String)
      (foldList branches (variant (Maybe CanonBranchK) None unit)
        (lambda (branch CanonBranchK)
          (lambda (acc (Maybe CanonBranchK))
            (case ((String.eqString (get branch constructor)) wanted)
              (true (variant Some branch))
              (false acc))))))))

(def Protoss.canonVariantBranchText
  (-> String (-> String String))
  (lambda (con String)
    (lambda (bodyText String)
      ((String.concat "(")
        ((String.concat con)
          ((String.concat " ") ((String.concat bodyText) ")")))))))

(def Protoss.canonVariantBranchesText
  (-> (List CanonTypeBinding)
    (-> CanonBranchSplitK
      (-> CanonCtx
        (-> CanonScope
          (-> (Maybe CanonFold) (-> ProtossType (Result String String)))))))
  (lambda (cases (List CanonTypeBinding))
    (lambda (split CanonBranchSplitK)
      (lambda (ctx CanonCtx)
        (lambda (scope CanonScope)
          (lambda (branchFold (Maybe CanonFold))
            (lambda (expectedBody ProtossType)
              (case
                (foldList (get split explicit) (variant (Result String Unit) Ok unit)
                  (lambda (branch CanonBranchK)
                    (lambda (acc (Result String Unit))
                      (case acc
                        (Err err (variant Err err))
                        (Ok ignored
                          (case ((Protoss.canonBindingLookup cases) (get branch constructor))
                            (Some payload (variant Ok unit))
                            (None
                              (variant Err
                                ((String.concat "unknown branch: ")
                                  (get branch constructor))))))))))
                (Err err (variant Err err))
                (Ok ignored
                  (case
                    (foldList cases
                      (variant (Result String (List CanonFieldText)) Ok (Nil CanonFieldText))
                      (lambda (entry CanonTypeBinding)
                        (lambda (acc (Result String (List CanonFieldText)))
                          (case acc
                            (Err err (variant Err err))
                            (Ok done
                              (let (branchInfo (Result String CanonBranchK)
                                (case ((Protoss.canonFindBranchK (get split explicit)) (get entry name))
                                  (Some branch
                                    (variant Ok
                                      (record
                                        (constructor (get entry name))
                                        (binder (get branch binder))
                                        (bodyK (get branch bodyK)))))
                                  (None
                                    (case (get split wildcard)
                                      (Some wildK
                                        (variant Ok
                                          (record
                                            (constructor (get entry name))
                                            (binder (variant Some ""))
                                            (bodyK wildK))))
                                      (None
                                        (variant Err
                                          ((String.concat "missing branch: ")
                                            (get entry name))))))))
                                (case branchInfo
                                  (Err err (variant Err err))
                                  (Ok info
                                    (let (innerScope
                                      (case (get info binder)
                                        (Some binder
                                          (record
                                            (locals
                                              (Cons CanonLocal
                                                (record (name binder) (typ (get entry typ)))
                                                (get scope locals)))
                                            (fold branchFold)))
                                        (None
                                          (record
                                            (locals
                                              (Cons CanonLocal
                                                (record (name "") (typ (get entry typ)))
                                                (get scope locals)))
                                            (fold (get scope fold))))))
                                      (case ((((get info bodyK) ctx) innerScope)
                                              (variant Some expectedBody))
                                        (Err err (variant Err err))
                                        (Ok bodyOut
                                          (case
                                            ((Protoss.canonInsertField
                                              (record
                                                (name (get entry name))
                                                (text
                                                  ((Protoss.canonVariantBranchText (get entry name))
                                                    (get bodyOut text)))))
                                              done)
                                            (Err err (variant Err err))
                                            (Ok inserted (variant Ok inserted))))))))))))))
                    (Err err (variant Err err))
                    (Ok sorted
                      (variant Ok
                        ((String.join " ")
                          (((inst List.map CanonFieldText String) sorted)
                            (lambda (entry CanonFieldText) (get entry text))))))))))))))))

(def Protoss.canonVariantFirstType
  (-> (List CanonTypeBinding)
    (-> CanonBranchSplitK
      (-> CanonCtx (-> CanonScope (-> (Maybe CanonFold) (Result String ProtossType))))))
  (lambda (cases (List CanonTypeBinding))
    (lambda (split CanonBranchSplitK)
      (lambda (ctx CanonCtx)
        (lambda (scope CanonScope)
          (lambda (branchFold (Maybe CanonFold))
            (let (firstInfo (Result String CanonBranchK)
              (caseList ((inst List.reverse CanonBranchK) (get split explicit))
                (Nil
                  (case (get split wildcard)
                    (Some wildK
                      (caseList cases
                        (Nil (variant Err "empty Variant case"))
                        (Cons firstCase rest
                          (variant Ok
                            (record
                              (constructor (get firstCase name))
                              (binder (variant Some ""))
                              (bodyK wildK))))))
                    (None (variant Err "empty Variant case"))))
                (Cons firstBranch rest (variant Ok firstBranch))))
              (case firstInfo
                (Err err (variant Err err))
                (Ok info
                  (case ((Protoss.canonBindingLookup cases) (get info constructor))
                    (None
                      (variant Err
                        ((String.concat "unknown branch: ") (get info constructor))))
                    (Some payload
                      (let (innerScope
                        (case (get info binder)
                          (Some binder
                            (record
                              (locals
                                (Cons CanonLocal
                                  (record (name binder) (typ payload))
                                  (get scope locals)))
                              (fold branchFold)))
                          (None
                            (record
                              (locals
                                (Cons CanonLocal
                                  (record (name "") (typ payload))
                                  (get scope locals)))
                              (fold (get scope fold))))))
                        (case ((((get info bodyK) ctx) innerScope) Protoss.canonNoExpected)
                          (Err err (variant Err err))
                          (Ok bodyOut (variant Ok (get bodyOut typ))))))))))))))))

(def Protoss.canonFindFieldK (-> (List CanonFieldK) (-> String (Maybe CanonFieldK)))
  (lambda (fields (List CanonFieldK))
    (lambda (wanted String)
      (foldList fields (variant (Maybe CanonFieldK) None unit)
        (lambda (field CanonFieldK)
          (lambda (acc (Maybe CanonFieldK))
            (case ((String.eqString (get field name)) wanted)
              (true (variant Some field))
              (false acc))))))))

(def Protoss.canonFieldEntryText (-> String (-> String String))
  (lambda (fieldName String)
    (lambda (bodyText String)
      ((String.concat "(")
        ((String.concat fieldName)
          ((String.concat " ") ((String.concat bodyText) ")")))))))

(def Protoss.canonRecordCheckText
  (-> (List CanonTypeBinding)
    (-> (List CanonFieldK) (-> CanonCtx (-> CanonScope (Result String String)))))
  (lambda (expectedFields (List CanonTypeBinding))
    (lambda (fieldKs (List CanonFieldK))
      (lambda (ctx CanonCtx)
        (lambda (scope CanonScope)
          (case
            (foldList fieldKs (variant (Result String Unit) Ok unit)
              (lambda (field CanonFieldK)
                (lambda (acc (Result String Unit))
                  (case acc
                    (Err err (variant Err err))
                    (Ok ignored
                      (case ((Protoss.canonBindingLookup expectedFields) (get field name))
                        (Some payload (variant Ok unit))
                        (None
                          (variant Err
                            ((String.concat "unknown record field: ") (get field name))))))))))
            (Err err (variant Err err))
            (Ok ignored
              (case
                (foldList expectedFields
                  (variant (Result String (List CanonFieldText)) Ok (Nil CanonFieldText))
                  (lambda (entry CanonTypeBinding)
                    (lambda (acc (Result String (List CanonFieldText)))
                      (case acc
                        (Err err (variant Err err))
                        (Ok done
                          (case ((Protoss.canonFindFieldK fieldKs) (get entry name))
                            (None
                              (variant Err
                                ((String.concat "record missing field: ") (get entry name))))
                            (Some field
                              (case ((((get field bodyK) ctx) scope)
                                      (variant Some (get entry typ)))
                                (Err err (variant Err err))
                                (Ok fieldOut
                                  (case
                                    ((Protoss.canonInsertField
                                      (record
                                        (name (get entry name))
                                        (text
                                          ((Protoss.canonFieldEntryText (get entry name))
                                            (get fieldOut text)))))
                                      done)
                                    (Err err (variant Err err))
                                    (Ok inserted (variant Ok inserted))))))))))))
                (Err err (variant Err err))
                (Ok sorted
                  (variant Ok
                    ((String.concat "(record ")
                      ((String.concat
                        ((String.join " ")
                          (((inst List.map CanonFieldText String) sorted)
                            (lambda (entry CanonFieldText) (get entry text)))))
                        ")"))))))))))))

(def Protoss.canonInsertBinding
  (-> CanonTypeBinding (-> (List CanonTypeBinding) (Result String (List CanonTypeBinding))))
  (lambda (x CanonTypeBinding)
    (lambda (xs (List CanonTypeBinding))
      (let (scan
        (foldList xs
          (variant (Result String CanonZipState) Ok
            (record (remaining (Nil ProtossType)) (out (Nil CanonTypeBinding)) (ok false)))
          (lambda (h CanonTypeBinding)
            (lambda (acc (Result String CanonZipState))
              (case acc
                (Err err (variant Err err))
                (Ok state
                  (case (get state ok)
                    (true
                      (variant Ok
                        (record
                          (remaining (Nil ProtossType))
                          (out (Cons CanonTypeBinding h (get state out)))
                          (ok true))))
                    (false
                      (let (order ((Protoss.canonCmpOrder (get h name)) (get x name)))
                        (case ((Nat.eqNat order) 3)
                          (true
                            (variant Err
                              "canonical ordering is undefined for non-ASCII names"))
                          (false
                            (case ((Nat.eqNat order) 0)
                              (true
                                (variant Ok
                                  (record
                                    (remaining (Nil ProtossType))
                                    (out
                                      (Cons CanonTypeBinding h
                                        (Cons CanonTypeBinding x (get state out))))
                                    (ok true))))
                              (false
                                (variant Ok
                                  (record
                                    (remaining (Nil ProtossType))
                                    (out (Cons CanonTypeBinding h (get state out)))
                                    (ok false))))))))))))))))
        (case scan
          (Err err (variant Err err))
          (Ok state
            (case (get state ok)
              (true (variant Ok (get state out)))
              (false (variant Ok (Cons CanonTypeBinding x (get state out)))))))))))

(def Protoss.canonRecordInferOut
  (-> (List CanonFieldK) (-> CanonCtx (-> CanonScope (Result String CanonOut))))
  (lambda (fieldKs (List CanonFieldK))
    (lambda (ctx CanonCtx)
      (lambda (scope CanonScope)
        (case
          (foldList fieldKs
            (variant
              (Result String (Pair (List CanonFieldText) (List CanonTypeBinding))) Ok
              (record (first (Nil CanonFieldText)) (second (Nil CanonTypeBinding))))
            (lambda (field CanonFieldK)
              (lambda (acc (Result String (Pair (List CanonFieldText) (List CanonTypeBinding))))
                (case acc
                  (Err err (variant Err err))
                  (Ok done
                    (case ((((get field bodyK) ctx) scope) Protoss.canonNoExpected)
                      (Err err (variant Err err))
                      (Ok fieldOut
                        (case
                          ((Protoss.canonInsertField
                            (record
                              (name (get field name))
                              (text
                                ((Protoss.canonFieldEntryText (get field name))
                                  (get fieldOut text)))))
                            (get done first))
                          (Err err (variant Err err))
                          (Ok sortedTexts
                            (case
                              ((Protoss.canonInsertBinding
                                (record (name (get field name)) (typ (get fieldOut typ))))
                                (get done second))
                              (Err err (variant Err err))
                              (Ok sortedTypes
                                (variant Ok
                                  (record (first sortedTexts) (second sortedTypes))))))))))))))
          (Err err (variant Err err))
          (Ok done
            (variant Ok
              (record
                (typ
                  (variant PTApply
                    (record
                      (name "Record")
                      (args
                        (((inst List.map CanonTypeBinding ProtossType) (get done second))
                          (lambda (entry CanonTypeBinding)
                            (variant PTApply
                              (record
                                (name (get entry name))
                                (args (Cons ProtossType (get entry typ) (Nil ProtossType)))))))))))
                (text
                  ((String.concat "(record ")
                    ((String.concat
                      ((String.join " ")
                        (((inst List.map CanonFieldText String) (get done first))
                          (lambda (entry CanonFieldText) (get entry text)))))
                      ")")))))))))))

(def Protoss.canonTvarArgsBindings (-> (List ProtossType) (List CanonTypeBinding))
  (lambda (args (List ProtossType))
    (let (len ((inst List.length ProtossType) args))
      (get
        (foldList args
          (record (first 0) (second (Nil CanonTypeBinding)))
          (lambda (arg ProtossType)
            (lambda (acc CanonIndexedBindings)
              (record
                (first (succ (get acc first)))
                (second
                  (Cons CanonTypeBinding
                    (record
                      (name
                        ((String.concat Protoss.canonTvarPrefix)
                          (Nat.toString
                            ((prim.Nat.sub (prim.Nat.pred len)) (get acc first)))))
                      (typ arg))
                    (get acc second)))))))
        second))))

(defrec Protoss.canonExprGo (-> ProtossExpr CanonExprK)
  (variant expr)
  (PEUnit ignored
    (lambda (ctx CanonCtx)
      (lambda (scope CanonScope)
        (lambda (expected (Maybe ProtossType))
          (variant Ok (record (typ Protoss.canonTUnit) (text "unit")))))))
  (PEBool value
    (lambda (ctx CanonCtx)
      (lambda (scope CanonScope)
        (lambda (expected (Maybe ProtossType))
          (variant Ok
            (record
              (typ Protoss.canonTBool)
              (text (case value (true "true") (false "false")))))))))
  (PEString value
    (lambda (ctx CanonCtx)
      (lambda (scope CanonScope)
        (lambda (expected (Maybe ProtossType))
          (variant Ok
            (record (typ Protoss.canonTString) (text (Protoss.canonQuote value))))))))
  (PERequest req
    (lambda (ctx CanonCtx)
      (lambda (scope CanonScope)
        (lambda (expected (Maybe ProtossType))
          (variant Ok
            (record
              (typ (Protoss.canonRequestType req))
              (text (Protoss.canonRequestText req))))))))
  (PEVar name
    (lambda (ctx CanonCtx)
      (lambda (scope CanonScope)
        (lambda (expected (Maybe ProtossType))
          (case (Protoss.canonNatOfDigits name)
            (Some value
              (variant Ok
                (record (typ Protoss.canonTNat) (text (Nat.toString value)))))
            (None
              (case ((Protoss.canonLocalLookup (get scope locals)) name)
                (Some local
                  (variant Ok
                    (record
                      (typ (get local typ))
                      (text ((String.concat "#") (Nat.toString (get local index)))))))
                (None
                  (case (Protoss.canonBuiltinSig name)
                    (Some sig
                      (variant Ok
                        (record
                          (typ sig)
                          (text
                            ((String.concat "(builtin ") ((String.concat name) ")"))))))
                    (None
                      (case ((Protoss.canonSigLookup (get ctx sigs)) name)
                        (None (variant Err ((String.concat "unknown name: ") name)))
                        (Some sig
                          (case ((Nat.eqNat (get sig arity)) 0)
                            (false
                              (variant Err
                                ((String.concat "polymorphic reference requires inst: ")
                                  name)))
                            (true
                              (variant Ok
                                (record
                                  (typ (get sig typ))
                                  (text
                                    ((String.concat "(ref ")
                                      ((String.concat ((Protoss.canonDefIdOf ctx) name))
                                        ")")))))))))))))))))))
  (PEApply call
    (let (fnK (recur (get call fn)))
      (let (argKs
        (foldList (get call args) (Nil CanonExprK)
          (lambda (arg ProtossExpr)
            (lambda (acc (List CanonExprK))
              (Cons CanonExprK (recur arg) acc)))))
        (lambda (ctx CanonCtx)
          (lambda (scope CanonScope)
            (lambda (expected (Maybe ProtossType))
              ((((Protoss.canonApplyChain argKs) ctx) scope)
                (((fnK ctx) scope) Protoss.canonNoExpected))))))))
  (PEInst instE
    (lambda (ctx CanonCtx)
      (lambda (scope CanonScope)
        (lambda (expected (Maybe ProtossType))
          (case ((Protoss.canonSigLookup (get ctx sigs)) (get instE name))
            (None
              (variant Err
                ((String.concat "unknown polymorphic definition: ") (get instE name))))
            (Some sig
              (case ((Nat.eqNat (get sig arity)) 0)
                (true
                  (variant Err
                    ((String.concat "definition is not polymorphic: ") (get instE name))))
                (false
                  (case
                    (foldList (get instE typeArgs)
                      (variant (Result String (List ProtossType)) Ok (Nil ProtossType))
                      (lambda (arg ProtossType)
                        (lambda (acc (Result String (List ProtossType)))
                          (case acc
                            (Err err (variant Err err))
                            (Ok done
                              (case ((Protoss.canonExpandType ctx) arg)
                                (Err err (variant Err err))
                                (Ok argT (variant Ok (Cons ProtossType argT done)))))))))
                    (Err err (variant Err err))
                    (Ok expandedArgs
                      (case
                        ((Nat.eqNat ((inst List.length ProtossType) expandedArgs))
                          (get sig arity))
                        (false
                          (variant Err
                            ((String.concat "wrong number of type arguments for inst: ")
                              (get instE name))))
                        (true
                          (case
                            ((Protoss.canonSubstTypeNames (get sig typ))
                              (Protoss.canonTvarArgsBindings expandedArgs))
                            (Err err (variant Err err))
                            (Ok instType
                              (case
                                (foldList expandedArgs
                                  (variant (Result String (List String)) Ok (Nil String))
                                  (lambda (arg ProtossType)
                                    (lambda (acc (Result String (List String)))
                                      (case acc
                                        (Err err (variant Err err))
                                        (Ok done
                                          (case (Protoss.canonTypeText arg)
                                            (Err err (variant Err err))
                                            (Ok text
                                              (variant Ok (Cons String text done)))))))))
                                (Err err (variant Err err))
                                (Ok argTexts
                                  (variant Ok
                                    (record
                                      (typ instType)
                                      (text
                                        ((String.concat "(inst ")
                                          ((String.concat
                                            ((Protoss.canonDefIdOf ctx) (get instE name)))
                                            ((String.concat " ")
                                              ((String.concat
                                                ((String.join " ") argTexts))
                                                ")")))))))))))))))))))))))
  (PELambda lambdaE
    (let (bodyK (recur (get lambdaE body)))
      (lambda (ctx CanonCtx)
        (lambda (scope CanonScope)
          (lambda (expected (Maybe ProtossType))
            (case ((Protoss.canonExpandType ctx) (get (get lambdaE param) typ))
              (Err err (variant Err err))
              (Ok paramType
                (let (bodyExpected (Maybe ProtossType)
                  (case expected
                    (Some e
                      (case e
                        (PTFun pair (variant Some (get pair second)))
                        (_ Protoss.canonNoExpected)))
                    (None Protoss.canonNoExpected)))
                  (case
                    (((bodyK ctx)
                      (((Protoss.canonLambdaScope scope)
                        (get (get lambdaE param) name))
                        paramType))
                      bodyExpected)
                    (Err err (variant Err err))
                    (Ok bodyOut
                      (case (Protoss.canonTypeText paramType)
                        (Err err (variant Err err))
                        (Ok paramText
                          (variant Ok
                            (record
                              (typ ((Protoss.canonFun paramType) (get bodyOut typ)))
                              (text
                                ((String.concat "(lam ")
                                  ((String.concat paramText)
                                    ((String.concat " ")
                                      ((String.concat (get bodyOut text)) ")")))))))))))))))))))
  (PELet letE
    (let (valueK (recur (get letE value)))
      (let (bodyK (recur (get letE body)))
        (lambda (ctx CanonCtx)
          (lambda (scope CanonScope)
            (lambda (expected (Maybe ProtossType))
              (let (valueInfo (Result String CanonOut)
                (case (get letE typ)
                  (Some ann
                    (case ((Protoss.canonExpandType ctx) ann)
                      (Err err (variant Err err))
                      (Ok annType
                        (case (((valueK ctx) scope) (variant Some annType))
                          (Err err (variant Err err))
                          (Ok valueOut
                            (variant Ok
                              (record (typ annType) (text (get valueOut text)))))))))
                  (None (((valueK ctx) scope) Protoss.canonNoExpected))))
                (case valueInfo
                  (Err err (variant Err err))
                  (Ok valueOut
                    (case
                      (((bodyK ctx)
                        (((Protoss.canonPush scope) (get letE name)) (get valueOut typ)))
                        expected)
                      (Err err (variant Err err))
                      (Ok bodyOut
                        (variant Ok
                          (record
                            (typ
                              (case expected
                                (Some e e)
                                (None (get bodyOut typ))))
                            (text
                              ((String.concat "(let ")
                                ((String.concat (get valueOut text))
                                  ((String.concat " ")
                                    ((String.concat (get bodyOut text)) ")"))))))))))))))))))
  (PERecord fields
    (let (fieldKs
      (foldList fields (Nil CanonFieldK)
        (lambda (field ProtossRecordFieldExpr)
          (lambda (acc (List CanonFieldK))
            (Cons CanonFieldK
              (record (name (get field name)) (bodyK (recur (get field expr))))
              acc)))))
      (lambda (ctx CanonCtx)
        (lambda (scope CanonScope)
          (lambda (expected (Maybe ProtossType))
            (let (checkedFields (Maybe (List CanonTypeBinding))
              (case expected
                (None (variant (Maybe (List CanonTypeBinding)) None unit))
                (Some e
                  (case ((Protoss.canonUnfoldNamed ctx) e)
                    (Err err (variant (Maybe (List CanonTypeBinding)) None unit))
                    (Ok unfolded
                      (case unfolded
                        (PTApply app
                          (case ((String.eqString (get app name)) "Record")
                            (false (variant (Maybe (List CanonTypeBinding)) None unit))
