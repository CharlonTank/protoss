(def Protoss.canonDefIdsParse (-> String (Result String (List CanonIdEntry)))
  (lambda (text String)
    (case (Sexp.parseText text)
      (Err err (variant Err err))
      (Ok forms
        (foldList forms
          (variant (Result String (List CanonIdEntry)) Ok (Nil CanonIdEntry))
          (lambda (form Sexp)
            (lambda (acc (Result String (List CanonIdEntry)))
              (case acc
                (Err err (variant Err err))
                (Ok done
                  (case form
                    (SList items
                      (caseList items
                        (Nil (variant Err "malformed def-id entry"))
                        (Cons nameNode rest
                          (caseList rest
                            (Nil (variant Err "malformed def-id entry"))
                            (Cons idNode extra
                              (caseList extra
                                (Nil
                                  (case nameNode
                                    (SAtom defName
                                      (case idNode
                                        (SAtom defId
                                          (variant Ok
                                            (Cons CanonIdEntry
                                              (record (name defName) (defId defId))
                                              done)))
                                        (SString defId
                                          (variant Ok
                                            (Cons CanonIdEntry
                                              (record (name defName) (defId defId))
                                              done)))
                                        (_ (variant Err "malformed def-id entry"))))
                                    (_ (variant Err "malformed def-id entry"))))
                                (Cons more moreRest
                                  (variant Err "malformed def-id entry"))))))))
                    (_ (variant Err "malformed def-id entry"))))))))))))

(def Protoss.canonDefRecDesugar (-> ProtossDefRec (Result String CanonDefSrc))
  (lambda (defRec ProtossDefRec)
    (case (get defRec typ)
      (PTFun pair
        (case (get defRec body)
          (PDRNat natRec
            (case (get pair first)
              (PTName natName
                (case ((String.eqString natName) "Nat")
                  (false (variant Err "defrec nat recursion requires a Nat domain"))
                  (true
                    (variant Ok
                      (record
                        (name (get defRec name))
                        (typeParams (get defRec typeParams))
                        (typ (get defRec typ))
                        (body
                          (variant PELambda
                            (record
                              (param
                                (record
                                  (name (get natRec param))
                                  (typ (variant PTName "Nat"))))
                              (body
                                (variant PEFoldNat
                                  (record
                                    (target (variant PEVar (get natRec param)))
                                    (zero (get natRec zero))
                                    (step
                                      (variant PELambda
                                        (record
                                          (param
                                            (record
                                              (name (get natRec acc))
                                              (typ (get pair second))))
                                          (body (get natRec step))))))))))))))))
              (_ (variant Err "defrec nat recursion requires a Nat domain"))))
          (PDRList listRec
            (case (get pair first)
              (PTApply listApp
                (case ((String.eqString (get listApp name)) "List")
                  (false (variant Err "defrec list recursion requires a List domain"))
                  (true
                    (caseList (get listApp args)
                      (Nil (variant Err "defrec list recursion requires a List domain"))
                      (Cons itemType extraArgs
                        (variant Ok
                          (record
                            (name (get defRec name))
                            (typeParams (get defRec typeParams))
                            (typ (get defRec typ))
                            (body
                              (variant PELambda
                                (record
                                  (param
                                    (record
                                      (name (get listRec param))
                                      (typ (get pair first))))
                                  (body
                                    (variant PEFoldList
                                      (record
                                        (target (variant PEVar (get listRec param)))
                                        (zero (get listRec nil))
                                        (step
                                          (variant PELambda
                                            (record
                                              (param
                                                (record
                                                  (name (get listRec item))
                                                  (typ itemType)))
                                              (body
                                                (variant PELambda
                                                  (record
                                                    (param
                                                      (record
                                                        (name (get listRec acc))
                                                        (typ (get pair second))))
                                                    (body (get listRec step)))))))))))))))))))))
              (_ (variant Err "defrec list recursion requires a List domain"))))
          (PDRVariant variantRec
            (variant Ok
              (record
                (name (get defRec name))
                (typeParams (get defRec typeParams))
                (typ (get defRec typ))
                (body
                  (variant PELambda
                    (record
                      (param
                        (record
                          (name (get variantRec param))
                          (typ (get pair first))))
                      (body
                        (variant PEFoldVariant
                          (record
                            (target (get pair first))
                            (result (get pair second))
                            (scrutinee (variant PEVar (get variantRec param)))
                            (branches (get variantRec branches)))))))))))))
      (_ (variant Err "defrec requires a function type")))))

(def Protoss.canonStructuralAliasBody
  (-> String (-> (List CanonTypeBinding) ProtossType))
  (lambda (head String)
    (lambda (entries (List CanonTypeBinding))
      (variant PTApply
        (record
          (name head)
          (args
            (((inst List.map CanonTypeBinding ProtossType) entries)
              (lambda (entry CanonTypeBinding)
                (variant PTApply
                  (record
                    (name (get entry name))
                    (args (Cons ProtossType (get entry typ) (Nil ProtossType)))))))))))))

(def Protoss.canonCollectDecls (-> (List ProtossDecl) (Result String CanonCollect))
  (lambda (decls (List ProtossDecl))
    (foldList decls
      (variant (Result String CanonCollect) Ok
        (record
          (caps (Nil String))
          (aliases (Nil CanonAlias))
          (defs (Nil CanonDefSrc))))
      (lambda (decl ProtossDecl)
        (lambda (acc (Result String CanonCollect))
          (case acc
            (Err err (variant Err err))
            (Ok done
              (case decl
                (PDCapabilities capNames
                  (variant Ok
                    (record
                      (caps (((inst List.append String) capNames) (get done caps)))
                      (aliases (get done aliases))
                      (defs (get done defs)))))
                (PDDef def
                  (variant Ok
                    (record
                      (caps (get done caps))
                      (aliases (get done aliases))
                      (defs
                        (Cons CanonDefSrc
                          (record
                            (name (get def name))
                            (typeParams (Nil String))
                            (typ (get def typ))
                            (body (get def expr)))
                          (get done defs))))))
                (PDDefCap def
                  (variant Ok
                    (record
                      (caps (get done caps))
                      (aliases (get done aliases))
                      (defs
                        (Cons CanonDefSrc
                          (record
                            (name (get def name))
                            (typeParams (Nil String))
                            (typ (get def typ))
                            (body (get def expr)))
                          (get done defs))))))
                (PDDefPoly def
                  (variant Ok
                    (record
                      (caps (get done caps))
                      (aliases (get done aliases))
                      (defs
                        (Cons CanonDefSrc
                          (record
                            (name (get def name))
                            (typeParams (get def typeParams))
                            (typ (get def typ))
                            (body (get def expr)))
                          (get done defs))))))
                (PDDefPolyCap def
                  (variant Ok
                    (record
                      (caps (get done caps))
                      (aliases (get done aliases))
                      (defs
                        (Cons CanonDefSrc
                          (record
                            (name (get def name))
                            (typeParams (get def typeParams))
                            (typ (get def typ))
                            (body (get def expr)))
                          (get done defs))))))
                (PDDefRec defRec
                  (case (Protoss.canonDefRecDesugar defRec)
                    (Err err (variant Err err))
                    (Ok def
                      (variant Ok
                        (record
                          (caps (get done caps))
                          (aliases (get done aliases))
                          (defs (Cons CanonDefSrc def (get done defs))))))))
                (PDType alias
                  (variant Ok
                    (record
                      (caps (get done caps))
                      (aliases
                        (Cons CanonAlias
                          (record
                            (name (get alias name))
                            (params (get alias typeParams))
                            (body (get alias body)))
                          (get done aliases)))
                      (defs (get done defs)))))
                (PDRecord decl
                  (variant Ok
                    (record
                      (caps (get done caps))
                      (aliases
                        (Cons CanonAlias
                          (record
                            (name (get decl name))
                            (params (get decl typeParams))
                            (body
                              ((Protoss.canonStructuralAliasBody "Record")
                                (((inst List.map ProtossField CanonTypeBinding)
                                  (get decl fields))
                                  (lambda (field ProtossField)
                                    (record
                                      (name (get field name))
                                      (typ (get field typ))))))))
                          (get done aliases)))
                      (defs (get done defs)))))
                (PDVariant decl
                  (variant Ok
                    (record
                      (caps (get done caps))
                      (aliases
                        (Cons CanonAlias
                          (record
                            (name (get decl name))
                            (params (get decl typeParams))
                            (body
                              ((Protoss.canonStructuralAliasBody "Variant")
                                (((inst List.map ProtossVariantCase CanonTypeBinding)
                                  (get decl cases))
                                  (lambda (variantCase ProtossVariantCase)
                                    (record
                                      (name (get variantCase name))
                                      (typ (get variantCase payload))))))))
                          (get done aliases)))
                      (defs (get done defs)))))
                (PDExport names (variant Ok done))
                (PDModule moduleName
                  (variant Err
                    "module declarations are not supported by the self-hosted canonicalizer"))
                (PDImport path
                  (variant Err
                    "imports are not supported by the self-hosted canonicalizer"))))))))))

(def Protoss.canonRecNames (-> (List CanonAlias) (List String))
  (lambda (aliases (List CanonAlias))
    (foldList aliases (Nil String)
      (lambda (alias CanonAlias)
        (lambda (acc (List String))
          (case ((Protoss.canonContains (get alias params)) (get alias name))
            (true acc)
            (false
              (case ((Protoss.canonTypeMentions (get alias body)) (get alias name))
                (true (Cons String (get alias name) acc))
                (false acc)))))))))

(def Protoss.canonSigsOf
  (-> (List CanonAlias)
    (-> (List String) (-> (List CanonDefSrc) (Result String (List CanonSig)))))
  (lambda (aliases (List CanonAlias))
    (lambda (recNames (List String))
      (lambda (defs (List CanonDefSrc))
        (foldList defs
          (variant (Result String (List CanonSig)) Ok (Nil CanonSig))
          (lambda (def CanonDefSrc)
            (lambda (acc (Result String (List CanonSig)))
              (case acc
                (Err err (variant Err err))
                (Ok done
                  (let (sigCtx CanonCtx
                    (record
                      (aliases aliases)
                      (recNames recNames)
                      (tvars (get def typeParams))
                      (sigs (Nil CanonSig))
                      (defIds (Nil CanonIdEntry))))
                    (case ((Protoss.canonExpandType sigCtx) (get def typ))
                      (Err err (variant Err err))
                      (Ok expanded
                        (variant Ok
                          (Cons CanonSig
                            (record
                              (name (get def name))
                              (arity ((inst List.length String) (get def typeParams)))
                              (typ expanded))
                            done))))))))))))))

(def Protoss.canonDefEntry (-> CanonCtx (-> CanonDefSrc (Result String CanonFieldText)))
  (lambda (ctx CanonCtx)
    (lambda (def CanonDefSrc)
      (case ((Protoss.canonSigLookup (get ctx sigs)) (get def name))
        (None
          (variant Err
            ((String.concat "missing signature for definition: ") (get def name))))
        (Some sig
          (let (defCtx CanonCtx
            (record
              (aliases (get ctx aliases))
              (recNames (get ctx recNames))
              (tvars (get def typeParams))
              (sigs (get ctx sigs))
              (defIds (get ctx defIds))))
            (case (Protoss.canonTypeText (get sig typ))
              (Err err (variant Err err))
              (Ok bodyTypeText
                (let (typeText String
                  (case ((Nat.eqNat (get sig arity)) 0)
                    (true bodyTypeText)
                    (false
                      ((String.concat "(Forall ")
                        ((String.concat (Nat.toString (get sig arity)))
                          ((String.concat " ")
                            ((String.concat bodyTypeText) ")")))))))
                  (case
                    ((((Protoss.canonExprGo (get def body)) defCtx)
                      (record
                        (locals (Nil CanonLocal))
                        (fold (variant (Maybe CanonFold) None unit))))
                      (variant Some (get sig typ)))
                    (Err err
                      (variant Err
                        ((String.concat (get def name))
                          ((String.concat ": ") err))))
                    (Ok bodyOut
                      (variant Ok
                        (record
                          (name (get def name))
                          (text
                            ((String.concat "(def ")
                              ((String.concat (get def name))
                                ((String.concat " ")
                                  ((String.concat ((Protoss.canonDefIdOf ctx) (get def name)))
                                    ((String.concat " ")
                                      ((String.concat typeText)
                                        ((String.concat " ")
                                          ((String.concat (get bodyOut text))
                                            ")"))))))))))))))))))))))

(def Protoss.canonProgramText (-> String (-> String (Result String String)))
  (lambda (defIdsText String)
    (lambda (source String)
      (case (Protoss.canonDefIdsParse defIdsText)
        (Err err (variant Err err))
        (Ok defIds
          (case (Protoss.parseText source)
            (Err err (variant Err err))
            (Ok decls
              (case (Protoss.canonCollectDecls decls)
                (Err err (variant Err err))
                (Ok collected
                  (let (recNames (Protoss.canonRecNames (get collected aliases)))
                    (case
                      (((Protoss.canonSigsOf (get collected aliases)) recNames)
                        (get collected defs))
                      (Err err (variant Err err))
                      (Ok sigs
                        (let (ctx CanonCtx
                          (record
                            (aliases (get collected aliases))
                            (recNames recNames)
                            (tvars (Nil String))
                            (sigs sigs)
                            (defIds defIds)))
                          (case
                            (foldList (get collected defs)
                              (variant (Result String (List CanonFieldText)) Ok
                                (Nil CanonFieldText))
                              (lambda (def CanonDefSrc)
                                (lambda (acc (Result String (List CanonFieldText)))
                                  (case acc
                                    (Err err (variant Err err))
                                    (Ok done
                                      (case ((Protoss.canonDefEntry ctx) def)
                                        (Err err (variant Err err))
                                        (Ok entry
                                          (case ((Protoss.canonInsertField entry) done)
                                            (Err err (variant Err err))
                                            (Ok inserted (variant Ok inserted))))))))))
                            (Err err (variant Err err))
                            (Ok sortedDefs
                              (case
                                (foldList (get collected caps)
                                  (variant (Result String (List String)) Ok (Nil String))
                                  (lambda (cap String)
                                    (lambda (acc (Result String (List String)))
                                      (case acc
                                        (Err err (variant Err err))
                                        (Ok done
                                          (case (((Protoss.canonInsertString true) cap) done)
                                            (Err err (variant Err err))
                                            (Ok inserted (variant Ok inserted))))))))
                                (Err err (variant Err err))
                                (Ok sortedCaps
                                  (variant Ok
                                    ((String.concat
                                      "(protoss-canon-v2 (program (caps ")
                                      ((String.concat ((String.join " ") sortedCaps))
                                        ((String.concat ") (defs ")
                                          ((String.concat
                                            ((String.join " ")
                                              (((inst List.map CanonFieldText String)
                                                sortedDefs)
                                                (lambda (entry CanonFieldText)
                                                  (get entry text)))))
                                            ")))"))))))))))))))))))))))

(def Protoss.tcTextJson (-> String String)
  (lambda (source String)
    (case (Protoss.tcText source)
      (Err err
        (Json.render
          (Protoss.jsonObjectOf
            (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "error"))
            (Cons (Pair String Json) ((Protoss.jf "error") (Protoss.tcErrorToJson err))
            (Nil (Pair String Json)))))))
      (Ok report (Json.render (Protoss.tcReportToJson report))))))

(def Protoss.selfParseJson (-> String String)
  (lambda (source String)
    (case (Protoss.parseText source)
      (Err err (Json.render (Protoss.jsonError err)))
      (Ok decls
        (let (resolve ProtossResolveReport (Protoss.resolveDecls decls))
          (Json.render
            (Protoss.jsonObjectOf
              (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "ok"))
              (Cons (Pair String Json) ((Protoss.jf "definitions") (Protoss.jsonStrings (get resolve definedTerms)))
              (Cons (Pair String Json) ((Protoss.jf "types") (Protoss.jsonStrings (get resolve definedTypes)))
              (Cons (Pair String Json) ((Protoss.jf "imports") (Protoss.jsonStrings (Protoss.declImportPaths decls)))
              (Cons (Pair String Json) ((Protoss.jf "exports") (Protoss.jsonStrings (get resolve exports)))
              (Nil (Pair String Json))))))))))))))

(def Protoss.selfResolveJson (-> String String)
  (lambda (source String)
    (case (Protoss.resolveText source)
      (Err err (Json.render (Protoss.jsonError err)))
      (Ok report (Json.render (Protoss.resolveReportToJson report))))))

(def Protoss.selfCapabilitiesJson (-> String String)
  (lambda (source String)
    (case (Protoss.capabilityReportText source)
      (Err err (Json.render (Protoss.jsonError err)))
      (Ok report (Json.render (Protoss.capabilityReportToJson report))))))

(def Protoss.selfDepsJson (-> String String)
  (lambda (source String)
    (case (Protoss.staticReportText source)
      (Err err (Json.render (Protoss.jsonError err)))
      (Ok report
        (Json.render
          (Protoss.jsonObjectOf
            (Cons (Pair String Json) ((Protoss.jf "termDeps") (Protoss.depOrderToJson (get report termOrder)))
            (Cons (Pair String Json) ((Protoss.jf "typeDeps") (Protoss.depOrderToJson (get (get report typeEnv) order)))
            (Nil (Pair String Json))))))))))

(def Protoss.selfStaticJson (-> String (-> String String))
  (lambda (frontendDefId String)
    (lambda (source String)
      (case (Protoss.parseText source)
        (Err err (Json.render (Protoss.jsonError err)))
        (Ok decls
          (Json.render
            (((Protoss.staticReportToJson frontendDefId)
               (Protoss.declImportPaths decls))
              (Protoss.staticReportDecls decls))))))))

(def Protoss.selfStaticText (-> String String)
  (lambda (source String)
    ((Protoss.selfStaticJson "-") source)))

(def Protoss.selfComponentOkJson (-> String (-> String String))
  (lambda (component String)
    (lambda (entry String)
      (Json.render
        (Protoss.jsonObjectOf
          (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "ok"))
          (Cons (Pair String Json) ((Protoss.jf "component") (Json.string component))
          (Cons (Pair String Json) ((Protoss.jf "entry") (Json.string entry))
          (Nil (Pair String Json))))))))))

(def Protoss.selfCanonicalizerJson (-> String String)
  (lambda (source String)
    (case ((Protoss.canonProgramText "") source)
      (Err err (Json.render (Protoss.jsonError err)))
      (Ok canonical
        (Json.render
          (Protoss.jsonObjectOf
            (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "ok"))
            (Cons (Pair String Json) ((Protoss.jf "component") (Json.string "canonicalizer"))
            (Cons (Pair String Json) ((Protoss.jf "entry") (Json.string "Protoss.canonProgramText"))
            (Cons (Pair String Json) ((Protoss.jf "canonicalCandidate") (Json.string canonical))
            (Cons (Pair String Json)
              ((Protoss.jf "parity")
                (Json.string
                  "run protoss self canon <file> --compare to verify byte-for-byte against the kernel"))
              (Nil (Pair String Json)))))))))))))

(def Protoss.selfHumanParserJson (-> String String)
  (lambda (source String)
    (case (Protoss.parseText source)
      (Err err (Json.render (Protoss.jsonError err)))
      (Ok parsed ((Protoss.selfComponentOkJson "protoss-h-parser") "Protoss.parseText")))))

