(def Protoss.selfTrustedBoundaryJson (-> String String)
  (lambda (source String)
    (Json.render
      (Protoss.jsonObjectOf
        (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "ok"))
        (Cons (Pair String Json) ((Protoss.jf "component") (Json.string "trusted-boundary"))
        (Cons (Pair String Json) ((Protoss.jf "tcb") (Protoss.jsonStrings
          (Cons String "hashes"
          (Cons String "binary-format"
          (Cons String "kernel-type-verifier"
          (Cons String "patch-validator"
          (Cons String "effect-runtime"
          (Nil String))))))))
        (Nil (Pair String Json)))))))))

(def Protoss.selfBootstrapPlanJson (-> String String)
  (lambda (source String)
    (Json.render
      (Protoss.jsonObjectOf
        (Cons (Pair String Json) ((Protoss.jf "status") (Json.string "ok"))
        (Cons (Pair String Json) ((Protoss.jf "component") (Json.string "bootstrap"))
        (Cons (Pair String Json) ((Protoss.jf "phases") (Protoss.jsonStrings
          (Cons String "0-hosted-reports"
          (Cons String "1-parity"
          (Cons String "2-advisory-candidates"
          (Cons String "3-kernel-verified-candidates"
          (Cons String "4-default-self-hosted"
          (Cons String "5-trusted-reduced-tcb"
          (Nil String)))))))))
        (Nil (Pair String Json)))))))))
