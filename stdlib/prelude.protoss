(def Stdlib.version String "v0.44")

(def Nat.add (-> Nat (-> Nat Nat))
  (lambda (a Nat)
    (lambda (b Nat)
      ((prim.Nat.add a) b))))

(def Nat.mul (-> Nat (-> Nat Nat))
  (lambda (a Nat)
    (lambda (b Nat)
      ((prim.Nat.mul a) b))))

(def Nat.eqNat (-> Nat (-> Nat Bool))
  (lambda (a Nat)
    (lambda (b Nat)
      ((prim.Nat.eq a) b))))

(def Nat.toString (-> Nat String)
  (lambda (n Nat)
    (prim.Nat.toString n)))

(def Nat.pred (-> Nat Nat)
  (lambda (n Nat)
    (prim.Nat.pred n)))

(def Nat.sub (-> Nat (-> Nat Nat))
  (lambda (a Nat)
    (lambda (b Nat)
      ((prim.Nat.sub a) b))))

(def Bool.not (-> Bool Bool)
  (lambda (b Bool)
    (case b (true false) (false true))))

(def Bool.and (-> Bool (-> Bool Bool))
  (lambda (a Bool)
    (lambda (b Bool)
      (case a (true b) (false false)))))

(def Bool.or (-> Bool (-> Bool Bool))
  (lambda (a Bool)
    (lambda (b Bool)
      (case a (true true) (false b)))))

(def Nat.lte (-> Nat (-> Nat Bool))
  (lambda (a Nat)
    (lambda (b Nat)
      ((prim.Nat.lte a) b))))

(def Nat.lt (-> Nat (-> Nat Bool))
  (lambda (a Nat)
    (lambda (b Nat)
      ((prim.Nat.lt a) b))))

(def Nat.gte (-> Nat (-> Nat Bool))
  (lambda (a Nat)
    (lambda (b Nat)
      ((prim.Nat.gte a) b))))

(def Nat.gt (-> Nat (-> Nat Bool))
  (lambda (a Nat)
    (lambda (b Nat)
      ((prim.Nat.gt a) b))))

(def String.empty String "")

(def String.concat (-> String (-> String String))
  (lambda (a String)
    (lambda (b String)
      ((prim.String.concat a) b))))

(def String.append (-> String (-> String String))
  (lambda (a String)
    (lambda (b String)
      ((String.concat a) b))))

(def String.eqString (-> String (-> String Bool))
  (lambda (a String)
    (lambda (b String)
      ((prim.String.eq a) b))))

(def String.length (-> String Nat)
  (lambda (value String)
    (prim.String.length value)))

(def String.slice (-> String (-> Nat (-> Nat String)))
  (lambda (value String)
    (lambda (start Nat)
      (lambda (count Nat)
        (((prim.String.slice value) start) count)))))

(def String.take (-> String (-> Nat String))
  (lambda (value String)
    (lambda (count Nat)
      (((String.slice value) 0) count))))

(def String.drop (-> String (-> Nat String))
  (lambda (value String)
    (lambda (count Nat)
      (((String.slice value) count) ((Nat.sub (String.length value)) count)))))

(def String.startsWith (-> String (-> String Bool))
  (lambda (value String)
    (lambda (prefix String)
      ((String.eqString (((String.slice value) 0) (String.length prefix))) prefix))))

(def String.charAt (-> String (-> Nat (Maybe String)))
  (lambda (value String)
    (lambda (index Nat)
      ((prim.String.charAt value) index))))

(def String.isEmpty (-> String Bool)
  (lambda (value String)
    ((String.eqString value) String.empty)))

(def String.nonEmpty (-> String Bool)
  (lambda (value String)
    (Bool.not (String.isEmpty value))))

(def String.whitespaceChars (List String)
  (Cons String " "
    (Cons String "\n"
      (Cons String "\t"
        (Cons String "\r" (Nil String))))))

(def String.digitChars (List String)
  (Cons String "0"
    (Cons String "1"
      (Cons String "2"
        (Cons String "3"
          (Cons String "4"
            (Cons String "5"
              (Cons String "6"
                (Cons String "7"
                  (Cons String "8"
                    (Cons String "9" (Nil String))))))))))))

(def String.delimiterChars (List String)
  (Cons String " "
    (Cons String "\n"
      (Cons String "\t"
        (Cons String "\r"
          (Cons String "("
            (Cons String ")"
              (Cons String "\""
                (Cons String ";" (Nil String))))))))))

(def String.isWhitespace (-> String Bool)
  (lambda (ch String)
    ((((inst List.member String) String.eqString) ch) String.whitespaceChars)))

(def String.isDigit (-> String Bool)
  (lambda (ch String)
    ((((inst List.member String) String.eqString) ch) String.digitChars)))

(def String.digitValue (-> String (Maybe Nat))
  (lambda (ch String)
    (case ((String.eqString ch) "0")
      (true (variant Some 0))
      (false (case ((String.eqString ch) "1")
        (true (variant Some 1))
        (false (case ((String.eqString ch) "2")
          (true (variant Some 2))
          (false (case ((String.eqString ch) "3")
            (true (variant Some 3))
            (false (case ((String.eqString ch) "4")
              (true (variant Some 4))
              (false (case ((String.eqString ch) "5")
                (true (variant Some 5))
                (false (case ((String.eqString ch) "6")
                  (true (variant Some 6))
                  (false (case ((String.eqString ch) "7")
                    (true (variant Some 7))
                    (false (case ((String.eqString ch) "8")
                      (true (variant Some 8))
                      (false (case ((String.eqString ch) "9")
                        (true (variant Some 9))
                        (false (variant None unit)))))))))))))))))))))
  ))

(def String.isDelimiter (-> String Bool)
  (lambda (ch String)
    ((((inst List.member String) String.eqString) ch) String.delimiterChars)))

(def String.isAtomChar (-> String Bool)
  (lambda (ch String)
    ((Bool.and (String.nonEmpty ch)) (Bool.not (String.isDelimiter ch)))))

(def String.join (-> String (-> (List String) String))
  (lambda (separator String)
    (lambda (items (List String))
      (foldList items String.empty
        (lambda (item String)
          (lambda (acc String)
            (case (String.isEmpty acc)
              (true item)
              (false ((String.concat item) ((String.concat separator) acc))))))))))

(def TextCursor.at (-> String (-> Nat TextCursor))
  (lambda (source String)
    (lambda (offset Nat)
      (record (source source) (offset offset)))))

(def TextCursor.start (-> String TextCursor)
  (lambda (source String)
    ((TextCursor.at source) 0)))

(def TextCursor.current (-> TextCursor (Maybe String))
  (lambda (cursor TextCursor)
    ((String.charAt (get cursor source)) (get cursor offset))))

(def TextCursor.advance (-> TextCursor TextCursor)
  (lambda (cursor TextCursor)
    ((TextCursor.at (get cursor source)) (succ (get cursor offset)))))

(def TextCursor.remaining (-> TextCursor String)
  (lambda (cursor TextCursor)
    ((String.drop (get cursor source)) (get cursor offset))))

(def TextCursor.isDone (-> TextCursor Bool)
  (lambda (cursor TextCursor)
    ((Nat.gte (get cursor offset)) (String.length (get cursor source)))))

(def TextCursor.peekIs (-> TextCursor (-> String Bool))
  (lambda (cursor TextCursor)
    (lambda (expected String)
      (case (TextCursor.current cursor)
        (None false)
        (Some ch ((String.eqString ch) expected))))))

(def SourceSpan.at (-> Nat (-> Nat SourceSpan))
  (lambda (line Nat)
    (lambda (column Nat)
      (record (line line) (column column)))))

(def SourceSpan.render (-> SourceSpan String)
  (lambda (span SourceSpan)
    ((String.concat (Nat.toString (get span line)))
      ((String.concat ":") (Nat.toString (get span column))))))

(def Diagnostic.at (-> SourceSpan (-> String Diagnostic))
  (lambda (span SourceSpan)
    (lambda (message String)
      (record (span span) (message message)))))

(def Diagnostic.render (-> Diagnostic String)
  (lambda (diagnostic Diagnostic)
    ((String.concat (SourceSpan.render (get diagnostic span)))
      ((String.concat ": ") (get diagnostic message)))))

(defpoly List.map (params A B)
  (-> (List A) (-> (-> A B) (List B)))
  (lambda (xs (List A))
    (lambda (f (-> A B))
      (foldList xs (Nil B)
        (lambda (x A)
          (lambda (acc (List B))
            (Cons B (f x) acc)))))))

(defpoly List.length (params A)
  (-> (List A) Nat)
  (lambda (xs (List A))
    (foldList xs 0
      (lambda (x A)
        (lambda (acc Nat)
          (succ acc))))))

(defpoly List.append (params A)
  (-> (List A) (-> (List A) (List A)))
  (lambda (xs (List A))
    (lambda (ys (List A))
      (foldList xs ys
        (lambda (x A)
          (lambda (acc (List A))
            (Cons A x acc)))))))

(defpoly List.fold (params A B)
  (-> (List A) (-> B (-> (-> A (-> B B)) B)))
  (lambda (xs (List A))
    (lambda (seed B)
      (lambda (step (-> A (-> B B)))
        (foldList xs seed step)))))

(defpoly List.concat (params A)
  (-> (List (List A)) (List A))
  (lambda (xss (List (List A)))
    (foldList xss (Nil A)
      (lambda (xs (List A))
        (lambda (acc (List A))
          (((inst List.append A) xs) acc))))))

(defpoly List.flatMap (params A B)
  (-> (List A) (-> (-> A (List B)) (List B)))
  (lambda (xs (List A))
    (lambda (f (-> A (List B)))
      (foldList xs (Nil B)
        (lambda (x A)
          (lambda (acc (List B))
            (((inst List.append B) (f x)) acc)))))))

(defpoly List.filter (params A)
  (-> (List A) (-> (-> A Bool) (List A)))
  (lambda (xs (List A))
    (lambda (pred (-> A Bool))
      (foldList xs (Nil A)
        (lambda (x A)
          (lambda (acc (List A))
            (case (pred x)
              (true (Cons A x acc))
              (false acc))))))))

(defpoly List.reverse (params A)
  (-> (List A) (List A))
  (lambda (xs (List A))
    (foldList xs (Nil A)
      (lambda (x A)
        (lambda (acc (List A))
          (((inst List.append A) acc) (Cons A x (Nil A))))))))

(defpoly List.any (params A)
  (-> (List A) (-> (-> A Bool) Bool))
  (lambda (xs (List A))
    (lambda (pred (-> A Bool))
      (foldList xs false
        (lambda (x A)
          (lambda (acc Bool)
            (case (pred x)
              (true true)
              (false acc))))))))

(defpoly List.all (params A)
  (-> (List A) (-> (-> A Bool) Bool))
  (lambda (xs (List A))
    (lambda (pred (-> A Bool))
      (foldList xs true
        (lambda (x A)
          (lambda (acc Bool)
            (case (pred x)
              (true acc)
              (false false))))))))

(defpoly List.member (params A)
  (-> (-> A (-> A Bool)) (-> A (-> (List A) Bool)))
  (lambda (eq (-> A (-> A Bool)))
    (lambda (value A)
      (lambda (xs (List A))
        (((inst List.any A) xs)
          (lambda (x A)
            ((eq x) value)))))))

(defpoly List.find (params A)
  (-> (List A) (-> (-> A Bool) (Maybe A)))
  (lambda (xs (List A))
    (lambda (pred (-> A Bool))
      (foldList xs (variant (Maybe A) None unit)
        (lambda (x A)
          (lambda (acc (Maybe A))
            (case (pred x)
              (true (variant Some x))
              (false acc))))))))

(def List.mapNat (-> (List Nat) (-> (-> Nat Nat) (List Nat)))
  (lambda (xs (List Nat))
    (lambda (f (-> Nat Nat))
      (foldList xs (Nil Nat)
        (lambda (x Nat)
          (lambda (acc (List Nat))
            (Cons Nat (f x) acc)))))))

(defpoly Maybe.withDefault (params A)
  (-> A (-> (Maybe A) A))
  (lambda (fallback A)
    (lambda (m (Maybe A))
      (case m
        (None _ fallback)
        (Some value value)))))

(defpoly Maybe.isSome (params A)
  (-> (Maybe A) Bool)
  (lambda (m (Maybe A))
    (case m
      (None false)
      (Some value true))))

(defpoly Maybe.isNone (params A)
  (-> (Maybe A) Bool)
  (lambda (m (Maybe A))
    (case m
      (None true)
      (Some value false))))

(defpoly Maybe.map (params A B)
  (-> (-> A B) (-> (Maybe A) (Maybe B)))
  (lambda (f (-> A B))
    (lambda (m (Maybe A))
      (case m
        (None _ (variant None unit))
        (Some value (variant Some (f value)))))))

(defpoly Maybe.map2 (params A B C)
  (-> (-> A (-> B C)) (-> (Maybe A) (-> (Maybe B) (Maybe C))))
  (lambda (f (-> A (-> B C)))
    (lambda (left (Maybe A))
      (lambda (right (Maybe B))
        (case left
          (None (variant None unit))
          (Some leftValue
            (case right
              (None (variant None unit))
              (Some rightValue (variant Some ((f leftValue) rightValue))))))))))

(defpoly Maybe.andThen (params A B)
  (-> (Maybe A) (-> (-> A (Maybe B)) (Maybe B)))
  (lambda (m (Maybe A))
    (lambda (f (-> A (Maybe B)))
      (case m
        (None (variant None unit))
        (Some value (f value))))))

(defpoly Maybe.toResult (params E A)
  (-> E (-> (Maybe A) (Result E A)))
  (lambda (err E)
    (lambda (m (Maybe A))
      (case m
        (None (variant Err err))
        (Some value (variant Ok value))))))

(defpoly Option.none (params A)
  (Option A)
  (variant None unit))

(defpoly Option.some (params A)
  (-> A (Option A))
  (lambda (value A)
    (variant Some value)))

(defpoly Option.withDefault (params A)
  (-> A (-> (Option A) A))
  (lambda (fallback A)
    (lambda (m (Option A))
      (((inst Maybe.withDefault A) fallback) m))))

(defpoly Option.isSome (params A)
  (-> (Option A) Bool)
  (lambda (m (Option A))
    ((inst Maybe.isSome A) m)))

(defpoly Option.isNone (params A)
  (-> (Option A) Bool)
  (lambda (m (Option A))
    ((inst Maybe.isNone A) m)))

(defpoly Option.map (params A B)
  (-> (-> A B) (-> (Option A) (Option B)))
  (lambda (f (-> A B))
    (lambda (m (Option A))
      (((inst Maybe.map A B) f) m))))

(defpoly Option.map2 (params A B C)
  (-> (-> A (-> B C)) (-> (Option A) (-> (Option B) (Option C))))
  (lambda (f (-> A (-> B C)))
    (lambda (left (Option A))
      (lambda (right (Option B))
        ((((inst Maybe.map2 A B C) f) left) right)))))

(defpoly Option.andThen (params A B)
  (-> (Option A) (-> (-> A (Option B)) (Option B)))
  (lambda (m (Option A))
    (lambda (f (-> A (Option B)))
      (((inst Maybe.andThen A B) m) f))))

(defpoly Option.toResult (params E A)
  (-> E (-> (Option A) (Result E A)))
  (lambda (err E)
    (lambda (m (Option A))
      (((inst Maybe.toResult E A) err) m))))

(defpoly Result.map (params E A B)
  (-> (-> A B) (-> (Result E A) (Result E B)))
  (lambda (f (-> A B))
    (lambda (r (Result E A))
      (case r
        (Err err (variant Err err))
        (Ok value (variant Ok (f value)))))))

(defpoly Result.map2 (params E A B C)
  (-> (-> A (-> B C)) (-> (Result E A) (-> (Result E B) (Result E C))))
  (lambda (f (-> A (-> B C)))
    (lambda (left (Result E A))
      (lambda (right (Result E B))
        (case left
          (Err err (variant Err err))
          (Ok leftValue
            (case right
              (Err err (variant Err err))
              (Ok rightValue (variant Ok ((f leftValue) rightValue))))))))))

(defpoly Result.withDefault (params E A)
  (-> A (-> (Result E A) A))
  (lambda (fallback A)
    (lambda (r (Result E A))
      (case r
        (Err err fallback)
        (Ok value value)))))

(defpoly Result.mapError (params E F A)
  (-> (-> E F) (-> (Result E A) (Result F A)))
  (lambda (f (-> E F))
    (lambda (r (Result E A))
      (case r
        (Err err (variant Err (f err)))
        (Ok value (variant Ok value))))))

(defpoly Result.andThen (params E A B)
  (-> (Result E A) (-> (-> A (Result E B)) (Result E B)))
  (lambda (r (Result E A))
    (lambda (f (-> A (Result E B)))
      (case r
        (Err err (variant Err err))
        (Ok value (f value))))))

(defpoly Result.toMaybe (params E A)
  (-> (Result E A) (Maybe A))
  (lambda (r (Result E A))
    (case r
      (Err err (variant None unit))
      (Ok value (variant Some value)))))

(defpoly Result.isOk (params E A)
  (-> (Result E A) Bool)
  (lambda (r (Result E A))
    (case r
      (Err err false)
      (Ok value true))))

(defpoly Result.isErr (params E A)
  (-> (Result E A) Bool)
  (lambda (r (Result E A))
    (case r
      (Err err true)
      (Ok value false))))

(defpoly Pair.swap (params A B)
  (-> (Pair A B) (Pair B A))
  (lambda (p (Pair A B))
    (record
      (first (get p second))
      (second (get p first)))))

(defpoly Assoc.empty (params K V)
  (Assoc K V)
  (Nil (Pair K V)))

(defpoly Assoc.insert (params K V)
  (-> K (-> V (-> (Assoc K V) (Assoc K V))))
  (lambda (key K)
    (lambda (value V)
      (lambda (entries (Assoc K V))
        (Cons (Pair K V)
          (record (first key) (second value))
          entries)))))

(defpoly Assoc.get (params K V)
  (-> (-> K (-> K Bool)) (-> K (-> (Assoc K V) (Maybe V))))
  (lambda (eq (-> K (-> K Bool)))
    (lambda (key K)
      (lambda (entries (Assoc K V))
        (foldList entries (variant (Maybe V) None unit)
          (lambda (entry (Pair K V))
            (lambda (acc (Maybe V))
              (case ((eq (get entry first)) key)
                (true (variant Some (get entry second)))
                (false acc)))))))))

(defpoly Assoc.contains (params K V)
  (-> (-> K (-> K Bool)) (-> K (-> (Assoc K V) Bool)))
  (lambda (eq (-> K (-> K Bool)))
    (lambda (key K)
      (lambda (entries (Assoc K V))
        ((inst Maybe.isSome V)
          ((((inst Assoc.get K V) eq) key) entries))))))

(def PackageRegistry.entry (-> String (-> String PackageRegistryEntry))
  (lambda (selector String)
    (lambda (path String)
      (record (selector selector) (path path)))))

(def PackageRegistry.resolution (-> String (-> String (-> String PackageResolution)))
  (lambda (selector String)
    (lambda (path String)
      (lambda (source String)
        (record (selector selector) (path path) (source source))))))

(def PackageRegistry.resolveIn (-> String (-> (List PackageRegistryEntry) (Maybe String)))
  (lambda (wanted String)
    (lambda (entries (List PackageRegistryEntry))
      (foldList entries (variant (Maybe String) None unit)
        (lambda (entry PackageRegistryEntry)
          (lambda (acc (Maybe String))
            (case ((String.eqString (get entry selector)) wanted)
              (true (variant Some (get entry path)))
              (false acc))))))))

(def PackageRegistry.resolveLocalGlobal
  (-> String (-> (List PackageRegistryEntry) (-> (List PackageRegistryEntry) (Result String PackageResolution))))
  (lambda (wanted String)
    (lambda (local (List PackageRegistryEntry))
      (lambda (global (List PackageRegistryEntry))
        (case ((PackageRegistry.resolveIn wanted) local)
          (Some path (variant Ok (((PackageRegistry.resolution wanted) path) "local")))
          (None
            (case ((PackageRegistry.resolveIn wanted) global)
              (Some path (variant Ok (((PackageRegistry.resolution wanted) path) "global")))
              (None (variant Err ((String.concat "missing package selector: ") wanted))))))))))

(defpoly Assoc.keys (params K V)
  (-> (Assoc K V) (List K))
  (lambda (entries (Assoc K V))
    (((inst List.map (Pair K V) K) entries)
      (lambda (entry (Pair K V))
        (get entry first)))))

(defpoly Assoc.values (params K V)
  (-> (Assoc K V) (List V))
  (lambda (entries (Assoc K V))
    (((inst List.map (Pair K V) V) entries)
      (lambda (entry (Pair K V))
        (get entry second)))))

(defpoly Map.empty (params K V)
  (Map K V)
  (inst Assoc.empty K V))

(defpoly Map.insert (params K V)
  (-> K (-> V (-> (Map K V) (Map K V))))
  (lambda (key K)
    (lambda (value V)
      (lambda (entries (Map K V))
        ((((inst Assoc.insert K V) key) value) entries)))))

(defpoly Map.get (params K V)
  (-> (-> K (-> K Bool)) (-> K (-> (Map K V) (Maybe V))))
  (lambda (eq (-> K (-> K Bool)))
    (lambda (key K)
      (lambda (entries (Map K V))
        ((((inst Assoc.get K V) eq) key) entries)))))

(defpoly Map.contains (params K V)
  (-> (-> K (-> K Bool)) (-> K (-> (Map K V) Bool)))
  (lambda (eq (-> K (-> K Bool)))
    (lambda (key K)
      (lambda (entries (Map K V))
        ((((inst Assoc.contains K V) eq) key) entries)))))

(defpoly Map.keys (params K V)
  (-> (Map K V) (List K))
  (lambda (entries (Map K V))
    ((inst Assoc.keys K V) entries)))

(defpoly Map.values (params K V)
  (-> (Map K V) (List V))
  (lambda (entries (Map K V))
    ((inst Assoc.values K V) entries)))

(defpoly Map.remove (params K V)
  (-> (-> K (-> K Bool)) (-> K (-> (Map K V) (Map K V))))
  (lambda (eq (-> K (-> K Bool)))
    (lambda (key K)
      (lambda (entries (Map K V))
        (((inst List.filter (Pair K V)) entries)
          (lambda (entry (Pair K V))
            (Bool.not ((eq (get entry first)) key))))))))

(defpoly Set.empty (params A)
  (Set A)
  (Nil A))

(defpoly Set.contains (params A)
  (-> (-> A (-> A Bool)) (-> A (-> (Set A) Bool)))
  (lambda (eq (-> A (-> A Bool)))
    (lambda (value A)
      (lambda (items (Set A))
        (foldList items false
          (lambda (item A)
            (lambda (acc Bool)
              (case ((eq item) value)
                (true true)
                (false acc)))))))))

(defpoly Set.insert (params A)
  (-> (-> A (-> A Bool)) (-> A (-> (Set A) (Set A))))
  (lambda (eq (-> A (-> A Bool)))
    (lambda (value A)
      (lambda (items (Set A))
        (case ((((inst Set.contains A) eq) value) items)
          (true items)
          (false (Cons A value items)))))))

(defpoly Set.union (params A)
  (-> (-> A (-> A Bool)) (-> (Set A) (-> (Set A) (Set A))))
  (lambda (eq (-> A (-> A Bool)))
    (lambda (left (Set A))
      (lambda (right (Set A))
        (foldList left right
          (lambda (item A)
            (lambda (acc (Set A))
              ((((inst Set.insert A) eq) item) acc))))))))

(defpoly Set.remove (params A)
  (-> (-> A (-> A Bool)) (-> A (-> (Set A) (Set A))))
  (lambda (eq (-> A (-> A Bool)))
    (lambda (value A)
      (lambda (items (Set A))
        (((inst List.filter A) items)
          (lambda (item A)
            (Bool.not ((eq item) value))))))))

(defpoly Set.intersect (params A)
  (-> (-> A (-> A Bool)) (-> (Set A) (-> (Set A) (Set A))))
  (lambda (eq (-> A (-> A Bool)))
    (lambda (left (Set A))
      (lambda (right (Set A))
        (((inst List.filter A) left)
          (lambda (item A)
            ((((inst Set.contains A) eq) item) right)))))))

(defpoly Set.difference (params A)
  (-> (-> A (-> A Bool)) (-> (Set A) (-> (Set A) (Set A))))
  (lambda (eq (-> A (-> A Bool)))
    (lambda (left (Set A))
      (lambda (right (Set A))
        (((inst List.filter A) left)
          (lambda (item A)
            (Bool.not ((((inst Set.contains A) eq) item) right))))))))

(def SexpLexerState.make (-> TextCursor (-> SexpLexMode (-> (List SexpToken) (-> (Maybe String) SexpLexerState))))
  (lambda (cursor TextCursor)
    (lambda (mode SexpLexMode)
      (lambda (tokens (List SexpToken))
        (lambda (error (Maybe String))
          (record (cursor cursor) (mode mode) (tokens tokens) (error error)))))))

(def SexpLexerState.ok (-> TextCursor (-> SexpLexMode (-> (List SexpToken) SexpLexerState)))
  (lambda (cursor TextCursor)
    (lambda (mode SexpLexMode)
      (lambda (tokens (List SexpToken))
        ((((SexpLexerState.make cursor) mode) tokens) (variant None unit))))))

(def SexpLexerState.fail (-> String (-> SexpLexerState SexpLexerState))
  (lambda (message String)
    (lambda (state SexpLexerState)
      ((((SexpLexerState.make (get state cursor)) (get state mode)) (get state tokens))
        (variant Some message)))))

(def SexpLexerState.withMode (-> SexpLexMode (-> SexpLexerState SexpLexerState))
  (lambda (mode SexpLexMode)
    (lambda (state SexpLexerState)
      ((((SexpLexerState.make (get state cursor)) mode) (get state tokens)) (get state error)))))

(def SexpLexerState.advance (-> SexpLexerState SexpLexerState)
  (lambda (state SexpLexerState)
    ((((SexpLexerState.make (TextCursor.advance (get state cursor))) (get state mode))
      (get state tokens))
      (get state error))))

(def SexpLexerState.addToken (-> SexpToken (-> SexpLexerState SexpLexerState))
  (lambda (token SexpToken)
    (lambda (state SexpLexerState)
      ((((SexpLexerState.make (get state cursor)) (get state mode))
        (Cons SexpToken token (get state tokens)))
        (get state error)))))

(def Sexp.lexDefaultChar (-> SexpLexerState (-> String SexpLexerState))
  (lambda (state SexpLexerState)
    (lambda (ch String)
      (case (String.isWhitespace ch)
        (true state)
        (false
          (case ((String.eqString ch) ";")
            (true ((SexpLexerState.withMode (variant SexpLexComment unit)) state))
            (false
              (case ((String.eqString ch) "(")
                (true ((SexpLexerState.addToken (variant SLParen unit)) state))
                (false
                  (case ((String.eqString ch) ")")
                    (true ((SexpLexerState.addToken (variant SRParen unit)) state))
                    (false
                      (case ((String.eqString ch) "\"")
                        (true ((SexpLexerState.withMode (variant SexpLexString "")) state))
                        (false
                          ((SexpLexerState.withMode (variant SexpLexAtom ch)) state))))))))))))))

(def Sexp.lexAtomChar (-> SexpLexerState (-> String (-> String SexpLexerState)))
  (lambda (state SexpLexerState)
    (lambda (atom String)
      (lambda (ch String)
        (case (String.isAtomChar ch)
          (true ((SexpLexerState.withMode (variant SexpLexAtom ((String.concat atom) ch))) state))
          (false
            ((Sexp.lexDefaultChar
              ((SexpLexerState.addToken (variant SAtomToken atom))
                ((SexpLexerState.withMode (variant SexpLexDefault unit)) state)))
              ch)))))))

(def Sexp.lexStringChar (-> SexpLexerState (-> String (-> String SexpLexerState)))
  (lambda (state SexpLexerState)
    (lambda (text String)
      (lambda (ch String)
        (case ((String.eqString ch) "\"")
          (true
            ((SexpLexerState.addToken (variant SStringToken text))
              ((SexpLexerState.withMode (variant SexpLexDefault unit)) state)))
          (false
            ((SexpLexerState.withMode (variant SexpLexString ((String.concat text) ch))) state)))))))

(def Sexp.lexCommentChar (-> SexpLexerState (-> String SexpLexerState))
  (lambda (state SexpLexerState)
    (lambda (ch String)
      (case ((String.eqString ch) "\n")
        (true ((SexpLexerState.withMode (variant SexpLexDefault unit)) state))
        (false state)))))

(def Sexp.lexStep (-> SexpLexerState (-> String SexpLexerState))
  (lambda (state SexpLexerState)
    (lambda (ch String)
      (case (get state error)
        (Some message state)
        (None
          (case (get state mode)
            (SexpLexDefault (Sexp.lexDefaultChar state ch))
            (SexpLexAtom atom (((Sexp.lexAtomChar state) atom) ch))
            (SexpLexString text (((Sexp.lexStringChar state) text) ch))
            (SexpLexComment (Sexp.lexCommentChar state ch))))))))

(def Sexp.lexCurrent (-> SexpLexerState SexpLexerState)
  (lambda (state SexpLexerState)
    (case (TextCursor.current (get state cursor))
      (None state)
      (Some ch (SexpLexerState.advance ((Sexp.lexStep state) ch))))))

(def Sexp.lexFinalize (-> SexpLexerState (Result String (List SexpToken)))
  (lambda (state SexpLexerState)
    (case (get state error)
      (Some message (variant Err message))
      (None
        (case (get state mode)
          (SexpLexDefault (variant Ok ((inst List.reverse SexpToken) (get state tokens))))
          (SexpLexComment (variant Ok ((inst List.reverse SexpToken) (get state tokens))))
          (SexpLexAtom atom
            (variant Ok
              ((inst List.reverse SexpToken)
                (Cons SexpToken (variant SAtomToken atom) (get state tokens)))))
          (SexpLexString text (variant Err "unterminated string")))))))

(def Sexp.lexTokens (-> String (Result String (List SexpToken)))
  (lambda (source String)
    (Sexp.lexFinalize
      (foldNat (String.length source)
        (((SexpLexerState.ok (TextCursor.start source)) (variant SexpLexDefault unit)) (Nil SexpToken))
        (lambda (state SexpLexerState)
          (Sexp.lexCurrent state))))))

(def Sexp.atom (-> String Sexp)
  (lambda (value String)
    (variant SAtom value)))

(def Sexp.string (-> String Sexp)
  (lambda (value String)
    (variant SString value)))

(def Sexp.list (-> (List Sexp) Sexp)
  (lambda (items (List Sexp))
    (variant SList items)))

(def SexpParserState.make (-> (List (List Sexp)) (-> (List Sexp) (-> (Maybe String) SexpParserState)))
  (lambda (stack (List (List Sexp)))
    (lambda (values (List Sexp))
      (lambda (error (Maybe String))
        (record (stack stack) (values values) (error error))))))

(def SexpParserState.ok (-> (List (List Sexp)) (-> (List Sexp) SexpParserState))
  (lambda (stack (List (List Sexp)))
    (lambda (values (List Sexp))
      (((SexpParserState.make stack) values) (variant None unit)))))

(def SexpParserState.initial SexpParserState
  ((SexpParserState.ok (Nil (List Sexp))) (Nil Sexp)))

(def SexpParserState.fail (-> String (-> SexpParserState SexpParserState))
  (lambda (message String)
    (lambda (state SexpParserState)
      (((SexpParserState.make (get state stack)) (get state values)) (variant Some message)))))

(def SexpParserState.openList (-> SexpParserState SexpParserState)
  (lambda (state SexpParserState)
    (((SexpParserState.make
      (Cons (List Sexp) (Nil Sexp) (get state stack)))
      (get state values))
      (get state error))))

(def SexpParserState.emit (-> Sexp (-> SexpParserState SexpParserState))
  (lambda (value Sexp)
    (lambda (state SexpParserState)
      (caseList (get state stack)
        (Nil
          (((SexpParserState.make (Nil (List Sexp)))
            (Cons Sexp value (get state values)))
            (get state error)))
        (Cons frame rest
          (((SexpParserState.make
            (Cons (List Sexp) (Cons Sexp value frame) rest))
            (get state values))
            (get state error)))))))

(def SexpParserState.closeList (-> SexpParserState SexpParserState)
  (lambda (state SexpParserState)
    (caseList (get state stack)
      (Nil ((SexpParserState.fail "unexpected )") state))
      (Cons frame rest
        ((SexpParserState.emit (Sexp.list ((inst List.reverse Sexp) frame)))
          (((SexpParserState.make rest) (get state values)) (get state error)))))))

(def Sexp.parseToken (-> SexpParserState (-> SexpToken SexpParserState))
  (lambda (state SexpParserState)
    (lambda (token SexpToken)
      (case (get state error)
        (Some message state)
        (None
          (case token
            (SLParen (SexpParserState.openList state))
            (SRParen (SexpParserState.closeList state))
            (SAtomToken atom ((SexpParserState.emit (Sexp.atom atom)) state))
            (SStringToken text ((SexpParserState.emit (Sexp.string text)) state))))))))

(def Sexp.parseFinalize (-> SexpParserState (Result String (List Sexp)))
  (lambda (state SexpParserState)
    (case (get state error)
      (Some message (variant Err message))
      (None
        (caseList (get state stack)
          (Nil (variant Ok ((inst List.reverse Sexp) (get state values))))
          (Cons frame rest (variant Err "unterminated list")))))))

(def Sexp.parseTokens (-> (List SexpToken) (Result String (List Sexp)))
  (lambda (tokens (List SexpToken))
    (Sexp.parseFinalize
      (foldList ((inst List.reverse SexpToken) tokens)
        SexpParserState.initial
        (lambda (token SexpToken)
          (lambda (state SexpParserState)
            ((Sexp.parseToken state) token)))))))

(def Sexp.parseText (-> String (Result String (List Sexp)))
  (lambda (source String)
    (case (Sexp.lexTokens source)
      (Err err (variant Err err))
      (Ok tokens (Sexp.parseTokens tokens)))))

(def Protoss.typeOk (-> ProtossType (Result String ProtossType))
  (lambda (typ ProtossType)
    (variant Ok typ)))

(def Protoss.typeErr (-> String (Result String ProtossType))
  (lambda (message String)
    (variant Err message)))

(def Protoss.typeListOk (-> (List ProtossType) (Result String (List ProtossType)))
  (lambda (types (List ProtossType))
    (variant Ok types)))

(def Protoss.typeListErr (-> String (Result String (List ProtossType)))
  (lambda (message String)
    (variant Err message)))

(defrec Protoss.parseType (-> Sexp (Result String ProtossType))
  (variant value)
  (SAtom name (Protoss.typeOk (variant PTName name)))
  (SString text (Protoss.typeErr "expected type"))
  (SList items
    (caseList items
      (Nil (Protoss.typeErr "expected type form"))
      (Cons head rawArgs
        (case head
          (SAtom name
            (case
              (foldList items (Protoss.typeListOk (Nil ProtossType))
                (lambda (item Sexp)
                  (lambda (acc (Result String (List ProtossType)))
                    (case (recur item)
                      (Err err (Protoss.typeListErr err))
                      (Ok parsedItem
                        (case acc
                          (Err err (Protoss.typeListErr err))
                          (Ok parsedItems
                            (Protoss.typeListOk
                              (Cons ProtossType parsedItem parsedItems)))))))))
              (Err err (Protoss.typeErr err))
              (Ok parsedItems
                (caseList parsedItems
                  (Nil (Protoss.typeErr "expected type form"))
                  (Cons parsedHead parsedArgs
                    (case ((String.eqString name) "->")
                      (true
                        (caseList parsedArgs
                          (Nil (Protoss.typeErr "expected function type arguments"))
                          (Cons fromType rest
                            (caseList rest
                              (Nil (Protoss.typeErr "expected function result type"))
                              (Cons toType extra
                                (caseList extra
                                  (Nil
                                    (Protoss.typeOk
                                      (variant PTFun
                                        (record (first fromType) (second toType)))))
                                  (Cons extraHead extraTail
                                    (Protoss.typeErr "too many function type arguments"))))))))
                      (false
                        (Protoss.typeOk
                          (variant PTApply
                            (record (name name) (args parsedArgs)))))))))))
          (_ (Protoss.typeErr "expected type constructor")))))))

(def Protoss.exprOk (-> ProtossExpr (Result String ProtossExpr))
  (lambda (expr ProtossExpr)
    (variant Ok expr)))

(def Protoss.exprErr (-> String (Result String ProtossExpr))
  (lambda (message String)
    (variant Err message)))

(def Protoss.exprListOk (-> (List ProtossExpr) (Result String (List ProtossExpr)))
  (lambda (exprs (List ProtossExpr))
    (variant Ok exprs)))

(def Protoss.exprListErr (-> String (Result String (List ProtossExpr)))
  (lambda (message String)
    (variant Err message)))

(def Protoss.atomExpr (-> String ProtossExpr)
  (lambda (name String)
    (case ((String.eqString name) "unit")
      (true (variant PEUnit unit))
      (false
        (case ((String.eqString name) "true")
          (true (variant PEBool true))
          (false
            (case ((String.eqString name) "false")
              (true (variant PEBool false))
              (false
                (case ((String.eqString name) "Nil")
                  (true
                    (variant PENil
                      (record
                        (typ (variant None unit))
                        (arg (variant None unit)))))
                  (false (variant PEVar name)))))))))))

(defrec Protoss.exprToType (-> ProtossExpr (Result String ProtossType))
  (variant expr)
  (PEVar name (Protoss.typeOk (variant PTName name)))
  (PEApply call
    (case (get call fn)
      (PEVar name
        (case
          (foldList (get call args) (Protoss.typeListOk (Nil ProtossType))
            (lambda (arg ProtossExpr)
              (lambda (acc (Result String (List ProtossType)))
                (case (recur arg)
                  (Err err (Protoss.typeListErr err))
                  (Ok parsedArg
                    (case acc
                      (Err err (Protoss.typeListErr err))
                      (Ok parsedArgs
                        (Protoss.typeListOk
                          (Cons ProtossType parsedArg parsedArgs)))))))))
          (Err err (Protoss.typeErr err))
          (Ok parsedArgs
            (case ((String.eqString name) "->")
              (true
                (caseList parsedArgs
                  (Nil (Protoss.typeErr "expected function type arguments"))
                  (Cons fromType rest
                    (caseList rest
                      (Nil (Protoss.typeErr "expected function result type"))
                      (Cons toType extra
                        (caseList extra
                          (Nil
                            (Protoss.typeOk
                              (variant PTFun
                                (record (first fromType) (second toType)))))
                          (Cons extraHead extraTail
                            (Protoss.typeErr "too many function type arguments"))))))))
              (false
                (Protoss.typeOk
                  (variant PTApply
                    (record (name name) (args parsedArgs)))))))))
      (_ (Protoss.typeErr "expected type constructor"))))
  (PEBind value (Protoss.typeErr "expected type"))
  (PEBool value (Protoss.typeErr "expected type"))
  (PECase value (Protoss.typeErr "expected type"))
  (PECaseList value (Protoss.typeErr "expected type"))
  (PECons value (Protoss.typeErr "expected type"))
  (PEDone value (Protoss.typeErr "expected type"))
  (PEField value (Protoss.typeErr "expected type"))
  (PEFoldNat value (Protoss.typeErr "expected type"))
  (PEFoldVariant value (Protoss.typeErr "expected type"))
  (PEFoldList value (Protoss.typeErr "expected type"))
  (PEInst value (Protoss.typeErr "expected type"))
  (PELambda value (Protoss.typeErr "expected type"))
  (PELet value (Protoss.typeErr "expected type"))
  (PENil value (Protoss.typeErr "expected type"))
  (PERecord value (Protoss.typeErr "expected type"))
  (PERecur value (Protoss.typeErr "expected type"))
  (PERequest value (Protoss.typeErr "expected type"))
  (PEString value (Protoss.typeErr "expected type"))
  (PEUnit value (Protoss.typeErr "expected type"))
  (PEVariant value (Protoss.typeErr "expected type")))

(def Protoss.paramOk (-> ProtossParam (Result String ProtossParam))
  (lambda (param ProtossParam)
    (variant Ok param)))

(def Protoss.paramErr (-> String (Result String ProtossParam))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseLambdaParam (-> ProtossExpr (Result String ProtossParam))
  (lambda (expr ProtossExpr)
    (case expr
      (PEApply call
        (case (get call fn)
          (PEVar name
            (caseList (get call args)
              (Nil (Protoss.paramErr "expected lambda parameter type"))
              (Cons typeExpr extra
                (caseList extra
                  (Nil
                    (case (Protoss.exprToType typeExpr)
                      (Err err (Protoss.paramErr err))
                      (Ok typ
                        (Protoss.paramOk (record (name name) (typ typ))))))
                  (Cons extraHead extraTail
                    (Protoss.paramErr "too many lambda parameter items"))))))
          (_ (Protoss.paramErr "expected lambda parameter name"))))
      (_ (Protoss.paramErr "expected lambda parameter")))))

(def Protoss.recordFieldExprOk
  (-> ProtossRecordFieldExpr (Result String ProtossRecordFieldExpr))
  (lambda (field ProtossRecordFieldExpr)
    (variant Ok field)))

(def Protoss.recordFieldExprErr (-> String (Result String ProtossRecordFieldExpr))
  (lambda (message String)
    (variant Err message)))

(def Protoss.recordFieldExprListOk
  (-> (List ProtossRecordFieldExpr) (Result String (List ProtossRecordFieldExpr)))
  (lambda (fields (List ProtossRecordFieldExpr))
    (variant Ok fields)))

(def Protoss.recordFieldExprListErr
  (-> String (Result String (List ProtossRecordFieldExpr)))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseRecordFieldExpr (-> ProtossExpr (Result String ProtossRecordFieldExpr))
  (lambda (expr ProtossExpr)
    (case expr
      (PEApply call
        (case (get call fn)
          (PEVar name
            (caseList (get call args)
              (Nil (Protoss.recordFieldExprErr "expected record field value"))
              (Cons value extra
                (caseList extra
                  (Nil (Protoss.recordFieldExprOk (record (name name) (expr value))))
                  (Cons extraHead extraTail
                    (Protoss.recordFieldExprErr "too many record field items"))))))
          (_ (Protoss.recordFieldExprErr "expected record field name"))))
      (_ (Protoss.recordFieldExprErr "expected record field form")))))

(def Protoss.parseRecordFieldExprs
  (-> (List ProtossExpr) (Result String (List ProtossRecordFieldExpr)))
  (lambda (fields (List ProtossExpr))
    (foldList fields (Protoss.recordFieldExprListOk (Nil ProtossRecordFieldExpr))
      (lambda (field ProtossExpr)
        (lambda (acc (Result String (List ProtossRecordFieldExpr)))
          (case (Protoss.parseRecordFieldExpr field)
            (Err err (Protoss.recordFieldExprListErr err))
            (Ok parsedField
              (case acc
                (Err err (Protoss.recordFieldExprListErr err))
                (Ok parsedFields
                  (Protoss.recordFieldExprListOk
                    (Cons ProtossRecordFieldExpr parsedField parsedFields)))))))))))

(def Protoss.stringOk (-> String (Result String String))
  (lambda (value String)
    (variant Ok value)))

(def Protoss.stringErr (-> String (Result String String))
  (lambda (message String)
    (variant Err message)))

(def Protoss.constructorName (-> ProtossExpr (Result String String))
  (lambda (expr ProtossExpr)
    (case expr
      (PEVar name (Protoss.stringOk name))
      (_ (Protoss.stringErr "expected variant constructor")))))

(def Protoss.caseConstructorName (-> ProtossExpr (Result String String))
  (lambda (expr ProtossExpr)
    (case expr
      (PEBool value
        (case value
          (true (Protoss.stringOk "true"))
          (false (Protoss.stringOk "false"))))
      (PEVar name (Protoss.stringOk name))
      (_ (Protoss.stringErr "expected case branch constructor")))))

(def Protoss.varName (-> ProtossExpr (Result String String))
  (lambda (expr ProtossExpr)
    (case expr
      (PEVar name (Protoss.stringOk name))
      (_ (Protoss.stringErr "expected name")))))

(def Protoss.stringLiteral (-> ProtossExpr (Result String String))
  (lambda (expr ProtossExpr)
    (case expr
      (PEString value (Protoss.stringOk value))
      (_ (Protoss.stringErr "expected string literal")))))

(def Protoss.parseTypeExprs
  (-> (List ProtossExpr) (Result String (List ProtossType)))
  (lambda (items (List ProtossExpr))
    (foldList items (Protoss.typeListOk (Nil ProtossType))
      (lambda (item ProtossExpr)
        (lambda (acc (Result String (List ProtossType)))
          (case (Protoss.exprToType item)
            (Err err (Protoss.typeListErr err))
            (Ok parsedItem
              (case acc
                (Err err (Protoss.typeListErr err))
                (Ok parsedItems
                  (Protoss.typeListOk
                    (Cons ProtossType parsedItem parsedItems)))))))))))

(def Protoss.letExprOk (-> ProtossLetExpr (Result String ProtossLetExpr))
  (lambda (expr ProtossLetExpr)
    (variant Ok expr)))

(def Protoss.letExprErr (-> String (Result String ProtossLetExpr))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseLetBinding
  (-> ProtossExpr (-> ProtossExpr (Result String ProtossLetExpr)))
  (lambda (binding ProtossExpr)
    (lambda (body ProtossExpr)
      (case binding
        (PEApply call
          (case (get call fn)
            (PEVar name
              (caseList (get call args)
                (Nil (Protoss.letExprErr "expected let binding value"))
                (Cons first rest
                  (caseList rest
                    (Nil
                      (Protoss.letExprOk
                        (record
                          (name name)
                          (typ (variant None unit))
                          (value first)
                          (body body))))
                    (Cons second extra
                      (caseList extra
                        (Nil
                          (case (Protoss.exprToType first)
                            (Err err (Protoss.letExprErr err))
                            (Ok typ
                              (Protoss.letExprOk
                                (record
                                  (name name)
                                  (typ (variant Some typ))
                                  (value second)
                                  (body body))))))
                        (Cons extraHead extraTail
                          (Protoss.letExprErr "too many let binding items"))))))))
            (_ (Protoss.letExprErr "expected let binding name"))))
        (_ (Protoss.letExprErr "expected let binding"))))))

(def Protoss.caseBranchOk
  (-> ProtossCaseBranch (Result String ProtossCaseBranch))
  (lambda (branch ProtossCaseBranch)
    (variant Ok branch)))

(def Protoss.caseBranchErr (-> String (Result String ProtossCaseBranch))
  (lambda (message String)
    (variant Err message)))

(def Protoss.caseBranchListOk
  (-> (List ProtossCaseBranch) (Result String (List ProtossCaseBranch)))
  (lambda (branches (List ProtossCaseBranch))
    (variant Ok branches)))

(def Protoss.caseBranchListErr
  (-> String (Result String (List ProtossCaseBranch)))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseCaseBranch (-> ProtossExpr (Result String ProtossCaseBranch))
  (lambda (expr ProtossExpr)
    (case expr
      (PEApply call
        (case (Protoss.caseConstructorName (get call fn))
          (Err err (Protoss.caseBranchErr err))
          (Ok constructor
            (caseList (get call args)
              (Nil (Protoss.caseBranchErr "expected case branch body"))
              (Cons first rest
                (caseList rest
                  (Nil
                    (Protoss.caseBranchOk
                      (record
                        (constructor constructor)
                        (binder (variant None unit))
                        (body first))))
                  (Cons second extra
                    (caseList extra
                      (Nil
                        (case first
                          (PEVar binder
                            (Protoss.caseBranchOk
                              (record
                                (constructor constructor)
                                (binder (variant Some binder))
                                (body second))))
                          (_ (Protoss.caseBranchErr "expected case branch binder"))))
                      (Cons extraHead extraTail
                        (Protoss.caseBranchErr "too many case branch items"))))))))
          ))
      (_ (Protoss.caseBranchErr "expected case branch form")))))

(def Protoss.parseCaseBranches
  (-> (List ProtossExpr) (Result String (List ProtossCaseBranch)))
  (lambda (branches (List ProtossExpr))
    (foldList branches (Protoss.caseBranchListOk (Nil ProtossCaseBranch))
      (lambda (branch ProtossExpr)
        (lambda (acc (Result String (List ProtossCaseBranch)))
          (case (Protoss.parseCaseBranch branch)
            (Err err (Protoss.caseBranchListErr err))
            (Ok parsedBranch
              (case acc
                (Err err (Protoss.caseBranchListErr err))
                (Ok parsedBranches
                  (Protoss.caseBranchListOk
                    (Cons ProtossCaseBranch parsedBranch parsedBranches)))))))))))

(def Protoss.variantExprOk (-> ProtossExpr (Result String ProtossExpr))
  (lambda (expr ProtossExpr)
    (Protoss.exprOk expr)))

(def Protoss.finishVariantExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected variant constructor"))
      (Cons first rest
        (caseList rest
          (Nil (Protoss.exprErr "expected variant payload"))
          (Cons second more
            (caseList more
              (Nil
                (case (Protoss.constructorName first)
                  (Err err (Protoss.exprErr err))
                  (Ok constructor
                    (Protoss.exprOk
                      (variant PEVariant
                        (record
                          (typeHint (variant None unit))
                          (constructor constructor)
                          (payload second)))))))
              (Cons third extra
                (caseList extra
                  (Nil
                    (case (Protoss.exprToType first)
                      (Err err (Protoss.exprErr err))
                      (Ok typ
                        (case (Protoss.constructorName second)
                          (Err err (Protoss.exprErr err))
                          (Ok constructor
                            (Protoss.exprOk
                              (variant PEVariant
                                (record
                                  (typeHint (variant Some typ))
                                  (constructor constructor)
                                  (payload third)))))))))
                  (Cons extraHead extraTail
                    (Protoss.exprErr "too many variant arguments")))))))))))

(def Protoss.finishLambdaExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected lambda parameter"))
      (Cons paramExpr rest
        (caseList rest
          (Nil (Protoss.exprErr "expected lambda body"))
          (Cons body extra
            (caseList extra
              (Nil
                (case (Protoss.parseLambdaParam paramExpr)
                  (Err err (Protoss.exprErr err))
                  (Ok param
                    (Protoss.exprOk
                      (variant PELambda (record (param param) (body body)))))))
              (Cons extraHead extraTail
                (Protoss.exprErr "too many lambda arguments")))))))))

(def Protoss.finishLetExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected let binding"))
      (Cons binding rest
        (caseList rest
          (Nil (Protoss.exprErr "expected let body"))
          (Cons body extra
            (caseList extra
              (Nil
                (case ((Protoss.parseLetBinding binding) body)
                  (Err err (Protoss.exprErr err))
                  (Ok parsedLet
                    (Protoss.exprOk (variant PELet parsedLet)))))
              (Cons extraHead extraTail
                (Protoss.exprErr "too many let arguments")))))))))

(def Protoss.finishCaseExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected case scrutinee"))
      (Cons scrutinee branches
        (caseList branches
          (Nil (Protoss.exprErr "expected case branch"))
          (Cons firstBranch restBranches
            (case (Protoss.parseCaseBranches branches)
              (Err err (Protoss.exprErr err))
              (Ok parsedBranches
                (Protoss.exprOk
                  (variant PECase
                    (record
                      (scrutinee scrutinee)
                      (branches parsedBranches))))))))))))

(def Protoss.finishFoldNatExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected foldNat target"))
      (Cons target rest
        (caseList rest
          (Nil (Protoss.exprErr "expected foldNat zero"))
          (Cons zero more
            (caseList more
              (Nil (Protoss.exprErr "expected foldNat step"))
              (Cons step extra
                (caseList extra
                  (Nil
                    (Protoss.exprOk
                      (variant PEFoldNat
                        (record
                          (target target)
                          (zero zero)
                          (step step)))))
                  (Cons extraHead extraTail
                    (Protoss.exprErr "too many foldNat arguments")))))))))))

(def Protoss.finishFoldVariantExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected foldVariant target type"))
      (Cons targetExpr rest
        (case (Protoss.exprToType targetExpr)
          (Err err (Protoss.exprErr err))
          (Ok target
            (caseList rest
              (Nil (Protoss.exprErr "expected foldVariant result type"))
              (Cons resultExpr more
                (case (Protoss.exprToType resultExpr)
                  (Err err (Protoss.exprErr err))
                  (Ok result
                    (caseList more
                      (Nil (Protoss.exprErr "expected foldVariant scrutinee"))
                      (Cons scrutinee branches
                        (caseList branches
                          (Nil (Protoss.exprErr "expected foldVariant branch"))
                          (Cons firstBranch restBranches
                            (case (Protoss.parseCaseBranches branches)
                              (Err err (Protoss.exprErr err))
                              (Ok parsedBranches
                                (Protoss.exprOk
                                  (variant PEFoldVariant
                                    (record
                                      (target target)
                                      (result result)
                                      (scrutinee scrutinee)
                                      (branches parsedBranches))))))))))))))))))))

(def Protoss.finishRecurExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected recur value"))
      (Cons value extra
        (caseList extra
          (Nil (Protoss.exprOk (variant PERecur value)))
          (Cons extraHead extraTail
            (Protoss.exprErr "too many recur arguments")))))))

(def Protoss.finishNilExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil
        (Protoss.exprOk
          (variant PENil
            (record
              (typ (variant None unit))
              (arg (variant None unit))))))
      (Cons typeExpr extra
        (caseList extra
          (Nil
            (case (Protoss.exprToType typeExpr)
              (Err err (Protoss.exprErr err))
              (Ok typ
                (Protoss.exprOk
                  (variant PENil
                    (record
                      (typ (variant Some typ))
                      (arg (variant Some typeExpr))))))))
          (Cons extraHead extraTail
            (Protoss.exprErr "too many Nil arguments")))))))

(def Protoss.finishConsExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected Cons head"))
      (Cons first rest
        (caseList rest
          (Nil (Protoss.exprErr "expected Cons tail"))
          (Cons second more
            (caseList more
              (Nil
                (Protoss.exprOk
                  (variant PECons
                    (record
                      (typ (variant None unit))
                      (head first)
                      (tail second)))))
              (Cons third extra
                (caseList extra
                  (Nil
                    (case (Protoss.exprToType first)
                      (Err err (Protoss.exprErr err))
                      (Ok typ
                        (Protoss.exprOk
                          (variant PECons
                            (record
                              (typ (variant Some typ))
                              (head second)
                              (tail third)))))))
                  (Cons extraHead extraTail
                    (Protoss.exprErr "too many Cons arguments")))))))))))

(def Protoss.finishGetExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected get target"))
      (Cons target rest
        (caseList rest
          (Nil (Protoss.exprErr "expected get field"))
          (Cons fieldExpr extra
            (caseList extra
              (Nil
                (case (Protoss.varName fieldExpr)
                  (Err err (Protoss.exprErr err))
                  (Ok field
                    (Protoss.exprOk
                      (variant PEField
                        (record (target target) (field field)))))))
              (Cons extraHead extraTail
                (Protoss.exprErr "too many get arguments")))))))))

(def Protoss.finishInstExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected inst name"))
      (Cons nameExpr typeArgs
        (case (Protoss.varName nameExpr)
          (Err err (Protoss.exprErr err))
          (Ok name
            (case (Protoss.parseTypeExprs typeArgs)
              (Err err (Protoss.exprErr err))
              (Ok parsedTypeArgs
                (Protoss.exprOk
                  (variant PEInst
                    (record (name name) (typeArgs parsedTypeArgs))))))))))))

(def Protoss.finishFoldListExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected foldList target"))
      (Cons target rest
        (caseList rest
          (Nil (Protoss.exprErr "expected foldList zero"))
          (Cons zero more
            (caseList more
              (Nil (Protoss.exprErr "expected foldList step"))
              (Cons step extra
                (caseList extra
                  (Nil
                    (Protoss.exprOk
                      (variant PEFoldList
                        (record
                          (target target)
                          (zero zero)
                          (step step)))))
                  (Cons extraHead extraTail
                    (Protoss.exprErr "too many foldList arguments")))))))))))

(def Protoss.parseCaseListNilBranch (-> ProtossExpr (Result String ProtossExpr))
  (lambda (branch ProtossExpr)
    (case branch
      (PENil nil
        (case (get nil arg)
          (None (Protoss.exprErr "expected caseList Nil body"))
          (Some body (Protoss.exprOk body))))
      (PEApply call
        (case (get call fn)
          (PEVar name
            (case ((String.eqString name) "Nil")
              (true
                (caseList (get call args)
                  (Nil (Protoss.exprErr "expected caseList Nil body"))
                  (Cons body extra
                    (caseList extra
                      (Nil (Protoss.exprOk body))
                      (Cons extraHead extraTail
                        (Protoss.exprErr "too many caseList Nil branch items"))))))
              (false (Protoss.exprErr "expected caseList Nil branch"))))
          (_ (Protoss.exprErr "expected caseList Nil branch"))))
      (_ (Protoss.exprErr "expected caseList Nil branch")))))

(def Protoss.caseListConsOk
  (-> ProtossCaseListConsBranch (Result String ProtossCaseListConsBranch))
  (lambda (branch ProtossCaseListConsBranch)
    (variant Ok branch)))

(def Protoss.caseListConsErr
  (-> String (Result String ProtossCaseListConsBranch))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseCaseListConsBranch
  (-> ProtossExpr (Result String ProtossCaseListConsBranch))
  (lambda (branch ProtossExpr)
    (case branch
      (PECons cons
        (case (get cons typ)
          (None (Protoss.caseListConsErr "expected caseList Cons branch"))
          (Some typ
            (case typ
              (PTName head
                (case (get cons head)
                  (PEVar tail
                    (Protoss.caseListConsOk
                      (record
                        (head head)
                        (tail tail)
                        (body (get cons tail)))))
                  (_ (Protoss.caseListConsErr "expected caseList Cons tail"))))
              (_ (Protoss.caseListConsErr "expected caseList Cons head"))))))
      (PEApply call
        (case (get call fn)
          (PEVar name
            (case ((String.eqString name) "Cons")
              (true
                (caseList (get call args)
                  (Nil (Protoss.caseListConsErr "expected caseList Cons head"))
                  (Cons headExpr rest
                    (case (Protoss.varName headExpr)
                      (Err err (Protoss.caseListConsErr err))
                      (Ok head
                        (caseList rest
                          (Nil (Protoss.caseListConsErr "expected caseList Cons tail"))
                          (Cons tailExpr more
                            (case (Protoss.varName tailExpr)
                              (Err err (Protoss.caseListConsErr err))
                              (Ok tail
                                (caseList more
                                  (Nil (Protoss.caseListConsErr "expected caseList Cons body"))
                                  (Cons body extra
                                    (caseList extra
                                      (Nil
                                        (Protoss.caseListConsOk
                                          (record
                                            (head head)
                                            (tail tail)
                                            (body body))))
                                      (Cons extraHead extraTail
                                        (Protoss.caseListConsErr
                                          "too many caseList Cons branch items"))))))))))))))
              (false (Protoss.caseListConsErr "expected caseList Cons branch"))))
          (_ (Protoss.caseListConsErr "expected caseList Cons branch"))))
      (_ (Protoss.caseListConsErr "expected caseList Cons branch")))))

(def Protoss.finishCaseListExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected caseList target"))
      (Cons target rest
        (caseList rest
          (Nil (Protoss.exprErr "expected caseList Nil branch"))
          (Cons nilBranch more
            (caseList more
              (Nil (Protoss.exprErr "expected caseList Cons branch"))
              (Cons consBranch extra
                (caseList extra
                  (Nil
                    (case (Protoss.parseCaseListNilBranch nilBranch)
                      (Err err (Protoss.exprErr err))
                      (Ok nilBody
                        (case (Protoss.parseCaseListConsBranch consBranch)
                          (Err err (Protoss.exprErr err))
                          (Ok parsedCons
                            (Protoss.exprOk
                              (variant PECaseList
                                (record
                                  (target target)
                                  (nilBody nilBody)
                                  (head (get parsedCons head))
                                  (tail (get parsedCons tail))
                                  (consBody (get parsedCons body))))))))))
                  (Cons extraHead extraTail
                    (Protoss.exprErr "too many caseList arguments")))))))))))

(def Protoss.finishDoneExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected done value"))
      (Cons value extra
        (caseList extra
          (Nil (Protoss.exprOk (variant PEDone value)))
          (Cons extraHead extraTail
            (Protoss.exprErr "too many done arguments")))))))

(def Protoss.finishBindExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected bind process"))
      (Cons process rest
        (caseList rest
          (Nil (Protoss.exprErr "expected bind continuation"))
          (Cons continuation extra
            (caseList extra
              (Nil
                (case continuation
                  (PELambda lam
                    (Protoss.exprOk
                      (variant PEBind
                        (record
                          (process process)
                          (param (get (get lam param) name))
                          (typ (get (get lam param) typ))
                          (body (get lam body))))))
                  (_ (Protoss.exprErr "expected bind lambda"))))
              (Cons extraHead extraTail
                (Protoss.exprErr "too many bind arguments")))))))))

(def Protoss.finishAskHumanExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected Human.ask prompt"))
      (Cons promptExpr extra
        (caseList extra
          (Nil
            (case (Protoss.stringLiteral promptExpr)
              (Err err (Protoss.exprErr err))
              (Ok prompt
                (Protoss.exprOk
                  (variant PERequest (variant PRAskHuman prompt))))))
          (Cons extraHead extraTail
            (Protoss.exprErr "too many Human.ask arguments")))))))

(def Protoss.finishHttpGetExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected Http.get url"))
      (Cons urlExpr extra
        (caseList extra
          (Nil
            (case (Protoss.stringLiteral urlExpr)
              (Err err (Protoss.exprErr err))
              (Ok url
                (Protoss.exprOk
                  (variant PERequest (variant PRHttpGet url))))))
          (Cons extraHead extraTail
            (Protoss.exprErr "too many Http.get arguments")))))))

(def Protoss.finishClockReadExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprOk (variant PERequest (variant PRClockRead unit))))
      (Cons extraHead extraTail
        (Protoss.exprErr "too many Clock.read arguments")))))

(def Protoss.finishLocalSaveExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected Local.save key"))
      (Cons keyExpr rest
        (caseList rest
          (Nil (Protoss.exprErr "expected Local.save value"))
          (Cons valueExpr extra
            (caseList extra
              (Nil
                (case (Protoss.stringLiteral keyExpr)
                  (Err err (Protoss.exprErr err))
                  (Ok key
                    (case (Protoss.stringLiteral valueExpr)
                      (Err err (Protoss.exprErr err))
                      (Ok value
                        (Protoss.exprOk
                          (variant PERequest
                            (variant PRSaveLocal
                              (record (key key) (value value))))))))))
              (Cons extraHead extraTail
                (Protoss.exprErr "too many Local.save arguments")))))))))

(def Protoss.finishLocalLoadExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected Local.load key"))
      (Cons keyExpr extra
        (caseList extra
          (Nil
            (case (Protoss.stringLiteral keyExpr)
              (Err err (Protoss.exprErr err))
              (Ok key
                (Protoss.exprOk
                  (variant PERequest (variant PRLoadLocal key))))))
          (Cons extraHead extraTail
            (Protoss.exprErr "too many Local.load arguments")))))))

(def Protoss.finishServerRequestExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (caseList args
      (Nil (Protoss.exprErr "expected Server.request route"))
      (Cons routeExpr rest
        (caseList rest
          (Nil (Protoss.exprErr "expected Server.request payload"))
          (Cons payloadExpr extra
            (caseList extra
              (Nil
                (case (Protoss.stringLiteral routeExpr)
                  (Err err (Protoss.exprErr err))
                  (Ok route
                    (case (Protoss.stringLiteral payloadExpr)
                      (Err err (Protoss.exprErr err))
                      (Ok payload
                        (Protoss.exprOk
                          (variant PERequest
                            (variant PRServerRequest
                              (record (route route) (payload payload))))))))))
              (Cons extraHead extraTail
                (Protoss.exprErr "too many Server.request arguments")))))))))

(def Protoss.finishRecordExpr (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (args (List ProtossExpr))
    (case (Protoss.parseRecordFieldExprs args)
      (Err err (Protoss.exprErr err))
      (Ok fields (Protoss.exprOk (variant PERecord fields))))))

(def Protoss.finishApplyExpr
  (-> ProtossExpr (-> (List ProtossExpr) (Result String ProtossExpr)))
  (lambda (fn ProtossExpr)
    (lambda (args (List ProtossExpr))
      (Protoss.exprOk (variant PEApply (record (fn fn) (args args)))))))

(def Protoss.finishRequestNamedExpr
  (-> String (-> (List ProtossExpr) (Result String ProtossExpr)))
  (lambda (name String)
    (lambda (args (List ProtossExpr))
      (case ((String.eqString name) "Human.ask")
        (true (Protoss.finishAskHumanExpr args))
        (false
          (case ((String.eqString name) "Http.get")
            (true (Protoss.finishHttpGetExpr args))
            (false
              (case ((String.eqString name) "Clock.read")
                (true (Protoss.finishClockReadExpr args))
                (false
                  (case ((String.eqString name) "Local.save")
                    (true (Protoss.finishLocalSaveExpr args))
                    (false
                      (case ((String.eqString name) "Local.load")
                        (true (Protoss.finishLocalLoadExpr args))
                        (false
                          (case ((String.eqString name) "Server.request")
                            (true (Protoss.finishServerRequestExpr args))
                            (false
                              ((Protoss.finishApplyExpr (variant PEVar name)) args))))))))))))))))

(def Protoss.finishExtendedNamedExpr
  (-> String (-> (List ProtossExpr) (Result String ProtossExpr)))
  (lambda (name String)
    (lambda (args (List ProtossExpr))
      (case ((String.eqString name) "get")
        (true (Protoss.finishGetExpr args))
        (false
          (case ((String.eqString name) "inst")
            (true (Protoss.finishInstExpr args))
            (false
              (case ((String.eqString name) "Cons")
                (true (Protoss.finishConsExpr args))
                (false
                  (case ((String.eqString name) "foldList")
                    (true (Protoss.finishFoldListExpr args))
                    (false
                      (case ((String.eqString name) "foldVariant")
                        (true (Protoss.finishFoldVariantExpr args))
                        (false
                          (case ((String.eqString name) "caseList")
                            (true (Protoss.finishCaseListExpr args))
                            (false
                              (case ((String.eqString name) "recur")
                                (true (Protoss.finishRecurExpr args))
                                (false
                                  (case ((String.eqString name) "done")
                                    (true (Protoss.finishDoneExpr args))
                                    (false
                                      (case ((String.eqString name) "bind")
                                        (true (Protoss.finishBindExpr args))
                                        (false
                                          ((Protoss.finishRequestNamedExpr name) args))))))))))))))))))))))

(def Protoss.finishNamedExpr
  (-> String (-> (List ProtossExpr) (Result String ProtossExpr)))
  (lambda (name String)
    (lambda (args (List ProtossExpr))
      (case ((String.eqString name) "lambda")
        (true (Protoss.finishLambdaExpr args))
        (false
          (case ((String.eqString name) "let")
            (true (Protoss.finishLetExpr args))
            (false
              (case ((String.eqString name) "case")
                (true (Protoss.finishCaseExpr args))
                (false
                  (case ((String.eqString name) "foldNat")
                    (true (Protoss.finishFoldNatExpr args))
                    (false
                      (case ((String.eqString name) "record")
                        (true (Protoss.finishRecordExpr args))
                        (false
                          (case ((String.eqString name) "variant")
                            (true (Protoss.finishVariantExpr args))
                            (false ((Protoss.finishExtendedNamedExpr name) args))))))))))))))))

(def Protoss.finishExprList (-> (List ProtossExpr) (Result String ProtossExpr))
  (lambda (items (List ProtossExpr))
    (caseList items
      (Nil (Protoss.exprErr "expected expression"))
          (Cons fn args
            (case fn
              (PENil nil (Protoss.finishNilExpr args))
              (PEVar name
                ((Protoss.finishNamedExpr name) args))
              (_ ((Protoss.finishApplyExpr fn) args)))))))

(defrec Protoss.parseExpr (-> Sexp (Result String ProtossExpr))
  (variant value)
  (SAtom name (Protoss.exprOk (Protoss.atomExpr name)))
  (SString text (Protoss.exprOk (variant PEString text)))
  (SList items
    (case
      (foldList items (Protoss.exprListOk (Nil ProtossExpr))
        (lambda (item Sexp)
          (lambda (acc (Result String (List ProtossExpr)))
            (case (recur item)
              (Err err (Protoss.exprListErr err))
              (Ok parsedItem
                (case acc
                  (Err err (Protoss.exprListErr err))
                  (Ok parsedItems
                    (Protoss.exprListOk
                      (Cons ProtossExpr parsedItem parsedItems)))))))))
      (Err err (Protoss.exprErr err))
      (Ok parsedItems (Protoss.finishExprList parsedItems)))))

(def Protoss.stringListOk (-> (List String) (Result String (List String)))
  (lambda (items (List String))
    (variant Ok items)))

(def Protoss.stringListErr (-> String (Result String (List String)))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseParamNames (-> (List Sexp) (Result String (List String)))
  (lambda (items (List Sexp))
    (foldList items (Protoss.stringListOk (Nil String))
      (lambda (item Sexp)
        (lambda (acc (Result String (List String)))
          (case item
            (SAtom name
              (case acc
                (Err err (Protoss.stringListErr err))
                (Ok names (Protoss.stringListOk (Cons String name names)))))
            (_ (Protoss.stringListErr "expected parameter name"))))))))

(def Protoss.parseNames
  (-> String (-> (List Sexp) (Result String (List String))))
  (lambda (message String)
    (lambda (items (List Sexp))
      (foldList items (Protoss.stringListOk (Nil String))
        (lambda (item Sexp)
          (lambda (acc (Result String (List String)))
            (case item
              (SAtom name
                (case acc
                  (Err err (Protoss.stringListErr err))
                  (Ok names (Protoss.stringListOk (Cons String name names)))))
              (_ (Protoss.stringListErr message)))))))))

(def Protoss.parseParamsClause (-> Sexp (Result String (List String)))
  (lambda (node Sexp)
    (case node
      (SList items
        (caseList items
          (Nil (Protoss.stringListErr "invalid type parameter clause"))
          (Cons head params
            (case head
              (SAtom tag
                (case ((String.eqString tag) "params")
                  (true (Protoss.parseParamNames params))
                  (false (Protoss.stringListErr "invalid type parameter clause"))))
              (_ (Protoss.stringListErr "invalid type parameter clause"))))))
      (_ (Protoss.stringListErr "invalid type parameter clause")))))

(def Protoss.parseCapabilityClause (-> Sexp (Result String (List String)))
  (lambda (node Sexp)
    (case node
      (SList items
        (caseList items
          (Nil (Protoss.stringListErr "invalid definition capabilities"))
          (Cons head caps
            (case head
              (SAtom tag
                (case ((String.eqString tag) "capabilities")
                  (true ((Protoss.parseNames "expected capability name") caps))
                  (false (Protoss.stringListErr "invalid definition capabilities"))))
              (_ (Protoss.stringListErr "invalid definition capabilities"))))))
      (_ (Protoss.stringListErr "invalid definition capabilities")))))

(def Protoss.parseClauseArgs
  (-> String (-> Sexp (Result String (List Sexp))))
  (lambda (expected String)
    (lambda (node Sexp)
      (case node
        (SList items
          (caseList items
            (Nil (variant Err ((String.concat "expected ") expected)))
            (Cons head args
              (case head
                (SAtom tag
                  (case ((String.eqString tag) expected)
                    (true (variant Ok args))
                    (false (variant Err ((String.concat "expected ") expected)))))
                (_ (variant Err ((String.concat "expected ") expected)))))))
        (_ (variant Err ((String.concat "expected ") expected)))))))

(def Protoss.parseNameClause
  (-> String (-> Sexp (Result String String)))
  (lambda (tag String)
    (lambda (node Sexp)
      (case ((Protoss.parseClauseArgs tag) node)
        (Err err (Protoss.stringErr err))
        (Ok args
          (caseList args
            (Nil (Protoss.stringErr ((String.concat "expected ") tag)))
            (Cons nameNode extra
              (caseList extra
                (Nil
                  (case nameNode
                    (SAtom name (Protoss.stringOk name))
                    (_ (Protoss.stringErr ((String.concat "expected ") tag)))))
                (Cons extraHead extraTail
                  (Protoss.stringErr ((String.concat "too many ") tag)))))))))))

(def Protoss.parseExprClause
  (-> String (-> Sexp (Result String ProtossExpr)))
  (lambda (tag String)
    (lambda (node Sexp)
      (case ((Protoss.parseClauseArgs tag) node)
        (Err err (Protoss.exprErr err))
        (Ok args
          (caseList args
            (Nil (Protoss.exprErr ((String.concat "expected ") tag)))
            (Cons exprNode extra
              (caseList extra
                (Nil (Protoss.parseExpr exprNode))
                (Cons extraHead extraTail
                  (Protoss.exprErr ((String.concat "too many ") tag)))))))))))

(def Protoss.defRecStepClauseOk
  (-> ProtossDefRecStepClause (Result String ProtossDefRecStepClause))
  (lambda (step ProtossDefRecStepClause)
    (variant Ok step)))

(def Protoss.defRecConsClauseOk
  (-> ProtossDefRecConsClause (Result String ProtossDefRecConsClause))
  (lambda (step ProtossDefRecConsClause)
    (variant Ok step)))

(def Protoss.parseStepClause
  (-> Sexp (Result String ProtossDefRecStepClause))
  (lambda (node Sexp)
    (case ((Protoss.parseClauseArgs "step") node)
      (Err err (variant Err err))
      (Ok args
        (caseList args
          (Nil (variant Err "expected step accumulator"))
          (Cons accNode rest
            (case accNode
              (SAtom acc
                (caseList rest
                  (Nil (variant Err "expected step body"))
                  (Cons bodyNode extra
                    (caseList extra
                      (Nil
                        (case (Protoss.parseExpr bodyNode)
                          (Err err (variant Err err))
                          (Ok body
                            (Protoss.defRecStepClauseOk
                              (record (acc acc) (body body))))))
                      (Cons extraHead extraTail
                        (variant Err "too many step fields"))))))
              (_ (variant Err "expected step accumulator")))))))))

(def Protoss.parseConsClause
  (-> Sexp (Result String ProtossDefRecConsClause))
  (lambda (node Sexp)
    (case ((Protoss.parseClauseArgs "cons") node)
      (Err err (variant Err err))
      (Ok args
        (caseList args
          (Nil (variant Err "expected cons item"))
          (Cons itemNode rest
            (case itemNode
              (SAtom item
                (caseList rest
                  (Nil (variant Err "expected cons accumulator"))
                  (Cons accNode bodyTail
                    (case accNode
                      (SAtom acc
                        (caseList bodyTail
                          (Nil (variant Err "expected cons body"))
                          (Cons bodyNode extra
                            (caseList extra
                              (Nil
                                (case (Protoss.parseExpr bodyNode)
                                  (Err err (variant Err err))
                                  (Ok body
                                    (Protoss.defRecConsClauseOk
                                      (record
                                        (item item)
                                        (acc acc)
                                        (body body))))))
                              (Cons extraHead extraTail
                                (variant Err "too many cons fields"))))))
                      (_ (variant Err "expected cons accumulator"))))))
              (_ (variant Err "expected cons item")))))))))

(def Protoss.paramTailOk (-> (List String) (-> (List Sexp) (Result String ProtossParamTail)))
  (lambda (params (List String))
    (lambda (rest (List Sexp))
      (variant Ok (record (typeParams params) (rest rest))))))

(def Protoss.paramTailErr (-> String (Result String ProtossParamTail))
  (lambda (message String)
    (variant Err message)))

(def Protoss.noParams (-> (List Sexp) (Result String ProtossParamTail))
  (lambda (tail (List Sexp))
    ((Protoss.paramTailOk (Nil String)) tail)))

(def Protoss.parseLeadingParams (-> (List Sexp) (Result String ProtossParamTail))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.noParams tail))
      (Cons first rest
        (case first
          (SList items
            (caseList items
              (Nil (Protoss.noParams tail))
              (Cons head params
                (case head
                  (SAtom tag
                    (case ((String.eqString tag) "params")
                      (true
                        (case (Protoss.parseParamNames params)
                          (Err err (Protoss.paramTailErr err))
                          (Ok names ((Protoss.paramTailOk names) rest))))
                      (false (Protoss.noParams tail))))
                  (_ (Protoss.noParams tail))))))
          (_ (Protoss.noParams tail)))))))

(def Protoss.declOk (-> ProtossDecl (Result String ProtossDecl))
  (lambda (decl ProtossDecl)
    (variant Ok decl)))

(def Protoss.declErr (-> String (Result String ProtossDecl))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseModuleDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected module name"))
      (Cons nameNode rest
        (caseList rest
          (Nil
            (case nameNode
              (SAtom name (Protoss.declOk (variant PDModule name)))
              (_ (Protoss.declErr "expected module name"))))
          (Cons extraHead extraTail
            (Protoss.declErr "too many module fields")))))))

(def Protoss.parseImportDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected import path"))
      (Cons pathNode rest
        (caseList rest
          (Nil
            (case pathNode
              (SString path (Protoss.declOk (variant PDImport path)))
              (_ (Protoss.declErr "expected import path"))))
          (Cons extraHead extraTail
            (Protoss.declErr "too many import fields")))))))

(def Protoss.parseExportDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (case ((Protoss.parseNames "expected export name") tail)
      (Err err (Protoss.declErr err))
      (Ok names (Protoss.declOk (variant PDExport names))))))

(def Protoss.parseCapabilitiesDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (case ((Protoss.parseNames "expected capability name") tail)
      (Err err (Protoss.declErr err))
      (Ok names (Protoss.declOk (variant PDCapabilities names))))))

(def Protoss.parseDefDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected def name"))
      (Cons nameNode defTail
        (case nameNode
          (SAtom name ((Protoss.parseDefTail name) defTail))
          (_ (Protoss.declErr "expected def name")))))))

(def Protoss.parseDefCapDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected defcap name"))
      (Cons nameNode defTail
        (case nameNode
          (SAtom name ((Protoss.parseDefCapTail name) defTail))
          (_ (Protoss.declErr "expected defcap name")))))))

(def Protoss.parseDefPolyDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected defpoly name"))
      (Cons nameNode defTail
        (case nameNode
          (SAtom name ((Protoss.parseDefPolyTail name) defTail))
          (_ (Protoss.declErr "expected defpoly name")))))))

(def Protoss.parseDefPolyCapDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected defpolycap name"))
      (Cons nameNode defTail
        (case nameNode
          (SAtom name ((Protoss.parseDefPolyCapTail name) defTail))
          (_ (Protoss.declErr "expected defpolycap name")))))))

(def Protoss.parseDefRecDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected defrec name"))
      (Cons nameNode defTail
        (case nameNode
          (SAtom name (((Protoss.parseDefRecTail name) (Nil String)) defTail))
          (_ (Protoss.declErr "expected defrec name")))))))

(def Protoss.parseDefRecPolyDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected defrecpoly name"))
      (Cons nameNode rest
        (case nameNode
          (SAtom name
            (caseList rest
              (Nil (Protoss.declErr "expected defrecpoly params"))
              (Cons paramsNode defTail
                (case (Protoss.parseParamsClause paramsNode)
                  (Err err (Protoss.declErr err))
                  (Ok typeParams
                    (((Protoss.parseDefRecTail name) typeParams) defTail))))))
          (_ (Protoss.declErr "expected defrecpoly name")))))))

(def Protoss.parseTypeDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected type name"))
      (Cons nameNode typeTail
        (case nameNode
          (SAtom name ((Protoss.parseTypeAliasTail name) typeTail))
          (_ (Protoss.declErr "expected type name")))))))

(def Protoss.parseRecordDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected record name"))
      (Cons nameNode recordTail
        (case nameNode
          (SAtom name ((Protoss.parseRecordTail name) recordTail))
          (_ (Protoss.declErr "expected record name")))))))

(def Protoss.parseVariantDecl (-> (List Sexp) (Result String ProtossDecl))
  (lambda (tail (List Sexp))
    (caseList tail
      (Nil (Protoss.declErr "expected variant name"))
      (Cons nameNode variantTail
        (case nameNode
          (SAtom name ((Protoss.parseVariantTail name) variantTail))
          (_ (Protoss.declErr "expected variant name")))))))

(def Protoss.parseDefTail
  (-> String (-> (List Sexp) (Result String ProtossDecl)))
  (lambda (name String)
    (lambda (tail (List Sexp))
      (caseList tail
        (Nil (variant Err "expected def type"))
        (Cons typeNode rest
          (caseList rest
            (Nil (variant Err "expected def expression"))
            (Cons expr extra
              (caseList extra
                (Nil
                  (case (Protoss.parseType typeNode)
                    (Err err (variant Err err))
                    (Ok typ
                      (case (Protoss.parseExpr expr)
                        (Err err (variant Err err))
                        (Ok parsedExpr
                          (Protoss.declOk
                            (variant PDDef
                              (record (name name) (typ typ) (expr parsedExpr)))))))))
                (Cons extraHead extraTail
                  (variant Err "too many def fields"))))))))))

(def Protoss.parseDefCapTail
  (-> String (-> (List Sexp) (Result String ProtossDecl)))
  (lambda (name String)
    (lambda (tail (List Sexp))
      (caseList tail
        (Nil (Protoss.declErr "expected defcap capabilities"))
        (Cons capsNode rest
          (caseList rest
            (Nil (Protoss.declErr "expected defcap type"))
            (Cons typeNode more
              (caseList more
                (Nil (Protoss.declErr "expected defcap expression"))
                (Cons expr extra
                  (caseList extra
                    (Nil
                      (case (Protoss.parseCapabilityClause capsNode)
                        (Err err (Protoss.declErr err))
                        (Ok capabilities
                          (case (Protoss.parseType typeNode)
                            (Err err (Protoss.declErr err))
                            (Ok typ
                              (case (Protoss.parseExpr expr)
                                (Err err (Protoss.declErr err))
                                (Ok parsedExpr
                                  (Protoss.declOk
                                    (variant PDDefCap
                                      (record
                                        (name name)
                                        (capabilities capabilities)
                                        (typ typ)
                                        (expr parsedExpr)))))))))))
                    (Cons extraHead extraTail
                      (Protoss.declErr "too many defcap fields"))))))))))))

(def Protoss.parseDefPolyTail
  (-> String (-> (List Sexp) (Result String ProtossDecl)))
  (lambda (name String)
    (lambda (tail (List Sexp))
      (caseList tail
        (Nil (Protoss.declErr "expected defpoly params"))
        (Cons paramsNode rest
          (caseList rest
            (Nil (Protoss.declErr "expected defpoly type"))
            (Cons typeNode more
              (caseList more
                (Nil (Protoss.declErr "expected defpoly expression"))
                (Cons expr extra
                  (caseList extra
                    (Nil
                      (case (Protoss.parseParamsClause paramsNode)
                        (Err err (Protoss.declErr err))
                        (Ok typeParams
                          (case (Protoss.parseType typeNode)
                            (Err err (Protoss.declErr err))
                            (Ok typ
                              (case (Protoss.parseExpr expr)
                                (Err err (Protoss.declErr err))
                                (Ok parsedExpr
                                  (Protoss.declOk
                                    (variant PDDefPoly
                                      (record
                                        (name name)
                                        (typeParams typeParams)
                                        (typ typ)
                                        (expr parsedExpr)))))))))))
                    (Cons extraHead extraTail
                      (Protoss.declErr "too many defpoly fields"))))))))))))

(def Protoss.parseDefPolyCapTail
  (-> String (-> (List Sexp) (Result String ProtossDecl)))
  (lambda (name String)
    (lambda (tail (List Sexp))
      (caseList tail
        (Nil (Protoss.declErr "expected defpolycap params"))
        (Cons paramsNode rest
          (caseList rest
            (Nil (Protoss.declErr "expected defpolycap capabilities"))
            (Cons capsNode more
              (caseList more
                (Nil (Protoss.declErr "expected defpolycap type"))
                (Cons typeNode exprTail
                  (caseList exprTail
                    (Nil (Protoss.declErr "expected defpolycap expression"))
                    (Cons expr extra
                      (caseList extra
                        (Nil
                          (case (Protoss.parseParamsClause paramsNode)
                            (Err err (Protoss.declErr err))
                            (Ok typeParams
                              (case (Protoss.parseCapabilityClause capsNode)
                                (Err err (Protoss.declErr err))
                                (Ok capabilities
                                  (case (Protoss.parseType typeNode)
                                    (Err err (Protoss.declErr err))
                                    (Ok typ
                                      (case (Protoss.parseExpr expr)
                                        (Err err (Protoss.declErr err))
                                        (Ok parsedExpr
                                          (Protoss.declOk
                                            (variant PDDefPolyCap
                                              (record
                                                (name name)
                                                (typeParams typeParams)
                                                (capabilities capabilities)
                                                (typ typ)
                                                (expr parsedExpr)))))))))))))
                        (Cons extraHead extraTail
                          (Protoss.declErr "too many defpolycap fields"))))))))))))))

(def Protoss.defRecBodyOk (-> ProtossDefRecBody (Result String ProtossDefRecBody))
  (lambda (body ProtossDefRecBody)
    (variant Ok body)))

(def Protoss.defRecBodyErr (-> String (Result String ProtossDefRecBody))
  (lambda (message String)
    (variant Err message)))

(def Protoss.clauseTag (-> Sexp (Result String String))
  (lambda (node Sexp)
    (case node
      (SList items
        (caseList items
          (Nil (Protoss.stringErr "expected defrec clause"))
          (Cons head rest
            (case head
              (SAtom tag (Protoss.stringOk tag))
              (_ (Protoss.stringErr "expected defrec clause"))))))
      (_ (Protoss.stringErr "expected defrec clause")))))

(def Protoss.parseDefRecBranch (-> Sexp (Result String ProtossCaseBranch))
  (lambda (node Sexp)
    (case (Protoss.parseExpr node)
      (Err err (Protoss.caseBranchErr err))
      (Ok expr (Protoss.parseCaseBranch expr)))))

(def Protoss.parseDefRecBranches
  (-> (List Sexp) (Result String (List ProtossCaseBranch)))
  (lambda (branches (List Sexp))
    (foldList branches (Protoss.caseBranchListOk (Nil ProtossCaseBranch))
      (lambda (branch Sexp)
        (lambda (acc (Result String (List ProtossCaseBranch)))
          (case (Protoss.parseDefRecBranch branch)
            (Err err (Protoss.caseBranchListErr err))
            (Ok parsedBranch
              (case acc
                (Err err (Protoss.caseBranchListErr err))
                (Ok parsedBranches
                  (Protoss.caseBranchListOk
                    (Cons ProtossCaseBranch parsedBranch parsedBranches)))))))))))

(def Protoss.parseDefRecNatRest
  (-> String (-> (List Sexp) (Result String ProtossDefRecBody)))
  (lambda (param String)
    (lambda (rest (List Sexp))
      (caseList rest
        (Nil (Protoss.defRecBodyErr "expected zero clause"))
        (Cons zeroNode more
          (caseList more
            (Nil (Protoss.defRecBodyErr "expected step clause"))
            (Cons stepNode extra
              (caseList extra
                (Nil
                  (case ((Protoss.parseExprClause "zero") zeroNode)
                    (Err err (Protoss.defRecBodyErr err))
                    (Ok zero
                      (case (Protoss.parseStepClause stepNode)
                        (Err err (Protoss.defRecBodyErr err))
                        (Ok step
                          (Protoss.defRecBodyOk
                            (variant PDRNat
                              (record
                                (param param)
                                (zero zero)
                                (acc (get step acc))
                                (step (get step body))))))))))
                (Cons extraHead extraTail
                  (Protoss.defRecBodyErr "too many defrec nat clauses"))))))))))

(def Protoss.parseDefRecListRest
  (-> String (-> (List Sexp) (Result String ProtossDefRecBody)))
  (lambda (param String)
    (lambda (rest (List Sexp))
      (caseList rest
        (Nil (Protoss.defRecBodyErr "expected nil clause"))
        (Cons nilNode more
          (caseList more
            (Nil (Protoss.defRecBodyErr "expected cons clause"))
            (Cons consNode extra
              (caseList extra
                (Nil
                  (case ((Protoss.parseExprClause "nil") nilNode)
                    (Err err (Protoss.defRecBodyErr err))
                    (Ok nil
                      (case (Protoss.parseConsClause consNode)
                        (Err err (Protoss.defRecBodyErr err))
                        (Ok cons
                          (Protoss.defRecBodyOk
                            (variant PDRList
                              (record
                                (param param)
                                (nil nil)
                                (item (get cons item))
                                (acc (get cons acc))
                                (step (get cons body))))))))))
                (Cons extraHead extraTail
                  (Protoss.defRecBodyErr "too many defrec list clauses"))))))))))

(def Protoss.parseDefRecVariantRest
  (-> String (-> (List Sexp) (Result String ProtossDefRecBody)))
  (lambda (param String)
    (lambda (branches (List Sexp))
      (caseList branches
        (Nil (Protoss.defRecBodyErr "expected defrec variant branch"))
        (Cons first rest
          (case (Protoss.parseDefRecBranches branches)
            (Err err (Protoss.defRecBodyErr err))
            (Ok parsedBranches
              (Protoss.defRecBodyOk
                (variant PDRVariant
                  (record
                    (param param)
                    (branches parsedBranches)))))))))))

(def Protoss.parseDefRecBody (-> (List Sexp) (Result String ProtossDefRecBody))
  (lambda (clauses (List Sexp))
    (caseList clauses
      (Nil (Protoss.defRecBodyErr "expected defrec clause"))
      (Cons head rest
        (case (Protoss.clauseTag head)
          (Err err (Protoss.defRecBodyErr err))
          (Ok tag
            (case ((String.eqString tag) "nat")
              (true
                (case ((Protoss.parseNameClause "nat") head)
                  (Err err (Protoss.defRecBodyErr err))
                  (Ok param ((Protoss.parseDefRecNatRest param) rest))))
              (false
                (case ((String.eqString tag) "list")
                  (true
                    (case ((Protoss.parseNameClause "list") head)
                      (Err err (Protoss.defRecBodyErr err))
                      (Ok param ((Protoss.parseDefRecListRest param) rest))))
                  (false
                    (case ((String.eqString tag) "variant")
                      (true
                        (case ((Protoss.parseNameClause "variant") head)
                          (Err err (Protoss.defRecBodyErr err))
                          (Ok param ((Protoss.parseDefRecVariantRest param) rest))))
                      (false
                        (Protoss.defRecBodyErr "expected defrec clause")))))))))))))

(def Protoss.parseDefRecTail
  (-> String (-> (List String) (-> (List Sexp) (Result String ProtossDecl))))
  (lambda (name String)
    (lambda (typeParams (List String))
      (lambda (tail (List Sexp))
        (caseList tail
          (Nil (Protoss.declErr "expected defrec type"))
          (Cons typeNode clauses
            (case (Protoss.parseType typeNode)
              (Err err (Protoss.declErr err))
              (Ok typ
                (case (Protoss.parseDefRecBody clauses)
                  (Err err (Protoss.declErr err))
                  (Ok body
                    (Protoss.declOk
                      (variant PDDefRec
                        (record
                          (name name)
                          (typeParams typeParams)
                          (typ typ)
                          (body body))))))))))))))

(def Protoss.parseTypeAliasTail
  (-> String (-> (List Sexp) (Result String ProtossDecl)))
  (lambda (name String)
    (lambda (tail (List Sexp))
      (caseList tail
        (Nil (Protoss.declErr "expected type body"))
        (Cons first rest
          (caseList rest
            (Nil
              (case (Protoss.parseType first)
                (Err err (Protoss.declErr err))
                (Ok body
                  (Protoss.declOk
                    (variant PDType
                      (record (name name) (typeParams (Nil String)) (body body)))))))
            (Cons bodyNode extra
              (caseList extra
                (Nil
                  (case first
                    (SList paramNodes
                      (case (Protoss.parseParamNames paramNodes)
                        (Err err (Protoss.declErr err))
                        (Ok params
                          (case (Protoss.parseType bodyNode)
                            (Err err (Protoss.declErr err))
                            (Ok body
                              (Protoss.declOk
                                (variant PDType
                                  (record (name name) (typeParams params) (body body)))))))))
                    (_ (Protoss.declErr "expected type parameter list"))))
                (Cons extraHead extraTail
                  (Protoss.declErr "too many type fields"))))))))))

(def Protoss.fieldOk (-> ProtossField (Result String ProtossField))
  (lambda (field ProtossField)
    (variant Ok field)))

(def Protoss.fieldErr (-> String (Result String ProtossField))
  (lambda (message String)
    (variant Err message)))

(def Protoss.fieldListOk (-> (List ProtossField) (Result String (List ProtossField)))
  (lambda (fields (List ProtossField))
    (variant Ok fields)))

(def Protoss.fieldListErr (-> String (Result String (List ProtossField)))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseField (-> Sexp (Result String ProtossField))
  (lambda (field Sexp)
    (case field
      (SList items
        (caseList items
          (Nil (Protoss.fieldErr "expected field name"))
          (Cons nameNode rest
            (case nameNode
              (SAtom name
                (caseList rest
                  (Nil (Protoss.fieldErr "expected field type"))
                  (Cons typeNode extra
                    (caseList extra
                      (Nil
                        (case (Protoss.parseType typeNode)
                          (Err err (Protoss.fieldErr err))
                          (Ok typ
                            (Protoss.fieldOk (record (name name) (typ typ))))))
                      (Cons extraHead extraTail
                        (Protoss.fieldErr "too many field items"))))))
              (_ (Protoss.fieldErr "expected field name"))))))
      (_ (Protoss.fieldErr "expected field form")))))

(def Protoss.parseFields (-> (List Sexp) (Result String (List ProtossField)))
  (lambda (fields (List Sexp))
    (foldList fields (Protoss.fieldListOk (Nil ProtossField))
      (lambda (field Sexp)
        (lambda (acc (Result String (List ProtossField)))
          (case (Protoss.parseField field)
            (Err err (Protoss.fieldListErr err))
            (Ok parsedField
              (case acc
                (Err err (Protoss.fieldListErr err))
                (Ok parsedFields
                  (Protoss.fieldListOk
                    (Cons ProtossField parsedField parsedFields)))))))))))

(def Protoss.parseRecordTail
  (-> String (-> (List Sexp) (Result String ProtossDecl)))
  (lambda (name String)
    (lambda (tail (List Sexp))
      (case (Protoss.parseLeadingParams tail)
        (Err err (Protoss.declErr err))
        (Ok paramTail
          (case (Protoss.parseFields (get paramTail rest))
            (Err err (Protoss.declErr err))
            (Ok fields
              (Protoss.declOk
                (variant PDRecord
                  (record
                    (name name)
                    (typeParams (get paramTail typeParams))
                    (fields fields)))))))))))

(def Protoss.variantCaseOk (-> ProtossVariantCase (Result String ProtossVariantCase))
  (lambda (variantCase ProtossVariantCase)
    (variant Ok variantCase)))

(def Protoss.variantCaseErr (-> String (Result String ProtossVariantCase))
  (lambda (message String)
    (variant Err message)))

(def Protoss.variantCaseListOk
  (-> (List ProtossVariantCase) (Result String (List ProtossVariantCase)))
  (lambda (cases (List ProtossVariantCase))
    (variant Ok cases)))

(def Protoss.variantCaseListErr (-> String (Result String (List ProtossVariantCase)))
  (lambda (message String)
    (variant Err message)))

(def Protoss.parseVariantCase (-> Sexp (Result String ProtossVariantCase))
  (lambda (variantCase Sexp)
    (case variantCase
      (SList items
        (caseList items
          (Nil (Protoss.variantCaseErr "expected variant case name"))
          (Cons nameNode rest
            (case nameNode
              (SAtom name
                (caseList rest
                  (Nil (Protoss.variantCaseErr "expected variant payload type"))
                  (Cons typeNode extra
                    (caseList extra
                      (Nil
                        (case (Protoss.parseType typeNode)
                          (Err err (Protoss.variantCaseErr err))
                          (Ok payload
                            (Protoss.variantCaseOk (record (name name) (payload payload))))))
                      (Cons extraHead extraTail
                        (Protoss.variantCaseErr "too many variant case items"))))))
              (_ (Protoss.variantCaseErr "expected variant case name"))))))
      (_ (Protoss.variantCaseErr "expected variant case form")))))

(def Protoss.parseVariantCases
  (-> (List Sexp) (Result String (List ProtossVariantCase)))
  (lambda (cases (List Sexp))
    (foldList cases (Protoss.variantCaseListOk (Nil ProtossVariantCase))
      (lambda (variantCase Sexp)
        (lambda (acc (Result String (List ProtossVariantCase)))
          (case (Protoss.parseVariantCase variantCase)
            (Err err (Protoss.variantCaseListErr err))
            (Ok parsedCase
              (case acc
                (Err err (Protoss.variantCaseListErr err))
                (Ok parsedCases
                  (Protoss.variantCaseListOk
                    (Cons ProtossVariantCase parsedCase parsedCases)))))))))))

(def Protoss.parseVariantTail
  (-> String (-> (List Sexp) (Result String ProtossDecl)))
  (lambda (name String)
    (lambda (tail (List Sexp))
      (case (Protoss.parseLeadingParams tail)
        (Err err (Protoss.declErr err))
        (Ok paramTail
          (case (Protoss.parseVariantCases (get paramTail rest))
            (Err err (Protoss.declErr err))
            (Ok cases
              (Protoss.declOk
                (variant PDVariant
                  (record
                    (name name)
                    (typeParams (get paramTail typeParams))
                    (cases cases)))))))))))

(def Protoss.parseDeclByTag
  (-> String (-> (List Sexp) (Result String ProtossDecl)))
  (lambda (tag String)
    (lambda (tail (List Sexp))
      (case ((String.eqString tag) "module")
        (true (Protoss.parseModuleDecl tail))
        (false
          (case ((String.eqString tag) "import")
            (true (Protoss.parseImportDecl tail))
            (false
              (case ((String.eqString tag) "export")
                (true (Protoss.parseExportDecl tail))
                (false
                  (case ((String.eqString tag) "capabilities")
                    (true (Protoss.parseCapabilitiesDecl tail))
                    (false
                      (case ((String.eqString tag) "def")
                        (true (Protoss.parseDefDecl tail))
                        (false
                          (case ((String.eqString tag) "defcap")
                            (true (Protoss.parseDefCapDecl tail))
                            (false
                              (case ((String.eqString tag) "defpoly")
                                (true (Protoss.parseDefPolyDecl tail))
                                (false
                                  (case ((String.eqString tag) "defpolycap")
                                    (true (Protoss.parseDefPolyCapDecl tail))
                                    (false
                                      (case ((String.eqString tag) "defrec")
                                        (true (Protoss.parseDefRecDecl tail))
                                        (false
                                          (case ((String.eqString tag) "defrecpoly")
                                            (true (Protoss.parseDefRecPolyDecl tail))
                                            (false
                                              (case ((String.eqString tag) "type")
                                                (true (Protoss.parseTypeDecl tail))
                                                (false
                                                  (case ((String.eqString tag) "alias")
                                                    (true (Protoss.parseTypeDecl tail))
                                                    (false
                                                      (case ((String.eqString tag) "record")
                                                        (true (Protoss.parseRecordDecl tail))
                                                        (false
                                                          (case ((String.eqString tag) "variant")
                                                            (true (Protoss.parseVariantDecl tail))
                                                            (false
                                                              (Protoss.declErr
                                                                "expected declaration tag"))))))))))))))))))))))))))))))))

(def Protoss.parseDecl (-> Sexp (Result String ProtossDecl))
  (lambda (form Sexp)
    (case form
      (SAtom atom (variant Err "expected declaration list"))
      (SString text (variant Err "expected declaration list"))
      (SList items
        (caseList items
          (Nil (variant Err "empty declaration"))
          (Cons head tail
            (case head
              (SAtom tag ((Protoss.parseDeclByTag tag) tail))
              (_ (variant Err "expected declaration tag")))))))))

(def Protoss.parseDecls (-> (List Sexp) (Result String (List ProtossDecl)))
  (lambda (forms (List Sexp))
    (foldList forms (variant Ok (Nil ProtossDecl))
      (lambda (form Sexp)
        (lambda (acc (Result String (List ProtossDecl)))
          (case (Protoss.parseDecl form)
            (Err err (variant Err err))
            (Ok decl
              (case acc
                (Err err (variant Err err))
                (Ok decls
                  (variant Ok (Cons ProtossDecl decl decls)))))))))))

(def Protoss.parseText (-> String (Result String (List ProtossDecl)))
  (lambda (source String)
    (case (Sexp.parseText source)
      (Err err (variant Err err))
      (Ok forms (Protoss.parseDecls forms)))))

(def Sexp.isAtom (-> Sexp Bool)
  (lambda (value Sexp)
    (case value
      (SAtom atom true)
      (_ false))))

(def Sexp.isString (-> Sexp Bool)
  (lambda (value Sexp)
    (case value
      (SString string true)
      (_ false))))

(def Sexp.isList (-> Sexp Bool)
  (lambda (value Sexp)
    (case value
      (SList items true)
      (_ false))))

(def Sexp.expectAtom (-> Sexp (Result String String))
  (lambda (value Sexp)
    (case value
      (SAtom atom (variant Ok atom))
      (_ (variant Err "expected Sexp atom")))))

(def Sexp.expectString (-> Sexp (Result String String))
  (lambda (value Sexp)
    (case value
      (SString string (variant Ok string))
      (_ (variant Err "expected Sexp string")))))

(def Sexp.expectList (-> Sexp (Result String (List Sexp)))
  (lambda (value Sexp)
    (case value
      (SList items (variant Ok items))
      (_ (variant Err "expected Sexp list")))))

(def Sexp.renderFlatString (-> String String)
  (lambda (value String)
    ((String.concat "\"") ((String.concat value) "\""))))

(def Sexp.renderFlat (-> Sexp String)
  (lambda (value Sexp)
    (case value
      (SAtom atom atom)
      (SString string (Sexp.renderFlatString string))
      (SList items
        (let (rendered
          ((String.join " ")
            (((inst List.map Sexp String) items)
              (lambda (item Sexp)
                (case item
                  (SAtom atom atom)
                  (SString string (Sexp.renderFlatString string))
                  (SList nested "(...)"))))))
          ((String.concat "(") ((String.concat rendered) ")")))))))

(defrec Sexp.render (-> Sexp String)
  (variant value)
  (SAtom atom atom)
  (SString string (Sexp.renderFlatString string))
  (SList items
    ((String.concat "(")
      ((String.concat
        (foldList items String.empty
          (lambda (item Sexp)
            (lambda (acc String)
              (let (current (recur item))
                (case (String.isEmpty acc)
                  (true current)
                  (false ((String.concat current) ((String.concat " ") acc))))))))
        ")")))))

(def Protoss.renderFormParts (-> (List String) String)
  (lambda (parts (List String))
    ((String.concat "(") ((String.concat ((String.join " ") parts)) ")"))))

(def Protoss.renderForm (-> String (-> (List String) String))
  (lambda (head String)
    (lambda (parts (List String))
      (Protoss.renderFormParts (Cons String head parts)))))

(defrec Protoss.renderType (-> ProtossType String)
  (variant typ)
  (PTName name name)
  (PTFun pair
    (Protoss.renderForm "->"
      (Cons String (recur (get pair first))
        (Cons String (recur (get pair second))
          (Nil String)))))
  (PTApply app
    (Protoss.renderForm (get app name)
      (foldList (get app args) (Nil String)
        (lambda (arg ProtossType)
          (lambda (acc (List String))
            (Cons String (recur arg) acc)))))))

(def Protoss.renderParam (-> ProtossParam String)
  (lambda (param ProtossParam)
    (Protoss.renderForm (get param name)
      (Cons String (Protoss.renderType (get param typ))
        (Nil String)))))

(def Protoss.renderBranchForm (-> String (-> (Maybe String) (-> String String)))
  (lambda (constructor String)
    (lambda (binder (Maybe String))
      (lambda (body String)
        (case binder
          (None _ (Protoss.renderForm constructor (Cons String body (Nil String))))
          (Some name
            (Protoss.renderForm constructor
              (Cons String name
                (Cons String body
                  (Nil String))))))))))

(def Protoss.renderRequest (-> ProtossRequest String)
  (lambda (request ProtossRequest)
    (case request
      (PRAskHuman prompt
        (Protoss.renderForm "Human.ask"
          (Cons String (Sexp.renderFlatString prompt)
            (Nil String))))
      (PRHttpGet url
        (Protoss.renderForm "Http.get"
          (Cons String (Sexp.renderFlatString url)
            (Nil String))))
      (PRClockRead
        (Protoss.renderForm "Clock.read" (Nil String)))
      (PRSaveLocal save
        (Protoss.renderForm "Local.save"
          (Cons String (Sexp.renderFlatString (get save key))
            (Cons String (Sexp.renderFlatString (get save value))
              (Nil String)))))
      (PRLoadLocal key
        (Protoss.renderForm "Local.load"
          (Cons String (Sexp.renderFlatString key)
            (Nil String))))
      (PRServerRequest request
        (Protoss.renderForm "Server.request"
          (Cons String (Sexp.renderFlatString (get request route))
            (Cons String (Sexp.renderFlatString (get request payload))
              (Nil String))))))))

(defrec Protoss.renderExpr (-> ProtossExpr String)
  (variant expr)
  (PEApply call
    (Protoss.renderForm (recur (get call fn))
      (foldList (get call args) (Nil String)
        (lambda (arg ProtossExpr)
          (lambda (acc (List String))
            (Cons String (recur arg) acc))))))
  (PEBind bindExpr
    (Protoss.renderForm "bind"
      (Cons String (recur (get bindExpr process))
        (Cons String
          (Protoss.renderForm "lambda"
            (Cons String
              (Protoss.renderForm (get bindExpr param)
                (Cons String (Protoss.renderType (get bindExpr typ))
                  (Nil String)))
              (Cons String (recur (get bindExpr body))
                (Nil String))))
          (Nil String)))))
  (PEBool value
    (case value
      (true "true")
      (false "false")))
  (PECase caseExpr
    (Protoss.renderForm "case"
      (Cons String (recur (get caseExpr scrutinee))
        (foldList (get caseExpr branches) (Nil String)
          (lambda (branch ProtossCaseBranch)
            (lambda (acc (List String))
              (Cons String
                (((Protoss.renderBranchForm (get branch constructor))
                  (get branch binder))
                  (recur (get branch body)))
                acc)))))))
  (PECaseList caseListExpr
    (Protoss.renderForm "caseList"
      (Cons String (recur (get caseListExpr target))
        (Cons String
          (Protoss.renderForm "Nil"
            (Cons String (recur (get caseListExpr nilBody))
              (Nil String)))
          (Cons String
            (Protoss.renderForm "Cons"
              (Cons String (get caseListExpr head)
                (Cons String (get caseListExpr tail)
                  (Cons String (recur (get caseListExpr consBody))
                    (Nil String)))))
            (Nil String))))))
  (PEDone value
    (Protoss.renderForm "done"
      (Cons String (recur value)
        (Nil String))))
  (PEField fieldExpr
    (Protoss.renderForm "get"
      (Cons String (recur (get fieldExpr target))
        (Cons String (get fieldExpr field)
          (Nil String)))))
  (PEFoldNat foldNatExpr
    (Protoss.renderForm "foldNat"
      (Cons String (recur (get foldNatExpr target))
        (Cons String (recur (get foldNatExpr zero))
          (Cons String (recur (get foldNatExpr step))
            (Nil String))))))
  (PEFoldVariant foldVariantExpr
    (Protoss.renderForm "foldVariant"
      (((inst List.append String)
        (Cons String (Protoss.renderType (get foldVariantExpr target))
          (Cons String (Protoss.renderType (get foldVariantExpr result))
            (Cons String (recur (get foldVariantExpr scrutinee))
              (Nil String)))))
        (foldList (get foldVariantExpr branches) (Nil String)
          (lambda (branch ProtossCaseBranch)
            (lambda (acc (List String))
              (Cons String
                (((Protoss.renderBranchForm (get branch constructor))
                  (get branch binder))
                  (recur (get branch body)))
                acc)))))))
  (PEFoldList foldListExpr
    (Protoss.renderForm "foldList"
      (Cons String (recur (get foldListExpr target))
        (Cons String (recur (get foldListExpr zero))
          (Cons String (recur (get foldListExpr step))
            (Nil String))))))
  (PEInst instExpr
    (Protoss.renderForm "inst"
      (Cons String (get instExpr name)
        (foldList (get instExpr typeArgs) (Nil String)
          (lambda (typ ProtossType)
            (lambda (acc (List String))
              (Cons String (Protoss.renderType typ) acc)))))))
  (PELambda lam
    (Protoss.renderForm "lambda"
      (Cons String (Protoss.renderParam (get lam param))
        (Cons String (recur (get lam body))
          (Nil String)))))
  (PELet letExpr
    (Protoss.renderForm "let"
      (Cons String
        (case (get letExpr typ)
          (None _
            (Protoss.renderForm (get letExpr name)
              (Cons String (recur (get letExpr value))
                (Nil String))))
          (Some typ
            (Protoss.renderForm (get letExpr name)
              (Cons String (Protoss.renderType typ)
                (Cons String (recur (get letExpr value))
                  (Nil String))))))
        (Cons String (recur (get letExpr body))
          (Nil String)))))
  (PECons consExpr
    (case (get consExpr typ)
      (None _
        (Protoss.renderForm "Cons"
          (Cons String (recur (get consExpr head))
            (Cons String (recur (get consExpr tail))
              (Nil String)))))
      (Some typ
        (Protoss.renderForm "Cons"
          (Cons String (Protoss.renderType typ)
            (Cons String (recur (get consExpr head))
              (Cons String (recur (get consExpr tail))
                (Nil String))))))))
  (PENil nilExpr
    (case (get nilExpr typ)
      (None _ "Nil")
      (Some typ
        (Protoss.renderForm "Nil"
          (Cons String (Protoss.renderType typ)
            (Nil String))))))
  (PERecord fields
    (Protoss.renderForm "record"
      (foldList fields (Nil String)
        (lambda (field ProtossRecordFieldExpr)
          (lambda (acc (List String))
            (Cons String
              (Protoss.renderForm (get field name)
                (Cons String (recur (get field expr))
                  (Nil String)))
              acc))))))
  (PERecur value
    (Protoss.renderForm "recur"
      (Cons String (recur value)
        (Nil String))))
  (PERequest request
    (Protoss.renderRequest request))
  (PEString value
    (Sexp.renderFlatString value))
  (PEUnit
    "unit")
  (PEVariant variantExpr
    (case (get variantExpr typeHint)
      (None _
        (Protoss.renderForm "variant"
          (Cons String (get variantExpr constructor)
            (Cons String (recur (get variantExpr payload))
              (Nil String)))))
      (Some typ
        (Protoss.renderForm "variant"
          (Cons String (Protoss.renderType typ)
            (Cons String (get variantExpr constructor)
              (Cons String (recur (get variantExpr payload))
                (Nil String))))))))
  (PEVar name name))

(def Protoss.renderFieldDecl (-> ProtossField String)
  (lambda (field ProtossField)
    (Protoss.renderForm (get field name)
      (Cons String (Protoss.renderType (get field typ))
        (Nil String)))))

(def Protoss.renderVariantCase (-> ProtossVariantCase String)
  (lambda (caseDecl ProtossVariantCase)
    (Protoss.renderForm (get caseDecl name)
      (Cons String (Protoss.renderType (get caseDecl payload))
        (Nil String)))))

(def Protoss.renderParamsClause (-> (List String) (List String))
  (lambda (params (List String))
    (caseList params
      (Nil (Nil String))
      (Cons first rest
        (Cons String (Protoss.renderForm "params" params)
          (Nil String))))))

(def Protoss.renderCapabilitiesClause (-> (List String) String)
  (lambda (capabilities (List String))
    (Protoss.renderForm "capabilities" capabilities)))

(def Protoss.renderDefRecBodyParts (-> ProtossDefRecBody (List String))
  (lambda (body ProtossDefRecBody)
    (case body
      (PDRNat nat
        (Cons String
          (Protoss.renderForm "nat"
            (Cons String (get nat param)
              (Nil String)))
          (Cons String
            (Protoss.renderForm "zero"
              (Cons String (Protoss.renderExpr (get nat zero))
                (Nil String)))
            (Cons String
              (Protoss.renderForm "step"
                (Cons String (get nat acc)
                  (Cons String (Protoss.renderExpr (get nat step))
                    (Nil String))))
              (Nil String)))))
      (PDRList listRec
        (Cons String
          (Protoss.renderForm "list"
            (Cons String (get listRec param)
              (Nil String)))
          (Cons String
            (Protoss.renderForm "nil"
              (Cons String (Protoss.renderExpr (get listRec nil))
                (Nil String)))
            (Cons String
              (Protoss.renderForm "cons"
                (Cons String (get listRec item)
                  (Cons String (get listRec acc)
                    (Cons String (Protoss.renderExpr (get listRec step))
                      (Nil String)))))
              (Nil String)))))
      (PDRVariant variantRec
        (Cons String
          (Protoss.renderForm "variant"
            (Cons String (get variantRec param)
              (Nil String)))
          (((inst List.map ProtossCaseBranch String) (get variantRec branches))
            (lambda (branch ProtossCaseBranch)
              (((Protoss.renderBranchForm (get branch constructor))
                (get branch binder))
                (Protoss.renderExpr (get branch body))))))))))

(def Protoss.renderDecl (-> ProtossDecl String)
  (lambda (decl ProtossDecl)
    (case decl
      (PDCapabilities names
        (Protoss.renderForm "capabilities" names))
      (PDDef def
        (Protoss.renderForm "def"
          (Cons String (get def name)
            (Cons String (Protoss.renderType (get def typ))
              (Cons String (Protoss.renderExpr (get def expr))
                (Nil String))))))
      (PDDefCap def
        (Protoss.renderForm "defcap"
          (Cons String (get def name)
            (Cons String (Protoss.renderCapabilitiesClause (get def capabilities))
              (Cons String (Protoss.renderType (get def typ))
                (Cons String (Protoss.renderExpr (get def expr))
                  (Nil String)))))))
      (PDDefPoly def
        (Protoss.renderForm "defpoly"
          (Cons String (get def name)
            (Cons String (Protoss.renderForm "params" (get def typeParams))
              (Cons String (Protoss.renderType (get def typ))
                (Cons String (Protoss.renderExpr (get def expr))
                  (Nil String)))))))
      (PDDefPolyCap def
        (Protoss.renderForm "defpolycap"
          (Cons String (get def name)
            (Cons String (Protoss.renderForm "params" (get def typeParams))
              (Cons String (Protoss.renderCapabilitiesClause (get def capabilities))
                (Cons String (Protoss.renderType (get def typ))
                  (Cons String (Protoss.renderExpr (get def expr))
                    (Nil String))))))))
      (PDDefRec def
        (caseList (get def typeParams)
          (Nil
            (Protoss.renderForm "defrec"
              (((inst List.append String)
                (Cons String (get def name)
                  (Cons String (Protoss.renderType (get def typ))
                    (Nil String))))
                (Protoss.renderDefRecBodyParts (get def body)))))
          (Cons first rest
            (Protoss.renderForm "defrecpoly"
              (((inst List.append String)
                (Cons String (get def name)
                  (Cons String (Protoss.renderForm "params" (get def typeParams))
                    (Cons String (Protoss.renderType (get def typ))
                      (Nil String)))))
                (Protoss.renderDefRecBodyParts (get def body)))))))
      (PDExport names
        (Protoss.renderForm "export" names))
      (PDImport path
        (Protoss.renderForm "import"
          (Cons String (Sexp.renderFlatString path)
            (Nil String))))
      (PDModule name
        (Protoss.renderForm "module"
          (Cons String name
            (Nil String))))
      (PDRecord recordDecl
        (Protoss.renderForm "record"
          (((inst List.append String)
            (Cons String (get recordDecl name)
              (Protoss.renderParamsClause (get recordDecl typeParams))))
            (((inst List.map ProtossField String) (get recordDecl fields))
              (lambda (field ProtossField)
                (Protoss.renderFieldDecl field))))))
      (PDType typeDecl
        (caseList (get typeDecl typeParams)
          (Nil
            (Protoss.renderForm "type"
              (Cons String (get typeDecl name)
                (Cons String (Protoss.renderType (get typeDecl body))
                  (Nil String)))))
          (Cons first rest
            (Protoss.renderForm "type"
              (Cons String (get typeDecl name)
                (Cons String (Protoss.renderFormParts (get typeDecl typeParams))
                  (Cons String (Protoss.renderType (get typeDecl body))
                    (Nil String))))))))
      (PDVariant variantDecl
        (Protoss.renderForm "variant"
          (((inst List.append String)
            (Cons String (get variantDecl name)
              (Protoss.renderParamsClause (get variantDecl typeParams))))
            (((inst List.map ProtossVariantCase String) (get variantDecl cases))
              (lambda (caseDecl ProtossVariantCase)
                (Protoss.renderVariantCase caseDecl)))))))))

(def Protoss.renderDecls (-> (List ProtossDecl) String)
  (lambda (decls (List ProtossDecl))
    ((String.join "\n")
      (((inst List.map ProtossDecl String) decls)
        (lambda (decl ProtossDecl)
          (Protoss.renderDecl decl))))))

(def Protoss.renderSexpForms (-> (List Sexp) String)
  (lambda (forms (List Sexp))
    ((String.join "\n")
      (((inst List.map Sexp String) forms)
        (lambda (form Sexp)
          (Sexp.render form))))))

(def Protoss.formatText (-> String (Result String String))
  (lambda (source String)
    (case (Protoss.parseText source)
      (Err err (variant Err err))
      (Ok decls (variant Ok (Protoss.renderDecls decls))))))

(def Protoss.builtinValueNames (List String)
  (Cons String "succ"
    (Cons String "prim.Nat.eq"
      (Cons String "prim.Nat.toString"
        (Cons String "prim.String.concat"
          (Cons String "prim.String.eq"
            (Cons String "prim.String.length"
              (Cons String "prim.String.slice"
                (Nil String)))))))))

(def Protoss.builtinTypeNames (List String)
  (Cons String "Unit"
    (Cons String "Bool"
      (Cons String "Nat"
        (Cons String "String"
          (Cons String "Process"
            (Cons String "List"
              (Cons String "View"
                (Cons String "Record"
                  (Cons String "Variant"
                    (Nil String)))))))))))

(def Protoss.nameSetContains (-> String (-> (List String) Bool))
  (lambda (name String)
    (lambda (names (List String))
      ((((inst Set.contains String) String.eqString) name) names))))

(def Protoss.nameSetInsertRaw (-> String (-> (List String) (List String)))
  (lambda (name String)
    (lambda (names (List String))
      ((((inst Set.insert String) String.eqString) name) names))))

(def Protoss.nameSetUnion (-> (List String) (-> (List String) (List String)))
  (lambda (left (List String))
    (lambda (right (List String))
      ((((inst Set.union String) String.eqString) left) right))))

(def Protoss.nameSetRemove (-> String (-> (List String) (List String)))
  (lambda (name String)
    (lambda (names (List String))
      ((((inst Set.remove String) String.eqString) name) names))))

(def Protoss.nameSetRemoveMany (-> (List String) (-> (List String) (List String)))
  (lambda (removed (List String))
    (lambda (names (List String))
      (foldList removed names
        (lambda (name String)
          (lambda (acc (List String))
            ((Protoss.nameSetRemove name) acc)))))))

(def Protoss.nameSetUnique (-> (List String) (List String))
  (lambda (names (List String))
    (foldList names (Nil String)
      (lambda (name String)
        (lambda (acc (List String))
          ((Protoss.nameSetInsertRaw name) acc))))))

(def Protoss.nameSetDuplicates (-> (List String) (List String))
  (lambda (names (List String))
    (get
      (foldList names
        (record
          (first (Nil String))
          (second (Nil String)))
        (lambda (name String)
          (lambda (state (Pair (List String) (List String)))
            (case ((Protoss.nameSetContains name) (get state first))
              (true
                (record
                  (first (get state first))
                  (second ((Protoss.nameSetInsertRaw name) (get state second)))))
              (false
                (record
                  (first ((Protoss.nameSetInsertRaw name) (get state first)))
                  (second (get state second))))))))
      second)))

(def Protoss.nameSetMissingFrom (-> (List String) (-> (List String) (List String)))
  (lambda (refs (List String))
    (lambda (available (List String))
      (((inst List.filter String) refs)
        (lambda (name String)
          (Bool.not ((Protoss.nameSetContains name) available)))))))

(def Protoss.nameSetIntersect (-> (List String) (-> (List String) (List String)))
  (lambda (left (List String))
    (lambda (right (List String))
      (((inst Set.intersect String) String.eqString) left right))))

(def Protoss.isBuiltinValueName (-> String Bool)
  (lambda (name String)
    ((Protoss.nameSetContains name) Protoss.builtinValueNames)))

(def Protoss.isBuiltinTypeName (-> String Bool)
  (lambda (name String)
    ((Protoss.nameSetContains name) Protoss.builtinTypeNames)))

(def Protoss.isNatLiteralName (-> String Bool)
  (lambda (name String)
    (case ((Nat.eqNat (String.length name)) 0)
      (true false)
      (false
        (let (scan (Pair Nat Bool)
          (foldNat (String.length name)
            (record (first 0) (second true))
            (lambda (state (Pair Nat Bool))
              (record
                (first (succ (get state first)))
                (second
                  (case (get state second)
                    (true
                      (case ((String.charAt name) (get state first))
                        (None _ false)
                        (Some ch (String.isDigit ch))))
                    (false false)))))))
          (get scan second))))))

(def Protoss.isValueReferenceName (-> String Bool)
  (lambda (name String)
    (case (String.isEmpty name)
      (true false)
      (false
        (case (Protoss.isBuiltinValueName name)
          (true false)
          (false (Bool.not (Protoss.isNatLiteralName name))))))))

(def Protoss.valueRefName (-> String (-> (List String) (List String)))
  (lambda (name String)
    (lambda (bound (List String))
      (case ((Protoss.nameSetContains name) bound)
        (true (Nil String))
        (false
          (case (Protoss.isValueReferenceName name)
            (true ((Protoss.nameSetInsertRaw name) (Nil String)))
            (false (Nil String))))))))

(def Protoss.typeRefName (-> String (-> (List String) (List String)))
  (lambda (name String)
    (lambda (bound (List String))
      (case ((Protoss.nameSetContains name) bound)
        (true (Nil String))
        (false
          (case (Protoss.isBuiltinTypeName name)
            (true (Nil String))
            (false ((Protoss.nameSetInsertRaw name) (Nil String)))))))))

(defrec Protoss.typeNames (-> ProtossType (List String))
  (variant typ)
  (PTName name
    ((Protoss.typeRefName name) (Nil String)))
  (PTFun pair
    ((Protoss.nameSetUnion (recur (get pair first)))
      (recur (get pair second))))
  (PTApply app
    ((Protoss.nameSetUnion ((Protoss.typeRefName (get app name)) (Nil String)))
      (foldList (get app args) (Nil String)
        (lambda (arg ProtossType)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion (recur arg)) acc)))))))

(def Protoss.typeNamesExcept (-> (List String) (-> ProtossType (List String)))
  (lambda (bound (List String))
    (lambda (typ ProtossType)
      ((Protoss.nameSetRemoveMany bound) (Protoss.typeNames typ)))))

(defrec Protoss.exprTermNames (-> ProtossExpr (List String))
  (variant expr)
  (PEApply call
    ((Protoss.nameSetUnion (recur (get call fn)))
      (foldList (get call args) (Nil String)
        (lambda (arg ProtossExpr)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion (recur arg)) acc))))))
  (PEBind bindExpr
    ((Protoss.nameSetUnion (recur (get bindExpr process)))
      ((Protoss.nameSetRemove (get bindExpr param)) (recur (get bindExpr body)))))
  (PEBool value
    (Nil String))
  (PECase caseExpr
    ((Protoss.nameSetUnion (recur (get caseExpr scrutinee)))
      (foldList (get caseExpr branches) (Nil String)
        (lambda (branch ProtossCaseBranch)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion
              (case (get branch binder)
                (None _ (recur (get branch body)))
                (Some name ((Protoss.nameSetRemove name) (recur (get branch body))))))
              acc))))))
  (PECaseList caseListExpr
    ((Protoss.nameSetUnion (recur (get caseListExpr target)))
      ((Protoss.nameSetUnion (recur (get caseListExpr nilBody)))
        ((Protoss.nameSetRemoveMany
          (Cons String (get caseListExpr head)
            (Cons String (get caseListExpr tail)
              (Nil String))))
          (recur (get caseListExpr consBody))))))
  (PEDone value
    (recur value))
  (PEField fieldExpr
    (recur (get fieldExpr target)))
  (PEFoldNat foldNatExpr
    ((Protoss.nameSetUnion (recur (get foldNatExpr target)))
      ((Protoss.nameSetUnion (recur (get foldNatExpr zero)))
        (recur (get foldNatExpr step)))))
  (PEFoldVariant foldVariantExpr
    ((Protoss.nameSetUnion (recur (get foldVariantExpr scrutinee)))
      (foldList (get foldVariantExpr branches) (Nil String)
        (lambda (branch ProtossCaseBranch)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion
              (case (get branch binder)
                (None _ (recur (get branch body)))
                (Some name ((Protoss.nameSetRemove name) (recur (get branch body))))))
              acc))))))
  (PEFoldList foldListExpr
    ((Protoss.nameSetUnion (recur (get foldListExpr target)))
      ((Protoss.nameSetUnion (recur (get foldListExpr zero)))
        (recur (get foldListExpr step)))))
  (PEInst instExpr
    ((Protoss.valueRefName (get instExpr name)) (Nil String)))
  (PELambda lam
    ((Protoss.nameSetRemove (get (get lam param) name))
      (recur (get lam body))))
  (PELet letExpr
    ((Protoss.nameSetUnion (recur (get letExpr value)))
      ((Protoss.nameSetRemove (get letExpr name))
        (recur (get letExpr body)))))
  (PECons consExpr
    ((Protoss.nameSetUnion (recur (get consExpr head)))
      (recur (get consExpr tail))))
  (PENil nilExpr
    (Nil String))
  (PERecord fields
    (foldList fields (Nil String)
      (lambda (field ProtossRecordFieldExpr)
        (lambda (acc (List String))
          ((Protoss.nameSetUnion (recur (get field expr))) acc)))))
  (PERecur value
    (recur value))
  (PERequest request
    (Nil String))
  (PEString value
    (Nil String))
  (PEUnit
    (Nil String))
  (PEVariant variantExpr
    (recur (get variantExpr payload)))
  (PEVar name
    ((Protoss.valueRefName name) (Nil String))))

(defrec Protoss.exprTypeNames (-> ProtossExpr (List String))
  (variant expr)
  (PEApply call
    ((Protoss.nameSetUnion (recur (get call fn)))
      (foldList (get call args) (Nil String)
        (lambda (arg ProtossExpr)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion (recur arg)) acc))))))
  (PEBind bindExpr
    ((Protoss.nameSetUnion (Protoss.typeNames (get bindExpr typ)))
      ((Protoss.nameSetUnion (recur (get bindExpr process)))
        (recur (get bindExpr body)))))
  (PEBool value
    (Nil String))
  (PECase caseExpr
    ((Protoss.nameSetUnion (recur (get caseExpr scrutinee)))
      (foldList (get caseExpr branches) (Nil String)
        (lambda (branch ProtossCaseBranch)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion (recur (get branch body))) acc))))))
  (PECaseList caseListExpr
    ((Protoss.nameSetUnion (recur (get caseListExpr target)))
      ((Protoss.nameSetUnion (recur (get caseListExpr nilBody)))
        (recur (get caseListExpr consBody)))))
  (PEDone value
    (recur value))
  (PEField fieldExpr
    (recur (get fieldExpr target)))
  (PEFoldNat foldNatExpr
    ((Protoss.nameSetUnion (recur (get foldNatExpr target)))
      ((Protoss.nameSetUnion (recur (get foldNatExpr zero)))
        (recur (get foldNatExpr step)))))
  (PEFoldVariant foldVariantExpr
    ((Protoss.nameSetUnion (Protoss.typeNames (get foldVariantExpr target)))
      ((Protoss.nameSetUnion (Protoss.typeNames (get foldVariantExpr result)))
        ((Protoss.nameSetUnion (recur (get foldVariantExpr scrutinee)))
          (foldList (get foldVariantExpr branches) (Nil String)
            (lambda (branch ProtossCaseBranch)
              (lambda (acc (List String))
                ((Protoss.nameSetUnion (recur (get branch body))) acc))))))))
  (PEFoldList foldListExpr
    ((Protoss.nameSetUnion (recur (get foldListExpr target)))
      ((Protoss.nameSetUnion (recur (get foldListExpr zero)))
        (recur (get foldListExpr step)))))
  (PEInst instExpr
    (foldList (get instExpr typeArgs) (Nil String)
      (lambda (typ ProtossType)
        (lambda (acc (List String))
          ((Protoss.nameSetUnion (Protoss.typeNames typ)) acc)))))
  (PELambda lam
    ((Protoss.nameSetUnion (Protoss.typeNames (get (get lam param) typ)))
      (recur (get lam body))))
  (PELet letExpr
    ((Protoss.nameSetUnion
      (case (get letExpr typ)
        (None _ (Nil String))
        (Some typ (Protoss.typeNames typ))))
      ((Protoss.nameSetUnion (recur (get letExpr value)))
        (recur (get letExpr body)))))
  (PECons consExpr
    ((Protoss.nameSetUnion
      (case (get consExpr typ)
        (None _ (Nil String))
        (Some typ (Protoss.typeNames typ))))
      ((Protoss.nameSetUnion (recur (get consExpr head)))
        (recur (get consExpr tail)))))
  (PENil nilExpr
    (case (get nilExpr typ)
      (None _ (Nil String))
      (Some typ (Protoss.typeNames typ))))
  (PERecord fields
    (foldList fields (Nil String)
      (lambda (field ProtossRecordFieldExpr)
        (lambda (acc (List String))
          ((Protoss.nameSetUnion (recur (get field expr))) acc)))))
  (PERecur value
    (recur value))
  (PERequest request
    (Nil String))
  (PEString value
    (Nil String))
  (PEUnit
    (Nil String))
  (PEVariant variantExpr
    ((Protoss.nameSetUnion
      (case (get variantExpr typeHint)
        (None _ (Nil String))
        (Some typ (Protoss.typeNames typ))))
      (recur (get variantExpr payload))))
  (PEVar name
    (Nil String)))

(def Protoss.defRecBodyTermNames (-> ProtossDefRecBody (List String))
  (lambda (body ProtossDefRecBody)
    (case body
      (PDRNat nat
        ((Protoss.nameSetUnion
          ((Protoss.nameSetRemove (get nat param)) (Protoss.exprTermNames (get nat zero))))
          ((Protoss.nameSetRemoveMany
            (Cons String (get nat acc)
              (Cons String (get nat param)
                (Nil String))))
            (Protoss.exprTermNames (get nat step)))))
      (PDRList listRec
        ((Protoss.nameSetUnion
          ((Protoss.nameSetRemove (get listRec param)) (Protoss.exprTermNames (get listRec nil))))
          ((Protoss.nameSetRemoveMany
            (Cons String (get listRec item)
              (Cons String (get listRec acc)
                (Cons String (get listRec param)
                  (Nil String)))))
            (Protoss.exprTermNames (get listRec step)))))
      (PDRVariant variantRec
        (foldList (get variantRec branches) (Nil String)
          (lambda (branch ProtossCaseBranch)
            (lambda (acc (List String))
              ((Protoss.nameSetUnion
                (case (get branch binder)
                  (None _
                    ((Protoss.nameSetRemove (get variantRec param))
                      (Protoss.exprTermNames (get branch body))))
                  (Some name
                    ((Protoss.nameSetRemoveMany
                      (Cons String name
                        (Cons String (get variantRec param)
                          (Nil String))))
                      (Protoss.exprTermNames (get branch body))))))
                acc))))))))

(def Protoss.defRecBodyTypeNames (-> ProtossDefRecBody (List String))
  (lambda (body ProtossDefRecBody)
    (case body
      (PDRNat nat
        ((Protoss.nameSetUnion (Protoss.exprTypeNames (get nat zero)))
          (Protoss.exprTypeNames (get nat step))))
      (PDRList listRec
        ((Protoss.nameSetUnion (Protoss.exprTypeNames (get listRec nil)))
          (Protoss.exprTypeNames (get listRec step))))
      (PDRVariant variantRec
        (foldList (get variantRec branches) (Nil String)
          (lambda (branch ProtossCaseBranch)
            (lambda (acc (List String))
              ((Protoss.nameSetUnion (Protoss.exprTypeNames (get branch body))) acc))))))))

(def Protoss.declTermNames (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDef def (Protoss.exprTermNames (get def expr)))
      (PDDefCap def (Protoss.exprTermNames (get def expr)))
      (PDDefPoly def (Protoss.exprTermNames (get def expr)))
      (PDDefPolyCap def (Protoss.exprTermNames (get def expr)))
      (PDDefRec def (Protoss.defRecBodyTermNames (get def body)))
      (_ (Nil String)))))

(def Protoss.declTypeNames (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDef def
        ((Protoss.nameSetUnion (Protoss.typeNames (get def typ)))
          (Protoss.exprTypeNames (get def expr))))
      (PDDefCap def
        ((Protoss.nameSetUnion (Protoss.typeNames (get def typ)))
          (Protoss.exprTypeNames (get def expr))))
      (PDDefPoly def
        ((Protoss.nameSetRemoveMany (get def typeParams))
          ((Protoss.nameSetUnion (Protoss.typeNames (get def typ)))
            (Protoss.exprTypeNames (get def expr)))))
      (PDDefPolyCap def
        ((Protoss.nameSetRemoveMany (get def typeParams))
          ((Protoss.nameSetUnion (Protoss.typeNames (get def typ)))
            (Protoss.exprTypeNames (get def expr)))))
      (PDDefRec def
        ((Protoss.nameSetRemoveMany (get def typeParams))
          ((Protoss.nameSetUnion (Protoss.typeNames (get def typ)))
            (Protoss.defRecBodyTypeNames (get def body)))))
      (PDRecord recordDecl
        ((Protoss.nameSetRemoveMany (get recordDecl typeParams))
          (foldList (get recordDecl fields) (Nil String)
            (lambda (field ProtossField)
              (lambda (acc (List String))
                ((Protoss.nameSetUnion (Protoss.typeNames (get field typ))) acc))))))
      (PDType typeDecl
        ((Protoss.nameSetRemoveMany (get typeDecl typeParams))
          (Protoss.typeNames (get typeDecl body))))
      (PDVariant variantDecl
        ((Protoss.nameSetRemoveMany (get variantDecl typeParams))
          (foldList (get variantDecl cases) (Nil String)
            (lambda (caseDecl ProtossVariantCase)
              (lambda (acc (List String))
                ((Protoss.nameSetUnion (Protoss.typeNames (get caseDecl payload))) acc))))))
      (_ (Nil String)))))

(def Protoss.declDefinedTermNames (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDef def (Cons String (get def name) (Nil String)))
      (PDDefCap def (Cons String (get def name) (Nil String)))
      (PDDefPoly def (Cons String (get def name) (Nil String)))
      (PDDefPolyCap def (Cons String (get def name) (Nil String)))
      (PDDefRec def (Cons String (get def name) (Nil String)))
      (_ (Nil String)))))

(def Protoss.declDefinedTypeNames (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDRecord recordDecl (Cons String (get recordDecl name) (Nil String)))
      (PDType typeDecl (Cons String (get typeDecl name) (Nil String)))
      (PDVariant variantDecl (Cons String (get variantDecl name) (Nil String)))
      (_ (Nil String)))))

(def Protoss.declExportNames (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDExport names names)
      (_ (Nil String)))))

(def Protoss.declsRawDefinedTermNames (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          (((inst List.append String) (Protoss.declDefinedTermNames decl)) acc))))))

(def Protoss.declsRawDefinedTypeNames (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          (((inst List.append String) (Protoss.declDefinedTypeNames decl)) acc))))))

(def Protoss.declsDefinedTermNames (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (Protoss.nameSetUnique (Protoss.declsRawDefinedTermNames decls))))

(def Protoss.declsDefinedTypeNames (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (Protoss.nameSetUnique (Protoss.declsRawDefinedTypeNames decls))))

(def Protoss.declsTermNames (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          ((Protoss.nameSetUnion (Protoss.declTermNames decl)) acc))))))

(def Protoss.declsTypeNames (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          ((Protoss.nameSetUnion (Protoss.declTypeNames decl)) acc))))))

(def Protoss.declsRawExportNames (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          (((inst List.append String) (Protoss.declExportNames decl)) acc))))))

(def Protoss.declsExportNames (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (Protoss.nameSetUnique (Protoss.declsRawExportNames decls))))

(def Protoss.resolveDeclsWith
  (-> (List String) (-> (List String) (-> (List ProtossDecl) ProtossResolveReport)))
  (lambda (externalTerms (List String))
    (lambda (externalTypes (List String))
      (lambda (decls (List ProtossDecl))
        (let (rawDefinedTerms (List String) (Protoss.declsRawDefinedTermNames decls))
          (let (rawDefinedTypes (List String) (Protoss.declsRawDefinedTypeNames decls))
            (let (definedTerms (List String) (Protoss.nameSetUnique rawDefinedTerms))
              (let (definedTypes (List String) (Protoss.nameSetUnique rawDefinedTypes))
                (let (termRefs (List String) (Protoss.declsTermNames decls))
                  (let (typeRefs (List String) (Protoss.declsTypeNames decls))
                    (let (exports (List String) (Protoss.declsExportNames decls))
                      (let (availableTerms (List String) ((Protoss.nameSetUnion definedTerms) externalTerms))
                        (let (availableTypes (List String) ((Protoss.nameSetUnion definedTypes) externalTypes))
                          (let (exportableNames (List String) ((Protoss.nameSetUnion definedTerms) definedTypes))
                            (record
                              (definedTerms definedTerms)
                              (definedTypes definedTypes)
                              (termRefs termRefs)
                              (typeRefs typeRefs)
                              (exports exports)
                              (missingTerms ((Protoss.nameSetMissingFrom termRefs) availableTerms))
                              (missingTypes ((Protoss.nameSetMissingFrom typeRefs) availableTypes))
                              (missingExports ((Protoss.nameSetMissingFrom exports) exportableNames))
                              (duplicateTerms (Protoss.nameSetDuplicates rawDefinedTerms))
                              (duplicateTypes (Protoss.nameSetDuplicates rawDefinedTypes)))))))))))))))))

(def Protoss.resolveDecls (-> (List ProtossDecl) ProtossResolveReport)
  (lambda (decls (List ProtossDecl))
    (((Protoss.resolveDeclsWith (Nil String)) (Nil String)) decls)))

(def Protoss.resolveTextWith
  (-> (List String) (-> (List String) (-> String (Result String ProtossResolveReport))))
  (lambda (externalTerms (List String))
    (lambda (externalTypes (List String))
      (lambda (source String)
        (case (Protoss.parseText source)
          (Err err (variant Err err))
          (Ok decls
            (variant Ok (((Protoss.resolveDeclsWith externalTerms) externalTypes) decls))))))))

(def Protoss.resolveText (-> String (Result String ProtossResolveReport))
  (lambda (source String)
    (((Protoss.resolveTextWith (Nil String)) (Nil String)) source)))

(def Protoss.declTermDepNode (-> (List String) (-> ProtossDecl (Maybe ProtossDepNode)))
  (lambda (definedTerms (List String))
    (lambda (decl ProtossDecl)
      (case decl
        (PDDef def
          (variant Some
            (record
              (name (get def name))
              (deps ((Protoss.nameSetIntersect (Protoss.declTermNames decl)) definedTerms)))))
        (PDDefCap def
          (variant Some
            (record
              (name (get def name))
              (deps ((Protoss.nameSetIntersect (Protoss.declTermNames decl)) definedTerms)))))
        (PDDefPoly def
          (variant Some
            (record
              (name (get def name))
              (deps ((Protoss.nameSetIntersect (Protoss.declTermNames decl)) definedTerms)))))
        (PDDefPolyCap def
          (variant Some
            (record
              (name (get def name))
              (deps ((Protoss.nameSetIntersect (Protoss.declTermNames decl)) definedTerms)))))
        (PDDefRec def
          (variant Some
            (record
              (name (get def name))
              (deps ((Protoss.nameSetIntersect (Protoss.declTermNames decl)) definedTerms)))))
        (_ (variant None unit))))))

(def Protoss.declsTermDepNodes (-> (List ProtossDecl) (List ProtossDepNode))
  (lambda (decls (List ProtossDecl))
    (let (definedTerms (List String) (Protoss.declsDefinedTermNames decls))
      (foldList decls (Nil ProtossDepNode)
        (lambda (decl ProtossDecl)
          (lambda (acc (List ProtossDepNode))
            (case ((Protoss.declTermDepNode definedTerms) decl)
              (None _ acc)
              (Some node (Cons ProtossDepNode node acc)))))))))

(def Protoss.depNodeNames (-> (List ProtossDepNode) (List String))
  (lambda (nodes (List ProtossDepNode))
    (((inst List.map ProtossDepNode String) nodes)
      (lambda (node ProtossDepNode)
        (get node name)))))

(def Protoss.depNodeReady (-> (List String) (-> ProtossDepNode Bool))
  (lambda (ordered (List String))
    (lambda (node ProtossDepNode)
      (((inst List.all String) (get node deps))
        (lambda (dep String)
          ((Protoss.nameSetContains dep) ordered))))))

(def Protoss.depPartitionReady
  (-> (List String) (-> (List ProtossDepNode) (Pair (List String) (List ProtossDepNode))))
  (lambda (ordered (List String))
    (lambda (nodes (List ProtossDepNode))
      (foldList nodes
        (record
          (first (Nil String))
          (second (Nil ProtossDepNode)))
        (lambda (node ProtossDepNode)
          (lambda (acc (Pair (List String) (List ProtossDepNode)))
            (case ((Protoss.depNodeReady ordered) node)
              (true
                (record
                  (first (Cons String (get node name) (get acc first)))
                  (second (get acc second))))
              (false
                (record
                  (first (get acc first))
                  (second (Cons ProtossDepNode node (get acc second))))))))))))

(def Protoss.depSortStep (-> ProtossDepSortState ProtossDepSortState)
  (lambda (state ProtossDepSortState)
    (caseList (get state remaining)
      (Nil state)
      (Cons first rest
        (let (partition (Pair (List String) (List ProtossDepNode))
          ((Protoss.depPartitionReady (get state ordered)) (get state remaining)))
          (caseList (get partition first)
            (Nil state)
            (Cons ready restReady
              (record
                (remaining (get partition second))
                (ordered (((inst List.append String) (get state ordered)) (get partition first)))))))))))

(def Protoss.termDependencyOrderDecls (-> (List ProtossDecl) ProtossDepOrder)
  (lambda (decls (List ProtossDecl))
    (let (nodes (List ProtossDepNode) (Protoss.declsTermDepNodes decls))
      (let (state ProtossDepSortState
        (foldNat ((inst List.length ProtossDepNode) nodes)
          (record
            (remaining nodes)
            (ordered (Nil String)))
          (lambda (acc ProtossDepSortState)
            (Protoss.depSortStep acc))))
        (caseList (get state remaining)
          (Nil (variant PDepOrderOk (get state ordered)))
          (Cons first rest (variant PDepOrderCycle (Protoss.depNodeNames (get state remaining)))))))))

(def Protoss.termDependencyOrderText (-> String (Result String ProtossDepOrder))
  (lambda (source String)
    (case (Protoss.parseText source)
      (Err err (variant Err err))
      (Ok decls (variant Ok (Protoss.termDependencyOrderDecls decls))))))

(def Protoss.declTypeDepNode (-> (List String) (-> ProtossDecl (Maybe ProtossDepNode)))
  (lambda (definedTypes (List String))
    (lambda (decl ProtossDecl)
      (case decl
        (PDRecord recordDecl
          (variant Some
            (record
              (name (get recordDecl name))
              (deps ((Protoss.nameSetIntersect (Protoss.declTypeNames decl)) definedTypes)))))
        (PDType typeDecl
          (variant Some
            (record
              (name (get typeDecl name))
              (deps ((Protoss.nameSetIntersect (Protoss.declTypeNames decl)) definedTypes)))))
        (PDVariant variantDecl
          (variant Some
            (record
              (name (get variantDecl name))
              (deps
                ((Protoss.nameSetRemove (get variantDecl name))
                  ((Protoss.nameSetIntersect (Protoss.declTypeNames decl)) definedTypes))))))
        (_ (variant None unit))))))

(def Protoss.declsTypeDepNodes (-> (List ProtossDecl) (List ProtossDepNode))
  (lambda (decls (List ProtossDecl))
    (let (definedTypes (List String) (Protoss.declsDefinedTypeNames decls))
      (foldList decls (Nil ProtossDepNode)
        (lambda (decl ProtossDecl)
          (lambda (acc (List ProtossDepNode))
            (case ((Protoss.declTypeDepNode definedTypes) decl)
              (None _ acc)
              (Some node (Cons ProtossDepNode node acc)))))))))

(def Protoss.typeDependencyOrderDecls (-> (List ProtossDecl) ProtossDepOrder)
  (lambda (decls (List ProtossDecl))
    (let (nodes (List ProtossDepNode) (Protoss.declsTypeDepNodes decls))
      (let (state ProtossDepSortState
        (foldNat ((inst List.length ProtossDepNode) nodes)
          (record
            (remaining nodes)
            (ordered (Nil String)))
          (lambda (acc ProtossDepSortState)
            (Protoss.depSortStep acc))))
        (caseList (get state remaining)
          (Nil (variant PDepOrderOk (get state ordered)))
          (Cons first rest (variant PDepOrderCycle (Protoss.depNodeNames (get state remaining)))))))))

(def Protoss.typeDependencyOrderText (-> String (Result String ProtossDepOrder))
  (lambda (source String)
    (case (Protoss.parseText source)
      (Err err (variant Err err))
      (Ok decls (variant Ok (Protoss.typeDependencyOrderDecls decls))))))

(def Protoss.qualifyName (-> String (-> String String))
  (lambda (owner String)
    (lambda (name String)
      ((String.concat ((String.concat owner) ".")) name))))

(def Protoss.qualifyNames (-> String (-> (List String) (List String)))
  (lambda (owner String)
    (lambda (names (List String))
      (((inst List.map String String) names)
        (lambda (name String)
          ((Protoss.qualifyName owner) name))))))

(def Protoss.recordFieldNames (-> ProtossRecordDecl (List String))
  (lambda (recordDecl ProtossRecordDecl)
    (((inst List.map ProtossField String) (get recordDecl fields))
      (lambda (field ProtossField)
        (get field name)))))

(def Protoss.variantCaseNames (-> ProtossVariantDecl (List String))
  (lambda (variantDecl ProtossVariantDecl)
    (((inst List.map ProtossVariantCase String) (get variantDecl cases))
      (lambda (caseDecl ProtossVariantCase)
        (get caseDecl name)))))

(def Protoss.declDuplicateTypeParams (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDefPoly def
        (Protoss.nameSetDuplicates (get def typeParams)))
      (PDDefPolyCap def
        (Protoss.nameSetDuplicates (get def typeParams)))
      (PDDefRec def
        (Protoss.nameSetDuplicates (get def typeParams)))
      (PDRecord recordDecl
        ((Protoss.qualifyNames (get recordDecl name))
          (Protoss.nameSetDuplicates (get recordDecl typeParams))))
      (PDType typeDecl
        ((Protoss.qualifyNames (get typeDecl name))
          (Protoss.nameSetDuplicates (get typeDecl typeParams))))
      (PDVariant variantDecl
        ((Protoss.qualifyNames (get variantDecl name))
          (Protoss.nameSetDuplicates (get variantDecl typeParams))))
      (_ (Nil String)))))

(def Protoss.declsDuplicateTypeParams (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          ((Protoss.nameSetUnion (Protoss.declDuplicateTypeParams decl)) acc))))))

(def Protoss.declDuplicateRecordFields (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDRecord recordDecl
        ((Protoss.qualifyNames (get recordDecl name))
          (Protoss.nameSetDuplicates (Protoss.recordFieldNames recordDecl))))
      (_ (Nil String)))))

(def Protoss.declsDuplicateRecordFields (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          ((Protoss.nameSetUnion (Protoss.declDuplicateRecordFields decl)) acc))))))

(def Protoss.declDuplicateVariantCases (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDVariant variantDecl
        ((Protoss.qualifyNames (get variantDecl name))
          (Protoss.nameSetDuplicates (Protoss.variantCaseNames variantDecl))))
      (_ (Nil String)))))

(def Protoss.declsDuplicateVariantCases (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          ((Protoss.nameSetUnion (Protoss.declDuplicateVariantCases decl)) acc))))))

(def Protoss.typeEnvEntry (-> (List String) (-> ProtossDecl (Maybe ProtossTypeEnvEntry)))
  (lambda (definedTypes (List String))
    (lambda (decl ProtossDecl)
      (case decl
        (PDRecord recordDecl
          (variant Some
            (record
              (name (get recordDecl name))
              (kind "record")
              (arity ((inst List.length String) (get recordDecl typeParams)))
              (deps ((Protoss.nameSetIntersect (Protoss.declTypeNames decl)) definedTypes)))))
        (PDType typeDecl
          (variant Some
            (record
              (name (get typeDecl name))
              (kind "alias")
              (arity ((inst List.length String) (get typeDecl typeParams)))
              (deps ((Protoss.nameSetIntersect (Protoss.declTypeNames decl)) definedTypes)))))
        (PDVariant variantDecl
          (variant Some
            (record
              (name (get variantDecl name))
              (kind "variant")
              (arity ((inst List.length String) (get variantDecl typeParams)))
              (deps
                ((Protoss.nameSetRemove (get variantDecl name))
                  ((Protoss.nameSetIntersect (Protoss.declTypeNames decl)) definedTypes))))))
        (_ (variant None unit))))))

(def Protoss.declsTypeEnvEntries (-> (List ProtossDecl) (List ProtossTypeEnvEntry))
  (lambda (decls (List ProtossDecl))
    (let (definedTypes (List String) (Protoss.declsDefinedTypeNames decls))
      (foldList decls (Nil ProtossTypeEnvEntry)
        (lambda (decl ProtossDecl)
          (lambda (acc (List ProtossTypeEnvEntry))
            (case ((Protoss.typeEnvEntry definedTypes) decl)
              (None _ acc)
              (Some entry (Cons ProtossTypeEnvEntry entry acc)))))))))

(def Protoss.typeArityUseOf (-> String (-> Nat ProtossTypeArityUse))
  (lambda (name String)
    (lambda (actual Nat)
      (record (name name) (actual actual)))))

(defrec Protoss.typeArityUses (-> ProtossType (List ProtossTypeArityUse))
  (variant typ)
  (PTName name
    (Cons ProtossTypeArityUse ((Protoss.typeArityUseOf name) 0) (Nil ProtossTypeArityUse)))
  (PTFun pair
    (((inst List.append ProtossTypeArityUse) (recur (get pair first)))
      (recur (get pair second))))
  (PTApply app
    (Cons ProtossTypeArityUse
      ((Protoss.typeArityUseOf (get app name)) ((inst List.length ProtossType) (get app args)))
      (foldList (get app args) (Nil ProtossTypeArityUse)
        (lambda (arg ProtossType)
          (lambda (acc (List ProtossTypeArityUse))
            (((inst List.append ProtossTypeArityUse) (recur arg)) acc)))))))

(def Protoss.typeArityUsesMaybe (-> (Maybe ProtossType) (List ProtossTypeArityUse))
  (lambda (maybeType (Maybe ProtossType))
    (case maybeType
      (None _ (Nil ProtossTypeArityUse))
      (Some typ (Protoss.typeArityUses typ)))))

(defrec Protoss.exprTypeArityUses (-> ProtossExpr (List ProtossTypeArityUse))
  (variant expr)
  (PEApply call
    (((inst List.append ProtossTypeArityUse) (recur (get call fn)))
      (foldList (get call args) (Nil ProtossTypeArityUse)
        (lambda (arg ProtossExpr)
          (lambda (acc (List ProtossTypeArityUse))
            (((inst List.append ProtossTypeArityUse) (recur arg)) acc))))))
  (PEBind bindExpr
    (((inst List.append ProtossTypeArityUse) (recur (get bindExpr process)))
      (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get bindExpr typ)))
        (recur (get bindExpr body)))))
  (PEBool value
    (Nil ProtossTypeArityUse))
  (PECase caseExpr
    (((inst List.append ProtossTypeArityUse) (recur (get caseExpr scrutinee)))
      (foldList (get caseExpr branches) (Nil ProtossTypeArityUse)
        (lambda (branch ProtossCaseBranch)
          (lambda (acc (List ProtossTypeArityUse))
            (((inst List.append ProtossTypeArityUse) (recur (get branch body))) acc))))))
  (PECaseList caseListExpr
    (((inst List.append ProtossTypeArityUse) (recur (get caseListExpr target)))
      (((inst List.append ProtossTypeArityUse) (recur (get caseListExpr nilBody)))
        (recur (get caseListExpr consBody)))))
  (PEDone value
    (recur value))
  (PEField fieldExpr
    (recur (get fieldExpr target)))
  (PEFoldNat foldNatExpr
    (((inst List.append ProtossTypeArityUse) (recur (get foldNatExpr target)))
      (((inst List.append ProtossTypeArityUse) (recur (get foldNatExpr zero)))
        (recur (get foldNatExpr step)))))
  (PEFoldVariant foldVariantExpr
    (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get foldVariantExpr target)))
      (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get foldVariantExpr result)))
        (((inst List.append ProtossTypeArityUse) (recur (get foldVariantExpr scrutinee)))
          (foldList (get foldVariantExpr branches) (Nil ProtossTypeArityUse)
            (lambda (branch ProtossCaseBranch)
              (lambda (acc (List ProtossTypeArityUse))
                (((inst List.append ProtossTypeArityUse) (recur (get branch body))) acc))))))))
  (PEFoldList foldListExpr
    (((inst List.append ProtossTypeArityUse) (recur (get foldListExpr target)))
      (((inst List.append ProtossTypeArityUse) (recur (get foldListExpr zero)))
        (recur (get foldListExpr step)))))
  (PEInst instExpr
    (foldList (get instExpr typeArgs) (Nil ProtossTypeArityUse)
      (lambda (typ ProtossType)
        (lambda (acc (List ProtossTypeArityUse))
          (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses typ)) acc)))))
  (PELambda lam
    (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get (get lam param) typ)))
      (recur (get lam body))))
  (PELet letExpr
    (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUsesMaybe (get letExpr typ)))
      (((inst List.append ProtossTypeArityUse) (recur (get letExpr value)))
        (recur (get letExpr body)))))
  (PECons consExpr
    (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUsesMaybe (get consExpr typ)))
      (((inst List.append ProtossTypeArityUse) (recur (get consExpr head)))
        (recur (get consExpr tail)))))
  (PENil nilExpr
    (Protoss.typeArityUsesMaybe (get nilExpr typ)))
  (PERecord fields
    (foldList fields (Nil ProtossTypeArityUse)
      (lambda (field ProtossRecordFieldExpr)
        (lambda (acc (List ProtossTypeArityUse))
          (((inst List.append ProtossTypeArityUse) (recur (get field expr))) acc)))))
  (PERecur value
    (recur value))
  (PERequest request
    (Nil ProtossTypeArityUse))
  (PEString value
    (Nil ProtossTypeArityUse))
  (PEUnit
    (Nil ProtossTypeArityUse))
  (PEVariant variantExpr
    (((inst List.append ProtossTypeArityUse)
      (Protoss.typeArityUsesMaybe (get variantExpr typeHint)))
      (recur (get variantExpr payload))))
  (PEVar name
    (Nil ProtossTypeArityUse)))

(def Protoss.defRecBodyTypeArityUses (-> ProtossDefRecBody (List ProtossTypeArityUse))
  (lambda (body ProtossDefRecBody)
    (case body
      (PDRNat nat
        (((inst List.append ProtossTypeArityUse) (Protoss.exprTypeArityUses (get nat zero)))
          (Protoss.exprTypeArityUses (get nat step))))
      (PDRList listRec
        (((inst List.append ProtossTypeArityUse) (Protoss.exprTypeArityUses (get listRec nil)))
          (Protoss.exprTypeArityUses (get listRec step))))
      (PDRVariant variantRec
        (foldList (get variantRec branches) (Nil ProtossTypeArityUse)
          (lambda (branch ProtossCaseBranch)
            (lambda (acc (List ProtossTypeArityUse))
              (((inst List.append ProtossTypeArityUse)
                (Protoss.exprTypeArityUses (get branch body)))
                acc))))))))

(def Protoss.declTypeArityUses (-> ProtossDecl (List ProtossTypeArityUse))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDef def
        (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get def typ)))
          (Protoss.exprTypeArityUses (get def expr))))
      (PDDefCap def
        (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get def typ)))
          (Protoss.exprTypeArityUses (get def expr))))
      (PDDefPoly def
        (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get def typ)))
          (Protoss.exprTypeArityUses (get def expr))))
      (PDDefPolyCap def
        (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get def typ)))
          (Protoss.exprTypeArityUses (get def expr))))
      (PDDefRec def
        (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get def typ)))
          (Protoss.defRecBodyTypeArityUses (get def body))))
      (PDRecord recordDecl
        (foldList (get recordDecl fields) (Nil ProtossTypeArityUse)
          (lambda (field ProtossField)
            (lambda (acc (List ProtossTypeArityUse))
              (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get field typ))) acc)))))
      (PDType typeDecl
        (Protoss.typeArityUses (get typeDecl body)))
      (PDVariant variantDecl
        (foldList (get variantDecl cases) (Nil ProtossTypeArityUse)
          (lambda (caseDecl ProtossVariantCase)
            (lambda (acc (List ProtossTypeArityUse))
              (((inst List.append ProtossTypeArityUse) (Protoss.typeArityUses (get caseDecl payload))) acc)))))
      (_ (Nil ProtossTypeArityUse)))))

(def Protoss.declTypeParams (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDefPoly def (get def typeParams))
      (PDDefPolyCap def (get def typeParams))
      (PDDefRec def (get def typeParams))
      (PDRecord recordDecl (get recordDecl typeParams))
      (PDType typeDecl (get typeDecl typeParams))
      (PDVariant variantDecl (get variantDecl typeParams))
      (_ (Nil String)))))

(def Protoss.builtinTypeArity (-> String (Maybe Nat))
  (lambda (name String)
    (case ((String.eqString name) "Unit")
      (true (variant Some 0))
      (false
        (case ((String.eqString name) "Bool")
          (true (variant Some 0))
          (false
            (case ((String.eqString name) "Nat")
              (true (variant Some 0))
              (false
                (case ((String.eqString name) "String")
                  (true (variant Some 0))
                  (false
                    (case ((String.eqString name) "List")
                      (true (variant Some 1))
                      (false
                        (case ((String.eqString name) "Process")
                          (true (variant Some 1))
                          (false
                            (case ((String.eqString name) "View")
                              (true (variant Some 1))
                              (false (variant None unit)))))))))))))))))

(def Protoss.typeEnvEntryByName
  (-> String (-> (List ProtossTypeEnvEntry) (Maybe ProtossTypeEnvEntry)))
  (lambda (name String)
    (lambda (entries (List ProtossTypeEnvEntry))
      (((inst List.find ProtossTypeEnvEntry) entries)
        (lambda (entry ProtossTypeEnvEntry)
          ((String.eqString (get entry name)) name))))))

(def Protoss.expectedTypeArity
  (-> (List ProtossTypeEnvEntry) (-> (List String) (-> (List String) (-> String (Maybe Nat)))))
  (lambda (entries (List ProtossTypeEnvEntry))
    (lambda (externalTypes (List String))
      (lambda (bound (List String))
        (lambda (name String)
          (case ((Protoss.nameSetContains name) bound)
            (true (variant Some 0))
            (false
              (case ((Protoss.typeEnvEntryByName name) entries)
                (Some entry (variant Some (get entry arity)))
                (None _
                  (case (Protoss.builtinTypeArity name)
                    (Some arity (variant Some arity))
                    (None _ (variant None unit))))))))))))

(def Protoss.typeArityIssueFromUse
  (-> (List ProtossTypeEnvEntry) (-> (List String) (-> (List String) (-> ProtossTypeArityUse (Maybe ProtossTypeArityIssue)))))
  (lambda (entries (List ProtossTypeEnvEntry))
    (lambda (externalTypes (List String))
      (lambda (bound (List String))
        (lambda (use ProtossTypeArityUse)
          (case ((((Protoss.expectedTypeArity entries) externalTypes) bound) (get use name))
            (None _ (variant None unit))
            (Some expected
              (case ((Nat.eqNat expected) (get use actual))
                (true (variant None unit))
                (false
                  (variant Some
                    (record
                      (name (get use name))
                      (expected expected)
                      (actual (get use actual)))))))))))))

(def Protoss.typeArityIssuesFromUses
  (-> (List ProtossTypeEnvEntry) (-> (List String) (-> (List String) (-> (List ProtossTypeArityUse) (List ProtossTypeArityIssue)))))
  (lambda (entries (List ProtossTypeEnvEntry))
    (lambda (externalTypes (List String))
      (lambda (bound (List String))
        (lambda (uses (List ProtossTypeArityUse))
          (foldList uses (Nil ProtossTypeArityIssue)
            (lambda (use ProtossTypeArityUse)
              (lambda (acc (List ProtossTypeArityIssue))
                (case ((((Protoss.typeArityIssueFromUse entries) externalTypes) bound) use)
                  (None _ acc)
                  (Some issue (Cons ProtossTypeArityIssue issue acc)))))))))))

(def Protoss.declTypeArityIssuesWith
  (-> (List ProtossTypeEnvEntry) (-> (List String) (-> ProtossDecl (List ProtossTypeArityIssue))))
  (lambda (entries (List ProtossTypeEnvEntry))
    (lambda (externalTypes (List String))
      (lambda (decl ProtossDecl)
        ((((Protoss.typeArityIssuesFromUses entries) externalTypes) (Protoss.declTypeParams decl))
          (Protoss.declTypeArityUses decl))))))

(def Protoss.declsTypeArityIssuesWith
  (-> (List ProtossTypeEnvEntry) (-> (List String) (-> (List ProtossDecl) (List ProtossTypeArityIssue))))
  (lambda (entries (List ProtossTypeEnvEntry))
    (lambda (externalTypes (List String))
      (lambda (decls (List ProtossDecl))
        (foldList decls (Nil ProtossTypeArityIssue)
          (lambda (decl ProtossDecl)
            (lambda (acc (List ProtossTypeArityIssue))
              (((inst List.append ProtossTypeArityIssue)
                (((Protoss.declTypeArityIssuesWith entries) externalTypes) decl))
                acc))))))))

(def Protoss.typeEnvReportDeclsWith
  (-> (List String) (-> (List ProtossDecl) ProtossTypeEnvReport))
  (lambda (externalTypes (List String))
    (lambda (decls (List ProtossDecl))
      (let (resolve ProtossResolveReport (((Protoss.resolveDeclsWith (Nil String)) externalTypes) decls))
        (let (entries (List ProtossTypeEnvEntry) (Protoss.declsTypeEnvEntries decls))
        (record
          (entries entries)
          (order (Protoss.typeDependencyOrderDecls decls))
          (missingTypes (get resolve missingTypes))
          (duplicateTypes (get resolve duplicateTypes))
          (duplicateTypeParams (Protoss.declsDuplicateTypeParams decls))
          (duplicateRecordFields (Protoss.declsDuplicateRecordFields decls))
          (duplicateVariantCases (Protoss.declsDuplicateVariantCases decls))
          (typeArityIssues (((Protoss.declsTypeArityIssuesWith entries) externalTypes) decls))))))))

(def Protoss.typeEnvReportDecls (-> (List ProtossDecl) ProtossTypeEnvReport)
  (lambda (decls (List ProtossDecl))
    ((Protoss.typeEnvReportDeclsWith (Nil String)) decls)))

(def Protoss.typeEnvReportTextWith
  (-> (List String) (-> String (Result String ProtossTypeEnvReport)))
  (lambda (externalTypes (List String))
    (lambda (source String)
      (case (Protoss.parseText source)
        (Err err (variant Err err))
        (Ok decls (variant Ok ((Protoss.typeEnvReportDeclsWith externalTypes) decls)))))))

(def Protoss.typeEnvReportText (-> String (Result String ProtossTypeEnvReport))
  (lambda (source String)
    ((Protoss.typeEnvReportTextWith (Nil String)) source)))

(def Protoss.typeArityIssueMessage (-> ProtossTypeArityIssue String)
  (lambda (issue ProtossTypeArityIssue)
    ((String.concat "wrong type arity: ")
      ((String.concat (get issue name))
        ((String.concat " expected ")
          ((String.concat (Nat.toString (get issue expected)))
            ((String.concat " got ") (Nat.toString (get issue actual)))))))))

(def Protoss.typeEnvFirstError (-> ProtossTypeEnvReport (Maybe String))
  (lambda (report ProtossTypeEnvReport)
    (caseList (get report duplicateTypes)
      (Nil
        (caseList (get report duplicateTypeParams)
          (Nil
            (caseList (get report duplicateRecordFields)
              (Nil
                (caseList (get report duplicateVariantCases)
                  (Nil
                    (caseList (get report missingTypes)
                      (Nil
                        (caseList (get report typeArityIssues)
                          (Nil
                            (case (get report order)
                              (PDepOrderOk ordered (variant None unit))
                              (PDepOrderCycle names
                                (variant Some
                                  ((String.concat "cyclic type dependency: ") ((String.join ",") names))))))
                          (Cons first rest (variant Some (Protoss.typeArityIssueMessage first)))))
                      (Cons first rest (variant Some ((String.concat "missing type: ") first)))))
                  (Cons first rest (variant Some ((String.concat "duplicate variant case: ") first)))))
              (Cons first rest (variant Some ((String.concat "duplicate record field: ") first)))))
          (Cons first rest (variant Some ((String.concat "duplicate type parameter: ") first)))))
      (Cons first rest (variant Some ((String.concat "duplicate type: ") first))))))

(def Protoss.checkTypeEnvDeclsWith
  (-> (List String) (-> (List ProtossDecl) (Result String ProtossTypeEnvReport)))
  (lambda (externalTypes (List String))
    (lambda (decls (List ProtossDecl))
      (let (report ProtossTypeEnvReport ((Protoss.typeEnvReportDeclsWith externalTypes) decls))
        (case (Protoss.typeEnvFirstError report)
          (None _ (variant Ok report))
          (Some err (variant Err err)))))))

(def Protoss.checkTypeEnvDecls (-> (List ProtossDecl) (Result String ProtossTypeEnvReport))
  (lambda (decls (List ProtossDecl))
    ((Protoss.checkTypeEnvDeclsWith (Nil String)) decls)))

(def Protoss.checkTypeEnvTextWith
  (-> (List String) (-> String (Result String ProtossTypeEnvReport)))
  (lambda (externalTypes (List String))
    (lambda (source String)
      (case (Protoss.parseText source)
        (Err err (variant Err err))
        (Ok decls ((Protoss.checkTypeEnvDeclsWith externalTypes) decls))))))

(def Protoss.checkTypeEnvText (-> String (Result String ProtossTypeEnvReport))
  (lambda (source String)
    ((Protoss.checkTypeEnvTextWith (Nil String)) source)))

(def Protoss.capabilityCatalog (List String)
  (Cons String "Human.ask"
    (Cons String "Http.get"
      (Cons String "Clock.read"
        (Cons String "Local.storage"
          (Cons String "Server.request"
            (Nil String)))))))

(def Protoss.requestCapability (-> ProtossRequest String)
  (lambda (request ProtossRequest)
    (case request
      (PRAskHuman prompt "Human.ask")
      (PRHttpGet url "Http.get")
      (PRClockRead _ "Clock.read")
      (PRSaveLocal save "Local.storage")
      (PRLoadLocal key "Local.storage")
      (PRServerRequest payload "Server.request"))))

(defrec Protoss.exprCapabilities (-> ProtossExpr (List String))
  (variant expr)
  (PEApply call
    ((Protoss.nameSetUnion (recur (get call fn)))
      (foldList (get call args) (Nil String)
        (lambda (arg ProtossExpr)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion (recur arg)) acc))))))
  (PEBind bindExpr
    ((Protoss.nameSetUnion (recur (get bindExpr process)))
      ((Protoss.nameSetRemove (get bindExpr param)) (recur (get bindExpr body)))))
  (PEBool value
    (Nil String))
  (PECase caseExpr
    ((Protoss.nameSetUnion (recur (get caseExpr scrutinee)))
      (foldList (get caseExpr branches) (Nil String)
        (lambda (branch ProtossCaseBranch)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion
              (case (get branch binder)
                (None _ (recur (get branch body)))
                (Some name ((Protoss.nameSetRemove name) (recur (get branch body))))))
              acc))))))
  (PECaseList caseListExpr
    ((Protoss.nameSetUnion (recur (get caseListExpr target)))
      ((Protoss.nameSetUnion (recur (get caseListExpr nilBody)))
        ((Protoss.nameSetRemoveMany
          (Cons String (get caseListExpr head)
            (Cons String (get caseListExpr tail)
              (Nil String))))
          (recur (get caseListExpr consBody))))))
  (PEDone value
    (recur value))
  (PEField fieldExpr
    (recur (get fieldExpr target)))
  (PEFoldNat foldNatExpr
    ((Protoss.nameSetUnion (recur (get foldNatExpr target)))
      ((Protoss.nameSetUnion (recur (get foldNatExpr zero)))
        (recur (get foldNatExpr step)))))
  (PEFoldVariant foldVariantExpr
    ((Protoss.nameSetUnion (recur (get foldVariantExpr scrutinee)))
      (foldList (get foldVariantExpr branches) (Nil String)
        (lambda (branch ProtossCaseBranch)
          (lambda (acc (List String))
            ((Protoss.nameSetUnion
              (case (get branch binder)
                (None _ (recur (get branch body)))
                (Some name ((Protoss.nameSetRemove name) (recur (get branch body))))))
              acc))))))
  (PEFoldList foldListExpr
    ((Protoss.nameSetUnion (recur (get foldListExpr target)))
      ((Protoss.nameSetUnion (recur (get foldListExpr zero)))
        (recur (get foldListExpr step)))))
  (PEInst instExpr
    (Nil String))
  (PELambda lam
    ((Protoss.nameSetRemove (get (get lam param) name))
      (recur (get lam body))))
  (PELet letExpr
    ((Protoss.nameSetUnion (recur (get letExpr value)))
      ((Protoss.nameSetRemove (get letExpr name))
        (recur (get letExpr body)))))
  (PECons consExpr
    ((Protoss.nameSetUnion (recur (get consExpr head)))
      (recur (get consExpr tail))))
  (PENil nilExpr
    (Nil String))
  (PERecord fields
    (foldList fields (Nil String)
      (lambda (field ProtossRecordFieldExpr)
        (lambda (acc (List String))
            ((Protoss.nameSetUnion (recur (get field expr))) acc)))))
  (PERecur value
    (recur value))
  (PERequest request
    (Cons String (Protoss.requestCapability request) (Nil String)))
  (PEString value
    (Nil String))
  (PEUnit
    (Nil String))
  (PEVariant variantExpr
    (recur (get variantExpr payload)))
  (PEVar name
    (Nil String)))

(def Protoss.defRecBodyCapabilities (-> ProtossDefRecBody (List String))
  (lambda (body ProtossDefRecBody)
    (case body
      (PDRNat nat
        ((Protoss.nameSetUnion (Protoss.exprCapabilities (get nat zero)))
          (Protoss.exprCapabilities (get nat step))))
      (PDRList listRec
        ((Protoss.nameSetUnion (Protoss.exprCapabilities (get listRec nil)))
          (Protoss.exprCapabilities (get listRec step))))
      (PDRVariant variantRec
        (foldList (get variantRec branches) (Nil String)
          (lambda (branch ProtossCaseBranch)
            (lambda (acc (List String))
              ((Protoss.nameSetUnion (Protoss.exprCapabilities (get branch body))) acc))))))))

(def Protoss.declCapabilities (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDCapabilities caps caps)
      (_ (Nil String)))))

(def Protoss.declScopedCapabilities (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDefCap def (get def capabilities))
      (PDDefPolyCap def (get def capabilities))
      (_ (Nil String)))))

(def Protoss.declUsedCapabilities (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDef def (Protoss.exprCapabilities (get def expr)))
      (PDDefCap def (Protoss.exprCapabilities (get def expr)))
      (PDDefPoly def (Protoss.exprCapabilities (get def expr)))
      (PDDefPolyCap def (Protoss.exprCapabilities (get def expr)))
      (PDDefRec def (Protoss.defRecBodyCapabilities (get def body)))
      (_ (Nil String)))))

(def Protoss.declDuplicateScopeCapabilities (-> ProtossDecl (List String))
  (lambda (decl ProtossDecl)
    (case decl
      (PDDefCap def
        (((inst List.map String String)
          (Protoss.nameSetDuplicates (get def capabilities)))
          (Protoss.qualifyName (get def name))))
      (PDDefPolyCap def
        (((inst List.map String String)
          (Protoss.nameSetDuplicates (get def capabilities)))
          (Protoss.qualifyName (get def name))))
      (_ (Nil String)))))

(def Protoss.declsCapabilities (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (Protoss.nameSetUnique
      (foldList decls (Nil String)
        (lambda (decl ProtossDecl)
          (lambda (acc (List String))
            (((inst List.append String) (Protoss.declCapabilities decl)) acc)))))))

(def Protoss.declsRawCapabilities (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          (((inst List.append String) (Protoss.declCapabilities decl)) acc))))))

(def Protoss.declsScopedCapabilities (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (Protoss.nameSetUnique
      (foldList decls (Nil String)
        (lambda (decl ProtossDecl)
          (lambda (acc (List String))
            (((inst List.append String) (Protoss.declScopedCapabilities decl)) acc)))))))

(def Protoss.declsUsedCapabilities (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (Protoss.nameSetUnique
      (foldList decls (Nil String)
        (lambda (decl ProtossDecl)
          (lambda (acc (List String))
            (((inst List.append String) (Protoss.declUsedCapabilities decl)) acc)))))))

(def Protoss.declsDuplicateScopeCapabilities (-> (List ProtossDecl) (List String))
  (lambda (decls (List ProtossDecl))
    (foldList decls (Nil String)
      (lambda (decl ProtossDecl)
        (lambda (acc (List String))
          (((inst List.append String) (Protoss.declDuplicateScopeCapabilities decl)) acc))))))

(def Protoss.capabilityReportDecls (-> (List ProtossDecl) ProtossCapabilityReport)
  (lambda (decls (List ProtossDecl))
    (let (declared (List String) (Protoss.declsCapabilities decls))
      (let (used (List String) (Protoss.declsUsedCapabilities decls))
        (let (scoped (List String) (Protoss.declsScopedCapabilities decls))
          (let (mentioned (List String)
            ((Protoss.nameSetUnion declared) ((Protoss.nameSetUnion used) scoped)))
            (record
              (declared declared)
              (used used)
              (scoped scoped)
              (unknownCapabilities
                ((Protoss.nameSetMissingFrom mentioned) Protoss.capabilityCatalog))
              (missingDeclarations
                ((Protoss.nameSetMissingFrom ((Protoss.nameSetUnion used) scoped)) declared))
              (duplicateDeclarations
                (Protoss.nameSetDuplicates (Protoss.declsRawCapabilities decls)))
              (duplicateScopes
                (Protoss.declsDuplicateScopeCapabilities decls)))))))))

(def Protoss.capabilityReportText (-> String (Result String ProtossCapabilityReport))
  (lambda (source String)
    (case (Protoss.parseText source)
      (Err err (variant Err err))
      (Ok decls (variant Ok (Protoss.capabilityReportDecls decls))))))

(def Protoss.capabilityFirstError (-> ProtossCapabilityReport (Maybe String))
  (lambda (report ProtossCapabilityReport)
    (caseList (get report unknownCapabilities)
      (Nil
        (caseList (get report duplicateDeclarations)
          (Nil
            (caseList (get report duplicateScopes)
              (Nil
                (caseList (get report missingDeclarations)
                  (Nil (variant None unit))
                  (Cons first rest
                    (variant Some ((String.concat "missing capability declaration: ") first)))))
              (Cons first rest
                (variant Some ((String.concat "duplicate scoped capability: ") first)))))
          (Cons first rest
            (variant Some ((String.concat "duplicate capability declaration: ") first)))))
      (Cons first rest
        (variant Some ((String.concat "unknown capability: ") first))))))

(def Protoss.checkCapabilityDecls (-> (List ProtossDecl) (Result String ProtossCapabilityReport))
  (lambda (decls (List ProtossDecl))
    (let (report ProtossCapabilityReport (Protoss.capabilityReportDecls decls))
      (case (Protoss.capabilityFirstError report)
        (None _ (variant Ok report))
        (Some err (variant Err err))))))

(def Protoss.checkCapabilityText (-> String (Result String ProtossCapabilityReport))
  (lambda (source String)
    (case (Protoss.parseText source)
      (Err err (variant Err err))
      (Ok decls (Protoss.checkCapabilityDecls decls)))))

(def Protoss.resolveFirstError (-> ProtossResolveReport (Maybe String))
  (lambda (report ProtossResolveReport)
    (caseList (get report duplicateTerms)
      (Nil
        (caseList (get report duplicateTypes)
          (Nil
            (caseList (get report missingTerms)
              (Nil
                (caseList (get report missingTypes)
                  (Nil
                    (caseList (get report missingExports)
                      (Nil (variant None unit))
                      (Cons first rest
                        (variant Some ((String.concat "missing export: ") first)))))
                  (Cons first rest
                    (variant Some ((String.concat "missing type: ") first)))))
              (Cons first rest
                (variant Some ((String.concat "missing term: ") first)))))
          (Cons first rest
            (variant Some ((String.concat "duplicate type: ") first)))))
      (Cons first rest
        (variant Some ((String.concat "duplicate term: ") first))))))

(def Protoss.depOrderFirstError (-> String (-> ProtossDepOrder (Maybe String)))
  (lambda (kind String)
    (lambda (order ProtossDepOrder)
      (case order
        (PDepOrderOk names (variant None unit))
        (PDepOrderCycle names
          (variant Some
            ((String.concat "cyclic ")
              ((String.concat kind)
                ((String.concat " dependency: ") ((String.join ",") names))))))))))

(def Protoss.staticReportDeclsWith
  (-> (List String) (-> (List String) (-> (List ProtossDecl) ProtossStaticReport)))
  (lambda (externalTerms (List String))
    (lambda (externalTypes (List String))
      (lambda (decls (List ProtossDecl))
        (record
          (resolve (((Protoss.resolveDeclsWith externalTerms) externalTypes) decls))
          (termOrder (Protoss.termDependencyOrderDecls decls))
          (typeEnv ((Protoss.typeEnvReportDeclsWith externalTypes) decls))
          (capabilities (Protoss.capabilityReportDecls decls)))))))

(def Protoss.staticReportDecls (-> (List ProtossDecl) ProtossStaticReport)
  (lambda (decls (List ProtossDecl))
    (((Protoss.staticReportDeclsWith (Nil String)) (Nil String)) decls)))

(def Protoss.staticReportTextWith
  (-> (List String) (-> (List String) (-> String (Result String ProtossStaticReport))))
  (lambda (externalTerms (List String))
    (lambda (externalTypes (List String))
      (lambda (source String)
        (case (Protoss.parseText source)
          (Err err (variant Err err))
          (Ok decls
            (variant Ok (((Protoss.staticReportDeclsWith externalTerms) externalTypes) decls))))))))

(def Protoss.staticReportText (-> String (Result String ProtossStaticReport))
  (lambda (source String)
    (((Protoss.staticReportTextWith (Nil String)) (Nil String)) source)))

(def Protoss.staticFirstError (-> ProtossStaticReport (Maybe String))
  (lambda (report ProtossStaticReport)
    (case (Protoss.resolveFirstError (get report resolve))
      (Some err (variant Some err))
      (None _
        (case ((Protoss.depOrderFirstError "term") (get report termOrder))
          (Some err (variant Some err))
          (None _
            (case (Protoss.typeEnvFirstError (get report typeEnv))
              (Some err (variant Some err))
              (None _
                (Protoss.capabilityFirstError (get report capabilities))))))))))

(def Protoss.checkStaticDeclsWith
  (-> (List String) (-> (List String) (-> (List ProtossDecl) (Result String ProtossStaticReport))))
  (lambda (externalTerms (List String))
    (lambda (externalTypes (List String))
      (lambda (decls (List ProtossDecl))
        (let (report ProtossStaticReport (((Protoss.staticReportDeclsWith externalTerms) externalTypes) decls))
          (case (Protoss.staticFirstError report)
            (None _ (variant Ok report))
            (Some err (variant Err err))))))))

(def Protoss.checkStaticDecls (-> (List ProtossDecl) (Result String ProtossStaticReport))
  (lambda (decls (List ProtossDecl))
    (((Protoss.checkStaticDeclsWith (Nil String)) (Nil String)) decls)))

(def Protoss.checkStaticTextWith
  (-> (List String) (-> (List String) (-> String (Result String ProtossStaticReport))))
  (lambda (externalTerms (List String))
    (lambda (externalTypes (List String))
      (lambda (source String)
        (case (Protoss.parseText source)
          (Err err (variant Err err))
          (Ok decls (((Protoss.checkStaticDeclsWith externalTerms) externalTypes) decls)))))))

(def Protoss.checkStaticText (-> String (Result String ProtossStaticReport))
  (lambda (source String)
    (((Protoss.checkStaticTextWith (Nil String)) (Nil String)) source)))

;; Self-hosted typechecker -------------------------------------------------
;; This is a reporting checker for the supported self-hosting subset. The
;; trusted OCaml kernel remains authoritative for canonicalization and safety.

(def Protoss.tcTypeName (-> String TypeExpr)
  (lambda (name String)
    (variant PTName name)))

(def Protoss.tcUnit TypeExpr (Protoss.tcTypeName "Unit"))
(def Protoss.tcBool TypeExpr (Protoss.tcTypeName "Bool"))
(def Protoss.tcNat TypeExpr (Protoss.tcTypeName "Nat"))
(def Protoss.tcString TypeExpr (Protoss.tcTypeName "String"))

(def Protoss.tcFun (-> TypeExpr (-> TypeExpr TypeExpr))
  (lambda (from TypeExpr)
    (lambda (to TypeExpr)
      (variant PTFun (record (first from) (second to))))))

(def Protoss.tcApplyType (-> String (-> (List TypeExpr) TypeExpr))
  (lambda (name String)
    (lambda (args (List TypeExpr))
      (variant PTApply (record (name name) (args args))))))

(def Protoss.tcList (-> TypeExpr TypeExpr)
  (lambda (item TypeExpr)
    ((Protoss.tcApplyType "List") (Cons TypeExpr item (Nil TypeExpr)))))

(def Protoss.tcProcess (-> TypeExpr TypeExpr)
  (lambda (item TypeExpr)
    ((Protoss.tcApplyType "Process") (Cons TypeExpr item (Nil TypeExpr)))))

(def Protoss.tcNoType (Maybe TypeExpr)
  (variant None unit))

(def Protoss.tcSomeType (-> TypeExpr (Maybe TypeExpr))
  (lambda (typ TypeExpr)
    (variant Some typ)))

(def Protoss.tcNoDef (Maybe String)
  (variant None unit))

(def Protoss.tcSomeDef (-> String (Maybe String))
  (lambda (name String)
    (variant Some name)))

(def TypecheckBoolCaseChecks.empty TypecheckBoolCaseChecks
  (record
    (trueCheck (variant (Maybe TypecheckExprChecker) None unit))
    (falseCheck (variant (Maybe TypecheckExprChecker) None unit))))

(def TypeEnv.empty TypeEnv
  (record
    (records (inst Assoc.empty String (List ProtossField)))
    (recordParams (inst Assoc.empty String (List String)))
    (variants (inst Assoc.empty String (List ProtossVariantCase)))
    (variantParams (inst Assoc.empty String (List String)))
    (aliases (inst Assoc.empty String TypeExpr))))

(def TermEnv.empty TermEnv
  (record
    (terms (inst Assoc.empty String TypeExpr))
    (polyTerms (inst Assoc.empty String TypeScheme))))

(def TypeEnv.lookupRecord (-> String (-> TypeEnv (Maybe (List ProtossField))))
  (lambda (name String)
    (lambda (env TypeEnv)
      ((((inst Assoc.get String (List ProtossField)) String.eqString) name)
        (get env records)))))

(def TypeEnv.lookupVariant
  (-> String (-> TypeEnv (Maybe (List ProtossVariantCase))))
  (lambda (name String)
    (lambda (env TypeEnv)
      ((((inst Assoc.get String (List ProtossVariantCase)) String.eqString) name)
        (get env variants)))))

(def TypeEnv.lookupRecordParams (-> String (-> TypeEnv (Maybe (List String))))
  (lambda (name String)
    (lambda (env TypeEnv)
      ((((inst Assoc.get String (List String)) String.eqString) name)
        (get env recordParams)))))

(def TypeEnv.lookupVariantParams (-> String (-> TypeEnv (Maybe (List String))))
  (lambda (name String)
    (lambda (env TypeEnv)
      ((((inst Assoc.get String (List String)) String.eqString) name)
        (get env variantParams)))))

(def TypeEnv.lookupAlias (-> String (-> TypeEnv (Maybe TypeExpr)))
  (lambda (name String)
    (lambda (env TypeEnv)
      ((((inst Assoc.get String TypeExpr) String.eqString) name)
        (get env aliases)))))

(def TermEnv.lookup (-> String (-> TermEnv (Maybe TypeExpr)))
  (lambda (name String)
    (lambda (env TermEnv)
      ((((inst Assoc.get String TypeExpr) String.eqString) name)
        (get env terms)))))

(def TermEnv.lookupPoly (-> String (-> TermEnv (Maybe TypeScheme)))
  (lambda (name String)
    (lambda (env TermEnv)
      ((((inst Assoc.get String TypeScheme) String.eqString) name)
        (get env polyTerms)))))

(def TermEnv.insert (-> String (-> TypeExpr (-> TermEnv TermEnv)))
  (lambda (name String)
    (lambda (typ TypeExpr)
      (lambda (env TermEnv)
        (record
          (terms ((((inst Assoc.insert String TypeExpr) name) typ)
            (get env terms)))
          (polyTerms (get env polyTerms)))))))

(def TermEnv.insertPoly (-> String (-> (List String) (-> TypeExpr (-> TermEnv TermEnv))))
  (lambda (name String)
    (lambda (typeParams (List String))
      (lambda (typ TypeExpr)
        (lambda (env TermEnv)
          (record
            (terms (get env terms))
            (polyTerms ((((inst Assoc.insert String TypeScheme) name)
              (record
                (typeParams typeParams)
                (typ typ)))
              (get env polyTerms)))))))))

(def Protoss.tcRecurKeyPrefix String "__protoss.recur:")
(def Protoss.tcRecurResultKey String "__protoss.recur:result")

(def Protoss.tcRecurVarKey (-> String String)
  (lambda (name String)
    ((String.concat Protoss.tcRecurKeyPrefix) name)))

(def Protoss.tcRecurFieldKey (-> String (-> String String))
  (lambda (name String)
    (lambda (field String)
      ((String.concat Protoss.tcRecurKeyPrefix)
        ((String.concat name) ((String.concat ".") field))))))

(def Protoss.tcRecurKey (-> Expr (Maybe String))
  (lambda (expr Expr)
    (case expr
      (PEVar name
        (variant Some (Protoss.tcRecurVarKey name)))
      (PEField fieldExpr
        (case (get fieldExpr target)
          (PEVar name
            (variant Some ((Protoss.tcRecurFieldKey name) (get fieldExpr field))))
          (_ (variant None unit))))
      (_ (variant None unit)))))

(def TermEnv.insertRecurAllowed
  (-> String (-> TypeExpr (-> TermEnv TermEnv)))
  (lambda (key String)
    (lambda (typ TypeExpr)
      (lambda (env TermEnv)
        (((TermEnv.insert key) typ) env)))))

(def TermEnv.insertRecurResult
  (-> TypeExpr (-> TermEnv TermEnv))
  (lambda (result TypeExpr)
    (lambda (env TermEnv)
      (((TermEnv.insert Protoss.tcRecurResultKey) result) env))))

(def TermEnv.insertDirectRecurPayload
  (-> TypeEnv (-> TypeExpr (-> String (-> TypeExpr (-> TermEnv TermEnv)))))
  (lambda (typeEnv TypeEnv)
    (lambda (target TypeExpr)
      (lambda (name String)
        (lambda (payloadType TypeExpr)
          (lambda (env TermEnv)
            (let (withPayload TermEnv
              (case (((Protoss.tcTypeEq typeEnv) target) payloadType)
                (true (((TermEnv.insertRecurAllowed (Protoss.tcRecurVarKey name)) target) env))
                (false env)))
              (case ((Protoss.tcRecordFieldsOfType typeEnv) payloadType)
                (None _ withPayload)
                (Some fields
                  (foldList fields withPayload
                    (lambda (field ProtossField)
                      (lambda (acc TermEnv)
                        (case (((Protoss.tcTypeEq typeEnv) target) (get field typ))
                          (true
                            (((TermEnv.insertRecurAllowed
                              ((Protoss.tcRecurFieldKey name) (get field name)))
                              target)
                              acc))
                          (false acc))))))))))))))

(def TypeEnv.insertAlias (-> String (-> TypeExpr (-> TypeEnv TypeEnv)))
  (lambda (name String)
    (lambda (typ TypeExpr)
      (lambda (env TypeEnv)
        (record
          (records (get env records))
          (recordParams (get env recordParams))
          (variants (get env variants))
          (variantParams (get env variantParams))
          (aliases ((((inst Assoc.insert String TypeExpr) name) typ)
            (get env aliases))))))))

(def TypeEnv.insertRecord
  (-> String (-> (List String) (-> (List ProtossField) (-> TypeEnv TypeEnv))))
  (lambda (name String)
    (lambda (typeParams (List String))
      (lambda (fields (List ProtossField))
        (lambda (env TypeEnv)
          (record
            (records ((((inst Assoc.insert String (List ProtossField)) name) fields)
              (get env records)))
            (recordParams ((((inst Assoc.insert String (List String)) name) typeParams)
              (get env recordParams)))
            (variants (get env variants))
            (variantParams (get env variantParams))
            (aliases (get env aliases))))))))

(def TypeEnv.insertVariant
  (-> String (-> (List String) (-> (List ProtossVariantCase) (-> TypeEnv TypeEnv))))
  (lambda (name String)
    (lambda (typeParams (List String))
      (lambda (cases (List ProtossVariantCase))
        (lambda (env TypeEnv)
          (record
            (records (get env records))
            (recordParams (get env recordParams))
            (variants ((((inst Assoc.insert String (List ProtossVariantCase)) name) cases)
              (get env variants)))
            (variantParams ((((inst Assoc.insert String (List String)) name) typeParams)
              (get env variantParams)))
            (aliases (get env aliases))))))))

(def Protoss.tcFieldTypeArg (-> ProtossField TypeExpr)
  (lambda (field ProtossField)
    ((Protoss.tcApplyType (get field name))
      (Cons TypeExpr (get field typ) (Nil TypeExpr)))))

(def Protoss.tcVariantCaseTypeArg (-> ProtossVariantCase TypeExpr)
  (lambda (caseDecl ProtossVariantCase)
    ((Protoss.tcApplyType (get caseDecl name))
      (Cons TypeExpr (get caseDecl payload) (Nil TypeExpr)))))

(def Protoss.tcRecordTypeOf (-> (List ProtossField) TypeExpr)
  (lambda (fields (List ProtossField))
    ((Protoss.tcApplyType "Record")
      (((inst List.map ProtossField TypeExpr) fields) Protoss.tcFieldTypeArg))))

(def Protoss.tcVariantTypeOf (-> (List ProtossVariantCase) TypeExpr)
  (lambda (cases (List ProtossVariantCase))
    ((Protoss.tcApplyType "Variant")
      (((inst List.map ProtossVariantCase TypeExpr) cases)
        Protoss.tcVariantCaseTypeArg))))

(def Protoss.tcSubstRecordField
  (-> (Assoc String TypeExpr) (-> ProtossField ProtossField))
  (lambda (subst (Assoc String TypeExpr))
    (lambda (field ProtossField)
      (record
        (name (get field name))
        (typ ((Protoss.tcSubstType (get field typ)) subst))))))

(def Protoss.tcSubstVariantCase
  (-> (Assoc String TypeExpr) (-> ProtossVariantCase ProtossVariantCase))
  (lambda (subst (Assoc String TypeExpr))
    (lambda (caseDecl ProtossVariantCase)
      (record
        (name (get caseDecl name))
        (payload ((Protoss.tcSubstType (get caseDecl payload)) subst))))))

(def Protoss.tcUnfoldType (-> TypeEnv (-> TypeExpr TypeExpr))
  (lambda (env TypeEnv)
    (lambda (typ TypeExpr)
      (case typ
        (PTName name
          (case ((TypeEnv.lookupAlias name) env)
            (Some alias alias)
            (None
              (case ((TypeEnv.lookupRecord name) env)
                (Some fields (Protoss.tcRecordTypeOf fields))
                (None
                  (case ((TypeEnv.lookupVariant name) env)
                    (Some cases (Protoss.tcVariantTypeOf cases))
                    (None typ)))))))
        (PTApply app
          (case ((TypeEnv.lookupRecordParams (get app name)) env)
            (Some params
              (case ((Nat.eqNat (List.length params)) (List.length (get app args)))
                (false typ)
                (true
                  (case ((TypeEnv.lookupRecord (get app name)) env)
                    (None _ typ)
                    (Some fields
                      (let (subst (Assoc String TypeExpr)
                        ((Protoss.tcBuildTypeSubst params) (get app args)))
                        (Protoss.tcRecordTypeOf
                          (((inst List.map ProtossField ProtossField) fields)
                            (Protoss.tcSubstRecordField subst)))))))))
            (None _
              (case ((TypeEnv.lookupVariantParams (get app name)) env)
                (Some params
                  (case ((Nat.eqNat (List.length params)) (List.length (get app args)))
                    (false typ)
                    (true
                      (case ((TypeEnv.lookupVariant (get app name)) env)
                        (None _ typ)
                        (Some cases
                          (let (subst (Assoc String TypeExpr)
                            ((Protoss.tcBuildTypeSubst params) (get app args)))
                            (Protoss.tcVariantTypeOf
                              (((inst List.map ProtossVariantCase ProtossVariantCase) cases)
                                (Protoss.tcSubstVariantCase subst)))))))))
                (None _ typ)))))
        (_ typ)))))

(def Protoss.tcTypeEq (-> TypeEnv (-> TypeExpr (-> TypeExpr Bool)))
  (lambda (env TypeEnv)
    (lambda (left TypeExpr)
      (lambda (right TypeExpr)
        ((String.eqString (Protoss.renderType ((Protoss.tcUnfoldType env) left)))
          (Protoss.renderType ((Protoss.tcUnfoldType env) right)))))))

(defrec Protoss.tcBuildTypeSubst
  (-> (List String) (-> (List TypeExpr) (Assoc String TypeExpr)))
  (list params)
  (nil
    (lambda (args (List TypeExpr))
      (inst Assoc.empty String TypeExpr)))
  (cons param acc
    (lambda (args (List TypeExpr))
      (caseList args
        (Nil (inst Assoc.empty String TypeExpr))
        (Cons arg rest
          ((((inst Assoc.insert String TypeExpr) param) arg) (acc rest)))))))

(defrec Protoss.tcSubstTypeFuel
  (-> Nat (-> TypeExpr (-> (Assoc String TypeExpr) TypeExpr)))
  (nat fuel)
  (zero
    (lambda (typ TypeExpr)
      (lambda (subst (Assoc String TypeExpr))
        (case typ
          (PTName name
            (case ((((inst Assoc.get String TypeExpr) String.eqString) name) subst)
              (Some replacement replacement)
              (None _ (variant PTName name))))
          (_ typ)))))
  (step previous
    (lambda (typ TypeExpr)
      (lambda (subst (Assoc String TypeExpr))
        (case typ
          (PTName name
            (case ((((inst Assoc.get String TypeExpr) String.eqString) name) subst)
              (Some replacement replacement)
              (None _ (variant PTName name))))
          (PTFun pair
            (variant PTFun
              (record
                (first ((previous (get pair first)) subst))
                (second ((previous (get pair second)) subst)))))
          (PTApply app
            (variant PTApply
              (record
                (name (get app name))
                (args
                  (((inst List.map TypeExpr TypeExpr) (get app args))
                    (lambda (arg TypeExpr)
                      ((previous arg) subst))))))))))))

(def Protoss.tcSubstType
  (-> TypeExpr (-> (Assoc String TypeExpr) TypeExpr))
  (lambda (typ TypeExpr)
    (lambda (subst (Assoc String TypeExpr))
      (((Protoss.tcSubstTypeFuel 64) typ) subst))))

(def Protoss.tcSubstTypes
  (-> (List TypeExpr) (-> (Assoc String TypeExpr) (List TypeExpr)))
  (lambda (types (List TypeExpr))
    (lambda (subst (Assoc String TypeExpr))
      (((inst List.map TypeExpr TypeExpr) types)
        (lambda (typ TypeExpr)
          ((Protoss.tcSubstType typ) subst))))))

(def Protoss.tcInstError
  (-> String (-> String (Result TypeError TypeExpr)))
  (lambda (summary String)
    (lambda (message String)
      (Protoss.tcErr
        ((((((Protoss.tcError "SELF_TC011") Protoss.tcNoDef)
          Protoss.tcNoType)
          Protoss.tcNoType)
          summary)
          message)))))

(def Protoss.tcInstantiateType
  (-> String (-> TypeScheme (-> (List TypeExpr) (Result TypeError TypeExpr))))
  (lambda (name String)
    (lambda (scheme TypeScheme)
      (lambda (args (List TypeExpr))
        (case ((Nat.eqNat (List.length (get scheme typeParams))) (List.length args))
          (false
            ((Protoss.tcInstError name)
              ((String.concat "polymorphic definition ")
                ((String.concat name) " received wrong number of type arguments"))))
          (true
            (let (subst (Assoc String TypeExpr)
              ((Protoss.tcBuildTypeSubst (get scheme typeParams)) args))
              (Protoss.tcOk ((Protoss.tcSubstType (get scheme typ)) subst)))))))))

(def Protoss.tcError
  (-> String (-> (Maybe String) (-> (Maybe TypeExpr) (-> (Maybe TypeExpr)
    (-> String (-> String TypeError))))))
  (lambda (code String)
    (lambda (definition (Maybe String))
      (lambda (expected (Maybe TypeExpr))
        (lambda (actual (Maybe TypeExpr))
          (lambda (summary String)
            (lambda (message String)
              (record
                (code code)
                (definition definition)
                (expected expected)
                (actual actual)
                (summary summary)
                (span (variant None unit))
                (message message)))))))))

(def Protoss.tcOk (-> TypeExpr (Result TypeError TypeExpr))
  (lambda (typ TypeExpr)
    (variant Ok typ)))

(def Protoss.tcErr (-> TypeError (Result TypeError TypeExpr))
  (lambda (err TypeError)
    (variant Err err)))

(def Protoss.tcMismatch
  (-> (Maybe String) (-> TypeExpr (-> TypeExpr (-> String (Result TypeError TypeExpr)))))
  (lambda (definition (Maybe String))
    (lambda (expected TypeExpr)
      (lambda (actual TypeExpr)
        (lambda (summary String)
          (Protoss.tcErr
            ((((((Protoss.tcError "SELF_TC002") definition)
              (Protoss.tcSomeType expected))
              (Protoss.tcSomeType actual))
              summary)
              ((String.concat "expected ")
                ((String.concat (Protoss.renderType expected))
                  ((String.concat ", got ") (Protoss.renderType actual)))))))))))

(def Protoss.tcUnsupported
  (-> (Maybe String) (-> String (Result TypeError TypeExpr)))
  (lambda (definition (Maybe String))
    (lambda (summary String)
      (Protoss.tcErr
        ((((((Protoss.tcError "SELF_TC004") definition)
          Protoss.tcNoType)
          Protoss.tcNoType)
          summary)
          ((String.concat "unsupported construct: ") summary))))))

(def Protoss.tcPolyInferenceTypeError
  (-> String (-> String TypeError))
  (lambda (name String)
    (lambda (message String)
      ((((((Protoss.tcError "SELF_TC011") Protoss.tcNoDef)
        Protoss.tcNoType)
        Protoss.tcNoType)
        name)
        message))))

(def Protoss.tcBindPolyTypeArg
  (-> TypeEnv (-> String (-> String (-> TypeExpr
    (-> (Assoc String TypeExpr)
      (Result TypeError (Assoc String TypeExpr)))))))
  (lambda (typeEnv TypeEnv)
    (lambda (polyName String)
      (lambda (param String)
        (lambda (actual TypeExpr)
          (lambda (subst (Assoc String TypeExpr))
            (case ((((inst Assoc.get String TypeExpr) String.eqString) param) subst)
              (None _
                (variant (Result TypeError (Assoc String TypeExpr)) Ok
                  ((((inst Assoc.insert String TypeExpr) param) actual) subst)))
              (Some existing
                (case (((Protoss.tcTypeEq typeEnv) existing) actual)
                  (true
                    (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                  (false
                    (variant (Result TypeError (Assoc String TypeExpr)) Err
                      ((Protoss.tcPolyInferenceTypeError polyName)
                        ((String.concat "conflicting inferred type argument ")
                          param)))))))))))))

(defrec Protoss.tcUnifyPolyTypeFuel
  (-> Nat (-> TypeEnv (-> String (-> (List String) (-> TypeExpr
    (-> TypeExpr (-> (Assoc String TypeExpr)
      (Result TypeError (Assoc String TypeExpr)))))))))
  (nat fuel)
  (zero
    (lambda (typeEnv TypeEnv)
      (lambda (polyName String)
        (lambda (typeParams (List String))
          (lambda (pattern TypeExpr)
            (lambda (actual TypeExpr)
              (lambda (subst (Assoc String TypeExpr))
                (case (((Protoss.tcTypeEq typeEnv) pattern) actual)
                  (true
                    (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                  (false
                    (variant (Result TypeError (Assoc String TypeExpr)) Err
                      ((Protoss.tcPolyInferenceTypeError polyName)
                        ((String.concat "cannot infer ") polyName)))))))))))
  )
  (step previous
    (lambda (typeEnv TypeEnv)
      (lambda (polyName String)
        (lambda (typeParams (List String))
          (lambda (pattern TypeExpr)
            (lambda (actual TypeExpr)
              (lambda (subst (Assoc String TypeExpr))
                (case pattern
                  (PTName name
                    (case ((((inst List.member String) String.eqString) name) typeParams)
                      (true
                        (((((Protoss.tcBindPolyTypeArg typeEnv) polyName) name)
                          actual)
                          subst))
                      (false
                        (case (((Protoss.tcTypeEq typeEnv) pattern) actual)
                          (true
                            (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                          (false
                            (variant (Result TypeError (Assoc String TypeExpr)) Err
                              ((Protoss.tcPolyInferenceTypeError polyName)
                                ((String.concat "cannot infer ") polyName))))))))
                  (PTFun patternPair
                    (case ((Protoss.tcUnfoldType typeEnv) actual)
                      (PTFun actualPair
                        (case ((((((previous typeEnv) polyName) typeParams)
                                  (get patternPair first))
                                  (get actualPair first))
                                  subst)
                          (Err err
                            (variant (Result TypeError (Assoc String TypeExpr)) Err err))
                          (Ok substAfterArg
                            ((((((previous typeEnv) polyName) typeParams)
                              (get patternPair second))
                              (get actualPair second))
                              substAfterArg))))
                      (_
                        (variant (Result TypeError (Assoc String TypeExpr)) Err
                          ((Protoss.tcPolyInferenceTypeError polyName)
                            ((String.concat "cannot infer ")
                              ((String.concat polyName) ": expected function type")))))))
                  (PTApply patternApp
                    (case actual
                      (PTApply actualApp
                        (case ((String.eqString (get patternApp name)) (get actualApp name))
                          (false
                            (case (((Protoss.tcTypeEq typeEnv) pattern) actual)
                              (true
                                (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                              (false
                                (variant (Result TypeError (Assoc String TypeExpr)) Err
                                  ((Protoss.tcPolyInferenceTypeError polyName)
                                    ((String.concat "cannot infer ") polyName))))))
                          (true
                            (case ((Nat.eqNat (List.length (get patternApp args)))
                                    (List.length (get actualApp args)))
                              (false
                                (variant (Result TypeError (Assoc String TypeExpr)) Err
                                  ((Protoss.tcPolyInferenceTypeError polyName)
                                    ((String.concat "cannot infer ")
                                      ((String.concat polyName)
                                        ": type argument arity differs")))))
                              (true
                                (let (state TypecheckPolyUnifyArgsState
                                  (foldList (get patternApp args)
                                    (record
                                      (actuals (get actualApp args))
                                      (subst subst)
                                      (error (variant (Maybe TypeError) None unit)))
                                    (lambda (patternArg TypeExpr)
                                      (lambda (state TypecheckPolyUnifyArgsState)
                                        (case (get state error)
                                          (Some err state)
                                          (None _
                                            (caseList (get state actuals)
                                              (Nil
                                                (record
                                                  (actuals (Nil TypeExpr))
                                                  (subst (get state subst))
                                                  (error
                                                    (variant Some
                                                      ((Protoss.tcPolyInferenceTypeError polyName)
                                                        ((String.concat "cannot infer ")
                                                          ((String.concat polyName)
                                                            ": type argument arity differs")))))))
                                              (Cons actualArg rest
                                                (case ((((((previous typeEnv) polyName) typeParams)
                                                        patternArg)
                                                        actualArg)
                                                        (get state subst))
                                                  (Err err
                                                    (record
                                                      (actuals rest)
                                                      (subst (get state subst))
                                                      (error (variant Some err))))
                                                  (Ok nextSubst
                                                    (record
                                                      (actuals rest)
                                                      (subst nextSubst)
                                                      (error
                                                        (variant (Maybe TypeError) None unit)))))))))))))
                                  (case (get state error)
                                    (Some err
                                      (variant (Result TypeError (Assoc String TypeExpr)) Err err))
                                    (None _
                                      (variant (Result TypeError (Assoc String TypeExpr)) Ok
                                        (get state subst))))))))))
                      (_
                        (case (((Protoss.tcTypeEq typeEnv) pattern) actual)
                          (true
                            (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                          (false
                            (variant (Result TypeError (Assoc String TypeExpr)) Err
                              ((Protoss.tcPolyInferenceTypeError polyName)
                                ((String.concat "cannot infer ") polyName))))))))))))))))
  )

(def Protoss.tcUnifyPolyType
  (-> TypeEnv (-> String (-> (List String) (-> TypeExpr
    (-> TypeExpr (-> (Assoc String TypeExpr)
      (Result TypeError (Assoc String TypeExpr))))))))
  (lambda (typeEnv TypeEnv)
    (lambda (polyName String)
      (lambda (typeParams (List String))
        (lambda (pattern TypeExpr)
          (lambda (actual TypeExpr)
            (lambda (subst (Assoc String TypeExpr))
              (((((((Protoss.tcUnifyPolyTypeFuel 64) typeEnv)
                polyName)
                typeParams)
                pattern)
                actual)
                subst)))))))
  )

(def Protoss.tcUnifyPolyTypeOrKeep
  (-> TypeEnv (-> String (-> (List String) (-> TypeExpr (-> TypeExpr
    (-> (Assoc String TypeExpr)
      (Result TypeError (Assoc String TypeExpr))))))))
  (lambda (typeEnv TypeEnv)
    (lambda (polyName String)
      (lambda (typeParams (List String))
        (lambda (pattern TypeExpr)
          (lambda (actual TypeExpr)
            (lambda (subst (Assoc String TypeExpr))
              (case ((((((Protoss.tcUnifyPolyType typeEnv) polyName) typeParams)
                        pattern)
                        actual)
                        subst)
                (Err err
                  (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                (Ok nextSubst
                  (variant (Result TypeError (Assoc String TypeExpr)) Ok
                    nextSubst)))))))))
  )

(defrec Protoss.tcPolySubstArgs
  (-> (List String) (-> String (-> (Assoc String TypeExpr)
    (Result TypeError (List TypeExpr)))))
  (list params)
  (nil
    (lambda (polyName String)
      (lambda (subst (Assoc String TypeExpr))
        (variant (Result TypeError (List TypeExpr)) Ok (Nil TypeExpr)))))
  (cons param acc
    (lambda (polyName String)
      (lambda (subst (Assoc String TypeExpr))
        (case ((((inst Assoc.get String TypeExpr) String.eqString) param) subst)
          (None _
            (variant (Result TypeError (List TypeExpr)) Err
              ((Protoss.tcPolyInferenceTypeError polyName)
                ((String.concat "cannot infer type argument ")
                  ((String.concat param)
                    ((String.concat " for ") polyName))))))
          (Some typ
            (case ((acc polyName) subst)
              (Err err (variant (Result TypeError (List TypeExpr)) Err err))
              (Ok rest
                (variant (Result TypeError (List TypeExpr)) Ok
                  (Cons TypeExpr typ rest))))))))))

(defrec Protoss.tcPolyTakeArgTypes
  (-> (List Expr) (-> TypeEnv (-> String (-> TypeExpr
    (Result TypeError TypecheckPolyAppShape)))))
  (list args)
  (nil
    (lambda (typeEnv TypeEnv)
      (lambda (polyName String)
        (lambda (typ TypeExpr)
          (variant (Result TypeError TypecheckPolyAppShape) Ok
            (record
              (argTypes (Nil TypeExpr))
              (result typ)))))))
  (cons arg acc
    (lambda (typeEnv TypeEnv)
      (lambda (polyName String)
        (lambda (typ TypeExpr)
          (case ((Protoss.tcUnfoldType typeEnv) typ)
            (PTFun pair
              (case (((acc typeEnv) polyName) (get pair second))
                (Err err
                  (variant (Result TypeError TypecheckPolyAppShape) Err err))
                (Ok shape
                  (variant (Result TypeError TypecheckPolyAppShape) Ok
                    (record
                      (argTypes
                        (Cons TypeExpr (get pair first) (get shape argTypes)))
                      (result (get shape result)))))))
            (_
              (variant (Result TypeError TypecheckPolyAppShape) Err
                ((Protoss.tcPolyInferenceTypeError polyName)
                  ((String.concat "too many arguments for polymorphic definition: ")
                    polyName))))))))))

(defrec Protoss.tcRunExpectedArgChecks
  (-> (List TypecheckExpectedExprChecker) (-> TypeEnv (-> TermEnv
    (-> (List TypeExpr) (Result TypeError TypeExpr)))))
  (list checks)
  (nil
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (params (List TypeExpr))
          (caseList params
            (Nil (Protoss.tcOk Protoss.tcUnit))
            (Cons param rest
              (Protoss.tcErr
                ((Protoss.tcPolyInferenceTypeError "application")
                  "not enough arguments for polymorphic application"))))))))
  (cons check acc
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (params (List TypeExpr))
          (caseList params
            (Nil
              (Protoss.tcErr
                ((Protoss.tcPolyInferenceTypeError "application")
                  "too many arguments for polymorphic application")))
            (Cons param rest
              (case (((check typeEnv) termEnv) param)
                (Err err (variant Err err))
                (Ok checkedArg (((acc typeEnv) termEnv) rest)))))))))
  )

(defrec Protoss.tcRunInferredArgChecks
  (-> (List Expr) (-> TypeEnv (-> TermEnv
    (-> (List TypeExpr) (Result TypeError TypeExpr)))))
  (list args)
  (nil
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (params (List TypeExpr))
          (caseList params
            (Nil (Protoss.tcOk Protoss.tcUnit))
            (Cons param rest
              (Protoss.tcErr
                ((Protoss.tcPolyInferenceTypeError "application")
                  "not enough arguments for polymorphic application"))))))))
  (cons arg acc
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (params (List TypeExpr))
          (caseList params
            (Nil
              (Protoss.tcErr
                ((Protoss.tcPolyInferenceTypeError "application")
                  "too many arguments for polymorphic application")))
            (Cons param rest
              (case (((Protoss.tcExpr typeEnv) termEnv) arg)
                (Err err (variant Err err))
                (Ok actual
                  (case (((Protoss.tcTypeEq typeEnv) param) actual)
                    (false
                      ((((Protoss.tcMismatch Protoss.tcNoDef) param) actual)
                        (Protoss.renderExpr arg)))
                    (true (((acc typeEnv) termEnv) rest)))))))))))
  )

(defrec Protoss.tcUnifyPolyExpectedArg
  (-> Expr (-> TypeEnv (-> TermEnv (-> String (-> (List String)
    (-> TypeExpr (-> (Assoc String TypeExpr)
      (Result TypeError (Assoc String TypeExpr)))))))))
  (variant expr)
  (PENil nilExpr
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (name String)
          (lambda (typeParams (List String))
            (lambda (pattern TypeExpr)
              (lambda (subst (Assoc String TypeExpr))
                (case ((Protoss.tcListItemType typeEnv) pattern)
                  (None _
                    (case (((Protoss.tcExpr typeEnv) termEnv) expr)
                      (Err err
                        (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                      (Ok actual
                        ((((((Protoss.tcUnifyPolyType typeEnv) name) typeParams)
                          pattern)
                          actual)
                          subst))))
                  (Some itemPattern
                    (case (get nilExpr typ)
                      (None _
                        (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                      (Some explicitItem
                        ((((((Protoss.tcUnifyPolyType typeEnv) name) typeParams)
                          itemPattern)
                          explicitItem)
                          subst))))))))))))
  (PECons consExpr
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (name String)
          (lambda (typeParams (List String))
            (lambda (pattern TypeExpr)
              (lambda (subst (Assoc String TypeExpr))
                (case ((Protoss.tcListItemType typeEnv) pattern)
                  (None _
                    (case (((Protoss.tcExpr typeEnv) termEnv) expr)
                      (Err err
                        (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                      (Ok actual
                        ((((((Protoss.tcUnifyPolyTypeOrKeep typeEnv) name) typeParams)
                          pattern)
                          actual)
                          subst))))
                  (Some itemPattern
                    (case (get consExpr typ)
                      (Some explicitItem
                        (case ((((((Protoss.tcUnifyPolyTypeOrKeep typeEnv) name)
                                  typeParams)
                                  itemPattern)
                                  explicitItem)
                                  subst)
                          (Err err
                            (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                          (Ok substWithExplicit
                            (case (((Protoss.tcExpr typeEnv) termEnv) (get consExpr head))
                              (Err err
                                (variant (Result TypeError (Assoc String TypeExpr)) Ok
                                  substWithExplicit))
                              (Ok headType
                                ((((((Protoss.tcUnifyPolyTypeOrKeep typeEnv) name)
                                  typeParams)
                                  itemPattern)
                                  headType)
                                  substWithExplicit))))))
                      (None _
                        (case (((Protoss.tcExpr typeEnv) termEnv) (get consExpr head))
                          (Err err
                            (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                          (Ok headType
                            ((((((Protoss.tcUnifyPolyTypeOrKeep typeEnv) name)
                              typeParams)
                              itemPattern)
                              headType)
                              subst))))))))))))))
  (_
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (name String)
          (lambda (typeParams (List String))
            (lambda (pattern TypeExpr)
              (lambda (subst (Assoc String TypeExpr))
                (case (((Protoss.tcExpr typeEnv) termEnv) expr)
                  (Err err
                    (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                  (Ok actual
                    ((((((Protoss.tcUnifyPolyType typeEnv) name) typeParams)
                      pattern)
                      actual)
                      subst))))))))))
  )

(defrec Protoss.tcUnifyPolyInferredArgs
  (-> (List Expr) (-> TypeEnv (-> TermEnv (-> String (-> (List String)
    (-> (List TypeExpr) (-> (Assoc String TypeExpr)
      (Result TypeError (Assoc String TypeExpr)))))))))
  (list args)
  (nil
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (name String)
          (lambda (typeParams (List String))
            (lambda (patterns (List TypeExpr))
              (lambda (subst (Assoc String TypeExpr))
                (variant (Result TypeError (Assoc String TypeExpr)) Ok subst)))))))
  )
  (cons arg acc
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (name String)
          (lambda (typeParams (List String))
            (lambda (patterns (List TypeExpr))
              (lambda (subst (Assoc String TypeExpr))
                (caseList patterns
                  (Nil
                    (variant (Result TypeError (Assoc String TypeExpr)) Ok subst))
                  (Cons pattern restPatterns
                    (case (((((((Protoss.tcUnifyPolyExpectedArg arg) typeEnv)
                                termEnv)
                                name)
                                typeParams)
                                pattern)
                                subst)
                      (Err err
                        ((((((acc typeEnv) termEnv) name) typeParams)
                          restPatterns)
                          subst))
                      (Ok nextSubst
                        ((((((acc typeEnv) termEnv) name) typeParams)
                          restPatterns)
                          nextSubst)))))))))))
  )
  )

(defrec Protoss.tcPolyAppSpine (-> Expr (Maybe TypecheckPolyApplication))
  (variant expr)
  (PEVar name
    (variant Some
      (record
        (name name)
        (args (Nil Expr)))))
  (PEApply call
    (case (recur (get call fn))
      (None _ (variant (Maybe TypecheckPolyApplication) None unit))
      (Some spine
        (variant Some
          (record
            (name (get spine name))
            (args
              (((inst List.append Expr) (get spine args))
                (get call args))))))))
  (_ (variant (Maybe TypecheckPolyApplication) None unit)))

(def Protoss.tcCheckPolyVarAs
  (-> TypeEnv (-> TermEnv (-> String (-> TypeExpr
    (Result TypeError TypeExpr)))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (name String)
        (lambda (expected TypeExpr)
          (case (Protoss.isNatLiteralName name)
            (true
              (case (((Protoss.tcTypeEq typeEnv) expected) Protoss.tcNat)
                (true (Protoss.tcOk expected))
                (false
                  ((((Protoss.tcMismatch Protoss.tcNoDef) expected)
                    Protoss.tcNat)
                    name))))
            (false
              (case ((TermEnv.lookup name) termEnv)
                (Some typ
                  (case (((Protoss.tcTypeEq typeEnv) expected) typ)
                    (true (Protoss.tcOk expected))
                    (false
                      ((((Protoss.tcMismatch Protoss.tcNoDef) expected) typ) name))))
                (None _
                  (case ((TermEnv.lookupPoly name) termEnv)
                    (None _
                      (Protoss.tcErr
                        ((((((Protoss.tcError "SELF_TC001") Protoss.tcNoDef)
                          Protoss.tcNoType)
                          Protoss.tcNoType)
                          name)
                          ((String.concat "unknown variable: ") name))))
                    (Some scheme
                      (case ((((((Protoss.tcUnifyPolyType typeEnv) name)
                                (get scheme typeParams))
                                (get scheme typ))
                                expected)
                                (inst Assoc.empty String TypeExpr))
                        (Err err (variant Err err))
                        (Ok subst
                          (case (((Protoss.tcPolySubstArgs
                                  (get scheme typeParams))
                                  name)
                                  subst)
                            (Err err (variant Err err))
                            (Ok typeArgs
                              (case (((Protoss.tcInstantiateType name) scheme) typeArgs)
                                (Err err (variant Err err))
                                (Ok instantiated
                                  (case (((Protoss.tcTypeEq typeEnv) expected)
                                          instantiated)
                                    (true (Protoss.tcOk expected))
                                    (false
                                      ((((Protoss.tcMismatch Protoss.tcNoDef)
                                        expected)
                                        instantiated)
                                        name)))))))))))))))))))
  )

(def Protoss.tcCheckPolyApplyAs
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> String (-> TypeScheme
    (-> (List Expr) (-> (List TypecheckExpectedExprChecker)
      (Result TypeError TypeExpr))))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expected TypeExpr)
        (lambda (name String)
          (lambda (scheme TypeScheme)
            (lambda (args (List Expr))
              (lambda (argChecks (List TypecheckExpectedExprChecker))
                (case ((((Protoss.tcPolyTakeArgTypes args) typeEnv)
                        name)
                        (get scheme typ))
                  (Err err (variant Err err))
                  (Ok shape
                    (case ((((((Protoss.tcUnifyPolyType typeEnv) name)
                              (get scheme typeParams))
                              (get shape result))
                              expected)
                              (inst Assoc.empty String TypeExpr))
                      (Err err (variant Err err))
                      (Ok subst
                        (case (((((((Protoss.tcUnifyPolyInferredArgs args)
                                    typeEnv)
                                    termEnv)
                                    name)
                                    (get scheme typeParams))
                                    (get shape argTypes))
                                    subst)
                          (Err err (variant Err err))
                          (Ok substWithArgs
                            (case (((Protoss.tcPolySubstArgs
                                    (get scheme typeParams))
                                    name)
                                    substWithArgs)
                              (Err err (variant Err err))
                              (Ok typeArgs
                                (let (instantiatedArgTypes (List TypeExpr)
                                  ((Protoss.tcSubstTypes (get shape argTypes)) substWithArgs))
                                  (let (instantiatedResult TypeExpr
                                    ((Protoss.tcSubstType (get shape result)) substWithArgs))
                                    (case (((Protoss.tcTypeEq typeEnv) expected)
                                            instantiatedResult)
                                      (false
                                        ((((Protoss.tcMismatch Protoss.tcNoDef)
                                          expected)
                                          instantiatedResult)
                                          name))
                                      (true
                                        (case ((((Protoss.tcRunExpectedArgChecks argChecks)
                                                typeEnv)
                                                termEnv)
                                                instantiatedArgTypes)
                                          (Err err (variant Err err))
                                          (Ok checkedArgs
                                            (Protoss.tcOk expected)))))))))))))))))))))))

(def Protoss.tcCheckPolySplitApplyAs
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> String (-> TypeScheme
    (-> (List Expr) (-> (List TypecheckExpectedExprChecker)
      (-> (List Expr) (-> (List TypecheckExpectedExprChecker)
        (Result TypeError TypeExpr))))))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expected TypeExpr)
        (lambda (name String)
          (lambda (scheme TypeScheme)
            (lambda (prefixArgs (List Expr))
              (lambda (prefixChecks (List TypecheckExpectedExprChecker))
                (lambda (suffixArgs (List Expr))
                  (lambda (suffixChecks (List TypecheckExpectedExprChecker))
                    (case ((((Protoss.tcPolyTakeArgTypes prefixArgs) typeEnv)
                            name)
                            (get scheme typ))
                      (Err err (variant Err err))
                      (Ok prefixShape
                        (case ((((Protoss.tcPolyTakeArgTypes suffixArgs) typeEnv)
                                name)
                                (get prefixShape result))
                          (Err err (variant Err err))
                          (Ok suffixShape
                            (case ((((((Protoss.tcUnifyPolyType typeEnv) name)
                                      (get scheme typeParams))
                                      (get suffixShape result))
                                      expected)
                                      (inst Assoc.empty String TypeExpr))
                              (Err err (variant Err err))
                              (Ok subst
                                (case (((((((Protoss.tcUnifyPolyInferredArgs prefixArgs)
                                            typeEnv)
                                            termEnv)
                                            name)
                                            (get scheme typeParams))
                                            (get prefixShape argTypes))
                                            subst)
                                  (Err err (variant Err err))
                                  (Ok substWithPrefix
                                    (case (((((((Protoss.tcUnifyPolyInferredArgs suffixArgs)
                                                typeEnv)
                                                termEnv)
                                                name)
                                                (get scheme typeParams))
                                                (get suffixShape argTypes))
                                                substWithPrefix)
                                      (Err err (variant Err err))
                                      (Ok substWithArgs
                                        (case (((Protoss.tcPolySubstArgs
                                                (get scheme typeParams))
                                                name)
                                                substWithArgs)
                                          (Err err (variant Err err))
                                          (Ok typeArgs
                                            (let (instantiatedPrefixArgTypes (List TypeExpr)
                                              ((Protoss.tcSubstTypes (get prefixShape argTypes))
                                                substWithArgs))
                                              (let (instantiatedSuffixArgTypes (List TypeExpr)
                                                ((Protoss.tcSubstTypes (get suffixShape argTypes))
                                                  substWithArgs))
                                                (let (instantiatedResult TypeExpr
                                                  ((Protoss.tcSubstType (get suffixShape result))
                                                    substWithArgs))
                                                  (case (((Protoss.tcTypeEq typeEnv) expected)
                                                          instantiatedResult)
                                                    (false
                                                      ((((Protoss.tcMismatch Protoss.tcNoDef)
                                                        expected)
                                                        instantiatedResult)
                                                        name))
                                                    (true
                                                      (case ((((Protoss.tcRunExpectedArgChecks
                                                                prefixChecks)
                                                              typeEnv)
                                                              termEnv)
                                                              instantiatedPrefixArgTypes)
                                                        (Err err (variant Err err))
                                                        (Ok checkedPrefix
                                                          (case ((((Protoss.tcRunExpectedArgChecks
                                                                    suffixChecks)
                                                                  typeEnv)
                                                                  termEnv)
                                                                  instantiatedSuffixArgTypes)
                                                            (Err err (variant Err err))
                                                            (Ok checkedSuffix
                                                              (Protoss.tcOk expected))))))))))))))))))))))))))))))))

(def Protoss.tcCheckPolyApplyInferArgsAs
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> String (-> TypeScheme
    (-> (List Expr) (Result TypeError TypeExpr)))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expected TypeExpr)
        (lambda (name String)
          (lambda (scheme TypeScheme)
            (lambda (args (List Expr))
              (case ((((Protoss.tcPolyTakeArgTypes args) typeEnv)
                      name)
                      (get scheme typ))
                (Err err (variant Err err))
                (Ok shape
                  (case ((((((Protoss.tcUnifyPolyType typeEnv) name)
                            (get scheme typeParams))
                            (get shape result))
                            expected)
                            (inst Assoc.empty String TypeExpr))
                    (Err err (variant Err err))
                    (Ok subst
                      (case (((((((Protoss.tcUnifyPolyInferredArgs args)
                                  typeEnv)
                                  termEnv)
                                  name)
                                  (get scheme typeParams))
                                  (get shape argTypes))
                                  subst)
                        (Err err (variant Err err))
                        (Ok substWithArgs
                          (case (((Protoss.tcPolySubstArgs
                                  (get scheme typeParams))
                                  name)
                                  substWithArgs)
                            (Err err (variant Err err))
                            (Ok typeArgs
                              (let (instantiatedArgTypes (List TypeExpr)
                                ((Protoss.tcSubstTypes (get shape argTypes)) substWithArgs))
                                (let (instantiatedResult TypeExpr
                                  ((Protoss.tcSubstType (get shape result)) substWithArgs))
                                  (case (((Protoss.tcTypeEq typeEnv) expected)
                                          instantiatedResult)
                                    (false
                                      ((((Protoss.tcMismatch Protoss.tcNoDef)
                                        expected)
                                        instantiatedResult)
                                        name))
                                    (true
                                      (case ((((Protoss.tcRunInferredArgChecks args)
                                              typeEnv)
                                              termEnv)
                                              instantiatedArgTypes)
                                        (Err err (variant Err err))
                                        (Ok checkedArgs
                                          (Protoss.tcOk expected)))))))))))))))))))))
  )

(def Protoss.tcPair (-> String (-> TypeExpr (Pair String TypeExpr)))
  (lambda (name String)
    (lambda (typ TypeExpr)
      (record (first name) (second typ)))))

(def TermEnv.builtin TermEnv
  (record
    (terms
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "succ") ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "Nat.add") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "Nat.mul") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "Nat.pred") ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "Nat.sub") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "Nat.eqNat") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "Bool.not") ((Protoss.tcFun Protoss.tcBool) Protoss.tcBool))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "Bool.and") ((Protoss.tcFun Protoss.tcBool) ((Protoss.tcFun Protoss.tcBool) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "Bool.or") ((Protoss.tcFun Protoss.tcBool) ((Protoss.tcFun Protoss.tcBool) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "String.concat") ((Protoss.tcFun Protoss.tcString) ((Protoss.tcFun Protoss.tcString) Protoss.tcString)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "String.append") ((Protoss.tcFun Protoss.tcString) ((Protoss.tcFun Protoss.tcString) Protoss.tcString)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "String.eqString") ((Protoss.tcFun Protoss.tcString) ((Protoss.tcFun Protoss.tcString) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "String.length") ((Protoss.tcFun Protoss.tcString) Protoss.tcNat))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.add") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.mul") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.pred") ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.sub") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcNat)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.eq") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.lte") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.lt") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.gte") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.gt") ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcFun Protoss.tcNat) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.Nat.toString") ((Protoss.tcFun Protoss.tcNat) Protoss.tcString))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.String.concat") ((Protoss.tcFun Protoss.tcString) ((Protoss.tcFun Protoss.tcString) Protoss.tcString)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.String.eq") ((Protoss.tcFun Protoss.tcString) ((Protoss.tcFun Protoss.tcString) Protoss.tcBool)))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.String.length") ((Protoss.tcFun Protoss.tcString) Protoss.tcNat))
      (Cons (Pair String TypeExpr) ((Protoss.tcPair "prim.String.charAt") ((Protoss.tcFun Protoss.tcString) ((Protoss.tcFun Protoss.tcNat) ((Protoss.tcApplyType "Maybe") (Cons TypeExpr Protoss.tcString (Nil TypeExpr))))))
      (Nil (Pair String TypeExpr))))))))))))))))))))))))))))))
    (polyTerms (inst Assoc.empty String TypeScheme))))

(def TypeEnv.addDecl (-> TypeEnv (-> Decl TypeEnv))
  (lambda (env TypeEnv)
    (lambda (decl Decl)
      (case decl
        (PDRecord recordDecl
          ((((TypeEnv.insertRecord (get recordDecl name))
            (get recordDecl typeParams))
            (get recordDecl fields))
            env))
        (PDVariant variantDecl
          ((((TypeEnv.insertVariant (get variantDecl name))
            (get variantDecl typeParams))
            (get variantDecl cases))
            env))
        (PDType typeDecl
          (((TypeEnv.insertAlias (get typeDecl name)) (get typeDecl body)) env))
        (_ env)))))

(def Protoss.tcTypeEnvOfDecls (-> (List Decl) TypeEnv)
  (lambda (decls (List Decl))
    (foldList decls TypeEnv.empty
      (lambda (decl Decl)
        (lambda (env TypeEnv)
          ((TypeEnv.addDecl env) decl))))))

(def TermEnv.addDecl (-> TermEnv (-> Decl TermEnv))
  (lambda (env TermEnv)
    (lambda (decl Decl)
      (case decl
        (PDDef def (((TermEnv.insert (get def name)) (get def typ)) env))
        (PDDefCap def (((TermEnv.insert (get def name)) (get def typ)) env))
        (PDDefPoly def ((((TermEnv.insertPoly (get def name)) (get def typeParams)) (get def typ)) env))
        (PDDefPolyCap def ((((TermEnv.insertPoly (get def name)) (get def typeParams)) (get def typ)) env))
        (PDDefRec def
          (caseList (get def typeParams)
            (Nil (((TermEnv.insert (get def name)) (get def typ)) env))
            (Cons first rest
              ((((TermEnv.insertPoly (get def name)) (get def typeParams))
                (get def typ))
                env))))
        (_ env)))))

(def Protoss.tcTermEnvOfDecls (-> (List Decl) TermEnv)
  (lambda (decls (List Decl))
    (foldList decls TermEnv.builtin
      (lambda (decl Decl)
        (lambda (env TermEnv)
          ((TermEnv.addDecl env) decl))))))

(def Protoss.tcTypeArgPayload (-> String (-> TypeExpr (Maybe TypeExpr)))
  (lambda (name String)
    (lambda (typ TypeExpr)
      (case typ
        (PTApply app
          (case ((String.eqString (get app name)) name)
            (true
              (caseList (get app args)
                (Nil (variant None unit))
                (Cons payload rest
                  (variant Some payload))))
            (false (variant None unit))))
        (_ (variant None unit))))))

(def Protoss.tcFindTypeArg (-> String (-> (List TypeExpr) (Maybe TypeExpr)))
  (lambda (name String)
    (lambda (args (List TypeExpr))
      (foldList args (variant (Maybe TypeExpr) None unit)
        (lambda (arg TypeExpr)
          (lambda (found (Maybe TypeExpr))
            (case ((Protoss.tcTypeArgPayload name) arg)
              (Some payload (variant Some payload))
              (None _ found))))))))

(def Protoss.tcFieldType (-> TypeEnv (-> TypeExpr (-> String (Maybe TypeExpr))))
  (lambda (env TypeEnv)
    (lambda (recordType TypeExpr)
      (lambda (field String)
        (case ((Protoss.tcUnfoldType env) recordType)
          (PTApply app
            (case ((String.eqString (get app name)) "Record")
              (true ((Protoss.tcFindTypeArg field) (get app args)))
              (false (variant None unit))))
          (_ (variant None unit)))))))

(def Protoss.tcVariantPayloadType
  (-> TypeEnv (-> TypeExpr (-> String (Maybe TypeExpr))))
  (lambda (env TypeEnv)
    (lambda (variantType TypeExpr)
      (lambda (constructor String)
        (case ((Protoss.tcUnfoldType env) variantType)
          (PTApply app
            (case ((String.eqString (get app name)) "Variant")
              (true ((Protoss.tcFindTypeArg constructor) (get app args)))
              (false (variant None unit))))
          (_ (variant None unit)))))))

(def Protoss.tcTypeArgVariantCase (-> TypeExpr (Maybe ProtossVariantCase))
  (lambda (typ TypeExpr)
    (case typ
      (PTApply app
        (caseList (get app args)
          (Nil (variant None unit))
          (Cons payload rest
            (variant Some
              (record
                (name (get app name))
                (payload payload))))))
      (_ (variant None unit)))))

(def Protoss.tcTypeArgRecordField (-> TypeExpr (Maybe ProtossField))
  (lambda (typ TypeExpr)
    (case typ
      (PTApply app
        (caseList (get app args)
          (Nil (variant None unit))
          (Cons payload rest
            (variant Some
              (record
                (name (get app name))
                (typ payload))))))
      (_ (variant None unit)))))

(def Protoss.tcRecordFieldsOfType
  (-> TypeEnv (-> TypeExpr (Maybe (List ProtossField))))
  (lambda (env TypeEnv)
    (lambda (typ TypeExpr)
      (case ((Protoss.tcUnfoldType env) typ)
        (PTApply app
          (case ((String.eqString (get app name)) "Record")
            (false (variant None unit))
            (true
              (foldList (get app args)
                (variant (Maybe (List ProtossField)) Some
                  (Nil ProtossField))
                (lambda (arg TypeExpr)
                  (lambda (acc (Maybe (List ProtossField)))
                    (case acc
                      (None _ (variant None unit))
                      (Some fields
                        (case (Protoss.tcTypeArgRecordField arg)
                          (None _ (variant None unit))
                          (Some fieldDecl
                            (variant Some
                              (Cons ProtossField fieldDecl fields))))))))))))
        (_ (variant None unit))))))

(def Protoss.tcVariantCasesOfType
  (-> TypeEnv (-> TypeExpr (Maybe (List ProtossVariantCase))))
  (lambda (env TypeEnv)
    (lambda (typ TypeExpr)
      (case ((Protoss.tcUnfoldType env) typ)
        (PTApply app
          (case ((String.eqString (get app name)) "Variant")
            (false (variant None unit))
            (true
              (foldList (get app args)
                (variant (Maybe (List ProtossVariantCase)) Some
                  (Nil ProtossVariantCase))
                (lambda (arg TypeExpr)
                  (lambda (acc (Maybe (List ProtossVariantCase)))
                    (case acc
                      (None _ (variant None unit))
                      (Some cases
                        (case (Protoss.tcTypeArgVariantCase arg)
                          (None _ (variant None unit))
                          (Some caseDecl
                            (variant Some
                              (Cons ProtossVariantCase caseDecl cases))))))))))))
        (_ (variant None unit))))))

(def Protoss.tcListItemType (-> TypeEnv (-> TypeExpr (Maybe TypeExpr)))
  (lambda (env TypeEnv)
    (lambda (listType TypeExpr)
      (case ((Protoss.tcUnfoldType env) listType)
        (PTApply app
          (case ((String.eqString (get app name)) "List")
            (true
              (caseList (get app args)
                (Nil (variant None unit))
                (Cons item rest (variant Some item))))
            (false (variant None unit))))
        (_ (variant None unit))))))

(def Protoss.tcProcessItemType (-> TypeEnv (-> TypeExpr (Maybe TypeExpr)))
  (lambda (env TypeEnv)
    (lambda (processType TypeExpr)
      (case ((Protoss.tcUnfoldType env) processType)
        (PTApply app
          (case ((String.eqString (get app name)) "Process")
            (true
              (caseList (get app args)
                (Nil (variant None unit))
                (Cons item rest (variant Some item))))
            (false (variant None unit))))
        (_ (variant None unit))))))

(def Protoss.tcCheckProcessLetFlow
  (-> TypeEnv (-> String (-> TypeExpr (-> TypeExpr (-> String (Result TypeError TypeExpr))))))
  (lambda (typeEnv TypeEnv)
    (lambda (name String)
      (lambda (valueType TypeExpr)
        (lambda (expected TypeExpr)
          (lambda (summary String)
            (case ((Protoss.tcProcessItemType typeEnv) valueType)
              (None _ (Protoss.tcOk expected))
              (Some itemType
                (case ((Protoss.tcProcessItemType typeEnv) expected)
                  (Some expectedItem (Protoss.tcOk expected))
                  (None _
                    ((((Protoss.tcMismatch Protoss.tcNoDef) valueType) expected)
                      ((String.concat "Process used as pure value in let ") name))))))))))))

(def Protoss.tcFindCaseBranch
  (-> String (-> (List ProtossCaseBranch) (Maybe ProtossCaseBranch)))
  (lambda (constructor String)
    (lambda (branches (List ProtossCaseBranch))
      (foldList branches (variant (Maybe ProtossCaseBranch) None unit)
        (lambda (branch ProtossCaseBranch)
          (lambda (found (Maybe ProtossCaseBranch))
            (case ((String.eqString (get branch constructor)) constructor)
              (true (variant Some branch))
              (false found))))))))

(def Protoss.tcMissingVariantBranch
  (-> (List ProtossVariantCase) (-> (List ProtossCaseBranch) (Maybe String)))
  (lambda (cases (List ProtossVariantCase))
    (lambda (branches (List ProtossCaseBranch))
      (foldList cases (variant (Maybe String) None unit)
        (lambda (caseDecl ProtossVariantCase)
          (lambda (missing (Maybe String))
            (case missing
              (Some name (variant Some name))
              (None
                (case ((Protoss.tcFindCaseBranch (get caseDecl name)) branches)
                  (Some branch (variant None unit))
                  (None _ (variant Some (get caseDecl name))))))))))))

(def Protoss.tcFindCaseBranchCheck
  (-> String (-> (List TypecheckCaseBranchCheck) (Maybe TypecheckCaseBranchCheck)))
  (lambda (constructor String)
    (lambda (branches (List TypecheckCaseBranchCheck))
      (foldList branches (variant (Maybe TypecheckCaseBranchCheck) None unit)
        (lambda (branch TypecheckCaseBranchCheck)
          (lambda (found (Maybe TypecheckCaseBranchCheck))
            (case ((String.eqString (get branch constructor)) constructor)
	              (true (variant Some branch))
	              (false found))))))))

(def Protoss.tcFindVariantCase
  (-> String (-> (List ProtossVariantCase) (Maybe ProtossVariantCase)))
  (lambda (constructor String)
    (lambda (cases (List ProtossVariantCase))
      (foldList cases (variant (Maybe ProtossVariantCase) None unit)
        (lambda (caseDecl ProtossVariantCase)
          (lambda (found (Maybe ProtossVariantCase))
            (case ((String.eqString (get caseDecl name)) constructor)
              (true (variant Some caseDecl))
              (false found))))))))

(def Protoss.tcFindRecordField
  (-> String (-> (List ProtossField) (Maybe ProtossField)))
  (lambda (name String)
    (lambda (fields (List ProtossField))
      (foldList fields (variant (Maybe ProtossField) None unit)
        (lambda (field ProtossField)
          (lambda (found (Maybe ProtossField))
            (case ((String.eqString (get field name)) name)
              (true (variant Some field))
              (false found))))))))

(def Protoss.tcFindRecordFieldExpr
  (-> String (-> (List ProtossRecordFieldExpr) (Maybe ProtossRecordFieldExpr)))
  (lambda (name String)
    (lambda (fields (List ProtossRecordFieldExpr))
      (foldList fields (variant (Maybe ProtossRecordFieldExpr) None unit)
        (lambda (field ProtossRecordFieldExpr)
          (lambda (found (Maybe ProtossRecordFieldExpr))
            (case ((String.eqString (get field name)) name)
              (true (variant Some field))
              (false found))))))))

(def Protoss.tcMissingRecordFieldExpr
  (-> (List ProtossField) (-> (List ProtossRecordFieldExpr) (Maybe String)))
  (lambda (expectedFields (List ProtossField))
    (lambda (fields (List ProtossRecordFieldExpr))
      (foldList expectedFields (variant (Maybe String) None unit)
        (lambda (field ProtossField)
          (lambda (missing (Maybe String))
            (case missing
              (Some name (variant Some name))
              (None
                (case ((Protoss.tcFindRecordFieldExpr (get field name)) fields)
                  (Some fieldExpr (variant None unit))
                  (None _ (variant Some (get field name))))))))))))

(def Protoss.tcMissingVariantCheckBranch
  (-> (List ProtossVariantCase) (-> (List TypecheckCaseBranchCheck) (Maybe String)))
  (lambda (cases (List ProtossVariantCase))
    (lambda (branches (List TypecheckCaseBranchCheck))
      (foldList cases (variant (Maybe String) None unit)
        (lambda (caseDecl ProtossVariantCase)
          (lambda (missing (Maybe String))
            (case missing
              (Some name (variant Some name))
              (None
                (case ((Protoss.tcFindCaseBranchCheck (get caseDecl name)) branches)
	                  (Some branch (variant None unit))
	                  (None _ (variant Some (get caseDecl name))))))))))))

(def Protoss.tcUnknownVariantCheckBranch
  (-> (List ProtossVariantCase) (-> (List TypecheckCaseBranchCheck) (Maybe String)))
  (lambda (cases (List ProtossVariantCase))
    (lambda (branches (List TypecheckCaseBranchCheck))
      (foldList branches (variant (Maybe String) None unit)
        (lambda (branch TypecheckCaseBranchCheck)
          (lambda (unknown (Maybe String))
            (case unknown
              (Some name (variant Some name))
              (None
                (case ((Protoss.tcFindVariantCase (get branch constructor)) cases)
                  (Some caseDecl (variant None unit))
                  (None _ (variant Some (get branch constructor))))))))))))

(def Protoss.tcFindExpectedCaseBranchCheck
  (-> String (-> (List TypecheckExpectedCaseBranchCheck)
    (Maybe TypecheckExpectedCaseBranchCheck)))
  (lambda (constructor String)
    (lambda (branches (List TypecheckExpectedCaseBranchCheck))
      (foldList branches (variant (Maybe TypecheckExpectedCaseBranchCheck) None unit)
        (lambda (branch TypecheckExpectedCaseBranchCheck)
          (lambda (found (Maybe TypecheckExpectedCaseBranchCheck))
            (case ((String.eqString (get branch constructor)) constructor)
              (true (variant Some branch))
              (false found))))))))

(def Protoss.tcMissingExpectedVariantCheckBranch
  (-> (List ProtossVariantCase) (-> (List TypecheckExpectedCaseBranchCheck) (Maybe String)))
  (lambda (cases (List ProtossVariantCase))
    (lambda (branches (List TypecheckExpectedCaseBranchCheck))
      (foldList cases (variant (Maybe String) None unit)
        (lambda (caseDecl ProtossVariantCase)
          (lambda (missing (Maybe String))
            (case missing
              (Some name (variant Some name))
              (None
                (case ((Protoss.tcFindExpectedCaseBranchCheck (get caseDecl name)) branches)
                  (Some branch (variant None unit))
                  (None _ (variant Some (get caseDecl name))))))))))))

(def Protoss.tcUnknownExpectedVariantCheckBranch
  (-> (List ProtossVariantCase) (-> (List TypecheckExpectedCaseBranchCheck) (Maybe String)))
  (lambda (cases (List ProtossVariantCase))
    (lambda (branches (List TypecheckExpectedCaseBranchCheck))
      (foldList branches (variant (Maybe String) None unit)
        (lambda (branch TypecheckExpectedCaseBranchCheck)
          (lambda (unknown (Maybe String))
            (case unknown
              (Some name (variant Some name))
              (None
                (case ((Protoss.tcFindVariantCase (get branch constructor)) cases)
                  (Some caseDecl (variant None unit))
                  (None _ (variant Some (get branch constructor))))))))))))

(def Protoss.tcRunCaseBranchCheck
  (-> TypeEnv (-> TermEnv (-> TypeExpr
    (-> TypecheckCaseBranchCheck (Result TypeError TypeExpr)))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (payloadType TypeExpr)
        (lambda (branch TypecheckCaseBranchCheck)
          (case (get branch binder)
            (None _
              (case (((Protoss.tcTypeEq typeEnv) Protoss.tcUnit) payloadType)
                (true (((get branch bodyCheck) typeEnv) termEnv))
                (false
                  (Protoss.tcErr
                    ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                      (Protoss.tcSomeType payloadType))
                      Protoss.tcNoType)
                      (get branch constructor))
                      "variant branch requires payload binder")))))
            (Some name
              (((get branch bodyCheck) typeEnv)
                (((TermEnv.insert name) payloadType) termEnv)))))))))

(def Protoss.tcRunExpectedCaseBranchCheck
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> TypeExpr
    (-> TypecheckExpectedCaseBranchCheck (Result TypeError TypeExpr))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (payloadType TypeExpr)
        (lambda (expected TypeExpr)
          (lambda (branch TypecheckExpectedCaseBranchCheck)
            (case (get branch binder)
              (None _
                (case (((Protoss.tcTypeEq typeEnv) Protoss.tcUnit) payloadType)
                  (true ((((get branch bodyCheck) typeEnv) termEnv) expected))
                  (false
                    (Protoss.tcErr
                      ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                        (Protoss.tcSomeType payloadType))
                        Protoss.tcNoType)
                        (get branch constructor))
                        "variant branch requires payload binder")))))
              (Some name
                ((((get branch bodyCheck) typeEnv)
                  (((TermEnv.insert name) payloadType) termEnv))
                  expected)))))))))

(def Protoss.tcRequestResultType (-> ProtossRequest TypeExpr)
  (lambda (request ProtossRequest)
    (case request
      (PRAskHuman prompt Protoss.tcString)
      (PRHttpGet url Protoss.tcString)
      (PRClockRead _ Protoss.tcString)
      (PRSaveLocal payload Protoss.tcUnit)
      (PRLoadLocal key Protoss.tcString)
      (PRServerRequest payload Protoss.tcString))))

(def Protoss.tcCheckVariantCaseBranches
  (-> TypeEnv (-> TermEnv (-> (List TypecheckCaseBranchCheck)
    (-> (List ProtossVariantCase) (-> Expr (Result TypeError TypeExpr))))))
  (lambda (typeEnv TypeEnv)
	    (lambda (termEnv TermEnv)
	      (lambda (branches (List TypecheckCaseBranchCheck))
	        (lambda (cases (List ProtossVariantCase))
	          (lambda (summaryExpr Expr)
	            (case ((Protoss.tcUnknownVariantCheckBranch cases) branches)
	              (Some unknown
	                (Protoss.tcErr
	                  ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
	                    Protoss.tcNoType)
	                    Protoss.tcNoType)
	                    unknown)
	                    ((String.concat "variant case unknown branch: ") unknown))))
	              (None _
	                (let (folded (Result TypeError (Maybe TypeExpr))
	                  (foldList cases
	                    (variant (Result TypeError (Maybe TypeExpr)) Ok
	                      (variant (Maybe TypeExpr) None unit))
	                    (lambda (caseDecl ProtossVariantCase)
	                      (lambda (acc (Result TypeError (Maybe TypeExpr)))
	                        (case acc
	                          (Err err (variant Err err))
	                          (Ok resultType
	                            (case ((Protoss.tcFindCaseBranchCheck (get caseDecl name)) branches)
	                              (None _
	                                (variant (Result TypeError (Maybe TypeExpr)) Err
	                                  ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
	                                    Protoss.tcNoType)
	                                    Protoss.tcNoType)
	                                    (get caseDecl name))
	                                    ((String.concat "variant case missing branch: ")
	                                      (get caseDecl name)))))
	                              (Some branch
	                                (case ((((Protoss.tcRunCaseBranchCheck typeEnv) termEnv)
	                                        (get caseDecl payload))
	                                        branch)
	                                  (Err err (variant Err err))
	                                  (Ok branchType
	                                    (case resultType
	                                      (None _
	                                        (variant (Result TypeError (Maybe TypeExpr)) Ok
	                                          (variant Some branchType)))
	                                      (Some expectedType
	                                        (case (((Protoss.tcTypeEq typeEnv) expectedType) branchType)
	                                          (true
	                                            (variant (Result TypeError (Maybe TypeExpr)) Ok
	                                              (variant Some expectedType)))
	                                          (false
	                                            (case ((((Protoss.tcMismatch Protoss.tcNoDef)
	                                                    expectedType)
	                                                    branchType)
	                                                    (Protoss.renderExpr summaryExpr))
	                                              (Err err
	                                                (variant (Result TypeError (Maybe TypeExpr)) Err err))
	                                              (Ok ignored
	                                                (variant (Result TypeError (Maybe TypeExpr)) Ok
	                                                  (variant Some expectedType))))))))))))))))))
	                  (case folded
	                    (Err err (variant Err err))
	                    (Ok resultType
	                      (case resultType
	                        (None _
	                          (Protoss.tcErr
	                            ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
	                              Protoss.tcNoType)
	                              Protoss.tcNoType)
	                              (Protoss.renderExpr summaryExpr))
	                              "variant case has no branches")))
                        (Some result (Protoss.tcOk result))))))))))))))

(def Protoss.tcCheckVariantCaseBranchesAs
  (-> TypeEnv (-> TermEnv (-> (List TypecheckExpectedCaseBranchCheck)
    (-> (List ProtossVariantCase) (-> TypeExpr (-> Expr (Result TypeError TypeExpr)))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (branches (List TypecheckExpectedCaseBranchCheck))
        (lambda (cases (List ProtossVariantCase))
          (lambda (expected TypeExpr)
            (lambda (summaryExpr Expr)
              (case ((Protoss.tcUnknownExpectedVariantCheckBranch cases) branches)
                (Some unknown
                  (Protoss.tcErr
                    ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                      Protoss.tcNoType)
                      Protoss.tcNoType)
                      unknown)
                      ((String.concat "variant case unknown branch: ") unknown))))
                (None _
                  (case ((Protoss.tcMissingExpectedVariantCheckBranch cases) branches)
                    (Some missing
                      (Protoss.tcErr
                        ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                          Protoss.tcNoType)
                          Protoss.tcNoType)
                          missing)
                          ((String.concat "variant case missing branch: ") missing))))
                    (None _
                      (foldList cases
                        (Protoss.tcOk expected)
                        (lambda (caseDecl ProtossVariantCase)
                          (lambda (acc (Result TypeError TypeExpr))
                            (case acc
                              (Err err (variant Err err))
                              (Ok ignored
                                (case ((Protoss.tcFindExpectedCaseBranchCheck
                                        (get caseDecl name))
                                        branches)
                                  (None _
                                    (Protoss.tcErr
                                      ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                                        Protoss.tcNoType)
                                        Protoss.tcNoType)
                                        (get caseDecl name))
                                        ((String.concat "variant case missing branch: ")
                                          (get caseDecl name)))))
                                  (Some branch
                                    (((((Protoss.tcRunExpectedCaseBranchCheck typeEnv)
                                      termEnv)
                                      (get caseDecl payload))
                                      expected)
                                      branch)))))))))))))))))))

(def Protoss.tcErrorWithDefinition (-> String (-> TypeError TypeError))
  (lambda (name String)
    (lambda (err TypeError)
      (record
        (code (get err code))
        (definition
          (case (get err definition)
            (Some existing (variant Some existing))
            (None _ (variant Some name))))
        (expected (get err expected))
        (actual (get err actual))
        (summary (get err summary))
        (span (get err span))
        (message (get err message))))))

(def Protoss.tcAtomExpr
  (-> TypeEnv (-> TermEnv (-> Expr (Result TypeError TypeExpr))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expr Expr)
        (case expr
          (PEUnit (Protoss.tcOk Protoss.tcUnit))
          (PEBool value (Protoss.tcOk Protoss.tcBool))
          (PEString value (Protoss.tcOk Protoss.tcString))
          (PEVar name
            (case (Protoss.isNatLiteralName name)
              (true (Protoss.tcOk Protoss.tcNat))
              (false
                (case ((TermEnv.lookup name) termEnv)
                  (Some typ (Protoss.tcOk typ))
                  (None _
                    (Protoss.tcErr
                      ((((((Protoss.tcError "SELF_TC001") Protoss.tcNoDef)
                        Protoss.tcNoType)
                        Protoss.tcNoType)
                        name)
                        ((String.concat "unknown variable: ") name))))))))
          (_
            ((Protoss.tcUnsupported Protoss.tcNoDef)
              (Protoss.renderExpr expr))))))))

(defrec Protoss.tcExprGo
  (-> Expr (-> TypeEnv (-> TermEnv (Result TypeError TypeExpr))))
  (variant expr)
  (PEUnit
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (Protoss.tcOk Protoss.tcUnit))))
  (PEBool value
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (Protoss.tcOk Protoss.tcBool))))
  (PEString value
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (Protoss.tcOk Protoss.tcString))))
  (PEVar name
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (case (Protoss.isNatLiteralName name)
          (true (Protoss.tcOk Protoss.tcNat))
          (false
            (case ((TermEnv.lookup name) termEnv)
              (Some typ (Protoss.tcOk typ))
              (None _
                (Protoss.tcErr
                  ((((((Protoss.tcError "SELF_TC001") Protoss.tcNoDef)
                    Protoss.tcNoType)
                    Protoss.tcNoType)
                    name)
                    ((String.concat "unknown variable: ") name))))))))))
  (PELambda lam
    (let (bodyCheck (recur (get lam body)))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (let (param ProtossParam (get lam param))
            (case ((bodyCheck typeEnv)
                    (((TermEnv.insert (get param name)) (get param typ)) termEnv))
              (Err err (variant Err err))
              (Ok bodyType
                (Protoss.tcOk ((Protoss.tcFun (get param typ)) bodyType)))))))))
  (PELet letExpr
    (let (valueCheck (recur (get letExpr value)))
      (let (bodyCheck (recur (get letExpr body)))
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (case ((valueCheck typeEnv) termEnv)
              (Err err (variant Err err))
              (Ok valueType
                (case (get letExpr typ)
                  (None _
                    ((bodyCheck typeEnv)
                      (((TermEnv.insert (get letExpr name)) valueType) termEnv)))
                  (Some annotation
                    (case (((Protoss.tcTypeEq typeEnv) annotation) valueType)
                      (false
                        ((((Protoss.tcMismatch Protoss.tcNoDef) annotation) valueType)
                          (Protoss.renderExpr (get letExpr value))))
                      (true
                        ((bodyCheck typeEnv)
                          (((TermEnv.insert (get letExpr name)) annotation) termEnv)))))))))))))
  (PEApply call
    (let (fnCheck (recur (get call fn)))
      (let (argsCheck
        (foldList (get call args)
          (lambda (typeEnv TypeEnv)
            (lambda (termEnv TermEnv)
              (lambda (currentType TypeExpr)
                (Protoss.tcOk currentType))))
          (lambda (arg Expr)
            (lambda (acc (-> TypeEnv (-> TermEnv (-> TypeExpr (Result TypeError TypeExpr)))))
              (let (argCheck (recur arg))
                (lambda (typeEnv TypeEnv)
                  (lambda (termEnv TermEnv)
                    (lambda (currentType TypeExpr)
                      (case ((Protoss.tcUnfoldType typeEnv) currentType)
                        (PTFun pair
                          (case ((argCheck typeEnv) termEnv)
                            (Err err (variant Err err))
                            (Ok argType
                              (case (((Protoss.tcTypeEq typeEnv) (get pair first)) argType)
                                (true (((acc typeEnv) termEnv) (get pair second)))
                                (false
                                  ((((Protoss.tcMismatch Protoss.tcNoDef)
                                    (get pair first))
                                    argType)
                                    (Protoss.renderExpr arg)))))))
                        (_
                          (Protoss.tcErr
                            ((((((Protoss.tcError "SELF_TC003") Protoss.tcNoDef)
                              Protoss.tcNoType)
                              (Protoss.tcSomeType currentType))
                              (Protoss.renderExpr arg))
                              ((String.concat "application of non-function: ")
                                (Protoss.renderType currentType))))))))))))))
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (case ((fnCheck typeEnv) termEnv)
              (Err err (variant Err err))
              (Ok fnType (((argsCheck typeEnv) termEnv) fnType))))))))
  (PERecord fields
    (let (fieldsCheck
      (foldList fields
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (variant (Result TypeError (List TypeExpr)) Ok (Nil TypeExpr))))
        (lambda (field ProtossRecordFieldExpr)
          (lambda (acc (-> TypeEnv (-> TermEnv (Result TypeError (List TypeExpr)))))
            (let (fieldCheck (recur (get field expr)))
              (lambda (typeEnv TypeEnv)
                (lambda (termEnv TermEnv)
                  (case ((fieldCheck typeEnv) termEnv)
                    (Err err (variant Err err))
                    (Ok fieldType
                      (case ((acc typeEnv) termEnv)
                        (Err err (variant Err err))
                        (Ok fieldTypes
                          (variant (Result TypeError (List TypeExpr)) Ok
                            (Cons TypeExpr
                              ((Protoss.tcApplyType (get field name))
                                (Cons TypeExpr fieldType (Nil TypeExpr)))
                              fieldTypes)))))))))))))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (case ((fieldsCheck typeEnv) termEnv)
            (Err err (variant Err err))
            (Ok fieldTypes
              (Protoss.tcOk ((Protoss.tcApplyType "Record") fieldTypes))))))))
  (PEField fieldExpr
    (let (targetCheck (recur (get fieldExpr target)))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (case ((targetCheck typeEnv) termEnv)
            (Err err (variant Err err))
            (Ok targetType
              (case (((Protoss.tcFieldType typeEnv) targetType) (get fieldExpr field))
                (Some fieldType (Protoss.tcOk fieldType))
                (None _
                  (Protoss.tcErr
                    ((((((Protoss.tcError "SELF_TC006") Protoss.tcNoDef)
                      Protoss.tcNoType)
                      (Protoss.tcSomeType targetType))
                      (Protoss.renderExpr expr))
                      ((String.concat "unknown record field: ") (get fieldExpr field))))))))))))
  (PEVariant variantExpr
    (let (payloadCheck (recur (get variantExpr payload)))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (case (get variantExpr typeHint)
            (None _
              ((Protoss.tcUnsupported Protoss.tcNoDef) "inferred variant constructor"))
            (Some targetType
              (case (((Protoss.tcVariantPayloadType typeEnv) targetType)
                      (get variantExpr constructor))
                (None _
                  (Protoss.tcErr
                    ((((((Protoss.tcError "SELF_TC007") Protoss.tcNoDef)
                      Protoss.tcNoType)
                      (Protoss.tcSomeType targetType))
                      (Protoss.renderExpr expr))
                      ((String.concat "unknown variant constructor: ")
                        (get variantExpr constructor)))))
                (Some payloadType
                  (case ((payloadCheck typeEnv) termEnv)
                    (Err err (variant Err err))
                    (Ok actualPayload
                      (case (((Protoss.tcTypeEq typeEnv) payloadType) actualPayload)
                        (true (Protoss.tcOk targetType))
                        (false
                          ((((Protoss.tcMismatch Protoss.tcNoDef) payloadType)
                            actualPayload)
                            (Protoss.renderExpr (get variantExpr payload)))))))))))))))
  (PENil nilExpr
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (case (get nilExpr typ)
          (Some itemType (Protoss.tcOk (Protoss.tcList itemType)))
          (None _ ((Protoss.tcUnsupported Protoss.tcNoDef) "unannotated Nil"))))))
  (PECons consExpr
    (let (headCheck (recur (get consExpr head)))
      (let (tailCheck (recur (get consExpr tail)))
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (case (get consExpr typ)
              (Some itemType
                (case ((headCheck typeEnv) termEnv)
                  (Err err (variant Err err))
                  (Ok headType
                    (case (((Protoss.tcTypeEq typeEnv) itemType) headType)
                      (false
                        ((((Protoss.tcMismatch Protoss.tcNoDef) itemType) headType)
                          (Protoss.renderExpr (get consExpr head))))
                      (true
                        (case ((tailCheck typeEnv) termEnv)
                          (Err err (variant Err err))
                          (Ok tailType
                            (case (((Protoss.tcTypeEq typeEnv) (Protoss.tcList itemType)) tailType)
                              (true (Protoss.tcOk tailType))
                              (false
                                ((((Protoss.tcMismatch Protoss.tcNoDef)
                                  (Protoss.tcList itemType))
                                  tailType)
                                  (Protoss.renderExpr (get consExpr tail))))))))))))
              (None _
                (case ((tailCheck typeEnv) termEnv)
                  (Err err (variant Err err))
                  (Ok tailType
                    (case ((Protoss.tcListItemType typeEnv) tailType)
                      (None _
                        ((Protoss.tcUnsupported Protoss.tcNoDef) "unannotated Cons tail"))
                      (Some itemType
                        (case ((headCheck typeEnv) termEnv)
                          (Err err (variant Err err))
                          (Ok headType
                            (case (((Protoss.tcTypeEq typeEnv) itemType) headType)
                              (true (Protoss.tcOk tailType))
                              (false
                                ((((Protoss.tcMismatch Protoss.tcNoDef) itemType) headType)
                                  (Protoss.renderExpr (get consExpr head))))))))))))))))))
  (PEFoldNat foldNatExpr
    (let (targetCheck (recur (get foldNatExpr target)))
      (let (zeroCheck (recur (get foldNatExpr zero)))
        (let (stepCheck (recur (get foldNatExpr step)))
          (lambda (typeEnv TypeEnv)
            (lambda (termEnv TermEnv)
              (case ((targetCheck typeEnv) termEnv)
                (Err err (variant Err err))
                (Ok targetType
                  (case (((Protoss.tcTypeEq typeEnv) Protoss.tcNat) targetType)
                    (false
                      ((((Protoss.tcMismatch Protoss.tcNoDef) Protoss.tcNat) targetType)
                        (Protoss.renderExpr (get foldNatExpr target))))
                    (true
                      (case ((zeroCheck typeEnv) termEnv)
                        (Err err (variant Err err))
                        (Ok resultType
                          (case ((stepCheck typeEnv) termEnv)
                            (Err err (variant Err err))
                            (Ok stepType
                              (let (expectedStep TypeExpr ((Protoss.tcFun resultType) resultType))
                                (case (((Protoss.tcTypeEq typeEnv) expectedStep) stepType)
                                  (true (Protoss.tcOk resultType))
                                  (false
                                    ((((Protoss.tcMismatch Protoss.tcNoDef) expectedStep) stepType)
                                      (Protoss.renderExpr (get foldNatExpr step))))))))))))))))))))
  (PEFoldList foldListExpr
    (let (targetCheck (recur (get foldListExpr target)))
      (let (zeroCheck (recur (get foldListExpr zero)))
        (let (stepCheck (recur (get foldListExpr step)))
          (lambda (typeEnv TypeEnv)
            (lambda (termEnv TermEnv)
              (case ((targetCheck typeEnv) termEnv)
                (Err err (variant Err err))
                (Ok targetType
                  (case ((Protoss.tcListItemType typeEnv) targetType)
                    (None _
                      (Protoss.tcErr
                        ((((((Protoss.tcError "SELF_TC002") Protoss.tcNoDef)
                          Protoss.tcNoType)
                          (Protoss.tcSomeType targetType))
                          (Protoss.renderExpr (get foldListExpr target)))
                          "foldList target must be List")))
                    (Some itemType
                      (case ((zeroCheck typeEnv) termEnv)
                        (Err err (variant Err err))
                        (Ok resultType
                          (case ((stepCheck typeEnv) termEnv)
                            (Err err (variant Err err))
                            (Ok stepType
                              (let (expectedStep TypeExpr
                                ((Protoss.tcFun itemType) ((Protoss.tcFun resultType) resultType)))
                                (case (((Protoss.tcTypeEq typeEnv) expectedStep) stepType)
                                  (true (Protoss.tcOk resultType))
                                  (false
                                    ((((Protoss.tcMismatch Protoss.tcNoDef) expectedStep) stepType)
                                      (Protoss.renderExpr (get foldListExpr step))))))))))))))))))))
  (PECaseList caseListExpr
    (let (targetCheck (recur (get caseListExpr target)))
      (let (nilCheck (recur (get caseListExpr nilBody)))
        (let (consCheck (recur (get caseListExpr consBody)))
          (lambda (typeEnv TypeEnv)
            (lambda (termEnv TermEnv)
              (case ((targetCheck typeEnv) termEnv)
                (Err err (variant Err err))
                (Ok targetType
                  (case ((Protoss.tcListItemType typeEnv) targetType)
                    (None _
                      (Protoss.tcErr
                        ((((((Protoss.tcError "SELF_TC002") Protoss.tcNoDef)
                          Protoss.tcNoType)
                          (Protoss.tcSomeType targetType))
                          (Protoss.renderExpr (get caseListExpr target)))
                          "caseList target must be List")))
                    (Some itemType
                      (case ((nilCheck typeEnv) termEnv)
                        (Err err (variant Err err))
                        (Ok resultType
                          (let (branchEnv TermEnv
                            (((TermEnv.insert (get caseListExpr head)) itemType)
                              (((TermEnv.insert (get caseListExpr tail))
                                (Protoss.tcList itemType))
                                termEnv)))
                            (case ((consCheck typeEnv) branchEnv)
                              (Err err (variant Err err))
                              (Ok consType
                                (case (((Protoss.tcTypeEq typeEnv) resultType) consType)
                                  (true (Protoss.tcOk resultType))
                                  (false
                                    ((((Protoss.tcMismatch Protoss.tcNoDef) resultType) consType)
                                      (Protoss.renderExpr (get caseListExpr consBody))))))))))))))))))))
  (PECase caseExpr
    (let (scrutCheck (recur (get caseExpr scrutinee)))
      (let (branchChecks
        (foldList (get caseExpr branches)
          (Nil TypecheckCaseBranchCheck)
          (lambda (branch ProtossCaseBranch)
            (lambda (acc (List TypecheckCaseBranchCheck))
              (let (bodyCheck (recur (get branch body)))
                (Cons TypecheckCaseBranchCheck
                  (record
                    (constructor (get branch constructor))
                    (binder (get branch binder))
                    (bodyCheck bodyCheck))
                  acc))))))
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (case ((scrutCheck typeEnv) termEnv)
              (Err err (variant Err err))
              (Ok scrutType
                (case (((Protoss.tcTypeEq typeEnv) Protoss.tcBool) scrutType)
                  (true
                    (case ((Protoss.tcFindCaseBranchCheck "true") branchChecks)
                      (None _
                        (Protoss.tcErr
                          ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                            (Protoss.tcSomeType Protoss.tcBool))
                            Protoss.tcNoType)
                            (Protoss.renderExpr expr))
                            "Bool case missing true branch")))
                      (Some trueBranch
                        (case ((Protoss.tcFindCaseBranchCheck "false") branchChecks)
                          (None _
                            (Protoss.tcErr
                              ((((((Protoss.tcError "SELF_TC009") Protoss.tcNoDef)
                                (Protoss.tcSomeType Protoss.tcBool))
                                Protoss.tcNoType)
                                (Protoss.renderExpr expr))
                                "Bool case missing false branch")))
                          (Some falseBranch
                            (case (((get trueBranch bodyCheck) typeEnv) termEnv)
                              (Err err (variant Err err))
                              (Ok trueType
                                (case (((get falseBranch bodyCheck) typeEnv) termEnv)
                                  (Err err (variant Err err))
                                  (Ok falseType
                                    (case (((Protoss.tcTypeEq typeEnv) trueType) falseType)
                                      (true (Protoss.tcOk trueType))
                                      (false
                                        ((((Protoss.tcMismatch Protoss.tcNoDef) trueType) falseType)
                                          (Protoss.renderExpr expr)))))))))))))
                  (false
                    (case ((Protoss.tcVariantCasesOfType typeEnv) scrutType)
                      (None _
                        ((Protoss.tcUnsupported Protoss.tcNoDef)
                          ((String.concat "case on unsupported type ")
                            (Protoss.renderType scrutType))))
                      (Some variantCases
                        (((((Protoss.tcCheckVariantCaseBranches typeEnv) termEnv)
                          branchChecks)
                          variantCases)
                          expr))))))))))))
  (PEDone value
    (let (valueCheck (recur value))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (case ((valueCheck typeEnv) termEnv)
            (Err err (variant Err err))
            (Ok valueType (Protoss.tcOk (Protoss.tcProcess valueType))))))))
  (PEBind bindExpr
    (let (processCheck (recur (get bindExpr process)))
      (let (bodyCheck (recur (get bindExpr body)))
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (case ((processCheck typeEnv) termEnv)
              (Err err (variant Err err))
              (Ok processType
                (case ((Protoss.tcProcessItemType typeEnv) processType)
                  (None _
                    ((((Protoss.tcMismatch Protoss.tcNoDef)
                      (Protoss.tcProcess (get bindExpr typ)))
                      processType)
                      (Protoss.renderExpr (get bindExpr process))))
                  (Some processItemType
                    (case (((Protoss.tcTypeEq typeEnv) (get bindExpr typ)) processItemType)
                      (false
                        ((((Protoss.tcMismatch Protoss.tcNoDef)
                          (get bindExpr typ))
                          processItemType)
                          (get bindExpr param)))
                      (true
                        (case ((bodyCheck typeEnv)
                                (((TermEnv.insert (get bindExpr param)) processItemType) termEnv))
                          (Err err (variant Err err))
                          (Ok bodyType
                            (case ((Protoss.tcProcessItemType typeEnv) bodyType)
                              (Some resultType (Protoss.tcOk bodyType))
                              (None _
                                (Protoss.tcErr
                                  ((((((Protoss.tcError "SELF_TC002") Protoss.tcNoDef)
                                    Protoss.tcNoType)
                                    (Protoss.tcSomeType bodyType))
                                    (Protoss.renderExpr (get bindExpr body)))
                                    "bind body must return Process")))))))))))))))))
  (PERequest request
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (Protoss.tcOk (Protoss.tcProcess (Protoss.tcRequestResultType request))))))
  (PEFoldVariant foldVariantExpr
    (let (scrutCheck (recur (get foldVariantExpr scrutinee)))
      (let (branchChecks
        (foldList (get foldVariantExpr branches)
          (Nil TypecheckCaseBranchCheck)
          (lambda (branch ProtossCaseBranch)
            (lambda (acc (List TypecheckCaseBranchCheck))
              (let (bodyCheck (recur (get branch body)))
                (Cons TypecheckCaseBranchCheck
                  (record
                    (constructor (get branch constructor))
                    (binder (get branch binder))
                    (bodyCheck bodyCheck))
                  acc))))))
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (case ((scrutCheck typeEnv) termEnv)
              (Err err (variant Err err))
              (Ok scrutType
                (case (((Protoss.tcTypeEq typeEnv) (get foldVariantExpr target)) scrutType)
                  (false
                    ((((Protoss.tcMismatch Protoss.tcNoDef)
                      (get foldVariantExpr target))
                      scrutType)
                      (Protoss.renderExpr (get foldVariantExpr scrutinee))))
                  (true
                    (case ((Protoss.tcVariantCasesOfType typeEnv)
                            (get foldVariantExpr target))
                      (None _
                        (Protoss.tcErr
                          ((((((Protoss.tcError "SELF_TC002") Protoss.tcNoDef)
                            Protoss.tcNoType)
                            (Protoss.tcSomeType (get foldVariantExpr target)))
                            (Protoss.renderType (get foldVariantExpr target)))
                            "foldVariant target must be Variant")))
                      (Some variantCases
                        (case (((((Protoss.tcCheckVariantCaseBranches typeEnv) termEnv)
                                branchChecks)
                                variantCases)
                                expr)
                          (Err err (variant Err err))
                          (Ok branchResultType
                            (case (((Protoss.tcTypeEq typeEnv)
                                    (get foldVariantExpr result))
                                    branchResultType)
                              (true (Protoss.tcOk (get foldVariantExpr result)))
                              (false
                                ((((Protoss.tcMismatch Protoss.tcNoDef)
                                  (get foldVariantExpr result))
                                  branchResultType)
	                                  (Protoss.renderExpr expr)))))))))))))))))
  (PEInst instExpr
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (case ((TermEnv.lookupPoly (get instExpr name)) termEnv)
          (None _
            ((Protoss.tcInstError (get instExpr name))
              ((String.concat "unknown polymorphic definition: ")
                (get instExpr name))))
          (Some scheme
            (((Protoss.tcInstantiateType (get instExpr name)) scheme)
              (get instExpr typeArgs)))))))
  (PERecur value
    (let (valueCheck (recur value))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (case (Protoss.tcRecurKey value)
            (None _ ((Protoss.tcUnsupported Protoss.tcNoDef) "recur"))
            (Some key
              (case ((TermEnv.lookup Protoss.tcRecurResultKey) termEnv)
                (None _ ((Protoss.tcUnsupported Protoss.tcNoDef) "recur"))
                (Some resultType
                  (case ((TermEnv.lookup key) termEnv)
                    (None _
                      (Protoss.tcErr
                        ((((((Protoss.tcError "SELF_TC002") Protoss.tcNoDef)
                          Protoss.tcNoType)
                          Protoss.tcNoType)
                          (Protoss.renderExpr value))
                          "recur argument is not a direct structural subterm")))
                    (Some targetType
                      (case ((valueCheck typeEnv) termEnv)
                        (Err err (variant Err err))
                        (Ok actualType
                          (case (((Protoss.tcTypeEq typeEnv) targetType) actualType)
                            (true (Protoss.tcOk resultType))
                            (false
                              ((((Protoss.tcMismatch Protoss.tcNoDef)
                                targetType)
                                actualType)
                                (Protoss.renderExpr value)))))))))))))))))

(def Protoss.tcExpr
  (-> TypeEnv (-> TermEnv (-> Expr (Result TypeError TypeExpr))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expr Expr)
        (((Protoss.tcExprGo expr) typeEnv) termEnv)))))

(def Protoss.tcCheckExprAsFallback
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> Expr (Result TypeError TypeExpr)))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expected TypeExpr)
        (lambda (expr Expr)
          (case (((Protoss.tcExpr typeEnv) termEnv) expr)
            (Err err (variant Err err))
            (Ok actual
              (case (((Protoss.tcTypeEq typeEnv) expected) actual)
                (true (Protoss.tcOk expected))
                (false
                  ((((Protoss.tcMismatch Protoss.tcNoDef) expected) actual)
                    (Protoss.renderExpr expr)))))))))))

(def Protoss.tcInferExpectedArgCheck (-> Expr TypecheckExpectedExprChecker)
  (lambda (expr Expr)
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected) expr))))))

(defrec Protoss.tcExpectedFnTypeForArgs
  (-> (List Expr) (-> TypeEnv (-> TermEnv (-> TypeExpr
    (Result TypeError TypeExpr)))))
  (list args)
  (nil
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          (Protoss.tcOk expected)))))
  (cons arg acc
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          (case (((Protoss.tcExpr typeEnv) termEnv) arg)
            (Err err (variant Err err))
            (Ok argType
              (case (((acc typeEnv) termEnv) expected)
                (Err err (variant Err err))
                (Ok restType
	                  (Protoss.tcOk ((Protoss.tcFun argType) restType)))))))))))

(def Protoss.tcCheckExpectedListTail
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> TypeExpr (-> Expr
    (-> TypecheckExpectedExprChecker (Result TypeError TypeExpr)))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expected TypeExpr)
        (lambda (itemType TypeExpr)
          (lambda (tail Expr)
            (lambda (tailCheck TypecheckExpectedExprChecker)
              (case tail
                (PENil nilExpr
                  (case (get nilExpr typ)
                    (None _ (Protoss.tcOk expected))
                    (Some explicitItem
                      (case (((Protoss.tcTypeEq typeEnv) itemType) explicitItem)
                        (true (Protoss.tcOk expected))
                        (false
                          ((((Protoss.tcMismatch Protoss.tcNoDef) itemType)
                            explicitItem)
                            (Protoss.renderExpr tail)))))))
                (_ (((tailCheck typeEnv) termEnv) expected))))))))))

(defrec Protoss.tcPrefixExpectedArgCheck
  (-> Expr TypecheckExpectedExprChecker)
  (variant expr)
  (PELambda lam
    (let (bodyCheck (recur (get lam body)))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (lambda (expected TypeExpr)
            (case ((Protoss.tcUnfoldType typeEnv) expected)
              (PTFun pair
                (let (param ProtossParam (get lam param))
                  (case (((Protoss.tcTypeEq typeEnv) (get pair first)) (get param typ))
                    (false
                      ((((Protoss.tcMismatch Protoss.tcNoDef)
                        (get pair first))
                        (get param typ))
                        (get param name)))
                    (true
                      (case ((bodyCheck typeEnv)
                              (((TermEnv.insert (get param name)) (get param typ)) termEnv)
                              (get pair second))
                        (Err err (variant Err err))
                        (Ok checkedBody (Protoss.tcOk expected)))))))
              (_
                ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                  (variant PELambda lam)))))))))
  (PERecord fields
    (let (fieldsCheck
      (foldList fields
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (lambda (expectedFields (List ProtossField))
              (lambda (expected TypeExpr)
                (Protoss.tcOk expected)))))
        (lambda (field ProtossRecordFieldExpr)
          (lambda (acc
            (-> TypeEnv (-> TermEnv (-> (List ProtossField)
              (-> TypeExpr (Result TypeError TypeExpr))))))
            (let (fieldCheck (recur (get field expr)))
              (lambda (typeEnv TypeEnv)
                (lambda (termEnv TermEnv)
                  (lambda (expectedFields (List ProtossField))
                    (lambda (expected TypeExpr)
                      (case ((((acc typeEnv) termEnv) expectedFields) expected)
                        (Err err (variant Err err))
                        (Ok ignored
                          (case ((Protoss.tcFindRecordField (get field name)) expectedFields)
                            (None _
                              (Protoss.tcErr
                                ((((((Protoss.tcError "SELF_TC006") Protoss.tcNoDef)
                                  Protoss.tcNoType)
                                  (Protoss.tcSomeType expected))
                                  (get field name))
                                  ((String.concat "unknown record field: ") (get field name)))))
                            (Some fieldDecl
                              (case (((fieldCheck typeEnv) termEnv) (get fieldDecl typ))
                                (Err err (variant Err err))
                                (Ok checkedField (Protoss.tcOk expected))))))))))))))))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (lambda (expected TypeExpr)
            (case ((Protoss.tcRecordFieldsOfType typeEnv) expected)
              (None _
                ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                  (variant PERecord fields)))
              (Some expectedFields
                (case ((Protoss.tcMissingRecordFieldExpr expectedFields) fields)
                  (Some missing
                    (Protoss.tcErr
                      ((((((Protoss.tcError "SELF_TC006") Protoss.tcNoDef)
                        (Protoss.tcSomeType expected))
                        Protoss.tcNoType)
                        missing)
                        ((String.concat "record missing field: ") missing))))
                  (None _
                    ((((fieldsCheck typeEnv) termEnv) expectedFields) expected))))))))))
  (PEVariant variantExpr
    (let (payloadCheck (recur (get variantExpr payload)))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (lambda (expected TypeExpr)
            (case (get variantExpr typeHint)
              (None _
                (case (((Protoss.tcVariantPayloadType typeEnv) expected)
                        (get variantExpr constructor))
                  (None _
                    (Protoss.tcErr
                      ((((((Protoss.tcError "SELF_TC007") Protoss.tcNoDef)
                        Protoss.tcNoType)
                        (Protoss.tcSomeType expected))
                        (Protoss.renderExpr expr))
                        ((String.concat "unknown variant constructor: ")
                          (get variantExpr constructor)))))
                  (Some payloadType
                    (case (((payloadCheck typeEnv) termEnv) payloadType)
                      (Err err (variant Err err))
                      (Ok checkedPayload (Protoss.tcOk expected))))))
              (Some targetType
                (case (((Protoss.tcTypeEq typeEnv) expected) targetType)
                  (false
                    ((((Protoss.tcMismatch Protoss.tcNoDef) expected) targetType)
                      (Protoss.renderExpr expr)))
                  (true
                    (case (((Protoss.tcVariantPayloadType typeEnv) targetType)
                            (get variantExpr constructor))
                      (None _
                        (Protoss.tcErr
                          ((((((Protoss.tcError "SELF_TC007") Protoss.tcNoDef)
                            Protoss.tcNoType)
                            (Protoss.tcSomeType targetType))
                            (Protoss.renderExpr expr))
                            ((String.concat "unknown variant constructor: ")
                              (get variantExpr constructor)))))
                      (Some payloadType
                        (case (((payloadCheck typeEnv) termEnv) payloadType)
                          (Err err (variant Err err))
                          (Ok checkedPayload (Protoss.tcOk expected))))))))))))))
  (PENil nilExpr
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          (case ((Protoss.tcListItemType typeEnv) expected)
            (None _
              ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                (variant PENil nilExpr)))
            (Some itemType
              (case (get nilExpr typ)
                (None _ (Protoss.tcOk expected))
                (Some explicitItem
                  (case (((Protoss.tcTypeEq typeEnv) itemType) explicitItem)
                    (true (Protoss.tcOk expected))
                    (false
                      ((((Protoss.tcMismatch Protoss.tcNoDef) itemType) explicitItem)
                        (Protoss.renderExpr expr))))))))))))
	  (PECons consExpr
	    (let (headCheck (Protoss.tcInferExpectedArgCheck (get consExpr head)))
	      (let (tailCheck (Protoss.tcInferExpectedArgCheck (get consExpr tail)))
	        (lambda (typeEnv TypeEnv)
	          (lambda (termEnv TermEnv)
	            (lambda (expected TypeExpr)
	              (case ((Protoss.tcListItemType typeEnv) expected)
	                (None _
	                  ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
	                    (variant PECons consExpr)))
	                (Some itemType
	                  (case (get consExpr typ)
	                    (Some explicitItem
	                      (case (((Protoss.tcTypeEq typeEnv) itemType) explicitItem)
	                        (false
	                          ((((Protoss.tcMismatch Protoss.tcNoDef) itemType) explicitItem)
	                            (Protoss.renderExpr expr)))
	                        (true
	                          (case (((headCheck typeEnv) termEnv) itemType)
	                            (Err err (variant Err err))
	                            (Ok checkedHead
	                              ((((((Protoss.tcCheckExpectedListTail typeEnv)
	                                  termEnv)
	                                  expected)
	                                  itemType)
	                                  (get consExpr tail))
	                                  tailCheck))))))
	                    (None _
	                      (case (((headCheck typeEnv) termEnv) itemType)
	                        (Err err (variant Err err))
	                        (Ok checkedHead
	                          ((((((Protoss.tcCheckExpectedListTail typeEnv)
	                              termEnv)
	                              expected)
	                              itemType)
	                              (get consExpr tail))
	                              tailCheck)))))))))))))
  (PEDone value
    (let (valueCheck (recur value))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (lambda (expected TypeExpr)
            (case ((Protoss.tcProcessItemType typeEnv) expected)
              (None _
                ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                  (variant PEDone value)))
              (Some itemType
                (case (((valueCheck typeEnv) termEnv) itemType)
                  (Err err (variant Err err))
                  (Ok checkedValue (Protoss.tcOk expected))))))))))
	  (_ (Protoss.tcInferExpectedArgCheck expr)))

(def Protoss.tcCheckPolySpineApplyAs
  (-> TypeEnv (-> TermEnv (-> TypeExpr (-> Expr (-> (List Expr)
    (-> (List TypecheckExpectedExprChecker) (Result TypeError TypeExpr)))))))
  (lambda (typeEnv TypeEnv)
    (lambda (termEnv TermEnv)
      (lambda (expected TypeExpr)
        (lambda (fnExpr Expr)
          (lambda (suffixArgs (List Expr))
            (lambda (suffixChecks (List TypecheckExpectedExprChecker))
              (case (Protoss.tcPolyAppSpine fnExpr)
                (None _
                  ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                    (variant PEApply
                      (record
                        (fn fnExpr)
                        (args suffixArgs)))))
                (Some spine
                  (let (prefixChecks (List TypecheckExpectedExprChecker)
                    (foldList (get spine args)
                        (Nil TypecheckExpectedExprChecker)
                        (lambda (arg Expr)
                          (lambda (acc (List TypecheckExpectedExprChecker))
                            (Cons TypecheckExpectedExprChecker
                              (Protoss.tcPrefixExpectedArgCheck arg)
                              acc)))))
                    (let (allArgs (List Expr)
                      (((inst List.append Expr) (get spine args)) suffixArgs))
                      (let (allChecks (List TypecheckExpectedExprChecker)
                        (((inst List.append TypecheckExpectedExprChecker)
                          prefixChecks)
                          suffixChecks))
                        (case ((TermEnv.lookup (get spine name)) termEnv)
                          (Some typ
                            ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                              (variant PEApply
                                (record
                                  (fn fnExpr)
                                  (args suffixArgs)))))
                          (None _
                            (case ((TermEnv.lookupPoly (get spine name)) termEnv)
                              (None _
                                ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                                  (variant PEApply
                                    (record
                                      (fn fnExpr)
                                      (args suffixArgs)))))
                              (Some scheme
                                (((((((Protoss.tcCheckPolyApplyAs typeEnv) termEnv)
                                  expected)
                                  (get spine name))
                                  scheme)
                                  allArgs)
                                  allChecks)))))))))))))))))

(defrec Protoss.tcCheckExprAsGo
  (-> Expr (-> TypeEnv (-> TermEnv (-> TypeExpr (Result TypeError TypeExpr)))))
  (variant expr)
  (PEUnit
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
            (variant PEUnit unit))))))
  (PEBool value
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
            (variant PEBool value))))))
  (PEString value
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
            (variant PEString value))))))
  (PEVar name
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          ((((Protoss.tcCheckPolyVarAs typeEnv) termEnv) name) expected)))))
  (PELambda lam
    (let (bodyCheck (recur (get lam body)))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (lambda (expected TypeExpr)
            (case ((Protoss.tcUnfoldType typeEnv) expected)
              (PTFun pair
                (let (param ProtossParam (get lam param))
                  (case (((Protoss.tcTypeEq typeEnv) (get pair first)) (get param typ))
                    (false
                      ((((Protoss.tcMismatch Protoss.tcNoDef)
                        (get pair first))
                        (get param typ))
                        (get param name)))
                    (true
                      (case ((bodyCheck typeEnv)
                              (((TermEnv.insert (get param name)) (get param typ)) termEnv)
                              (get pair second))
                        (Err err (variant Err err))
                        (Ok checkedBody (Protoss.tcOk expected)))))))
              (_
                ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                  (variant PELambda lam)))))))))
  (PELet letExpr
    (let (valueCheck (recur (get letExpr value)))
      (let (bodyCheck (recur (get letExpr body)))
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (lambda (expected TypeExpr)
              (case (get letExpr typ)
                (None _
                  (case (((Protoss.tcExpr typeEnv) termEnv) (get letExpr value))
                    (Err err (variant Err err))
                    (Ok valueType
                      (case (((((Protoss.tcCheckProcessLetFlow typeEnv)
                                (get letExpr name))
                                valueType)
                                expected)
                                (Protoss.renderExpr (get letExpr body)))
                        (Err err (variant Err err))
                        (Ok checkedFlow
                          ((bodyCheck typeEnv)
                            (((TermEnv.insert (get letExpr name)) valueType) termEnv)
                            expected))))))
                (Some annotation
                  (case (((valueCheck typeEnv) termEnv) annotation)
                    (Err err (variant Err err))
                    (Ok checkedValue
                      (case (((((Protoss.tcCheckProcessLetFlow typeEnv)
                                (get letExpr name))
                                annotation)
                                expected)
                                (Protoss.renderExpr (get letExpr body)))
                        (Err err (variant Err err))
                        (Ok checkedFlow
                          ((bodyCheck typeEnv)
                            (((TermEnv.insert (get letExpr name)) annotation) termEnv)
                            expected)))))))))))))
	  (PEApply call
	    (let (argChecks
	        (foldList (get call args)
	          (Nil TypecheckExpectedExprChecker)
	          (lambda (arg Expr)
	            (lambda (acc (List TypecheckExpectedExprChecker))
	              (Cons TypecheckExpectedExprChecker (recur arg) acc)))))
	        (lambda (typeEnv TypeEnv)
	          (lambda (termEnv TermEnv)
	            (lambda (expected TypeExpr)
	              (case (get call fn)
	                (PEVar name
	                  (case ((TermEnv.lookup name) termEnv)
	                    (Some typ
	                      ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
	                        (variant PEApply call)))
	                    (None _
	                      (case ((TermEnv.lookupPoly name) termEnv)
	                        (None _
	                          ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
	                            (variant PEApply call)))
	                        (Some scheme
	                          (((((((Protoss.tcCheckPolyApplyAs typeEnv) termEnv)
	                            expected)
	                            name)
	                            scheme)
	                            (get call args))
	                            argChecks))))))
                (_
	                  ((((((Protoss.tcCheckPolySpineApplyAs typeEnv) termEnv)
	                    expected)
	                    (get call fn))
	                    (get call args))
	                    argChecks))))))))
  (PERecord fields
    (let (fieldsCheck
      (foldList fields
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (lambda (expectedFields (List ProtossField))
              (lambda (expected TypeExpr)
                (Protoss.tcOk expected)))))
        (lambda (field ProtossRecordFieldExpr)
          (lambda (acc
            (-> TypeEnv (-> TermEnv (-> (List ProtossField)
              (-> TypeExpr (Result TypeError TypeExpr))))))
            (let (fieldCheck (recur (get field expr)))
              (lambda (typeEnv TypeEnv)
                (lambda (termEnv TermEnv)
                  (lambda (expectedFields (List ProtossField))
                    (lambda (expected TypeExpr)
                      (case ((((acc typeEnv) termEnv) expectedFields) expected)
                        (Err err (variant Err err))
                        (Ok ignored
                          (case ((Protoss.tcFindRecordField (get field name)) expectedFields)
                            (None _
                              (Protoss.tcErr
                                ((((((Protoss.tcError "SELF_TC006") Protoss.tcNoDef)
                                  Protoss.tcNoType)
                                  (Protoss.tcSomeType expected))
                                  (get field name))
                                  ((String.concat "unknown record field: ") (get field name)))))
                            (Some fieldDecl
                              (case (((fieldCheck typeEnv) termEnv) (get fieldDecl typ))
                                (Err err (variant Err err))
                                (Ok checkedField (Protoss.tcOk expected))))))))))))))))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (lambda (expected TypeExpr)
            (case ((Protoss.tcRecordFieldsOfType typeEnv) expected)
              (None _
                ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                  (variant PERecord fields)))
              (Some expectedFields
                (case ((Protoss.tcMissingRecordFieldExpr expectedFields) fields)
                  (Some missing
                    (Protoss.tcErr
                      ((((((Protoss.tcError "SELF_TC006") Protoss.tcNoDef)
                        (Protoss.tcSomeType expected))
                        Protoss.tcNoType)
                        missing)
                        ((String.concat "record missing field: ") missing))))
                  (None _
                    ((((fieldsCheck typeEnv) termEnv) expectedFields) expected))))))))))
  (PEField fieldExpr
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
            (variant PEField fieldExpr))))))
  (PEVariant variantExpr
    (let (payloadCheck (recur (get variantExpr payload)))
      (lambda (typeEnv TypeEnv)
        (lambda (termEnv TermEnv)
          (lambda (expected TypeExpr)
            (case (get variantExpr typeHint)
              (None _
                (case (((Protoss.tcVariantPayloadType typeEnv) expected)
                        (get variantExpr constructor))
                  (None _
                    (Protoss.tcErr
                      ((((((Protoss.tcError "SELF_TC007") Protoss.tcNoDef)
                        Protoss.tcNoType)
                        (Protoss.tcSomeType expected))
                        (Protoss.renderExpr expr))
                        ((String.concat "unknown variant constructor: ")
                          (get variantExpr constructor)))))
                  (Some payloadType
                    (case (((payloadCheck typeEnv) termEnv) payloadType)
                      (Err err (variant Err err))
                      (Ok checkedPayload (Protoss.tcOk expected))))))
              (Some targetType
                (case (((Protoss.tcTypeEq typeEnv) expected) targetType)
                  (false
                    ((((Protoss.tcMismatch Protoss.tcNoDef) expected) targetType)
                      (Protoss.renderExpr expr)))
                  (true
                    (case (((Protoss.tcVariantPayloadType typeEnv) targetType)
                            (get variantExpr constructor))
                      (None _
                        (Protoss.tcErr
                          ((((((Protoss.tcError "SELF_TC007") Protoss.tcNoDef)
                            Protoss.tcNoType)
                            (Protoss.tcSomeType targetType))
                            (Protoss.renderExpr expr))
                            ((String.concat "unknown variant constructor: ")
                              (get variantExpr constructor)))))
                      (Some payloadType
                        (case (((payloadCheck typeEnv) termEnv) payloadType)
                          (Err err (variant Err err))
                          (Ok checkedPayload (Protoss.tcOk expected))))))))))))))
  (PENil nilExpr
    (lambda (typeEnv TypeEnv)
      (lambda (termEnv TermEnv)
        (lambda (expected TypeExpr)
          (case ((Protoss.tcListItemType typeEnv) expected)
            (None _
              ((((Protoss.tcCheckExprAsFallback typeEnv) termEnv) expected)
                (variant PENil nilExpr)))
            (Some itemType
              (case (get nilExpr typ)
                (None _ (Protoss.tcOk expected))
                (Some explicitItem
                  (case (((Protoss.tcTypeEq typeEnv) itemType) explicitItem)
                    (true (Protoss.tcOk expected))
                    (false
                      ((((Protoss.tcMismatch Protoss.tcNoDef) itemType) explicitItem)
                        (Protoss.renderExpr expr))))))))))))
  (PECons consExpr
    (let (headCheck (recur (get consExpr head)))
      (let (tailCheck (recur (get consExpr tail)))
        (lambda (typeEnv TypeEnv)
          (lambda (termEnv TermEnv)
            (lambda (expected TypeExpr)
              (case ((Protoss.tcListItemType typeEnv) expected)
