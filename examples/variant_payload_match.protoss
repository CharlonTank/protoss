(variant LeadEvent
  (Lead (Record
    (name String)
    (status String))))

(def event LeadEvent
  (variant Lead
    (record
      (name "Ada")
      (status "open"))))

(def status String
  (match event
    (Lead (record name (status s)) s)))

(variant PairMsg
  (Pair (Tuple Nat String)))

(def msg PairMsg
  (variant Pair (tuple 7 "score")))

(def score Nat
  (match msg
    (Pair (tuple n label) n)))
