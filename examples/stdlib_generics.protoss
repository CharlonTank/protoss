(def protossDepOrderParsedValid (Result String ProtossDepOrder)
  (Protoss.termDependencyOrderText "(def c Nat b)\n(def b Nat a)\n(def a Nat 1)"))

(def protossDepOrderValid (ProtossDepOrder)
  (case protossDepOrderParsedValid
    (Err err (variant PDepOrderCycle (Cons String err (Nil String))))
    (Ok order order)))

(def protossDepOrderParsedCycle (Result String ProtossDepOrder)
  (Protoss.termDependencyOrderText "(def a Nat b)\n(def b Nat a)"))

(def protossDepOrderCycle (ProtossDepOrder)
  (case protossDepOrderParsedCycle
    (Err err (variant PDepOrderCycle (Cons String err (Nil String))))
    (Ok order order)))

(def protossDepOrderParsedExternal (Result String ProtossDepOrder)
  (Protoss.termDependencyOrderText "(def local Nat externalValue)"))

(def protossDepOrderExternal (ProtossDepOrder)
  (case protossDepOrderParsedExternal
    (Err err (variant PDepOrderCycle (Cons String err (Nil String))))
    (Ok order order)))

(def protossDepNodesParsed (Result String (List ProtossDecl))
  (Protoss.parseText "(def c Nat b)\n(def b Nat a)\n(def a Nat 1)"))

(def protossDepNodes (List ProtossDepNode)
  (case protossDepNodesParsed
    (Err err (Nil ProtossDepNode))
    (Ok decls (Protoss.declsTermDepNodes decls))))

(def protossTypeDepOrderParsedValid (Result String ProtossDepOrder)
  (Protoss.typeDependencyOrderText "(variant UseBox (Some Box))\n(record Box (value Id))\n(type Id Nat)"))

(def protossTypeDepOrderValid (ProtossDepOrder)
  (case protossTypeDepOrderParsedValid
    (Err err (variant PDepOrderCycle (Cons String err (Nil String))))
    (Ok order order)))

(def protossTypeDepOrderParsedCycle (Result String ProtossDepOrder)
  (Protoss.typeDependencyOrderText "(type A B)\n(type B A)"))

(def protossTypeDepOrderCycle (ProtossDepOrder)
  (case protossTypeDepOrderParsedCycle
    (Err err (variant PDepOrderCycle (Cons String err (Nil String))))
    (Ok order order)))

(def protossTypeDepOrderParsedRecursiveVariant (Result String ProtossDepOrder)
  (Protoss.typeDependencyOrderText "(variant Tree (params A) (Leaf A) (Node (Tree A)))"))

(def protossTypeDepOrderRecursiveVariant (ProtossDepOrder)
  (case protossTypeDepOrderParsedRecursiveVariant
    (Err err (variant PDepOrderCycle (Cons String err (Nil String))))
    (Ok order order)))

(def protossTypeDepNodesParsed (Result String (List ProtossDecl))
  (Protoss.parseText "(variant UseBox (Some Box))\n(record Box (value Id))\n(type Id Nat)"))

(def protossTypeDepNodes (List ProtossDepNode)
  (case protossTypeDepNodesParsed
    (Err err (Nil ProtossDepNode))
    (Ok decls (Protoss.declsTypeDepNodes decls))))

(def protossTypeEnvParsedValid (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(variant UseBox (Some (Box Nat)))\n(record Box (params A) (value A))\n(type Id Nat)"))

(def protossTypeEnvValidEntries (List ProtossTypeEnvEntry)
  (case protossTypeEnvParsedValid
    (Err err (Nil ProtossTypeEnvEntry))
    (Ok report (get report entries))))

(def protossTypeEnvValidOrder (ProtossDepOrder)
  (case protossTypeEnvParsedValid
    (Err err (variant PDepOrderCycle (Cons String err (Nil String))))
    (Ok report (get report order))))

(def protossTypeEnvValidArityIssues (List ProtossTypeArityIssue)
  (case protossTypeEnvParsedValid
    (Err err (Nil ProtossTypeArityIssue))
    (Ok report (get report typeArityIssues))))

(def protossTypeEnvDuplicateType (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(type Box Nat)\n(record Box (value Nat))"))

(def protossTypeEnvMissingType (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(record Box (value Missing))"))

(def protossTypeEnvDuplicateParam (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(record Box (params A A) (value A))"))

(def protossTypeEnvDuplicateRecordField (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(record Box (value Nat) (value String))"))

(def protossTypeEnvDuplicateVariantCase (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(variant Maybe (Some Nat) (Some String))"))

(def protossTypeEnvCycle (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(type A B)\n(type B A)"))

(def protossTypeEnvWrongArityNamed (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(record Box (params A) (value A))\n(record Use (value (Box Nat String)))"))

(def protossTypeEnvWrongArityBuiltin (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(record Use (value List))"))

(def protossTypeEnvWrongArityParam (Result String ProtossTypeEnvReport)
  (Protoss.checkTypeEnvText "(record Box (params A) (value (A Nat)))"))

(def protossTypeEnvArityReportParsed (Result String ProtossTypeEnvReport)
  (Protoss.typeEnvReportText "(record Box (params A) (value A))\n(record Use (value (Box Nat String)))"))

(def protossTypeEnvArityIssues (List ProtossTypeArityIssue)
  (case protossTypeEnvArityReportParsed
    (Err err (Nil ProtossTypeArityIssue))
    (Ok report (get report typeArityIssues))))

(def jsonProfile Json
  (Json.object
    ((((inst Assoc.insert String Json) "name") (Json.string "Ada"))
      ((((inst Assoc.insert String Json) "age") (Json.nat 41))
        (inst Assoc.empty String Json)))))

(def jsonName (Maybe Json)
  ((Json.getField "name") jsonProfile))

(def jsonMissing (Maybe Json)
  ((Json.getField "missing") jsonProfile))

(def jsonNameString (Result String String)
  (case jsonName
    (None (variant Err "missing name"))
    (Some value (Json.expectString value))))

(def jsonAgeNat (Result String Nat)
  (case ((Json.getField "age") jsonProfile)
    (None (variant Err "missing age"))
    (Some value (Json.expectNat value))))

(def jsonNullIsNull Bool
  (Json.isNull Json.null))

(def jsonProfileObject (Result String (Assoc String Json))
  (Json.expectObject jsonProfile))

(def jsonNameField (Result String Json)
  ((Json.expectField "name") jsonProfile))

(def jsonNameViaDecoder (Result String String)
  (((inst Json.expectFieldAs String) Json.expectString) "name" jsonProfile))

(def jsonMissingField (Result String Json)
  ((Json.expectField "missing") jsonProfile))

(def total Nat
  (foldList bumped 0
    (lambda (x Nat)
      (lambda (acc Nat)
        ((Nat.add x) acc)))))
