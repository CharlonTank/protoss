(def protossResolveParsedValid (Result String ProtossResolveReport)
  (Protoss.resolveText "(type Count Nat)\n(def base Count 1)\n(def total Count (succ base))\n(export total Count)"))

(def protossResolveValidMissingTerms (List String)
  (case protossResolveParsedValid
    (Err err (Cons String err (Nil String)))
    (Ok report (get report missingTerms))))

(def protossResolveValidMissingTypes (List String)
  (case protossResolveParsedValid
    (Err err (Cons String err (Nil String)))
    (Ok report (get report missingTypes))))

(def protossResolveValidMissingExports (List String)
  (case protossResolveParsedValid
    (Err err (Cons String err (Nil String)))
    (Ok report (get report missingExports))))

