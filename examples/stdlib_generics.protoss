(def protossDepsParsedDef (Result String (List ProtossDecl))
  (Protoss.parseText "(def total (Pair Nat String) ((Nat.add base) (let (x Nat 1) (succ x))))"))

(def protossTermNamesDef (List String)
  (case protossDepsParsedDef
    (Err err (Nil String))
    (Ok decls
      (caseList decls
        (Nil (Nil String))
        (Cons decl rest (Protoss.declTermNames decl))))))

